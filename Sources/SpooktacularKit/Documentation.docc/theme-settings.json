      },
      "fill": {
        "dark": "#07050f",
        "light": "#ffffff"
      },
      "fill-secondary": {
        "dark": "#1a1035",
        "light": "#f0eaff"
      },
      "fill-tertiary": {
        "dark": "#251648",
        "light": "#e8deff"
      },
      "nav-solid-background": {
        "dark": "#0f0a1a",
        "light": "#ffffff"
      },
      "nav-dark-solid-background": "#0f0a1a",
      "standard-purple": "hsl(263, 90%, 55%)",
      "figure-blue": {
        "dark": "#a78bfa",
        "light": "#7c3aed"
      },
      "tutorials-teal": {
        "dark": "#a78bfa",
        "light": "#7c3aed"
      },
      "documentation-intro-accent": {
        "dark": "#a78bfa",
        "light": "#7c3aed"
      },
      "documentation-intro-eyebrow": {
        "dark": "#c4b5fd",
        "light": "#5b21b6"
      },
      "documentation-intro-figure": {
        "dark": "#a78bfa",
        "light": "#7c3aed"
      },
      "documentation-intro-title": {
        "dark": "#f0eaff",
        "light": "#1a1035"
      }
    },
    "typography": {
      "html-font": "-apple-system, BlinkMacSystemFont, 'Inter', 'SF Pro Display', system-ui, sans-serif",
