{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"sections":[],"metadata":{"externalID":"SpooktacularKit","symbolKind":"module","modules":[{"name":"SpooktacularKit"}],"role":"collection","roleHeading":"Framework","title":"SpooktacularKit"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"SpooktacularKit is the core library powering Spooktacular — a lightweight"},{"type":"text","text":" "},{"type":"text","text":"macOS app for running macOS virtual machines. Built on Apple’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","isActive":true},{"type":"text","text":" "},{"type":"text","text":"framework, it provides a Swift API for VM lifecycle management,"},{"type":"text","text":" "},{"type":"text","text":"IPSW installation, instant APFS cloning, and enterprise provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text","text":" "},{"type":"text","text":"running macOS 14.0 (Sonoma) or later."}],"type":"paragraph"}],"name":"Important","type":"aside","style":"important"},{"level":3,"type":"heading","text":"Design Principles","anchor":"Design-Principles"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"text":" ","type":"text"},{"text":"patterns exactly:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice","code":"VZVirtualMachine"},{"type":"text","text":" — no unnecessary abstractions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Value types ("},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"type":"text","text":", "},{"code":"VirtualMachineMetadata","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":") for all configuration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Sendable","type":"codeVoice"},{"type":"text","text":" conformance throughout for Swift 6 strict concurrency"}]}]},{"content":[{"inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"Creating a Virtual Machine","anchor":"Creating-a-Virtual-Machine"},{"syntax":"swift","type":"codeListing","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"]}]}],"kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"variants":[{"paths":["\/documentation\/spooktacularkit"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections"