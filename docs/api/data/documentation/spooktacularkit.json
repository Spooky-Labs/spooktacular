 Swift 6 strict concurrency","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}]}]}]},{"type":"heading","level":3,"anchor":"Creating-a-Virtual-Machine","text":"Creating a Virtual Machine"},{"type":"codeListing","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"title":"Configuring Jenkins Nodes"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"title":"Getting Started with Spooktacular"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacu