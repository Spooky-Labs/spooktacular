{"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","type":"reference"},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use SpooktacularKit directly in your Swift project, or interact with it","type":"text"},{"text":" ","type":"text"},{"text":"through the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI, the Spooktacular GUI app, or the Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"operator. All interfaces share the same library and produce identical","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}],"type":"paragraph"},{"style":"important","content":[{"inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important"},{"text":"Design Principles","level":3,"type":"heading","anchor":"Design-Principles"},{"inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"text":" ","type":"text"},{"text":"patterns exactly:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Direct use of ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":" — no unnecessary abstractions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Value types (","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":", ","type":"text"},{"code":"VirtualMachineMetadata","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"NetworkMode","type":"codeVoice"},{"text":") for all configuration","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"Sendable","type":"codeVoice"},{"text":" conformance throughout for Swift 6 strict concurrency","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Creating a Virtual Machine","level":3,"type":"heading","anchor":"Creating-a-Virtual-Machine"},{"syntax":"swift","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"type":"codeListing"}],"kind":"content"}],"metadata":{"role":"collection","roleHeading":"Framework","title":"SpooktacularKit","symbolKind":"module","modules":[{"name":"SpooktacularKit"}],"externalID":"SpooktacularKit"},"sections":[],"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"topicSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documenta