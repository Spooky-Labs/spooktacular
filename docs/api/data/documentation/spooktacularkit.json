{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"SpooktacularKit is the core library powering Spooktacular — a lightweight"},{"type":"text","text":" "},{"type":"text","text":"macOS app for running macOS virtual machines. Built on Apple’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","isActive":true},{"type":"text","text":" "},{"type":"text","text":"framework, it provides a Swift API for VM lifecycle management,"},{"type":"text","text":" "},{"type":"text","text":"IPSW installation, instant APFS cloning, and enterprise provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}]}],"name":"Important","type":"aside"},{"level":3,"type":"heading","text":"Design Principles","anchor":"Design-Principles"},{"inlineContent":[{"type":"text","text":"SpooktacularKit follows Apple’s Virtualization framework sample code"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice","code":"VZVirtualMachine"},{"type":"text","text":" — no unnecessary abstractions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Value types ("},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":", "},{"type":"codeVoice","code":"VirtualMachineMetadata"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":") for all configuration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" conformance throughout for Swift 6 strict concurrency"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full DocC documentation on every public API"}]}]}]},{"level":3,"type":"heading","text":"Creating a Virtual Machine","anchor":"Creating-a-Virtual-Machine"},{"code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Framework","title":"SpooktacularKit","symbolKind":"module","role":"collection","externalID":"SpooktacularKit"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on