{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"SpooktacularKit is the core library powering Spooktacular — a lightweight"},{"type":"text","text":" "},{"type":"text","text":"macOS app for running macOS virtual machines. Built on Apple’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","isActive":true},{"type":"text","text":" "},{"type":"text","text":"framework, it provides a Swift API for VM lifecycle management,"},{"type":"text","text":" "},{"type":"text","text":"IPSW installation, instant APFS cloning, and enterprise provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}]}]},{"text":"Design Principles","type":"heading","level":3,"anchor":"Design-Principles"},{"inlineContent":[{"type":"text","text":"SpooktacularKit follows Apple’s Virtualization framework sample code"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice"