{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"SpooktacularKit is the core library powering Spooktacular — a lightweight"},{"type":"text","text":" "},{"type":"text","text":"macOS app for running macOS virtual machines. Built on Apple’s"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework, it provides a Swift API for VM lifecycle management,"},{"type":"text","text":" "},{"type":"text","text":"IPSW installation, instant APFS cloning, and enterprise provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}]}],"style":"important","name":"Important","type":"aside"},{"level":3,"text":"Design Principles","anchor":"Design-Principles","type":"heading"},{"inlineContent":[{"type":"text","text":"SpooktacularKit follows Apple’s Virtualization framework sample code"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Direct use of ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":" — no unnecessary abstractions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Value types (","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"text":", ","type":"text"},{"type":"codeVoice","code":"VirtualMachineMetadata"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NetworkMode"},{"text":") for all configuration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Sendable"},{"text":" conformance throughout for Swift 6 strict concurrency","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"text":"Creating a Virtual Machine","anchor":"Creating-a-Virtual-Machine","type":"heading"},{"code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"syntax":"swift","type":"codeListing"}]}],"hierarchy":{"paths":[[]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"metadata":{"symbolKind":"module","externalID":"SpooktacularKit","modules":[{"name":"SpooktacularKit"}],"title":"SpooktacularKit","roleHeading":"Framework","role":"collection"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","d