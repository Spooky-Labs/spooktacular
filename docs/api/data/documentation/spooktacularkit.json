ncurrency","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}],"type":"paragraph"}]}]},{"text":"Creating a Virtual Machine","anchor":"Creating-a-Virtual-Machine","type":"heading","level":3},{"code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","kind":"article","role":"collectionGroup","title":"Machine Learning Workloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"type":"topic","kind":"article","role":"collectionGroup","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","kind":"article","role":"collectionGroup","title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remot