{"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}]}],"style":"important","type":"aside"},{"anchor":"Design-Principles","level":3,"type":"heading","text":"Design Principles"},{"inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Direct use of ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":" — no unnecessary abstractions","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Value types ("},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"type":"text","text":", "},{"code":"VirtualMachineMetadata","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":") for all configuration"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" conformance throughout for Swift 6 strict concurrency"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Full DocC documentation on every public API"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Creating a Virtual Machine","anchor":"Creating-a-Virtual-Machine","level":3,"type":"heading"},{"syntax":"swift","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"type":"codeListing"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","do