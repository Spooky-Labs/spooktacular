ktacular GUI app, or the Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"operator. All interfaces share the same library and produce identical","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text","text":" "},{"type":"text","text":"running macOS 14.0 (Sonoma) or later."}],"type":"paragraph"}],"style":"important","name":"Important"},{"type":"heading","anchor":"Design-Principles","level":3,"text":"Design Principles"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"text":" ","type":"text"},{"text":"patterns exactly:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Direct use of ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":" — no unnecessary abstractions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Value types (","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":", ","type":"text"},{"code":"VirtualMachineMetadata","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"NetworkMode","type":"codeVoice"},{"text":") for all configuration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Sendable","type":"codeVoice"},{"text":" conformance throughout for Swift 6 strict concurrency","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}]}]}]},{"type":"heading","anchor":"Creating-a-Virtual-Machine","level":3,"text":"Creating a Virtual Machine"},{"type":"codeListing","syntax":"swift","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"]}]}],"kind":"symbol","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"variants":[{"paths":["\/documentation\/spooktacularkit"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"externalID":"SpooktacularKit","role":"collection","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Framework","symbolKind":"module","title":"SpooktacularKit"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"title":"Kubernetes Integration","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"type":"topic","url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"title":"Getting Started with Spooktacular","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article","abstract":[{"text":"Run ML training and inference on Apple Silicon