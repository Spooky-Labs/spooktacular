{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"SpooktacularKit is the core library powering Spooktacular — a lightweight"},{"type":"text","text":" "},{"type":"text","text":"macOS app for running macOS virtual machines. Built on Apple’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework, it provides a Swift API for VM lifecycle management,"},{"type":"text","text":" "},{"type":"text","text":"IPSW installation, instant APFS cloning, and enterprise provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text","text":" "},{"type":"text","text":"running macOS 14.0 (Sonoma) or later."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"anchor":"Design-Principles","level":3,"type":"heading","text":"Design Principles"},{"inlineContent":[{"type":"text","text":"SpooktacularKit follows Apple’s Virtualization framework sample code"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Direct use of ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":" — no unnecessary abstractions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Value types (","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"text":", ","type":"text"},{"type":"codeVoice","code":"VirtualMachineMetadata"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NetworkMode"},{"text":") for all configuration","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Sendable"},{"text":" conformance throughout for Swift 6 strict concurrency","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Full DocC documentation on every public API","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Creating-a-Virtual-Machine","level":3,"type":"heading","text":"Creating a Virtual Machine"},{"syntax":"swift","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"type":"codeListing"}],"kind":"content"}],"topicSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"sections":[],"hierarchy":{"paths":[[]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit"]}],"metadata":{"symbolKind":"module","role":"collection","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Framework","externalID":"SpooktacularKit","title":"SpooktacularKit"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"title":"Running BlueBubbles iMessage Server","kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide","role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"kind":"article","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources u