{"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use SpooktacularKit directly in your Swift project, or interact with it","type":"text"},{"text":" ","type":"text"},{"text":"through the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI, the Spooktacular GUI app, or the Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"operator. All interfaces share the same library and produce identical","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)","type":"text"},{"text":" ","type":"text"},{"text":"running macOS 14.0 (Sonoma) or later.","type":"text"}]}],"style":"important","type":"aside","name":"Important"},{"text":"Design Principles","level":3,"type":"heading","anchor":"Design-Principles"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"text":" ","type":"text"},{"text":"patterns exactly:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice","code":"VZVirtualMachine"},{"type":"text","text":" — no unnecessary abstractions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Value types ("},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":", "},{"type":"codeVoice","code":"VirtualMachineMetadata"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":") for all configuration"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Sendable"},{"type":"text","text":" conformance throughout for Swift 6 strict concurrency"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Full DocC documentation on every public API"}],"type":"paragraph"}]}]},{"text":"Creating a Virtual Machine","level":3,"type":"heading","anchor":"Creating-a-Virtual-Machine"},{"code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit"]}],"kind":"symbol","metadata":{"roleHeading":"Framework","externalID":"SpooktacularKit","symbolKind":"module","title":"SpooktacularKit","modules":[{"name":"SpooktacularKit"}],"role":"collection"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"section