{"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization"},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"type":"paragraph"},{"style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text","text":" "},{"type":"text","text":"running macOS 14.0 (Sonoma) or later."}],"type":"paragraph"}],"type":"aside"},{"level":3,"text":"Design Principles","type":"heading","anchor":"Design-Principles"},{"inlineContent":[{"text":"SpooktacularKit follows Apple’s Virtualization framework sample code","type":"text"},{"text":" ","type":"text"},{"text":"patterns exactly:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice","code":"VZVirtualMachine"},