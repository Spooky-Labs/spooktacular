{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"hierarchy":{"paths":[[]]},"metadata":{"modules":[{"name":"SpooktacularKit"}],"symbolKind":"module","roleHeading":"Framework","externalID":"SpooktacularKit","title":"SpooktacularKit","role":"collection"},"kind":"symbol","variants":[{"paths":["\/documentation\/spooktacularkit"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use SpooktacularKit directly in your Swift project, or interact with it","type":"text"},{"text":" ","type":"text"},{"text":"through the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI, the Spooktacular GUI app, or the Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"operator. All interfaces share the same library and produce identical","type":"text"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}]},{"type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text