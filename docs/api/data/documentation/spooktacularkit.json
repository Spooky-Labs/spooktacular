{"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"SpooktacularKit is the core library powering Spooktacular — a lightweight","type":"text"},{"text":" ","type":"text"},{"text":"macOS app for running macOS virtual machines. Built on Apple’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization","type":"reference"},{"text":" ","type":"text"},{"text":"framework, it provides a Swift API for VM lifecycle management,","type":"text"},{"text":" ","type":"text"},{"text":"IPSW installation, instant APFS cloning, and enterprise provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use SpooktacularKit directly in your Swift project, or interact with it"},{"type":"text","text":" "},{"type":"text","text":"through the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI, the Spooktacular GUI app, or the Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"operator. All interfaces share the same library and produce identical"},{"text":" ","type":"text"},{"text":"behavior.","type":"text"}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SpooktacularKit requires an Apple Silicon Mac (M1 or later)"},{"type":"text","text":" "},{"type":"text","text":"running macOS 14.0 (Sonoma) or later."}]}],"style":"important","name":"Important"},{"type":"heading","text":"Design Principles","level":3,"anchor":"Design-Principles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SpooktacularKit follows Apple’s Virtualization framework sample code"},{"type":"text","text":" "},{"type":"text","text":"patterns exactly:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct use of "},{"type":"codeVoice","code":"VZVirtualMachine"},{"type":"text","text":" — no unnecessary abstractions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Value types (","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"text":", ","type":"text"},{"type":"codeVoice","code":"VirtualMachineMetadata"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NetworkMode"},{"text":") for all configuration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Sendable","type":"codeVoice"},{"text":" conformance throughout for Swift 6 strict concurrency","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Full DocC documentation on every public API"}],"type":"paragraph"}]}]},{"type":"heading","text":"Creating a Virtual Machine","level":3,"anchor":"Creating-a-Virtual-Machine"},{"syntax":"swift","type":"codeListing","code":["import SpooktacularKit","","\/\/ Create a VM bundle with a hardware specification.","let spec = VirtualMachineSpecification(","    cpuCount: 8,","    memorySizeInBytes: 16 * 1024 * 1024 * 1024",")","let bundle = try VirtualMachineBundle.create(at: bundleURL, spec: spec)","","\/\/ Clone the bundle instantly using APFS copy-on-write.","let clone = try CloneManager.clone(source: bundle, to: cloneURL)","","\/\/ Build a Virtualization framework configuration.","let config = VZVirtualMachineConfiguration()","try VirtualMachineConfiguration.applySpec(spec, to: config)"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit"]}],"sections":[],"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[[]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Framework","role":"collection","title":"SpooktacularKit","externalID":"SpooktacularKit","symbolKind":"module"},"schemaVersion"