":"enum","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"variants":[{"paths":["\/documentation\/spooktacularkit\/networkmode"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"text":"network traffic is routed relative to the host and the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"external network."}]},{"anchor":"Choosing-a-Network-Mode","type":"heading","text":"Choosing a Network Mode","level":2},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guest → Internet"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host → Guest"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entitlement"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Via resolved IP"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Own LAN IP"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"com.apple.vm.networking"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For host-guest communication without full network access,"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" mode and communicate via the VirtIO socket"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"type":"codeVoice","code":"VZVirtioSocketDeviceConfiguration"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"type":"text","text":"attached regardless of network mode."}]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}]}]},{"anchor":"Why-There-Is-No-Host-Only-Mode","type":"heading","text":"Why There Is No Host-Only Mode","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"type":"codeVoice","code":"VZNATNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"VZBridgedNetworkDeviceAttachment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}]}],"kind":"content"}],"references":{"doc://SpooktacularKit/SE":{"title":"Swift.Encodable","identifier":"doc:\/\/SpooktacularKit\/SE","type":"unresolvable"},"doc://SpooktacularKit/SH":{"title":"Swift.Hashable","identifier":"doc:\/\/SpooktacularKit\/SH","type":"unresolvable"},"doc://SpooktacularKit/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/SpooktacularKit\/s16SendableMetatypeP","type":"unresolvable"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/init(from:)":{"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(from:)","abstract":[{"type":"text","text":"Decodes a network mode from its serialized string representation."}],"url":"\/documentation\/spooktacularkit\/networkmode\/init(from:)","type":"topic","title":"init(from:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": any ","kind":"text"},{"text":"Decoder","preciseIdentifier":"s:s7DecoderP","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/nat":{"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","abstract":[{"type":"text","text":"Network address translation through the host."}],"url":"\/documentation\/spooktacularkit\/networkmode\/nat","type":"topic","title":"NetworkMode.nat","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"nat","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/encode(to:)":{"url":"\/documentation\/spooktacularkit\/networkmo