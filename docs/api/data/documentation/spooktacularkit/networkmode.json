nd packet routing — a"},{"type":"text","text":" "},{"text":"substantial subsystem that would need its own lifecycle","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"type":"paragraph","inlineContent":[{"text":"If you need isolated host-guest communication, use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"text":" ","type":"text"},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"text":" ","type":"text"},{"type":"text","text":"between VMs, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"type":"text","text":" on a dedicated"},{"text":" ","type":"text"},{"text":"host-only network interface.","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/networkmode"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"