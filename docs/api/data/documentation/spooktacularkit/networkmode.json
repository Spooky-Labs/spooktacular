text":" ","type":"text"},{"text":"use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"},{"text":" mode and communicate via the VirtIO socket","type":"text"},{"text":" ","type":"text"},{"text":"device (","type":"text"},{"code":"VZVirtioSocketDeviceConfiguration","type":"codeVoice"},{"text":"), which is always","type":"text"},{"text":" ","type":"text"},{"text":"attached regardless of network mode.","type":"text"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Bridged mode requires the ","type":"text"},{"code":"com.apple.vm.networking","type":"codeVoice"},{"text":" ","type":"text"},{"text":"restricted entitlement, which must be requested from Apple","type":"text"},{"text":" ","type":"text"},{"text":"Developer Technical Support.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"anchor":"Why-There-Is-No-Host-Only-Mode","type":"heading","text":"Why There Is No Host-Only Mode","level":3},{"type":"paragraph","inlineContent":[{"text":"Apple’s Virtualization framework provides three network","type":"text"},{"text":" ","type":"text"},{"text":"attachment types: ","type":"text"},{"code":"VZNATNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"VZBridgedNetworkDeviceAttachment","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":". None of these","type":"text"},{"text":" ","type":"text"},{"text":"implements host-only semantics directly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A host-only mode would require a user-space virtual network","type":"text"},{"text":" ","type":"text"},{"text":"switch built on top of ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"handling raw Ethernet frame