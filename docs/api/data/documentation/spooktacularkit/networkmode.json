":"text","text":"switch built on top of "},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"handling raw Ethernet frames, DHCP, and packet routing — a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"text":" ","type":"text"},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"text":" ","type":"text"},{"text":"(which would give VMs unintended internet access), this enum","type":"text"},{"text":" ","type":"text"},{"text":"only exposes modes that the Virtualization framework supports","type":"text"},{"text":" ","type":"text"},{"text":"natively.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/networkmode"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"title":"NetworkMode.bridged(interface:)","abstract":[{"text":"Bridged directly