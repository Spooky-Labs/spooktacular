enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}]},{"level":2,"type":"heading","text":"Choosing a Network Mode","anchor":"Choosing-a-Network-Mode"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Guest → Internet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host → Guest"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entitlement"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Via resolved IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Own LAN IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"com.apple.vm.networking"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For host-guest communication without full network access,"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" mode and communicate via the VirtIO socket"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"type":"codeVoice","code":"VZVirtioSocketDeviceConfiguration"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"type":"text","text":"attached regardless of network mode."}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}],"type":"paragraph"}]},{"level":3,"type":"heading","text":"Why There Is No Host-Only Mode","anchor":"Why-There-Is-No-Host-Only-Mode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"type":"codeVoice","code":"VZNATNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"VZBridgedNetworkDeviceAttachment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/Equatable-Implementations":{"url":"\/documentation\/spooktacularkit\/networkmode\/equatable-implement