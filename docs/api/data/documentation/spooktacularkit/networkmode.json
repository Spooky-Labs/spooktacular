[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}],"type":"paragraph"},{"anchor":"Choosing-a-Network-Mode","text":"Choosing a Network Mode","level":2,"type":"heading"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Guest → Internet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host → Guest"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Entitlement","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Via resolved IP","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Own LAN IP"}]}],[{"type":"paragraph","inlineContent":[{"code":"com.apple.vm.networking","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"}]}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"text":"For host-guest communication without full network access,","type":"text"},{"text":" ","type":"text"},{"text":"use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"},{"text":" mode and communicate via the VirtIO socket","type":"text"},{"text":" ","type":"text"},{"text":"device (","type":"text"},{"code":"VZVirtioSocketDeviceConfiguration","type":"codeVoice"},{"text":"), which is always","type":"text"},{"text":" ","type":"text"},{"text":"attached regardless of network mode.","type":"text"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}],"type":"paragraph"}],"name":"Note"},{"text":"Why There Is No Host-Only Mode","type":"heading","level":3,"anchor":"Why-There-Is-No-Host-Only-Mode"},{"type":"paragraph","inlineContent":[{"text":"Apple’s Virtualization framework provides three network","type":"text"},{"text":" ","type":"text"},{"text":"attachment types: ","type":"text"},{"code":"VZNATNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"VZBridgedNetworkDeviceAttachment","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":". None of these","type":"text"},{"text":" ","type":"text"},{"text":"implements host-only semantics directly.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"text":" ","type":"text"},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"text":" ","type":"text"},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}],"type":"paragraph"}],"kind":"content"}],"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/Spook