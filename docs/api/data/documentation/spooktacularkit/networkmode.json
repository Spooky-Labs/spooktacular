{"kind":"symbol","relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"type":"conformsTo"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","interfaceLanguage":"swift"},"metadata":{"externalID":"s:15SpooktacularKit11NetworkModeO","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"symbolKind":"enum","role":"symbol","roleHeading":"Enumeration","title":"NetworkMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"modules":[{"name":"SpooktacularKit"}]},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}]},{"anchor":"Choosing-a-Network-Mode","text":"Choosing a Network Mode","type":"heading","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guest → Internet"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host → Guest"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entitlement"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Via resolved IP"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Own LAN IP"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"com.apple.vm.networking"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]]],"type":"table"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For host-guest communication without full network access,"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" mode and communicate via the VirtIO socket"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"type":"codeVoice","code":"VZVirtioSocketDeviceConfiguration"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"type":"text","text":"attached regardless of network mode."}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}]}],"name":"Note","type":"aside"},{"anchor":"Why-There-Is-No-Host-Only-Mode","text":"Why There Is No Host-Only Mode","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"type":"codeVoice","code":"VZNATNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"VZBridgedNetworkDeviceAttachment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"o