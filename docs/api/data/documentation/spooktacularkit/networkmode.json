e"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"heading","text":"Why There Is No Host-Only Mode","level":3,"anchor":"Why-There-Is-No-Host-Only-Mode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"code":"VZNATNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"VZBridgedNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":", and"},{"text":" ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":". None of these","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implements host-only semantics directly."}]},{"type":"paragraph","inlineContent":[{"text":"A host-only mode would require a user-space virtual network","type":"text"},{"text":" ","type":"text"},{"text":"switch built on top of ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"handling raw Ethernet frames, DHCP, and packet routing — a","type":"text"},{"text":" ","type":"text"},{"text":"substantial subsystem that would need its own lifecycle","type":"text"},{"text":" ","type":"text"},{"text":"management and security hardening. Rather than ship a","type":"text"},{"text":" ","type":"text"},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"type":"text","text":" "},{"text":"(which would give VMs unintended internet access), this enum","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}]}]}],"kind":"symbol","topicSections":[{"generated":true,"anchor":"Enumeration-Cases","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"],"title":"Enumeration Cases"},{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(from:)"],"title":"Initializers"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/Equatable-Implementations"],"title":"Default Implementations"}],"metadata":{"title":"NetworkMode","externalID":"s:15SpooktacularKit11NetworkModeO","role":"symbol","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"roleHeading":"Enumeration","symbolKind":"enum"},"references":{"doc://SpooktacularKit/Se":{"type":"unresolvable","title":"Swift.Decodable","identifier":"doc:\/\/SpooktacularKit\/Se"},"doc://SpooktacularKit/documentation/Spooktacu