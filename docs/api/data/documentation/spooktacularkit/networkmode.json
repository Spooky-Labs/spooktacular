{"metadata":{"navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"symbolKind":"enum","roleHeading":"Enumeration","role":"symbol","title":"NetworkMode","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit11NetworkModeO","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}],"type":"paragraph"},{"level":2,"text":"Choosing a Network Mode","type":"heading","anchor":"Choosing-a-Network-Mode"},{"type":"table","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Guest → Internet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host → Guest"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entitlement"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\