yword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"externalID":"s:15SpooktacularKit11NetworkModeO","role":"symbol","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"symbolKind":"enum"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/networkmode"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"code":"Virtualization.framework","type":"codeVoice"},{"text":" network","type":"text"},{"text":" ","type":"text"},{"text":"device attachment type. The mode determines how the guest’s","type":"text"},{"text":" ","type":"text"},{"text":"network traffic is routed relative to the host and the","type":"text"},{"text":" ","type":"text"},{"text":"external network.","type":"text"}]},{"anchor":"Choosing-a-Network-Mode","type":"heading","level":2,"text":"Choosing a Network Mode"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Guest → Internet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host → Guest"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entitlement"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"inlineContent":[{"type":"text","text":"Via resolved IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Own LAN IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"com.apple.vm.networking"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"text":"✗","type":"text"}]}],[{"inlineContent":[{"text":"None","type":"text"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"For host-guest communication without full network access,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" mode and communicate via the VirtIO socket"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"code":"VZVirtioSocketDeviceConfiguration","type":"codeVoice"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"text":"attached regardless of network mode.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"text":"Developer Technical Support.","type":"text"}]}],"style":"note","name":"Note","type":"aside"},{"anchor":"Why-There-Is-No-Host-Only-Mode","type":"heading","level":3,"text":"Why There Is No Host-Only Mode"},{"inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"code":"VZNATNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"VZBridgedNetworkDeviceAttachment","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":". None of these","type":"text"},{"text":" ","type":"text"},{"text":"implements host-only semantics directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A host-only mode would require a user-space virtual network","type":"text"},{"text":" ","type":"text"},{"text":"switch built on top of ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"handling raw Ethernet frames, DHCP, and packet routing — a","type":"text"},{"text":" ","type":"text"},{"text":"substantial subsystem that would need its own lifecycle","type":"text"},{"text":" ","type":"text"},{"text":"management and security hardening. Rather than ship a","type":"text"},{"text":" ","type":"text"},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"text":" ","type":"text"},{"text":"(which would give VMs unintended internet access), this enum","type":"text"},{"text":" ","type":"text"},{"text":"only exposes modes that the Virtualization framework supports","type":"text"},{"text":" ","type":"text"},{"text":"natively.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you need isolated host-guest communication, use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"with the VirtIO socket device. If you need full IP networking","type":"text"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"},{"text":" on a dedicated","type":"text"},{"type":"text","text":" "},{"text":"host-only network interface.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/Equatable-Implementations":{"role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/networkmode\/equatable-implementations","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/Equatable-Implementations","title":"Equatable Implementations","kind":"article","abstract":[]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"title":"NetworkMode","kind":"symbol","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"url":"\/documentation\/spooktacularkit\/networkmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/init(serialized:)":{"role":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/networkmode\/init(serialized:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(serialized:)","title":"init(serialized:)","kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"?(","kind":"text"},{"text":"serialized","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Creates a network mode from its serialized string representation."}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"text":"Create and manage ma