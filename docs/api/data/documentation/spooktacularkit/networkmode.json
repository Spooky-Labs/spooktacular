hment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"text":" ","type":"text"},{"text":"switch built on top of ","type":"text"},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"handling raw Ethernet frames, DHCP, and packet routing — a","type":"text"},{"text":" ","type":"text"},{"text":"substantial subsystem that would need its own lifecycle","type":"text"},{"text":" ","type":"text"},{"text":"management and security hardening. Rather than ship a","type":"text"},{"type":"text","text":" "},{"text":"half-baked implementation or silently fall back to NAT","type":"text"},{"type":"text","text":" "},{"text":"(which would give VMs unintended internet access), this enum","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"type":"paragraph","inlineContent":[{"text":"If you need isolated host-guest communication, use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"with the VirtIO socket device. If you need full IP networking","type":"text"},{"text":" ","type":"text"},{"text":"between VMs, use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"text":" on a dedicated","type":"text"},{"text":" ","type":"text"},{"text":"host-only network interface.","type":"text"}]}]}],"