{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"metadata":{"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit11NetworkModeO","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum","role":"symbol","title":"NetworkMode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/spooktacularkit\/networkmode"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"Each mode maps to a specific ","type":"text"},{"code":"Virtualization.framework","type":"codeVoice"},{"text":" network","type":"text"},{"text":" ","type":"text"},{"text":"device attachment type. The mode determines how the guest’s","type":"text"},{"text":" ","type":"text"},{"text":"network traffic is routed relative to the host and the","type":"text"},{"text":" ","type":"text"},{"text":"external network.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Choosing a Network Mode","anchor":"Choosing-a-Network-Mode"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Guest → Internet"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host → Guest"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entitlement"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Via resolved IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Own LAN IP"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"com.apple.vm.networking"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✗"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"For host-guest communication without full network access,","type":"text"},{"text":" ","type":"text"},{"text":"use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"},{"text":" mode and communicate via the VirtIO socket","type":"text"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"type":"codeVoice","code":"VZVirtioSocketDeviceConfiguration"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"text":"attached regardless of network mode.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Bridged mode requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"restricted entitlement, which must be requested from Apple"},{"type":"text","text":" "},{"type":"text","text":"Developer Technical Support."}],"type":"paragraph"}]},{"level":3,"anchor":"Why-There-Is-No-Host-Only-Mode","type":"heading","text":"Why There Is No Host-Only Mode"},{"inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"type":"codeVoice","code":"VZNATNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"VZBridgedNetworkDeviceAttachment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}],"type":"paragraph"},{"inlineContent":[{"type":"tex