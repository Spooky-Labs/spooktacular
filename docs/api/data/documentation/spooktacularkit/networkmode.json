{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","interfaceLanguage":"swift"},"sections":[],"metadata":{"role":"symbol","symbolKind":"enum","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","externalID":"s:15SpooktacularKit11NetworkModeO","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"code":"Virtualization.framework","type":"codeVoice"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}]},{"level":2,"type":"heading","text":"Choosing a Network Mode","anchor":"Choosing-a-Network-Mode"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guest → Internet"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host → Guest"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entitlement"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\