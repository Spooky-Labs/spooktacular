{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Each mode maps to a specific ","type":"text"},{"type":"codeVoice","code":"Virtualization.framework"},{"text":" network","type":"text"},{"text":" ","type":"text"},{"text":"device attachment type. The mode determines how the guest’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"network traffic is routed relative to the host and the"},{"text":" ","type":"text"},{"type":"text","text":"external network."}]},{"type":"heading","text":"Choosing a Network Mode","level":2,"anchor":"Choosing-a-Network-Mode"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"text":"Guest → Internet","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host → Guest"}]}],[{"type":"paragraph","inlineContent":[{"text":"Entitlement","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"✓","type":"