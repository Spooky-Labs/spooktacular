{"metadata":{"navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum","role":"symbol","title":"NetworkMode","externalID":"s:15SpooktacularKit11NetworkModeO","roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}]},"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}]},{"anchor":"Choosing-a-Network-Mode","text":"Choosing a Network Mode","type":"heading","level":2},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Guest → Internet","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Host → Guest","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Entitlement","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/