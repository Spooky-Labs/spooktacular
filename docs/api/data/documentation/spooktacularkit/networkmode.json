{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"title":"NetworkMode","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"symbolKind":"enum","externalID":"s:15SpooktacularKit11NetworkModeO"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"Each mode maps to a specific ","type":"text"},{"type":"codeVoice","code":"Virtualization.framework"},{"text":" network","type":"text"},{"text":" ","type":"text"},{"text":"device attachment type. The mode determines how the guest’s","type":"text"},{"text":" ","type":"text"},{"text":"network traffic is routed relative to the host and the","type":"text"},{"text":" ","type":"text"},{"text":"external network.","type":"text"}],"type":"paragraph"},{"anchor":"Choosing-a-Network-Mode","type":"heading","level":2,"text":"Choosing a Network Mode"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guest → Internet"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host → Guest"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entitlement"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✓"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Via resolved IP"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference"}]}],[{"inlineContent":[{"type":"text","text":"✓"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Own LAN IP","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"com.apple.vm.networking","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"✗","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✗"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"For host-guest communication without full network access,","type":"text"},{"type":"text","text":" "},{"text":"use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"text":" mode and communicate via the VirtIO socket","type":"text"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"code":"VZVirtioSocketDeviceConfiguration","type":"codeVoice"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"type":"text","text":"attached regardless of network mode."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"Bridged mode requires the ","type":"text"},{"type":"codeVoice","code":"com.apple.vm.networking"},{"text":" ","type":"text"},{"text":"restricted entitlement, which must be requested from Apple","type":"text"},{"text":" ","type":"text"},{"text":"Developer Technical Support.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"anchor":"Why-There-Is-No-Host-Only-Mode","level":3,"text":"Why There Is No Host-Only Mode","type":"heading"},{"inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"code":"VZNATNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"VZBridgedNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"code":"VZFileHandleNetworkDeviceAttachment","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/networkmode"]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"sections":[],"topicSections":[{"anchor":"Enumeration-Cases","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"],"title":"Enumeration Cases","generated":true},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(serialized:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/serialized"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/encode(to:)"],"title":"Instance Methods","g