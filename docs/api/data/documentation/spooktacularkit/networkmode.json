{"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"Each mode maps to a specific ","type":"text"},{"code":"Virtualization.framework","type":"codeVoice"},{"text":" network","type":"text"},{"text":" ","type":"text"},{"text":"device attachment type. The mode determines how the guest’s","type":"text"},{"text":" ","type":"text"},{"text":"network traffic is routed relative to the host and the","type":"text"},{"text":" ","type":"text"},{"text":"external network.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Choosing-a-Network-Mode","text":"Choosing a Network Mode","type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Guest → Internet","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Host → Guest","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Entitlement","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"}],"type":"paragraph"}],[{"inlineContent":[{"text":"✓","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Via resolved IP","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"None","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"✓","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Own LAN IP","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"com.app