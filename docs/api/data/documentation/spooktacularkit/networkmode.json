\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"title":"NetworkMode","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"doc://SpooktacularKit/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/SpooktacularKit\/s8SendableP","title":"Swift.Sendable"},"doc://SpooktacularKit/SH":{"type":"unresolvable","identifier":"doc:\/\/SpooktacularKit\/SH","title":"Swift.Hashable"},"doc://SpooktacularKit/SQ":{"type":"unresolvable","identifier":"doc:\/\/SpooktacularKit\/SQ","title":"Swift.Equatable"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/Equatable-Implementations":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/Equatable-Implementations","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/networkmode\/equatable-implementations","abstract":[],"kind":"article","type":"topic","title":"Equatable Implementations"},"doc://SpooktacularKit/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/SpooktacularKit\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/init(from:)":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(from:)","role":"symbol","abstract":[{"text":"Decodes a network mode from its 