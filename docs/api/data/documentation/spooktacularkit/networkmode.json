{"metadata":{"symbolKind":"enum","externalID":"s:15SpooktacularKit11NetworkModeO","title":"NetworkMode","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"role":"symbol","roleHeading":"Enumeration"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Each mode maps to a specific "},{"type":"codeVoice","code":"Virtualization.framework"},{"type":"text","text":" network"},{"type":"text","text":" "},{"type":"text","text":"device attachment type. The mode determines how the guest’s"},{"type":"text","text":" "},{"type":"text","text":"network traffic is routed relative to the host and the"},{"type":"text","text":" "},{"type":"text","text":"external network."}],"type":"paragraph"},{"anchor":"Choosing-a-Network-Mode","type":"heading","level":2,"text":"Choosing a Network Mode"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Guest → Internet","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Host → Guest","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Entitlement","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"✓","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Via resolved IP","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"None","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"✓","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Own LAN IP","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"com.apple.vm.networking","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"✗","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"✗","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"None","type":"text"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"type":"text","text":"For host-guest communication without full network access,"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" mode and communicate via the VirtIO socket"},{"type":"text","text":" "},{"type":"text","text":"device ("},{"type":"codeVoice","code":"VZVirtioSocketDeviceConfiguration"},{"type":"text","text":"), which is always"},{"type":"text","text":" "},{"type":"text","text":"attached regardless of network mode."}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Bridged mode requires the ","type":"text"},{"code":"com.apple.vm.networking","type":"codeVoice"},{"text":" ","type":"text"},{"text":"restricted entitlement, which must be requested from Apple","type":"text"},{"text":" ","type":"text"},{"text":"Developer Technical Support.","type":"text"}]}],"name":"Note"},{"anchor":"Why-There-Is-No-Host-Only-Mode","type":"heading","level":3,"text":"Why There Is No Host-Only Mode"},{"inlineContent":[{"type":"text","text":"Apple’s Virtualization framework provides three network"},{"type":"text","text":" "},{"type":"text","text":"attachment types: "},{"type":"codeVoice","code":"VZNATNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"VZBridgedNetworkDeviceAttachment"},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":". None of these"},{"type":"text","text":" "},{"type":"text","text":"implements host-only semantics directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A host-only mode would require a user-space virtual network"},{"type":"text","text":" "},{"type":"text","text":"switch built on top of "},{"type":"codeVoice","code":"VZFileHandleNetworkDeviceAttachment"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"handling raw Ethernet frames, DHCP, and packet routing — a"},{"type":"text","text":" "},{"type":"text","text":"substantial subsystem that would need its own lifecycle"},{"type":"text","text":" "},{"type":"text","text":"management and security hardening. Rather than ship a"},{"type":"text","text":" "},{"type":"text","text":"half-baked implementation or silently fall back to NAT"},{"type":"text","text":" "},{"type":"text","text":"(which would give VMs unintended internet access), this enum"},{"type":"text","text":" "},{"type":"text","text":"only exposes modes that the Virtualization framework supports"},{"type":"text","text":" "},{"type":"text","text":"natively."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you need isolated host-guest communication, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" "},{"type":"text","text":"with the VirtIO socket device. If you need full IP networking"},{"type":"text","text":" "},{"type":"text","text":"between VMs, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true},{"type":"text","text":" on a dedicated"},{"type":"text","text":" "},{"type":"text","text":"host-only network interface."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/networkmode"]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/Se","doc:\/\/SpooktacularKit\/SE","doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/SH","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"],"title":"Enumeration Cases","generated":true,"anchor":"Enumeration-Cases"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/init(from:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/Equatable-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/Equatable-Implementations":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Ne