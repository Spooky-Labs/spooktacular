"place with "},{"type":"codeVoice","code":"FileManager.replaceItemAt(_:withItemAt:)"},{"text":". If the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"destination does not yet exist, the temporary file is moved"},{"type":"text","text":" "},{"text":"instead (atomic on APFS). This prevents data loss if the","type":"text"},{"text":" ","type":"text"},{"text":"process is interrupted mid-restore.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"On APFS, both ","type":"text"},{"type":"codeVoice","code":"copyItem"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"replaceItemAt"},{"text":" leverage","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"clonefile(2)"},{"text":" for copy-on-write semantics, keeping restore","type":"text"},{"text":" ","type":"text"},{"text":"near-instantaneous regardless of image size.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError\/notFound(label:)","isActive":true,"type":"reference"},{"text":" if no snapshot","type":"text"},{"text":" ","type":"text"},{"text":"with the given label exists.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Throws"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"]]},"metadata":{"role":"symbol","externalID":"s:15SpooktacularKit15SnapshotManagerO7restore6bundle5labelyAA20VirtualMachineBundleV_SStKFZ","modules":[{"name":"SpooktacularKit"}],"title":"restore(bundle:label:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"restore","kind":"identifier"},{"text":"(","kind":"text"},{"text":"bundle","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15SpooktacularKit