uides","title":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"The Spooktacular Kubernetes operator lets you manage macOS VMs","type":"text"},{"text":" ","type":"text"},{"text":"declaratively with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":". The Swift controller watches","type":"text"},{"text":" ","type":"text"},{"code":"MacOSVM","type":"codeVoice"},{"text":" custom resources and reconciles them by calling the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular HTTP API on your Mac nodes.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Architecture","anchor":"Architecture","type":"heading"},{"syntax":null,"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"type":"codeListing"},{"inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}],"type":"paragraph"},{"level":2,"text":"Prerequisites","anchor":"Prerequisites","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"level":3,"text":"1. Apply the CRD","anchor":"1-Apply-the-CRD","type":"heading"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing"},{"level":3,"text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart","type":"heading"},{"syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing"},{"level":3,"text":"3. Create a VM","anchor":"3-Create-a-VM","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"type":"codeListing"},{"syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing"},{"level":2,"text":"MacOSVM CRD Reference","anchor":"MacOSVM-CRD-Reference","type":"heading"},{"level":3,"text":"Spec Fields","anchor":"Spec-Fields","type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"sourceVM","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"(required)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Base VM to clone from","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"cpu","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Virtual CPU cores","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"memoryInGigabytes","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RAM in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"diskInGigabytes","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"64","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Disk size in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"network","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"nat","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"nat","type":"codeVoice"},{"text":", ","type":"text"},{"code":"isolated","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"bridged:<interface>","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ephemeral","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"boolean","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"false","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Delete VM when it stops","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"template","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"github-runner","type":"codeVoice"},{"text":", ","type":"text"},{"code":"remote-desktop","type":"codeVoice"},{"text":", or ","type":"text"},{"code":"openclaw","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"provisioning.mode","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ssh","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ssh","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"disk-inject","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"provisioning.script","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Shell script to execute","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"provisioning.user","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"admin","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"SSH user","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeSelector","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"object","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"text":"Status Fields","anchor":"Status-Fields","type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"phase","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ip","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeName","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"message","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Human-readable status message","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"text":"Printer Columns","anchor":"Printer-Columns","type":"heading"},{"syntax":"bash","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"type":"codeListing"},{"level":2,"text":"Examples","anchor":"Examples","type":"heading"},{"level":3,"text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","type":"heading"},{"inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Controller Details","anchor":"Controller-Details","type":"heading"},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"KubernetesClient","type":"text"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Reconciler","type":"text"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"NodeManager","type":"text"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"MacOSVMResource","type":"text"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Mac Node Setup","anchor":"Mac-Node-Setup","type":"heading"},{"inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing"},{"inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing"},{"level":2,"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading"},{"level":3,"text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending","type":"heading"},{"inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing"},{"level":3,"text":"Connection refused to Mac node","anchor":"Connection-refused-to-Mac-node","type":"heading"},{"inlineContent":[{"text":"Verify ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" is running and the port is reachable:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"type":"codeListing"},{"level":3,"text":"Provisioning failed","anchor":"Provisioning-failed","type":"heading"},{"inlineContent":[{"text":"Check the VM events:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl describe mvm runner-01"],"type":"codeListing"},{"inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"role":"collectionGroup","type":"topic","title":"Running BlueBubbles iMessage Server","kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","abstract":[{"text":"Run two isolated OpenClaw AI agent