0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing","syntax":"bash"},{"text":"3. Create a VM","anchor":"3-Create-a-VM","type":"heading","level":3},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"type":"codeListing","syntax":"yaml"},{"code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing","syntax":"bash"},{"text":"MacOSVM CRD Reference","anchor":"MacOSVM-CRD-Reference","type":"heading","level":2},{"level":3,"anchor":"Spec-Fields","type":"heading","text":"Spec Fields"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Field"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"sourceVM","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(required)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Base VM to clone from"}]}]],[[{"inlineContent":[{"code":"cpu","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"integer"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Virtual CPU cores","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"memoryInGigabytes","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"integer"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"8"}],"type":"