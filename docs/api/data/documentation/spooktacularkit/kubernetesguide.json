:"text","text":")"}]}]}]},{"type":"heading","level":2,"text":"Quick Start","anchor":"Quick-Start"},{"type":"heading","level":3,"text":"1. Apply the CRD","anchor":"1-Apply-the-CRD"},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash"},{"type":"heading","level":3,"text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart"},{"type":"codeListing","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"syntax":"bash"},{"type":"heading","level":3,"text":"3. Create a VM","anchor":"3-Create-a-VM"},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"syntax":"yaml"},{"type":"codeListing","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"syntax":"bash"},{"type":"heading","level":2,"text":"MacOSVM CRD Reference","anchor":"MacOSVM-CRD-Reference"},{"type":"heading","level":3,"text":"Spec Fields","anchor":"Spec-Fields"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Field"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceVM"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(required)"}]}],[{"type":"paragraph