":"yaml"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Remote-Desktop","text":"Remote Desktop","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing","syntax":"yaml"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","type":"heading"},{"inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}],"type":"paragraph"},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Controller-Details","text":"Controller Details","type":"heading"},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Mac-Node-Setup","text":"Mac Node Setup","type":"heading"},{"inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}],"type":"paragraph"},{"code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing","syntax":"bash"},{"level":2,"anchor":"Troubleshooting","text":"Troubleshooting","type":"heading"},{"level":3,"anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","type":"heading"},{"inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}],"type":"paragraph"},{"code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing","syntax":"bash"},{"level":3,"anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","type":"heading"},{"inlineContent":[{"text":"Verify ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" is running and the port is reachable:","type":"text"}],"type":"paragraph"},{"code":["curl -k https:\/\/10.0.1.50:8484\/health"],"type":"codeListing","syntax":"bash"},{"level":3,"anchor":"Provisioning-failed","text":"Provisioning failed","type":"heading"},{"inlineContent":[{"text":"Check the VM events:","type":"text"}],"type":"paragraph"},{"code":["kubectl describe mvm runner-01"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/kubernetesguide"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","title":"Configuring Jenkins Nodes","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"url":"\/documentation\/spooktacularkit\/jenkinsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","url":"\/documentation\/spooktacularkit\/clireference","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type