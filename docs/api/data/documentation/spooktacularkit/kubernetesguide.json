{"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"type":"codeVoice","code":"MacOSVM"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}]},{"type":"heading","anchor":"Architecture","text":"Architecture","level":3},{"type":"codeListing","syntax":null,"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}]},{"type":"heading","anchor":"Prerequisites","text":"Prerequisites","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":" access"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Quick-Start","text":"Quick Start","level":2},{"type":"heading","anchor":"1-Apply-the-CRD","text":"1. Apply the CRD","level":3},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"]},{"type":"heading","anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart","level":3},{"type":"codeListing","syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"]},{"type":"heading","anchor":"3-Create-a-VM","text":"3. Create a VM","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"]},{"type":"heading","anchor":"MacOSVM-CRD-Reference","text":"MacOSVM CRD Reference","level":2},{"type":"heading","anchor":"Spec-Fields","text":"Spec Fields","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"sourceVM","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"(required)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Base VM to clone from","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"cpu","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Virtual CPU cores","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"memoryInGigabytes","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"RAM in GB","type":"text"}]}]],[[{"type":"paragraph","inl