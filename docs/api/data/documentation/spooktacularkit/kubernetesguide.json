e":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ssh","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ssh","type":"codeVoice"},{"type":"text","text":" or "},{"code":"disk-inject","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"provisioning.script","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Shell script to execute"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"provisioning.user","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"code":"admin","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"SSH user"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeSelector","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"object"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Match Mac nodes by labels"}],"type":"paragraph"}]]]},{"type":"heading","level":3,"text":"Status Fields","anchor":"Status-Fields"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Field"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"phase","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ip","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Resolved VM IP address"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeName","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac host the VM is running on"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"message","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Human-readable status message"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}],"type":"paragraph"}]]]},{"type":"heading","level":3,"text":"Printer Columns","anchor":"Printer-Columns"},{"type":"codeListing","syntax":"bash","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"]},{"type":"heading","level":2,"text":"Examples","anchor":"Examples"},{"type":"heading","level":3,"text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}]},{"type":"heading","level":3,"text":"Remote Desktop","anchor":"Remote-Desktop"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"text":" for the full example.","type":"text"}]},{"type":"heading","level":3,"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"type":"heading","level":2,"text":"Controller Details","anchor":"Controller-Details"},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"KubernetesClient"}]},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reconciler"}]},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"text":" — Codable types matching the CRD schema","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"type":"heading","level":2,"text":"Mac Node Setup","anchor":"Mac-Node-Setup"},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"type":"heading","level":2,"text":"Troubleshooting","anchor":"Troubleshooting"},{"type":"heading","level"