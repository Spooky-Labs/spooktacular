{"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Kubernetes Integration"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"type":"codeVoice","code":"MacOSVM"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}],"type":"paragraph"},{"anchor":"Architecture","type":"heading","text":"Architecture","level":3},{"type":"codeListing","syntax":null,"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"]},{"inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}],"type":"paragraph"},{"anchor":"Prerequisites","type":"heading","text":"Prerequisites","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Quick-Start","type":"heading","text":"Quick Start","level":2},{"anchor":"1-Apply-the-CRD","type":"heading","text":"1. Apply the CRD","level":3},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"]},{"anchor":"2-Install-the-Helm-chart","type":"heading","text":"2. Install the Helm chart","level":3},{"type":"codeListing","syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"]},{"anchor":"3-Create-a-VM","type":"heading","text":"3. Create a VM","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64"