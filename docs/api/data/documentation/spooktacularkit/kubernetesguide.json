    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"type":"text","text":" for the full example."}]},{"type":"heading","anchor":"Remote-Desktop","text":"Remote Desktop","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}]},{"type":"heading","anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}]},{"type":"heading","anchor":"Controller-Details","text":"Controller Details","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift controller ("},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"type":"text","text":") consists of:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"KubernetesClient"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reconciler"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}]},{"type":"heading","anchor":"Mac-Node-Setup","text":"Mac Node Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for 