{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"topicSections":[{"title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"anchor":"Related-Guides"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"The Spooktacular Kubernetes operator lets you manage macOS VMs","type":"text"},{"text":" ","type":"text"},{"text":"declaratively with ","type":"text"},{"type":"codeVoice","code":"kubectl"},{"text":". The Swift controller watches","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MacOSVM"},{"text":" custom resources and reconciles them by calling the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular HTTP API on your Mac nodes.","type":"text"}],"type":"paragraph"},{"anchor":"Architecture","text":"Architecture","type":"heading","level":3},{"syntax":null,"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌───