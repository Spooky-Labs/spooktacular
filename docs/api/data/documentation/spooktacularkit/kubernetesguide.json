}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"phase"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Resolved VM IP address"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeName"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"message","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Human-readable status message"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Printer-Columns","text":"Printer Columns","type":"heading"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash","type":"codeListing"},{"level":2,"anchor":"Examples","text":"Examples","type":"heading"},{"level":3,"anchor":"GitHub-Actions-Runner","text":"GitHub Actions Runner","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Remote-Desktop","text":"Remote Desktop","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","type":"heading"},{"inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}],"type":"paragraph"},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"level":2,"anchor":"Controller-Details","text":"Controller Details","type":"heading"},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"level":2,"text":"Mac Node Setup","anchor":"Mac-Node-Setup","type":"heading"},{"inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service insta