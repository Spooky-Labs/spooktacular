nject"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.script","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shell script to execute"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.user","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"code":"admin","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH user"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeSelector","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"object"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}]}]]],"header":"row"},{"text":"Status Fields","anchor":"Status-Fields","type":"heading","level":3},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"phase"}]}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeName","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"message","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Human-readable status message"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]]},{"text":"Printer Columns","anchor":"Printer-Columns","level":3,"type":"heading"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash","type":"codeListing"},{"text":"Examples","anchor":"Examples","level":2,"type":"heading"},{"type":"heading","text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"anchor":"Remote-Desktop","level":3,"text":"Remote Desktop","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Ephemeral-Runner-Pool","level":3,"text":"Ephemeral Runner Pool","type":"heading"},{"inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}],"type":"paragraph"},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}],"type":"paragraph"},{"anchor":"Controller-Details","level":2,"text":"Controller Details","type":"heading"},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"anchor":"Mac-Node-Setup","level":2,"text":"Mac Node Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"text":"Troubleshooting","type":"heading","anchor":"Troubleshooting","level":2},{"text":"VM stuck in Pending","type":"heading","anchor":"VM-stuck-in-Pending","level":3},{"inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"text":"Connection refused to Mac node","type":"heading","anchor":"Connection-refused-to-Mac-node","level":3},{"inlineContent":[{"type":"text","text":"Verify "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash","type":"codeListing"},{"level":3,"type":"heading","text":"Provisioning failed","anchor":"Provisioning-failed"},{"inlineContent":[{"text":"Check the VM events:","type":"text"}],"type":"paragraph"},{"code":["kubectl describe mvm runner-01"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Kubernetes Integration"},"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"url":"\/documentation\/spooktacularkit\/jenkinsguide","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"role":"collectionGroup","title":"Configuring Jenkins Nodes","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","identifier":"doc:\/\/SpooktacularKit