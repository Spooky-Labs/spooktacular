Hub-Actions-Runner"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"type":"text","text":" for the full example."}]},{"level":3,"type":"heading","text":"Remote Desktop","anchor":"Remote-Desktop"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}]},{"level":3,"type":"heading","text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"syntax":"bash","type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}]},{"level":2,"type":"heading","text":"Controller Details","anchor":"Controller-Details"},{"type":"paragraph"