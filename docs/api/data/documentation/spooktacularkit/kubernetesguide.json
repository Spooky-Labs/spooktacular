─────┘"],"type":"codeListing"},{"inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}],"type":"paragraph"},{"anchor":"Prerequisites","text":"Prerequisites","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Quick Start","anchor":"Quick-Start","level":2},{"type":"heading","text":"1. Apply the CRD","anchor":"1-Apply-the-CRD","level":3},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing","syntax":"bash"},{"type":"heading","text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart","level":3},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"typ