:[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}]},{"level":3,"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"text":" for the full example.","type":"text"}]},{"level":3,"text":"Ephemeral Runner Pool","type":"heading","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"syntax":"bash","type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"type":"heading","anchor":"Controller-Details","level":2,"text":"Controller Details"},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"KubernetesClient"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"level":2,"text":"Mac Node Setup","type":"heading","anchor":"Mac-Node-Setup"},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTP API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"level":2,"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading"},{"type":"heading","anchor":"VM-stuck-in-Pending","level":3,"text":"VM stuck in Pending"},{"inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"]},{"type":"heading","anchor":"Connection-refused-to-Mac-node","level":3,"text":"Connection refused to Mac node"},{"inlineContent":[{"text":"Verify ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["curl http:\/\/10.0.1.50:8484\/health"]},{"anchor":"Provisioning-failed","text":"Provisioning failed","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Check the VM events:","type":"text"}]},{"syntax":"bash","code":["kubectl describe mvm runner-01"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","interfaceLanguage":"swift"},"metadata":{"title":"Kubernetes Integration","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"role":"symbol","type":"topic","title":"VirtualMachineSpecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","kind":"symbol","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}],"navigatorTitle