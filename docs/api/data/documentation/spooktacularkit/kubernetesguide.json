h"}],[{"inlineContent":[{"type":"codeVoice","code":"ssh"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"disk-inject"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.script"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Shell script to execute","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.user"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"admin"}],"type":"paragraph"}],[{"inlineContent":[{"text":"SSH user","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeSelector"}],"type":"paragraph"}],[{"inlineContent":[{"text":"object","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Status Fields","anchor":"Status-Fields","level":3},{"type":"table","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"phase"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeName"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"message"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Human-readable status message","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Printer Columns","anchor":"Printer-Columns","level":3},{"type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash"},{"type":"heading","text":"Examples","anchor":"Examples","level":2},{"type":"heading","text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"type":"heading","text":"Remote Desktop","anchor":"Remote-Desktop","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"type":"heading","text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","level":3},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"type":"heading","text":"Controller Details","anchor":"Controller-Details","level":2},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"type":"heading","text":"Mac Node Setup","anchor":"Mac-Node-Setup","level":2},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"type":"heading","text":"Troubleshooting","anchor":"Troubleshooting","level":2},{"type":"heading","text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending","level":3},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports ma