───────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTP API on Mac nodes        │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTP :8484   │ HTTP :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}]},{"anchor":"Prerequisites","type":"heading","level":2,"text":"Prerequisites"},{"items":[{"content":[{"inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"type":"codeVoice","code":"kubectl"},{"text":" access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"type":"codeVoice","code":"spook serve --host 0.0.0.0"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Quick-Start","type":"heading","level":2,"text":"Quick Start"},{"anchor":"1-Apply-the-CRD","type":"heading","level":3,"text":"1. Apply the CRD"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing"},{"anchor":"2-Install-the-Helm-chart","type":"heading","level":3,"text":"2. Install the Helm chart"},{"syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing"},{"anchor":"3-Create-a-VM","type":"heading","level":3,"text":"3. Create a VM"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"type":"codeListing"},{"syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing"},{"anchor":"MacOSVM-CRD-Reference","type":"heading","level":2,"text":"MacOSVM CRD Reference"},{"anchor":"Spec-Fields","type":"heading","level":3,"text":"Spec Fields"},{"rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"sourceVM"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"(req