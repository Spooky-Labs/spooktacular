ode":"provisioning.user"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"admin","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH user"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeSelector"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"object"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}]}]]]},{"level":3,"type":"heading","text":"Status Fields","anchor":"Status-Fields"},{"type":"table","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"phase","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}]}]],[[{"inlineContent":[{"code":"ip","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Resolved VM IP address"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeName","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac host the VM is running on"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"message"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Human-readable status message","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}]}]]],"header":"row"},{"type":"heading","anchor":"Printer-Columns","level":3,"text":"Printer Columns"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"type":"codeListing","syntax":"bash"},{"anchor":"Examples","level":2,"type":"heading","text":"Examples"},{"anchor":"GitHub-Actions-Runner","level":3,"type":"heading","text":"GitHub Actions Runner"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"anchor":"Remote-Desktop","type":"heading","level":3,"text":"Remote Desktop"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Controller Details","type":"heading","anchor":"Controller-Details"},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Reconciler","type":"text"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"NodeManager","type":"text"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}]},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"level":2,"anchor":"Mac-Node-Setup","type":"heading","text":"Mac Node Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"level":2,"anchor":"Troubleshooting","type":"heading","text":"Troubleshooting"},{"level":3,"anchor":"VM-stuck-in-Pending","type":"heading","text":"VM stuck in Pending"},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"]},{"level":3,"anchor":"Connection-refused-to-Mac-node","type":"heading","text":"Connection refused to Mac node"},{"type":"paragraph","inlineContent":[{"text":"Verify ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" is running and the port is reachable:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["curl -k https:\/\/10.0.1.50:8484\/health"]},{"level":3,"anchor":"Provisioning-failed","type":"heading","text":"Provisioning failed"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the VM events:"}]},{"type":"codeListing","syntax":"bash","code":["kubectl describe mvm runner-01"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}]}],"kind":"content"}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Kubernetes Integration"},"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"title":"Related Guides"}],"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"role":"collectionGroup","type":"topic","title":"Machine Learning Workloads","url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"kind":"article","url":"\/documentation\/spooktacularkit\/clireference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","abstract":[{"text":"Manage m