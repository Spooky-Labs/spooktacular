{"inlineContent":[{"code":"phase","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeName","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mac host the VM is running on"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"message","type":"codeVoice"}]}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Human-readable status message"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}]}]]]},{"text":"Printer Columns","type":"heading","anchor":"Printer-Columns","level":3},{"syntax":"bash","type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"]},{"text":"Examples","type":"heading","anchor":"Examples","level":2},{"text":"GitHub Actions Runner","type":"heading","anchor":"GitHub-Actions-Runner","level":3},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}]},{"level":3,"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"anchor":"Ephemeral-Runner-Pool","type":"heading","level":3,"text":"Ephemeral Runner Pool"},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"anchor":"Controller-Details","type":"heading","level":2,"text":"Controller Details"},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"KubernetesClient"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reconciler"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"anchor":"Mac-Node-Setup","type":"heading","level":2,"text":"Mac Node Setup"},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTP API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for t