"text":" for the full example.","type":"text"}],"type":"paragraph"},{"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading","level":3},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","type":"heading","level":3},{"inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"text":"Controller Details","anchor":"Controller-Details","type":"heading","level":2},{"inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Reconciler","type":"text"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"MacOSVMResource","type":"text"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"level":2,"text":"Mac Node Setup","anchor":"Mac-Node-Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}]},{"syntax":"bash","type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"level":2,"anchor":"Troubleshooting","type":"heading","text":"Troubleshooting"},{"level":3,"anchor":"VM-stuck-in-Pending","type":"heading","text":"VM stuck in Pending"},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"]},{"level":3,"anchor":"Connection-refused-to-Mac-node","type":"heading","text":"Connection refused to Mac node"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}]},{"syntax":"bash","type":"codeListing","code":["curl -k https:\/\/10.0.1.50:8484\/health"]},{"level":3,"anchor":"Provisioning-failed","type":"heading","text":"Provisioning failed"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the VM events:"}]},{"syntax":"bash","type":"codeListing","code":["kubectl describe mvm runner-01"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}]}]}],"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes","url":"\/documentation\/spooktacularkit\/jenkinsguide","role":"collectionGroup","kind":"article","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","type":"topic","abstract":