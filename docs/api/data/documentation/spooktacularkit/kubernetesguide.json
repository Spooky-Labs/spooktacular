text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}],"type":"paragraph"},{"level":2,"text":"Prerequisites","anchor":"Prerequisites","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"type":"codeVoice","code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem"}]}]},{"content":[{"inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Quick-Start","text":"Quick Start"},{"level":3,"type":"heading","anchor":"1-Apply-the-CRD","text":"1. Apply the CRD"},{"syntax":"bash","type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"]},{"level":3,"type":"heading","anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart"},{"syntax":"bash","type":"codeListing","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"]},{"level":3,"type":"heading","anchor":"3-Create-a-VM","text":"3. Create a VM"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","