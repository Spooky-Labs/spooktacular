}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}]}]]]},{"type":"heading","anchor":"Printer-Columns","text":"Printer Columns","level":3},{"type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash"},{"type":"heading","anchor":"Examples","text":"Examples","level":2},{"type":"heading","anchor":"GitHub-Actions-Runner","text":"GitHub Actions Runner","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"type":"heading","anchor":"Remote-Desktop","text":"Remote Desktop","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"type":"heading","anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","level":3},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"type":"heading","anchor":"Controller-Details","text":"Controller Details","level":2},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"type":"heading","anchor":"Mac-Node-Setup","text":"Mac Node Setup","level":2},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting","level":2},{"type":"heading","anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","level":3},{"inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"type":"heading","anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","level":3},{"inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"type":"codeListing","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash"},{"type":"heading","anchor":"Provisioning-failed","t