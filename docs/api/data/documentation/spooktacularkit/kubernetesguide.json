ktacularKit\/Versioning"],"anchor":"Guides"}],"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"topicSections":[{"title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"anchor":"Related-Guides"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"code":"MacOSVM","type":"codeVoice"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}],"type":"paragraph"},{"anchor":"Architecture","level":3,"text":"Architecture","type":"heading"},{"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}],"type":"paragraph"},{"anchor":"Prerequisites","level":2,"text":"Prerequisites","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":" access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"type":"codeVoice","code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"anchor":"Quick-Start","level":2,"text":"Quick Start","type":"heading"},{"anchor":"1-Apply-the-CRD","level":3,"text":"1. Apply the CRD","type":"heading"},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash","type":"codeListing"},{"anchor":"2-Install-the-Helm-chart","level":3,"text":"2. Install the Helm chart","type":"heading"},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"syntax":"bash","type":"codeListing"},{"anchor":"3-Create-a-VM","level":3,"text":"3. Create a VM","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"syntax":"yaml","type":"codeListing"},{"code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"syntax":"bash","type":"codeListing"},{"anchor":"MacOSVM-CRD-Reference","level":2,"text":"MacOSVM CRD Reference","type":"heading"},{"anchor":"Spec-Fields","level":3,"text":"Spec Fields","type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Field"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceVM"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(required)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Base VM to clone from"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cpu"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"integer"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Virtual CPU cores"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"memoryInGigabytes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"integer"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"8"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"RAM in GB"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"diskInGigabytes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"integer"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"64"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk size in GB"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"network"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nat"},{"type":"text","text":", "},{"type":"codeVoice","code":"isolated"},{"type":"text","text":", or "},{"type":"codeVoice","code":"bridged:<interface>"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ephemeral"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"boolean"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"false"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Delete VM when it stops"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"template"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"github-runner"},{"type":"text","text":", "},{"type":"codeVoice","code":"remote-desktop"},{"type":"text","text":", or "},{"type":"codeVoice","code":"openclaw"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"provisioning.mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ssh"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ssh"},{"type":"text","text":" or "},{"type":"codeVoice","code":"disk-inject"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"provisioning.script"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shell script to execute"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"provisioning.user"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"admin"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH user"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nodeSelector"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"object"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Match Mac nodes by labels"}]}]]],"type":"table"},{"anchor":"Status-Fields","level":3,"text":"Status Fields","type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Field"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"phase"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolved VM IP address"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nodeName"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mac host the VM is running on"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"message"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Human-readable status message"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}]}]]],"type":"table"},{"anchor":"Printer-Columns","level":3,"text":"Printer Columns","type":"heading"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash","type":"codeListing"},{"anchor":"Examples","level":2,"text":"Examples","type":"heading"},{"anchor":"GitHub-Actions-Runner","level":3,"text":"GitHub Actions Runner","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Remote-Desktop","level":3,"text":"Remote Desktop","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Ephemeral-Runner-Pool","level":3,"text":"Ephemeral Runner Pool","type":"heading"},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"anchor":"Controller-Details","level":2,"text":"Controller Details","type":"heading"},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"KubernetesClient"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reconciler"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"NodeManager"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"anchor":"Mac-Node-Setup","level":2,"text":"Mac Node Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}],"type":"paragraph"},{"code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash","type":"codeListing"},{"anchor":"Troubleshooting","level":2,"text":"Troubleshooting","type":"heading"},{"anchor":"VM-stuck-in-Pending","level":3,"text":"VM stuck in Pending","type":"heading"},{"inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}],"type":"paragraph"},{"code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash","type":"codeListing"},{"anchor":"Connection-refused-to-Mac-node","level":3,"text":"Connection refused to Mac node","type":"heading"},{"inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash","type":"codeListing"},{"anchor":"Provisioning-failed","level":3,"text":"Provisioning failed","type":"heading"},{"inlineContent":[{"type":"text","text":"Check the VM events:"}],"type":"paragraph"},{"code":["kubectl describe mvm runner-01"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}],"type":"paragraph"}]}],"kind":"article","metadata":{"title":"Kubernetes Integration","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"role":"collectionGroup","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"type":"topic","url":"\/documentation\/spooktacularkit\/mlworkloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"role":"collectionGroup","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"type":"topic","url":"\/documentation\/spooktacula