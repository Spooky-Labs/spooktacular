 containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}]},{"level":2,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":" access"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Quick Start","anchor":"Quick-Start"},{"level":3,"type":"heading","text":"1. Apply the CRD","anchor":"1-Apply-the-CRD"},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"]},{"level":3,"type":"heading","text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart"},{"type":"codeListing","syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"]},{"level":3,"type":"heading","text":"3. Create a VM","anchor":"3-Create-a-VM"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"]},{"level":2,"type":"heading","text":"MacOSVM CRD Reference","anchor":"MacOSVM-CRD-Reference"},{"level":3,"type":"heading","text":"Spec Fields","anchor":"Spec-Fields"},{"type":"table","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"sourceVM","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"(required)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Base VM to clone from","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"cpu","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Virtual CPU cores","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"memoryInGigabytes","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RAM in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"diskInGigabytes","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"64","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Disk size in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"network","type":"codeVo