ode Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTP API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}]},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"anchor":"Troubleshooting","text":"Troubleshooting","type":"heading","level":2},{"anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}]},{"type":"codeListing","code":["curl http:\/\/10.0.1.50:8484\/health"],"syntax":"bash"},{"anchor":"Provisioning-failed","text":"Provisioning failed","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Check the VM events:","type":"text"}]},{"type":"codeListing","code":["kubectl describe mvm runner-01"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Common causes: SSH no