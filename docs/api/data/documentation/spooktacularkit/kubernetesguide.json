ype":"codeVoice","code":"template"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"github-runner"},{"type":"text","text":", "},{"type":"codeVoice","code":"remote-desktop"},{"type":"text","text":", or "},{"type":"codeVoice","code":"openclaw"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ssh"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ssh"},{"type":"text","text":" or "},{"type":"codeVoice","code":"disk-inject"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.script"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Shell script to execute"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.user"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"admin"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"SSH user"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeSelector"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"object"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Match Mac nodes by labels"}],"type":"paragraph"}]]],"header":"row"},{"anchor":"Status-Fields","text":"Status Fields","type":"heading","level":3},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Field"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"phase"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Resolved VM IP address"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeName"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac host the VM is running on"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"message"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Human-readable status message"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}],"type":"paragraph"}]]],"header":"row"},{"anchor":"Printer-Columns","text":"Printer Columns","type":"heading","level":3},{"syntax":"bash","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"type":"codeListing"},{"anchor":"Examples","text":"Examples","type":"heading","level":2},{"anchor":"GitHub-Actions-Runner","text":"GitHub Actions Runner","type":"heading","level":3},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Remote-Desktop","text":"Remote Desktop","type":"heading","level":3},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"anchor":"Controller-Details","text":"Controller Details","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"MacOSVMResource"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"anchor":"Mac-Node-Setup","text":"Mac Node Setup","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing"},{"anchor":"Troubleshooting","text":"Troubleshooting","type":"heading","level":2},{"anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing"},{"anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"syntax":"bash","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"type":"codeListing"},{"anchor":"Provisioning-failed","text":"Provisioning failed","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Check the VM events:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl describe mvm runner-01"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}],"type":"paragraph"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"titl