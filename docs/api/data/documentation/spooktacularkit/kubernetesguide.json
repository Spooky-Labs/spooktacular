─┘"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}]},{"type":"heading","level":2,"anchor":"Prerequisites","text":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":" access"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"type":"codeVoice","code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Quick-Start","text":"Quick Start"},{"type":"heading","level":3,"anchor":"1-Apply-the-CRD","text":"1. Apply the CRD"},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart"},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"3-Create-a-VM","text":"3. Create a VM"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"type":"codeListing","syntax":"yaml"},{"code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":2,"anchor":"MacOSVM-CRD-Reference","text":"MacOSVM CRD Reference"},{"type":"heading","level":3,"anchor":"Spec-Fields","text":"Spec Fields"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceVM"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"(required)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Base VM to clone from","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cpu"}]}],[{"type":"paragraph","inlineContent":[{"text":"integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Virtual CPU cores","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"memoryInGigabytes"}]}],[{"type":"paragraph","inlineContent":[{"text":"integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8","type":"text"}]}],[{"type":"paragraph",