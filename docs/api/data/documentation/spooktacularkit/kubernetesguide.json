","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"disk-inject","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.script","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Shell script to execute","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.user","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"admin","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"SSH user","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeSelector","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"object","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}]}]]],"header":"row","type":"table"},{"text":"Status Fields","level":3,"type":"heading","anchor":"Status-Fields"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Field"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"phase"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Resolved VM IP address"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeName"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac host the VM is running on"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"message"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Human-readable status message"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Printer Columns","level":3,"type":"heading","anchor":"Printer-Columns"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash","type":"codeListing"},{"text":"Examples","level":2,"type":"heading","anchor":"Examples"},{"text":"GitHub Actions Runner","level":3,"type":"heading","anchor":"GitHub-Actions-Runner"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ep