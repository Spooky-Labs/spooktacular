aph"}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"nodeName","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"message","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Human-readable status message","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]]},{"level":3,"text":"Printer Columns","type":"heading","anchor":"Printer-Columns"},{"code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"type":"codeListing","syntax":"bash"},{"level":2,"text":"Examples","type":"heading","anchor":"Examples"},{"level":3,"text":"GitHub Actions Runner","type":"heading","anchor":"GitHub-Actions-Runner"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}]},{"level":3,"text":"Remote Desktop","type":"heading","anchor":"Remote-Desktop"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}]},{"level":3,"text":"Ephemeral Runner Pool","type":"heading","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}]},{"level":2,"text":"Controller Details","type":"heading","anchor":"Controller-Details"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"text":" — Codable types matching the CRD schema","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}]},{"level":2,"text":"Mac Node Setup","type":"heading","anchor":"Mac-Node-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}]},{"code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}]},{"code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing","syntax":"bash"},{"level":2,"text":"Troubleshooting","type":"heading","anchor":"Troubleshooting"},{"level":3,"text":"VM stuck in Pending","type":"heading","anchor":"VM-stuck-in-Pending"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}]},{"code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing","syntax":"bash"},{"level":3,"text":"Connection refused to Mac node","type":"heading","anchor":"Connection-refused-to-Mac-node"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}]},{"code":["curl -k https:\/\/10.0.1.50:8484\/health"],"type":"codeListing","syntax":"bash"},{"level":3,"text":"Provisioning failed","type":"heading","anchor":"Provisioning-failed"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the VM events:"}]},{"code":["kubectl describe mvm runner-01"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","url":"\/documentation\/spooktacularkit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/Spoo