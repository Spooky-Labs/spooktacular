g","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"level":3,"type":"heading","text":"Printer Columns","anchor":"Printer-Columns"},{"type":"codeListing","syntax":"bash","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"]},{"level":2,"type":"heading","text":"Examples","anchor":"Examples"},{"level":3,"type":"heading","text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}]},{"level":3,"type":"heading","text":"Remote Desktop","anchor":"Remote-Desktop"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}]},{"level":3,"type":"heading","text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}]},{"level":2,"type":"heading","text":"Controller Details","anchor":"Controller-Details"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"KubernetesClient","type":"text"}],"type":"strong"},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Reconciler","type":"text"}],"type":"strong"},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"NodeManager","type":"text"}],"type":"strong"},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"MacOSVMResource","type":"text"}],"type":"strong"},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}]},{"level":2,"type":"heading","text":"Mac Node Setup","anchor":"Mac-Node-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}]},{"type":"codeListing","syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"level":2,"type":"heading","text":"Troubleshooting","anchor":"Troubleshooting"},{"level":3,"type":"heading","text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}]},{"type":"codeListing","syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"]},{"level":3,"type":"heading","text":"Connection refused to Mac node","anchor":"Connection-refused-to-Mac-node"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}]},{"type":"codeListing","syntax":"bash","code":["curl -k https:\/\/10.0.1.50:8484\/health"]}