e --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Quick-Start","text":"Quick Start"},{"level":3,"type":"heading","anchor":"1-Apply-the-CRD","text":"1. Apply the CRD"},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash"},{"level":3,"type":"heading","anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart"},{"type":"codeListing","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"syntax":"bash"},{"level":3,"type":"heading","anchor":"3-Create-a-VM","text":"3. Create a VM"},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"syntax":"yaml"},{"type":"codeListing","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"syntax":"bash"},{"level":2,"type":"heading","anchor":"MacOSVM-CRD-Reference","text":"MacOSVM CRD Reference"},{"level":3,"type":"heading","anchor":"Spec-Fields","text":"Spec Fields"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"sourceVM","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","in