":"ssh"},{"type":"text","text":" or "},{"type":"codeVoice","code":"disk-inject"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"provisioning.script"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shell script to execute"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"provisioning.user"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"admin"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH user"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nodeSelector"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"object"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Match Mac nodes by labels"}]}]]]},{"anchor":"Status-Fields","type":"heading","level":3,"text":"Status Fields"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Field"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"phase"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolved VM IP address"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nodeName"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mac host the VM is running on"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"message"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Human-readable status message"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 8601 timestamp"}]}]]]},{"anchor":"Printer-Columns","type":"heading","level":3,"text":"Printer Columns"},{"type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash"},{"anchor":"Examples","type":"heading","level":2,"text":"Examples"},{"anchor":"GitHub-Actions-Runner","type":"heading","level":3,"text":"GitHub Actions Runner"},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"type":"text","text":" for the full example."}]},{"anchor":"Remote-Desktop","type":"heading","level":3,"text":"Remote Desktop"},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}]},{"anchor":"Ephemeral-Runner-Pool","type":"heading","level":3,"text":"Ephemeral Runner Pool"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}]},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}]},{"anchor":"Controller-Details","type":"heading","level":2,"text":"Controller Details"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift controller ("},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"type":"text","text":") consists of:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"MacOSVMResource"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}]},{"anchor":"Mac-Node-Setup","type":"heading","level":2,"text":"Mac Node Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}]},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}]},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"anchor":"Troubleshooting","type":"heading","level":2,"text":"Troubleshooting"},{"anchor":"VM-stuck-in-Pending","type":"heading","level":3,"text":"VM stuck in Pending"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}]},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"anchor":"Connection-refused-to-Mac-node","type":"heading","level":3,"text":"Connection refused to Mac node"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}]},{"type":"codeListing","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash"},{"anchor":"Provisioning-failed","type":"heading","level":3,"text":"Provisioning failed"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the VM events:"}]},{"type":"codeListing","code":["kubectl describe mvm runner-01"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}]}],"kind":"content"}],"topicSections":[{"title":"Related Guides","anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/bluebubblesguide","title":"Running BlueBubbles iMessage Server","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","kind":"article","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"role":"collectionGroup","title":"Configuring GitHub Actions Runners"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","role":"collection","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/openclawguide","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIRefe