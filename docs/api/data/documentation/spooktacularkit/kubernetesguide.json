────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"]},{"type":"paragraph","inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}]},{"type":"heading","level":2,"text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Quick Start","anchor":"Quick-Start"},{"type":"heading","level":3,"text":"1. Apply the CRD","anchor":"1-Apply-the-CRD"},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"]},{"type":"heading","level":3,"text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart"},{"type":"codeListing","syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"]},{"type":"heading","level":3,"text":"3. Create a VM","anchor":"3-Create-a-VM"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"]},{"type":"heading","level":2,"text":"MacOSVM CRD Reference","anchor":"MacOSVM-CRD-Reference"},{"type":"heading","level":3,"text":"Spec Fields","anchor":"Spec-Fields"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Field"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"sourceVM","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"(required)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Base VM to clone from"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"cpu","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"integer"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4"}],"ty