cumentation\/SpooktacularKit\/Versioning"],"title":"Guides","anchor":"Guides"}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular Kubernetes operator lets you manage macOS VMs","type":"text"},{"text":" ","type":"text"},{"text":"declaratively with ","type":"text"},{"type":"codeVoice","code":"kubectl"},{"text":". The Swift controller watches","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"MacOSVM"},{"text":" custom resources and reconciles them by calling the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular HTTP API on your Mac nodes.","type":"text"}]},{"type":"heading","anchor":"Architecture","text":"Architecture","level":3},{"type":"codeListing","code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}]},{"type":"heading","anchor":"Prerequisites","text":"Prerequisites","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"type":"codeVoice","code":"kubectl"},{"text":" access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"type":"codeVoice","code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Quick-Start","text":"Quick Start","level":2},{"type":"heading","anchor":"1-Apply-the-CRD","text":"1. Apply the CRD","level":3},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash"},{"type":"heading","anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart","level":3},{"type":"codeListing","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"syntax":"bash"},{"type":"heading","anchor":"3-Create-a-VM","text":"3. Create a VM","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"syntax":"yaml"},{"type":"codeListing","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"syntax":"bash"},{"type":"heading","anchor":"MacOSVM-CRD-Reference","text":"MacOSVM CRD Reference","level":2},{"type":"heading","anchor":"Spec-Fields","text":"Spec Fields","level":3},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"sourceVM"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"(required)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Base VM to clone from","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"cpu"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Virtual CPU cores","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"memoryInGigabytes"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RAM in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"diskInGigabytes"}],"type":"paragraph"}],[{"inlineContent":[{"text":"integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"64","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Disk size in GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"network"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"nat"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"nat"},{"text":", ","type":"text"},{"type":"codeVoice","code":"isolated"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"bridged:<interface>"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ephemeral"}],"type":"paragraph"}],[{"inlineContent":[{"text":"boolean","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"false","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Delete VM when it stops","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"template"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"github-runner"},{"text":", ","type":"text"},{"type":"codeVoice","code":"remote-desktop"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"openclaw"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.mode"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ssh"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ssh"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"disk-inject"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.script"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Shell script to execute","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"provisioning.user"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"admin"}],"type":"paragraph"}],[{"inlineContent":[{"text":"SSH user","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeSelector"}],"type":"paragraph"}],[{"inlineContent":[{"text":"object","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","anchor":"Status-Fields","text":"Status Fields","level":3},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Field","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"phase"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ip"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Resolved VM IP address","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"nodeName"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac host the VM is running on","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"message"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Human-readable status message","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"lastTransitionTime"}],"type":"paragraph"}],[{"inlineContent":[{"text":"string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","anchor":"Printer-Columns","text":"Printer Columns","level":3},{"type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash"},{"type":"heading","anchor":"Examples","text":"Examples","level":2},{"type":"heading","anchor":"GitHub-Actions-Runner","text":"GitHub Actions Runner","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}]},{"type":"heading","anchor":"Remote-Desktop","text":"Remote Desktop","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"text":" for the full example.","type":"text"}]},{"type":"heading","anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","level":3},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"type":"heading","anchor":"Controller-Details","text":"Controller Details","level":2},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"KubernetesClient","type":"text"}]},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Reconciler","type":"text"}]},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"NodeManager","type":"text"}]},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"MacOSVMResource","type":"text"}]},{"type":"text","text":" — Codable types matching the CRD schema"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"type":"heading","anchor":"Mac-Node-Setup","text":"Mac Node Setup","level":2},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":":","type":"text"}]},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting","level":2},{"type":"heading","anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","level":3},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"type":"heading","anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","level":3},{"type":"paragraph","inlineContent":[{"text":"Verify ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" is running and the port is reachable:","type":"text"}]},{"type":"codeListing","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash"},{"type":"heading","anchor":"Provisioning-failed","text":"Provisioning failed","level":3},{"type":"paragraph","inlineContent":[{"text":"Check the VM events:","type":"text"}]},{"type":"codeListing","code":["kubectl describe mvm runner-01"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"metadata":{"role":"collectionGroup","title":"Kubernetes Integration","modules":[{"name":"SpooktacularKit"}]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"title":"Related Guides","anchor":"Related-Guides"}],"kind":"article","sections":[],"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/kubernetesguide"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"url":"\/documentation\/spooktacularkit\/openclawguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","role":"collectionGroup","type":"topic","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","type":"topic","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","type":"topic","kind":"symbol","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","role":"collectionGroup","type":"topic","title":"Machine Learning Workloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"url":"\/documentation\/spooktacularkit\/bluebubblesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","role":"collectionGroup","type":"topic","title":"Running BlueBubbles iMessage Server","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","role":"collectionGroup","type":"topic","title":"Deploying on EC2 Mac","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDe