n\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"code":"MacOSVM","type":"codeVoice"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}],"type":"paragraph"},{"level":3,"text":"Architecture","anchor":"Architecture","type":"heading"},{"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}],"type":"paragraph"},{"level":2,"text":"Prerequisites","anchor":"Prerequisites","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":" access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"level":3,"text":"1. Apply the CRD","anchor":"1-Apply-the-CRD","type":"heading"},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash","type":"codeListing"},{"level":3,"text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart","type":"heading"},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/s