ull example."}]},{"level":3,"type":"heading","text":"Remote Desktop","anchor":"Remote-Desktop"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}]},{"level":3,"type":"heading","text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool"},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"level":2,"type":"heading","text":"Controller Details","anchor":"Controller-Details"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift controller ("},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"KubernetesClient","type":"text"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"NodeManager","type":"text"}],"type":"strong"},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MacOSVMResource"}]},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}]},{"level":2,"text":"Mac Node Setup","type":"heading","anchor":"Mac-Node-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}]},{"syntax":"bash","type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading","level":2},{"text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"t