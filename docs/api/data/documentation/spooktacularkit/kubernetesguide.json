────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"]},{"inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"type":"text","text":" "},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"type":"text","text":" "},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Prerequisites","text":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":" access"}]}]},{"content":[{"inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Quick-Start","text":"Quick Start","level":2},{"type":"heading","anchor":"1-Apply-the-CRD","text":"1. Apply the CRD","level":3},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing","syntax":"bash"},{"anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart","type":"heading","level":3},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"syntax":"bash","type":"codeListing"},{"text":"3. Create a VM","level":3,"anchor":"3-Create-a-VM","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"syntax":"yaml","type":"codeListing"},{"code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing","syntax":"bash"},{"level":2,"anchor":"MacOSVM-CRD-Reference","type":"heading","text":"MacOSVM CRD Reference"},{"level":3,"anchor":"Spec-Fields","type":"heading","text":"Spec Fields"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"sourceVM"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"string"}],"type":"paragraph"}],[{"in