"heading","level":2},{"text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner","type":"heading","level":3},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading","level":3},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}],"type":"paragraph"},{"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}],"type":"paragraph"},{"text":"Cont