ice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.mode","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"disk-inject","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.script","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Shell script to execute","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.user","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"admin","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"SSH user","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeSelector","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"object","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}]}]]]},{"text":"Status Fields","anchor":"Status-Fields","type":"heading","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"phase","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ip","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Resolved VM IP address","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeName","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Mac host the VM is running on","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"message","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Human-readable status message","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}]}]]]},{"text":"Printer Columns","anchor":"Printer-Columns","type":"heading","level":3},{"type":"codeListing","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"],"syntax":"bash"},{"text":"Examples","anchor":"Examples","type":"heading","level":2},{"text":"GitHub Actions Runner","anchor":"GitHub-Actions-Runner","type":"heading","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"syntax":"yaml"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading","level":3},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"syntax":"yaml"},{"inlineContent":[{"type":"text","text":"See "},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"text":"Controller Details","anchor":"Controller-Details","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"MacOSVMResource"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"text":"Mac Node Setup","anchor":"Mac-Node-Setup","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"syntax":"bash"},{"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading","level":2},{"text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"syntax":"bash"},{"text":"Connection refused to Mac node","anchor":"Connection-refused-to-Mac-node","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Verify "},{"code":"spook serve","type":"codeVoice"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"type":"codeListing","code":["curl -k https:\/\/10.0.1.50:8484\/health"],"syntax":"bash"},{"text":"Provisioning failed","anchor":"Provisioning-failed","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Check the VM events:"}],"type":"paragraph"},{"type":"codeListing","code":["kubectl describe mvm runner-01"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","role":"collection","title":"SpooktacularKit","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"url":"\/documentation\/spooktacularkit\/jenkinsguide","identifier":"doc:\/\/Spooktac