\/JenkinsGuide"],"anchor":"Related-Guides","title":"Related Guides"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","title":"Guides"}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"type":"codeVoice","code":"MacOSVM"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}],"type":"paragraph"},{"type":"heading","text":"Architecture","level":3,"anchor":"Architecture"},{"type":"codeListing","code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"syntax":null},{"inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}],"type":"paragraph"},{"type":"heading","text":"Prerequisites","level":2,"anchor":"Prerequisites"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":" access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"type":"text","text":")"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Quick Start","level":2,"anchor":"Quick-Start"},{"type":"heading","text":"1. Apply the CRD","level":3,"anchor":"1-Apply-the-CRD"},{"type":"codeListing","co