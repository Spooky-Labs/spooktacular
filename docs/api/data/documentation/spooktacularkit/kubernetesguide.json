ioning"],"title":"Guides","anchor":"Guides"}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"title":"Related Guides","anchor":"Related-Guides"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular Kubernetes operator lets you manage macOS VMs","type":"text"},{"text":" ","type":"text"},{"text":"declaratively with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":". The Swift controller watches","type":"text"},{"text":" ","type":"text"},{"code":"MacOSVM","type":"codeVoice"},{"text":" custom resources and reconciles them by calling the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular HTTP API on your Mac nodes.","type":"text"}]},{"type":"heading","text":"Architecture","anchor":"Architecture","level":3},{"type":"codeListing","code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"The controller runs on a Linux node in your cluster. Mac nodes","type":"text"},{"text":" ","type":"text"},{"text":"run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}]},{"type":"heading","text":"Prerequisites","anchor":"Prerequisites","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":" access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"type":"codeVoice","code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"type":"codeVoice","code":"spook create base --from-ipsw latest"},{"type":"text","text":")"}]}]}]},{"type":"heading","text":"Quick Start","anchor":"Quick-Start","level":2},{"type":"heading","text":"1. Apply the CRD","anchor":"1-Apply-the-CRD","level":3},{"type":"codeListing","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"syntax":"bash"},{"type":"heading","text":"2. Install the Helm chart","anchor":"2-Install-the-Helm-chart","level":3},{"type":"codeListing","code":["helm install spooktacular dep