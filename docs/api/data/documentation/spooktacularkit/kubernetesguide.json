doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"sections":[],"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"kind":"article","topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"],"title":"Related Guides"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The Spooktacular Kubernetes operator lets you manage macOS VMs"},{"type":"text","text":" "},{"type":"text","text":"declaratively with "},{"type":"codeVoice","code":"kubectl"},{"type":"text","text":". The Swift controller watches"},{"type":"text","text":" "},{"type":"codeVoice","code":"MacOSVM"},{"type":"text","text":" custom resources and reconciles them by calling the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular HTTP API on your Mac nodes."}],"type":"paragraph"},{"level":3,"anchor":"Architecture","text":"Architecture","type":"heading"},{"syntax":null,"code":["┌────────────────────────────────────────────┐","│  Kubernetes Cluster (Linux)                │","│                                            │","│  ┌──────────────────────────────────────┐  │","│  │  spook-controller (Deployment)       │  │","│  │  Watches MacOSVM CRDs               │  │","│  │  Calls HTTPS API on Mac nodes       │  │","│  └──────────┬──────────────┬────────────┘  │","└─────────────│──────────────│───────────────┘","              │ HTTPS :8484  │ HTTPS :8484","     ┌────────▼──────┐  ┌───▼───────────┐","     │  Mac Host 01  │  │  Mac Host 02  │","     │  spook serve  │  │  spook serve  │","     │  ┌────┐┌────┐ │  │  ┌────┐┌────┐ │","     │  │VM-1││VM-2│ │  │  │VM-3││VM-4│ │","     │  └────┘└────┘ │  │  └────┘└────┘ │","     └───────────────┘  └───────────────┘"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The controller runs on a Linux node in your cluster. Mac nodes"},{"type":"text","text":" "},{"type":"text","text":"run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" natively as a LaunchDaemon (not as a pod —"},{"type":"text","text":" "},{"type":"text","text":"Mac nodes can’t run OCI containers). Each Mac supports up to"},{"type":"text","text":" "},{"type":"text","text":"2 concurrent VMs per Apple’s EULA Section 2B(iii)."}],"type":"paragraph"},{"level":2,"anchor":"Prerequisites","text":"Prerequisites","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A Kubernetes cluster (v1.26+) with ","type":"text"},{"code":"kubectl","type":"codeVoice"},{"text":" access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"One or more Apple Silicon Macs running ","type":"text"},{"code":"spook serve --host 0.0.0.0 --tls-cert cert.pem --tls-key key.pem","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Helm v3 for installing the operator","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A base VM on each Mac (created with ","type":"text"},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"text":")","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Quick-Start","text":"Quick Start","type":"heading"},{"level":3,"anchor":"1-Apply-the-CRD","text":"1. Apply the CRD","type":"heading"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing"},{"level":3,"anchor":"2-Install-the-Helm-chart","text":"2. Install the Helm chart","type":"heading"},{"syntax":"bash","code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing"},{"level":3,"anchor":"3-Create-a-VM","text":"3. Create a VM","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: runner-01","  namespace: default","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  diskInGigabytes: 64","  network: nat","  ephemeral: false","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      echo \"Hello from Kubernetes!\""],"type":"codeListing"},{"syntax":"bash","code":["kubectl apply -f runner-01.yaml","kubectl get mvm -w"],"type":"codeListing"},{"level":2,"anchor":"MacOSVM-CRD-Reference","text":"MacOSVM CRD Reference","type":"heading"},{"level":3,"anchor":"Spec-Fields","text":"Spec Fields","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"sourceVM","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"(required)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Base VM to clone from","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"cpu","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"tex