}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"ssh","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"disk-inject","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.script","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Shell script to execute","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"provisioning.user","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"admin","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"SSH user","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeSelector","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"object","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Match Mac nodes by labels","type":"text"}]}]]],"header":"row","type":"table"},{"anchor":"Status-Fields","level":3,"text":"Status Fields","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Field","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"phase","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Pending, Cloning, Starting, Running, Stopping, Failed, Deleted","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ip","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Resolved VM IP address","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nodeName","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Mac host the VM is running on","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"message","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Human-readable status message","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"lastTransitionTime","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"ISO 8601 timestamp","type":"text"}]}]]],"header":"row","type":"table"},{"anchor":"Printer-Columns","level":3,"text":"Printer Columns","type":"heading"},{"type":"codeListing","syntax":"bash","code":["kubectl get mvm","# NAME        PHASE     IP              NODE     AGE","# runner-01   Running   192.168.64.3    mac-01   5m","# runner-02   Running   192.168.64.4    mac-01   3m"]},{"anchor":"Examples","level":2,"text":"Examples","type":"heading"},{"anchor":"GitHub-Actions-Runner","level":3,"text":"GitHub Actions Runner","type":"heading"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: gha-runner-01","spec:","  sourceVM: base","  cpu: 4","  memoryInGigabytes: 8","  ephemeral: true","  template: github-runner","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      cd \/Users\/admin","      curl -o actions-runner.tar.gz -L \\","        https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"text":" for the full example.","type":"text"}]},{"anchor":"Remote-Desktop","level":3,"text":"Remote Desktop","type":"heading"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"text":" for the full example.","type":"text"}]},{"anchor":"Ephemeral-Runner-Pool","level":3,"text":"Ephemeral Runner Pool","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"]},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"anchor":"Controller-Details","level":2,"text":"Controller Details","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"text":") consists of:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"MacOSVMResource"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"anchor":"Mac-Node-Setup","level":2,"text":"Mac Node Setup","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"]},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"]},{"anchor":"Troubleshooting","level":2,"text":"Troubleshooting","type":"heading"},{"anchor":"VM-stuck-in-Pending","level":3,"text":"VM stuck in Pending","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"]},{"anchor":"Connection-refused-to-Mac-node","level":3,"text":"Connection refused to Mac node","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Verify ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" is running and the port is reachable:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["curl -k https:\/\/10.0.1.50:8484\/health"]},{"anchor":"Provisioning-failed","level":3,"text":"Provisioning failed","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Check the VM events:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["kubectl describe mvm runner-01"]},{"type":"paragraph","inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation