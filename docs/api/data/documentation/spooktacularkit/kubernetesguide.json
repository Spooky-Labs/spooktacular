  https:\/\/github.com\/actions\/runner\/releases\/latest\/download\/actions-runner-osx-arm64-2.x.x.tar.gz","      tar xzf actions-runner.tar.gz","      .\/config.sh --url https:\/\/github.com\/your-org\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/github-runner.yaml"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"level":3,"anchor":"Remote-Desktop","text":"Remote Desktop","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"deploy\/kubernetes\/examples\/remote-desktop.yaml"},{"type":"text","text":" for the full example."}],"type":"paragraph"},{"level":3,"anchor":"Ephemeral-Runner-Pool","text":"Ephemeral Runner Pool","type":"heading"},{"inlineContent":[{"type":"text","text":"Create multiple ephemeral runners using a multi-document YAML:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates 3 runners that auto-destroy after each job completes."}],"type":"paragraph"},{"level":2,"anchor":"Controller-Details","text":"Controller Details","type":"heading"},{"inlineContent":[{"type":"text","text":"The Swift controller ("},{"type":"codeVoice","code":"Sources\/spook-controller\/"},{"type":"text","text":") consists of:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"KubernetesClient","type":"text"}],"type":"strong"},{"type":"text","text":" — Reads service account credentials,"},{"type":"text","text":" "},{"type":"text","text":"makes authenticated requests to the K8s API"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Reconciler","type":"text"}],"type":"strong"},{"type":"text","text":" — List+watch pattern with auto-reconnection."},{"type":"text","text":" "},{"type":"text","text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),"},{"type":"text","text":" "},{"type":"text","text":"and DELETED (stop+delete) events"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"NodeManager","type":"text"}],"type":"strong"},{"type":"text","text":" — Discovers Mac nodes by label, maps to"},{"type":"text","text":" "},{"type":"text","text":"HTTP API endpoints, periodic health checks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"MacOSVMResource","type":"text"}],"type":"strong"},{"type":"text","text":" — Codable types matching the CRD schema"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The controller is stateless — all state lives in CRD status"},{"type":"text","text":" "},{"type":"text","text":"fields and on the Mac nodes themselves."}],"type":"paragraph"},{"level":2,"anchor":"Mac-Node-Setup","text":"Mac Node Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Each Mac node must run "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTP API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Label Mac nodes in Kubernetes for the controller to discover:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing"},{"level":2,"anchor":"Troubleshooting","text":"Troubleshooting","type":"heading"},{"level":3,"anchor":"VM-stuck-in-Pending","text":"VM stuck in Pending","type":"heading"},{"inlineContent":[{"type":"text","text":"No Mac node has available capacity. Each Mac supports max 2 VMs."},{"type":"text","text":" "},{"type":"text","text":"Check node status:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing"},{"level":3,"anchor":"Connection-refused-to-Mac-node","text":"Connection refused to Mac node","type":"heading"},{"inlineContent":[{"type":"text","text":"Verify "},{"type":"codeVoice","code":"spook serve"},{"type":"text","text":" is running and the port is reachable:"}],"type":"paragraph"},{"syntax":"bash","code":["curl http:\/\/10.0.1.50:8484\/health"],"type":"codeListing"},{"level":3,"anchor":"Provisioning-failed","text":"Provisioning failed","type":"heading"},{"inlineContent":[{"type":"text","text":"Check the VM events:"}],"type":"paragraph"},{"syntax":"bash","code":["kubectl describe mvm runner-01"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Common causes: SSH not enabled in the base VM, wrong"},{"type":"text","text":" "},{"type":"text","text":"provisioning mode, script errors."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/kubernetesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"title":"Deploying on EC2 Mac","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"fragments