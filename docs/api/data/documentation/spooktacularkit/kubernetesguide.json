rg\/repo \\","        --token YOUR_TOKEN --ephemeral","      .\/run.sh"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/github-runner.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"text":"Remote Desktop","anchor":"Remote-Desktop","type":"heading","level":3},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-01","spec:","  sourceVM: base","  cpu: 8","  memoryInGigabytes: 16","  template: remote-desktop","  network: \"bridged:en0\""],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"deploy\/kubernetes\/examples\/remote-desktop.yaml","type":"codeVoice"},{"text":" for the full example.","type":"text"}]},{"text":"Ephemeral Runner Pool","anchor":"Ephemeral-Runner-Pool","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Create multiple ephemeral runners using a multi-document YAML:","type":"text"}]},{"code":["kubectl apply -f deploy\/kubernetes\/examples\/ephemeral-pool.yaml"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"This creates 3 runners that auto-destroy after each job completes.","type":"text"}]},{"text":"Controller Details","anchor":"Controller-Details","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The Swift controller (","type":"text"},{"code":"Sources\/spook-controller\/","type":"codeVoice"},{"text":") consists of:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"KubernetesClient"}],"type":"strong"},{"text":" — Reads service account credentials,","type":"text"},{"text":" ","type":"text"},{"text":"makes authenticated requests to the K8s API","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reconciler"}],"type":"strong"},{"text":" — List+watch pattern with auto-reconnection.","type":"text"},{"text":" ","type":"text"},{"text":"Handles ADDED (clone+start), MODIFIED (retry\/resolve IP),","type":"text"},{"text":" ","type":"text"},{"text":"and DELETED (stop+delete) events","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"NodeManager"}],"type":"strong"},{"text":" — Discovers Mac nodes by label, maps to","type":"text"},{"text":" ","type":"text"},{"text":"HTTP API endpoints, periodic health checks","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"MacOSVMResource"}],"type":"strong"},{"text":" — Codable types matching the CRD schema","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The controller is stateless — all state lives in CRD status","type":"text"},{"text":" ","type":"text"},{"text":"fields and on the Mac nodes themselves.","type":"text"}]},{"text":"Mac Node Setup","anchor":"Mac-Node-Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Each Mac node must run ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["# Install Spooktacular","brew install --cask spooktacular","","# Create a base VM","spook create base --from-ipsw latest","","# Start the HTTPS API (bind to all interfaces for cluster access)","spook serve --host 0.0.0.0 --port 8484 \\","  --tls-cert \/etc\/spooktacular\/tls\/cert.pem \\","  --tls-key \/etc\/spooktacular\/tls\/key.pem","","# Or install as a service for persistence","sudo spook service install base  # for the base VM"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Label Mac nodes in Kubernetes for the controller to discover:","type":"text"}]},{"code":["kubectl label node mac-01 spooktacular.app\/role=mac-host"],"type":"codeListing","syntax":"bash"},{"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading","level":2},{"text":"VM stuck in Pending","anchor":"VM-stuck-in-Pending","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"No Mac node has available capacity. Each Mac supports max 2 VMs.","type":"text"},{"text":" ","type":"text"},{"text":"Check node status:","type":"text"}]},{"code":["kubectl logs -n spooktacular-system deployment\/spooktacular-operator"],"type":"codeListing","syntax":"bash"},{"text":"Connection refused to Mac node","anchor":"Connection-refused-to-Mac-node","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Verify ","type":"text"},{"code":"spook serve","type":"codeVoice"},{"text":" is running and the port is reachable:","type":"text"}]},{"code":["curl -k https:\/\/10.0.1.50:8484\/health"],"type":"codeListing","syntax":"bash"},{"text":"Provisioning failed","anchor":"Provisioning-failed","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Check the VM events:","type":"text"}]},{"code":["kubectl describe mvm runner-01"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Common causes: SSH not enabled in the base VM, wrong","type":"text"},{"text":" ","type":"text"},{"text":"provisioning mode, script errors.","type":"text"}]}]}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","kind":"article","role":"collectionGroup","title":"Deploying on EC2 Mac","abstract":[{"type":"text","text":"Run Spo