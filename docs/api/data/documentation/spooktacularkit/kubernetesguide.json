":"text"},{"text":"run ","type":"text"},{"type":"codeVoice","code":"spook serve"},{"text":" natively as a LaunchDaemon (not as a pod —","type":"text"},{"text":" ","type":"text"},{"text":"Mac nodes can’t run OCI containers). Each Mac supports up to","type":"text"},{"text":" ","type":"text"},{"text":"2 concurrent VMs per Apple’s EULA Section 2B(iii).","type":"text"}],"type":"paragraph"},{"text":"Prerequisites","level":2,"type":"heading","anchor":"Prerequisites"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A Kubernetes cluster (v1.26+) with "},{"code":"kubectl","type":"codeVoice"},{"type":"text","text":" access"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One or more Apple Silicon Macs running "},{"code":"spook serve --host 0.0.0.0","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Helm v3 for installing the operator"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM on each Mac (created with "},{"code":"spook create base --from-ipsw latest","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Quick Start","level":2,"type":"heading","anchor":"Quick-Start"},{"text":"1. Apply the CRD","level":3,"type":"heading","anchor":"1-Apply-the-CRD"},{"code":["kubectl apply -f deploy\/kubernetes\/crds\/macosvm-crd.yaml"],"type":"codeListing","syntax":"bash"},{"text":"2. Install the Helm chart","level":3,"type":"heading","anchor":"2-Install-the-Helm-chart"},{"code":["helm install spooktacular deploy\/kubernetes\/helm\/spooktacular\/ \\","  --namespace spooktacular-system \\","  --create-namespace \\","  --set macNodes[0].name=mac-01 \\","  --set macNodes[0].host=10.0.1.50 \\","  --set macNodes[0].port=8484"],"type":"codeListing","syntax":"bash"},{"level":3,"text":"3. Create a VM","anchor":"3-Create-a-VM","type":"heading"},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:"," 