{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular turns every Apple Silicon Mac into a GitHub Actions"},{"type":"text","text":" "},{"type":"text","text":"runner host that supports "},{"type":"strong","inlineContent":[{"text":"2 concurrent runners","type":"text"}]},{"text":" instead of 1.","type":"text"},{"text":" ","type":"text"},{"text":"Each runner runs inside an isolated macOS VM that can be destroyed","type":"text"},{"text":" ","type":"text"},{"text":"and recreated between jobs for a clean-room guarantee.","type":"text"}]},{"type":"heading","text":"Why Self-Hosted macOS Runners?","anchor":"Why-Self-Hosted-macOS-Runners","level":3},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Factor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GitHub-hosted"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Self-hosted (bare metal)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cost (per runner\/month)"}]}],[{"inlineContent":[{"type":"text","text":"~$2,400 (macOS L)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$780 (EC2 Mac)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390 (EC2 Mac, 2x)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Xcode version control"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Limited"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full"}]}],[{"type":"paragraph","inlineContent":[{"text":"Full","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware access (GPU, Neural Engine)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes (1 runner)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes (2 runners)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Clean environment per job"}]}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes (ephemeral VMs)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Queue time"}]}],[{"type":"paragraph","inlineContent":[{"text":"Minutes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Seconds"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Seconds"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scaling"}]}],[{"inlineContent":[{"type":"text","text":"Automatic"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Manual"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Automatic","type":"text"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular gives you the cost savings of self-hosted infrastructure"},{"type":"text","text":" "},{"type":"text","text":"with the clean-environment guarantees of GitHub-hosted runners."}]},{"type":"heading","text":"Quick Start: One Mac, Two Runners","anchor":"Quick-Start-One-Mac-Two-Runners","level":2},{"type":"paragraph","inlineContent":[{"text":"The fastest path from zero to two working GitHub Actions runners:","type":"text"}]},{"code":["# 1. Install Spooktacular","brew install --cask spooktacular","","# 2. Create two runner VMs","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --user-data ~\/github-runner-setup.sh \\","    --provision disk-inject","","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --user-data ~\/github-runner-setup.sh \\","    --provision disk-inject","","# 3. Start both runners headless","spook start runner-01 --headless","spook start runner-02 --headless"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where "},{"code":"github-runner-setup.sh","type":"codeVoice"},{"type":"text","text":" contains:"}]},{"type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","REPO=\"myorg\/myrepo\"","TOKEN=\"ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"","LABELS=\"macos,arm64,xcode16\"","","# Download the runner","cd \/Users\/admin","mkdir -p actions-runner && cd actions-runner","curl -o actions-runner.tar.gz -L \\","    \"https:\/\/github.com\/actions\/runner\/releases\/download\/v2.320.0\/actions-runner-osx-arm64-2.320.0.tar.gz\"","tar xzf actions-runner.tar.gz","","# Register with GitHub",".\/config.sh --url \"https:\/\/github.com\/$REPO\" \\","    --token \"$TOKEN\" \\","    --labels \"$LABELS\" \\","    --name \"$(hostname)\" \\","    --ephemeral \\","    --unattended","","# Install and start as a LaunchDaemon",".\/svc.sh install",".\/svc.sh start"],"syntax":"bash"},{"type":"heading","text":"The –github-runner Template","anchor":"The-github-runner-Template","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular includes a built-in ","type":"text"},{"type":"codeVoice","code":"github-runner"},{"type":"text","text":" template that"},{"type":"text","text":" "},{"type":"text","text":"automates all runner setup:"}]},{"type":"codeListing","code":["spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --github-runner --github-repo myorg\/myrepo --github-token ghp_xxxx"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"--github-runner","type":"codeVoice"},{"type":"text","text":" flag:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Downloads the latest GitHub Actions runner binary","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Registers the runner with your repository (or organization)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Configures labels for workflow targeting","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Installs the runner as a LaunchDaemon for automatic startup"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Optionally configures ephemeral mode for single-use VMs","type":"text"}]}]}]},{"type":"heading","text":"GitHub Runner Options","anchor":"GitHub-Runner-Options","level":3},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Option"}]}],[{"type":"paragraph","inlineContent":[{"text":"Required","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"--github-runner","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enables GitHub Actions runner setup"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"--github-repo <org\/repo>","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GitHub repository (e.g., "},{"type":"codeVoice","code":"myorg\/myrepo"},{"type":"text","text":")"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"--github-token <token>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GitHub PAT or registration token"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"--ephemeral","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runner exits after one job, VM auto-destroys"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Ephemeral Runners","anchor":"Ephemeral-Runners","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Ephemeral runners are destroyed and recreated after every job."},{"text":" ","type":"text"},{"text":"This guarantees a clean, unmodified environment for each CI run,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"eliminating “works on my runner” issues."}]},{"anchor":"How-Ephemeral-Mode-Works","type":"heading","level":3,"text":"How Ephemeral Mode Works"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"VM boots with a fresh macOS image","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Runner registers with GitHub using ","type":"text"},{"type":"codeVoice","code":"--ephemeral"},{"type":"text","text":" flag"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runner picks up one job and executes it"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Job completes, runner deregisters itself"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular destroys the VM"}]}]},{"content":[{"inlineContent":[{"text":"A new VM is created from the same base image","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Cycle repeats"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"CLI Setup","level":3,"anchor":"CLI-Setup","type":"heading"},{"syntax":"bash","code":["# Create an ephemeral runner that auto-replaces","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --github-runner --github-repo myorg\/myrepo --github-token ghp_xxxx \\","    --ephemeral"],"type":"codeListing"},{"anchor":"Kubernetes-Setup","type":"heading","text":"Kubernetes Setup","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: ephemeral-runners","spec:","  replicas: 4","  image: ghcr.io\/spooktacular\/macos-xcode:15.4-16.2","  template: github-runner","  templateArgs:","    repo: myorg\/myrepo","    token: ghp_xxxxxxxxxxxx","    labels: macos,arm64,xcode16","  ephemeral: true","  provisioning:","    mode: agent"]},{"type":"paragraph","inlineContent":[{"text":"The operator automatically replaces each VM after its job completes.","type":"text"}]},{"type":"heading","level":2,"text":"Runner Pool with Auto-Replacement","anchor":"Runner-Pool-with-Auto-Replacement"},{"inlineContent":[{"text":"For persistent (non-ephemeral) runners that still get replaced on","type":"text"},{"text":" ","type":"text"},{"text":"failure:","type":"text"}],"type":"paragraph"},{"code":["#!\/bin\/bash","# pool-manager.sh — runs on the Mac host","","POOL_SIZE=2","","while true; do","    for i in $(seq 1 $POOL_SIZE); do","        name=\"runner-$(printf '%02d' $i)\"","","        if ! spook list --json | jq -e \".[] | select(.name == \\\"$name\\\")\" > \/dev\/null 2>&1; then","            echo \"Replacing $name...\"","            spook clone base \"$name\"","            spook start \"$name\" --headless","        fi","    done","","    sleep 60","done"],"syntax":"bash","type":"codeListing"},{"anchor":"Webhook-Driven-Autoscaling","text":"Webhook-Driven Autoscaling","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Scale your runner pool based on actual demand using GitHub webhook","type":"text"},{"type":"text","text":" "},{"text":"events.","type":"text"}]},{"text":"Architecture","type":"heading","level":3,"anchor":"Architecture"},{"syntax":null,"type":"codeListing","code":["GitHub ──workflow_job event──▶ Webhook Receiver ──▶ Scale MacOSVMPool"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"type":"codeVoice","code":"workflow_job"},{"type":"text","text":" event with "},{"code":"action: queued","type":"codeVoice"},{"type":"text","text":" arrives, the"},{"type":"text","text":" "},{"type":"text","text":"autoscaler increases the pool size. When "},{"code":"action: completed","type":"codeVoice"},{"type":"text","text":", it"},{"type":"text","text":" "},{"text":"decreases after the idle timeout.","type":"text"}]},{"text":"Kubernetes Configuration","type":"heading","level":3,"anchor":"Kubernetes-Configuration"},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: autoscale-runners","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos-xcode:15.4-16.2","  template: github-runner","  templateArgs:","    repo: myorg\/myrepo","    token: ghp_xxxxxxxxxxxx","    labels: macos,arm64","  ephemeral: true","  scaling:","    minReplicas: 0","    maxReplicas: 8","    idleTimeout: 5m","    webhook:","      path: \/webhook\/github","      secret: github-webhook-secret"],"syntax":"yaml"},{"text":"GitHub Webhook Setup","type":"heading","level":3,"anchor":"GitHub-Webhook-Setup"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Go to your repository or organization Settings > Webhooks"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a webhook:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Payload URL:"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/your-operator.example.com\/webhook\/github"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Content type:"}]},{"type":"text","text":" "},{"code":"application\/json","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Secret:"}],"type":"strong"},{"type":"text","text":" The value in your "},{"code":"github-webhook-secret","type":"codeVoice"},{"type":"text","text":" K8s Secret"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Events:"}]},{"type":"text","text":" Select “Workflow jobs”"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"orderedList"},{"text":"Webhook Secret","type":"heading","level":3,"anchor":"Webhook-Secret"},{"type":"codeListing","code":["kubectl create secret generic github-webhook-secret \\","    --from-literal=secret=\"$(openssl rand -hex 32)\" \\","    -n spooktacular-system"],"syntax":"bash"},{"text":"GitHub App vs PAT for Runner Registration","type":"heading","level":2,"anchor":"GitHub-App-vs-PAT-for-Runner-Registration"},{"text":"Personal Access Token (PAT)","type":"heading","level":3,"anchor":"Personal-Access-Token-PAT"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Simpler to set up, but less secure for organizations:"}]},{"type":"codeListing","code":["# Fine-grained PAT with \"Administration\" repository permission (read\/write)","# Or classic PAT with \"repo\" scope","TOKEN=\"ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"","","spook create runner --from-ipsw latest \\","    --github-runner --github-repo myorg\/myrepo --github-token \"$TOKEN\""],"syntax":"bash"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Classic PATs with "},{"code":"repo","type":"codeVoice"},{"type":"text","text":" scope grant broad access. Prefer"},{"type":"text","text":" "},{"type":"text","text":"fine-grained PATs with only the “Administration” permission."}]}]},{"anchor":"GitHub-App-Recommended-for-Organizations","type":"heading","level":3,"text":"GitHub App (Recommended for Organizations)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"More secure — the app generates short-lived tokens:"}]},{"type":"codeListing","code":["# 1. Create a GitHub App with \"Self-hosted runners\" organization permission","# 2. Install the app on your organization","# 3. Generate an installation access token","","APP_ID=\"123456\"","PRIVATE_KEY_PATH=\".\/my-app.pem\"","INSTALLATION_ID=\"789012\"","","# Generate a JWT","JWT=$(python3 -c \"","import jwt, time","payload = {'iat': int(time.time()), 'exp': int(time.time()) + 600, 'iss': '$APP_ID'}","print(jwt.encode(payload, open('$PRIVATE_KEY_PATH').read(), algorithm='RS256'))","\")","","# Exchange for an installation token","TOKEN=$(curl -s -X POST \\","    -H \"Authorization: Bearer $JWT\" \\","    -H \"Accept: application\/vnd.github+json\" \\","    \"https:\/\/api.github.com\/app\/installations\/$INSTALLATION_ID\/access_tokens\" \\","    | jq -r .token)","","spook create runner --from-ipsw latest \\","    --github-runner --github-repo myorg\/myrepo --github-token \"$TOKEN\""],"syntax":"bash"},{"type":"heading","level":2,"anchor":"Xcode-Version-Management","text":"Xcode Version Management"},{"level":3,"anchor":"Multiple-Base-Images","type":"heading","text":"Multiple Base Images"},{"inlineContent":[{"type":"text","text":"Maintain base images for each Xcode version your projects need:"}],"type":"paragraph"},{"type":"codeListing","code":["# Create base images for different Xcode versions","spook create base-xcode15 --from-ipsw latest --cpu 4 --memory 8 --disk 100","spook start base-xcode15","# Install Xcode 15.4, accept license, run first launch","spook stop base-xcode15","","spook create base-xcode16 --from-ipsw latest --cpu 4 --memory 8 --disk 100","spook start base-xcode16","# Install Xcode 16.2, accept license, run first launch","spook stop base-xcode16","","# Clone runners from the appropriate base","spook clone base-xcode15 runner-xcode15-01","spook clone base-xcode16 runner-xcode16-01"],"syntax":"bash"},{"level":3,"anchor":"Using-Clones-for-Fast-Deployment","type":"heading","text":"Using Clones for Fast Deployment"},{"inlineContent":[{"type":"text","text":"Clone from a base VM with Xcode pre-installed:"}],"type":"paragraph"},{"syntax":"bash","code":["# Clone runners from the appropriate base","spook clone base-xcode15 runner-xcode15-01","spook clone base-xcode16 runner-xcode16-01"],"type":"codeListing"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"OCI image pull is on the roadmap. For now, create base VMs"},{"type":"text","text":" "},{"type":"text","text":"from IPSW, install Xcode manually, then clone for fast deployment."}],"type":"paragraph"}]},{"type":"heading","level":3,"anchor":"Workflow-Targeting","text":"Workflow Targeting"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use runner labels to target specific Xcode versions in your"},{"type":"text","text":" "},{"type":"text","text":"workflows:"}]},{"code":["# .github\/workflows\/build.yml","jobs:","  build-ios:","    runs-on: [self-hosted, macos, arm64, xcode16]","    steps:","      - uses: actions\/checkout@v4","      - run: xcodebuild -version","      - run: xcodebuild -scheme MyApp -sdk iphoneos build","","  build-legacy:","    runs-on: [self-hosted, macos, arm64, xcode15]","    steps:","      - uses: actions\/checkout@v4","      - run: xcodebuild -scheme MyApp -sdk iphoneos build"],"type":"codeListing","syntax":"yaml"},{"type":"heading","level":2,"anchor":"Scaling-with-Kubernetes","text":"Scaling with Kubernetes"},{"type":"heading","level":3,"anchor":"MacOSVMPool-for-GitHub-Actions","text":"MacOSVMPool for GitHub Actions"},{"type":"paragraph","inlineContent":[{"text":"The most robust scaling approach uses the Kubernetes operator with","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"code":"MacOSVMPool","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: xcode16-runners","  namespace: ci","spec:","  replicas: 6","  image: ghcr.io\/spooktacular\/macos-xcode:15.4-16.2","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  template: github-runner","  templateArgs:","    org: myorg","    token: ghp_xxxxxxxxxxxx","    labels: macos,arm64,xcode16","  ephemeral: true","  provisioning:","    mode: agent","  scaling:","    minReplicas: 2","    maxReplicas: 6","    idleTimeout: 10m","    webhook:","      path: \/webhook\/github","      secret: github-webhook-secret"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},{"type":"text","text":" for the full Kubernetes setup."}],"type":"paragraph"},{"level":2,"anchor":"EC2-Mac-Fleet-for-GitHub-Actions","text":"EC2 Mac Fleet for GitHub Actions","type":"heading"},{"inlineContent":[{"type":"text","text":"A complete production setup using EC2 Mac hosts:"}],"type":"paragraph"},{"level":3,"text":"Step 1: Provision EC2 Mac Hosts","type":"heading","anchor":"Step-1-Provision-EC2-Mac-Hosts"},{"code":["# terraform\/main.tf","module \"runner_fleet\" {","  source = \"spooktacular\/ec2-mac\/aws\"","","  host_count       = 5","  instance_type    = \"mac2-m2pro.metal\"","  subnet_ids       = module.vpc.private_subnets","  security_groups  = [aws_security_group.runners.id]","  key_name         = aws_key_pair.deploy.key_name","  vms_per_host     = 2","  vm_image         = \"ghcr.io\/spooktacular\/macos-xcode:15.4-16.2\"","  github_org       = \"myorg\"","  github_token_ssm = aws_ssm_parameter.github_token.name","}"],"syntax":"hcl","type":"codeListing"},{"anchor":"Step-2-Install-the-Kubernetes-Operator","level":3,"type":"heading","text":"Step 2: Install the Kubernetes Operator"},{"code":["helm install spooktacular-operator spooktacular\/operator \\","    --namespace spooktacular-system \\","    --create-namespace \\","    -f values.yaml"],"syntax":"bash","type":"codeListing"},{"anchor":"Step-3-Deploy-the-Runner-Pool","level":3,"type":"heading","text":"Step 3: Deploy the Runner Pool"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: production-runners","  namespace: ci","spec:","  replicas: 10","  image: ghcr.io\/spooktacular\/macos-xcode:15.4-16.2","  template: github-runner","  templateArgs:","    org: myorg","    token: ghp_xxxxxxxxxxxx","    labels: macos,arm64,xcode16,production","  ephemeral: true","  scaling:","    minReplicas: 4","    maxReplicas: 10","    idleTimeout: 15m"],"syntax":"yaml","type":"codeListing"},{"level":3,"text":"Capacity Planning","type":"heading","anchor":"Capacity-Planning"},{"rows":[[[{"inlineContent":[{"type":"text","text":"EC2 Mac hosts"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Instance type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runners"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Monthly cost (on-demand)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Per runner"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"mac2.metal (M1)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$2,340"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"5"}]}],[{"inlineContent":[{"type":"text","text":"mac2-m2pro.metal"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$3,900"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"mac2-m2pro.metal"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"20"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$7,800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"Compare to GitHub-hosted macOS runners at ~$2,400\/runner\/month (L size)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","isActive":true,"type":"reference"},{"type":"text","text":" for detailed EC2 Mac cost optimization."}],"type":"paragraph"},{"level":2,"text":"Cost Comparison","type":"heading","anchor":"Cost-Comparison"},{"level":3,"text":"Monthly Cost per macOS Runner","type":"heading","anchor":"Monthly-Cost-per-macOS-Runner"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Provider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runner type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cost\/month"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Clean env?"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GPU access?"}],"type":"paragraph"}]]