 ghp_xxxx\" \\","    \"https:\/\/api.github.com\/repos\/myorg\/myrepo\/actions\/runners\" | \\","    jq '.runners[] | {name, status, busy}'"],"syntax":"bash","type":"codeListing"},{"level":3,"text":"From Kubernetes","type":"heading","anchor":"From-Kubernetes"},{"code":["# Pool health","kubectl get macosvmpool -n ci","kubectl describe macosvmpool production-runners -n ci","","# Individual runner VMs","kubectl get macosvm -n ci","","# Operator logs","kubectl logs -n spooktacular-system deployment\/spooktacular-operator -f"],"type":"codeListing","syntax":"bash"},{"anchor":"Health-Check-Script","level":3,"type":"heading","text":"Health Check Script"},{"type":"codeListing","code":["#!\/bin\/bash","# check-runners.sh — verify runners are healthy","","REPO=\"myorg\/myrepo\"","TOKEN=\"ghp_xxxx\"","","runners=$(curl -s -H \"Authorization: token $TOKEN\" \\","    \"https:\/\/api.github.com\/repos\/$REPO\/actions\/runners\" | \\","    jq -r '.runners[] | \"\\(.name) \\(.status) \\(.busy)\"')","","echo \"Runner Status:\"","echo \"$runners\" | while read name status busy; do","    if [ \"$status\" = \"online\" ]; then","        echo \"  $name: online (busy=$busy)\"","    else","        echo \"  $name: OFFLINE — needs attention\"","    fi","done","","offline_count=$(echo \"$runners\" | grep -c \"offline\" || true)","if [ \"$offline_count\" -gt 0 ]; then","    echo \"\"","    echo \"WARNING: $offline_count runner(s) offline\"","    exit 1","fi"],"syntax":"bash"},{"type":"heading","anchor":"Troubleshooting","level":2,"text":"Troubleshooting"},{"type":"heading","anchor":"Runner-Not-Picking-Up-Jobs","level":3,"text":"Runner Not Picking Up Jobs"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" Jobs queue but no runner starts executing them."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" Label mismatch between the workflow "},{"type":"codeVoice","code":"runs-on"},{"type":"text","text":" and the"},{"type":"text","text":" "},{"type":"text","text":"runner’s configured labels."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# Check runner labels in GitHub","curl -s -H \"Authorization: token ghp_xxxx\" \\","    \"https:\/\/api.github.com\/repos\/myorg\/myrepo\/actions\/runners\" | \\","    jq '.runners[] | {name, labels: [.labels[].name]}'","","# Verify workflow runs-on matches","# .github\/workflows\/build.yml:","#   runs-on: [self-hosted, macos, arm64, xcode16]","# Runner must have ALL of these labels."]},{"level":3,"anchor":"Token-Expiry","type":"heading","text":"Token Expiry"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"text":" Runner fails to register or deregisters unexpectedly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"text":" The GitHub PAT or registration token has expired.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]}]},{"type":"codeListing","code":["# For PATs: generate a new token in GitHub Settings > Developer settings","# For GitHub Apps: tokens auto-refresh, but check the app installation","","# Update the token in your VM pool","kubectl edit macosvmpool production-runners -n ci","# Update templateArgs.token","","# Or rotate via Helm","helm upgrade spooktacular-operator spooktacular\/operator \\","    --set pools.runners.templateArgs.token=ghp_NEW_TOKEN"],"syntax":"bash"},{"text":"Disk Full","anchor":"Disk-Full","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"type":"text","text":" Builds fail with “No space left on device” inside"},{"type":"text","text":" "},{"type":"text","text":"the runner VM."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"type":"text","text":" The VM’s disk image has reached its configured maximum,"},{"type":"text","text":" "},{"type":"text","text":"or build artifacts have accumulated."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]}]},{"code":["# Check disk usage inside the VM","spook exec runner-01 -- df -h \/","","# For ephemeral runners, this is self-correcting — the VM is","# destroyed after each job. If using persistent runners:","spook exec runner-01 -- rm -rf \/Users\/admin\/actions-runner\/_work\/_temp\/*","spook exec runner-01 -- xcrun simctl delete unavailable","","# Or increase disk size for new VMs","spook create runner --cpu 4 --memory 8 --disk 128"],"type":"codeListing","syntax":"bash"},{"text":"VM Stuck in Starting State","anchor":"VM-Stuck-in-Starting-State","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"spook list"},{"type":"text","text":" shows the VM in "},{"type":"codeVoice","code":"starting"},{"type":"text","text":" state"},{"type":"text","text":" "},{"type":"text","text":"indefinitely."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cause:","type":"text"}],"type":"strong"},{"type":"text","text":" Typically a resource contention issue or a corrupt VM"},{"type":"text","text":" "},{"type":"text","text":"bundle."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]}]},{"type":"codeListing","syntax":"bash","code":["# Force stop and restart","spook stop runner-01","spook start runner-01 --headless","","# If that fails, delete and recreate from the base image","spook delete runner-01 --force","spook clone base-xcode16 runner-01","spoo