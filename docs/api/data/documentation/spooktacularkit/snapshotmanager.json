:"paragraph"},{"anchor":"How-Snapshots-Work","text":"How Snapshots Work","type":"heading","level":2},{"inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The VM ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be stopped"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Restoring replaces the current disk and auxiliary storage","type":"text"},{"type":"text","text":" "},{"text":"with the snapshot copies.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"APFS-Copy-on-Write","type":"heading","level":2,"text":"APFS Copy-on-Write"},{"inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}],"type":"paragraph"},{"anchor":"Snapshot-Directory-Layout","type":"heading","level":2,"text":"Snapshot Directory Layout"},{"type":"c