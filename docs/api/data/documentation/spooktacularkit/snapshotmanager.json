{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"type":"text","text":" provides save, restore, list, and delete"},{"type":"text","text":" "},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":") and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"type":"text","text":"), stored in a named subdirectory under the"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" directory."}],"type":"paragraph"},{"text":"How Snapshots Work","anchor":"How-Snapshots-Work","level":2,"type":"heading"},{"inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"type":"text","text":" "},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The VM ","type":"text"},{"inlineContent":[{"type":"text","text":"must be stopped"}],"type":"strong"},{"text":" before saving or restoring.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"text":" ","type":"text"},{"type":"text","text":"with the snapshot copies."}],"type":"paragraph"}]}]},{"type":"heading","text":"APFS Copy-on-Write","level":2,"anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"code":"FileManager.copyItem","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"level":2,"text":"Snapshot Directory Layout","anchor":"Snapshot-Directory-Layout","type":"heading"},{"type":"codeListing","syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"generated":true,"anchor":"Type-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"generated":true,"anchor":"Type-Methods"}],"seeAlsoSections":[{"title":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"generated":true,"anchor":"Snapshots"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Manages disk-level snapshots for virtual machine bundles.","type":"text"}],"metadata":{"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SnapshotManagerO","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"title":"SnapshotManager","symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"role":"symbol"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotError":{"iden