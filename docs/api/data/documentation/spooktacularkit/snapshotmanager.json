{"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"anchor":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"generated":true,"title":"Snapshots"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"title":"Type Properties","generated":true,"anchor":"Type-Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"title":"Type Methods","generated":true,"anchor":"Type-Methods"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":") and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"How-Snapshots-Work","level":2,"text":"How Snapshots Work"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"inlineContent":[{"text":"must be stopped","type":"text"}],"type":"strong"},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"APFS Copy-on-Write","anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"type":"heading","level":2,"text":"Snapshot Directory Layout","anchor":"Snapshot-Directory-Layout"},{"type":"codeListing","syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Manages disk-level snapshots for virtual machine bundles.","type":"text"}],"metadata":{"role":"symbol","title":"SnapshotManager","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SnapshotManagerO","modules":[{"name":"SpooktacularKit"}]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/saved