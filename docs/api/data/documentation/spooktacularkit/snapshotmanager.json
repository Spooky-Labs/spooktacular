{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"topicSections":[{"anchor":"Type-Properties","title":"Type Properties","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"anchor":"Type-Methods","title":"Type Methods","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SnapshotManagerO","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"symbolKind":"enum","role":"symbol","title":"SnapshotManager"},"seeAlsoSections":[{"anchor":"Snapshots","title":"Snapshots","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":") and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}],"type":"paragraph"},{"anchor":"How-Snapshots-Work","level":2,"type":"heading","text":"How Snapshots Work"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"type":"text","text":"must be stopped"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Snapshots work across processes and reboots.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"anchor":"APFS-Copy-on-Write","level":2,"type":"heading","text":"APFS Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which the system maps to ","type":"text"},{"type":"codeVoice","code":"clonefile(2)"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"text":"Snapshot Directory Layout","anchor":"Snapshot-Directory-Layout","type":"heading","level":2},{"syntax":null,"type":"codeListing","code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"text":"Example","anchor":"Example","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}]}],"abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentat