{"kind":"symbol","abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"topicSections":[{"anchor":"Type-Properties","generated":true,"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"anchor":"Type-Methods","generated":true,"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"title":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"generated":true,"anchor":"Snapshots"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/snapshotmanager"]}],"metadata":{"roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"title":"SnapshotManager","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"navigatorTitle":[{"text":"SnapshotManager","kind":"identifier"}],"symbolKind":"enum","externalID":"s:15SpooktacularKit15SnapshotManagerO"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"type":"text","text":" provides save, restore, list, and delete"},{"type":"text","text":" "},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":") and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"type":"text","text":"), stored in a named subdirectory under the"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" directory."}],"type":"paragraph"},{"anchor":"How-Snapshots-Work","type":"heading","level":2,"text":"How Snapshots Work"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"text":" before saving or restoring.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}]},{"anchor":"APFS-Copy-on-Write","type":"heading","level":2,"text":"APFS Copy-on-Write"},{"inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"type":"codeVoice","code":"FileManager.copyItem"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which the system maps to "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"type":"text","text":"copy-on-write clone instead of a byte-for-byte copy, making"},{"type":"text","text":" "},{"type":"text","text":"snapshot creation and restoration near-instantaneous regardless"},{"type":"text","text":" "},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}],"type":"paragraph"},{"anchor":"Snapshot-Directory-Layout","type":"heading","level":2,"text":"Snapshot Directory Layout"},{"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"],"syntax":null,"type":"codeListing"},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"syntax":"swift","type":"codeListing"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/infoF