{"abstract":[{"text":"Manages disk-level snapshots for virtual machine bundles.","type":"text"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":"), auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"type":"text","text":"), and machine identifier ("},{"type":"codeVoice","code":"machine-identifier.bin"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"stored in a named subdirectory under the bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" "},{"type":"text","text":"directory."}]},{"text":"How Snapshots Work","anchor":"How-Snapshots-Work","level":2,"type":"heading"},{"inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"text":" ","type":"text"},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"APFS Copy-on-Write","anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}]},{"level":2,"text":"Snapshot Directory Layout","type":"heading","anchor":"Snapshot-Directory-Layout"},{"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"],"type":"codeListing","syntax":null},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing"}]}],"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"generated":true,"anchor":"Type-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"generated":true,"anchor":"Type-Methods"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"generated":true,"title":"Snapshots"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"roleHeading":"Enumeration","title":"SnapshotManager","symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"role":"symbol","externalID":"s:15SpooktacularKit15SnapshotManagerO","modules":[{"name":"SpooktacularKit"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"ide