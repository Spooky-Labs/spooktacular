{"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"anchor":"Type-Properties","generated":true},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"anchor":"Type-Methods","generated":true}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"type":"codeVoice","code":"disk.img"},{"text":") and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"type":"text","text":"), stored in a named subdirectory under the"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" directory."}]},{"type":"heading","level":2,"text":"How Snapshots Work","anchor":"How-Snapshots-Work"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}]}]},{"content":[{"inlineContent":[{"text":"Snapshots work across processes and reboots.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}]},{"type":"heading","level":2,"text":"APFS Copy-on-Write","anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"type":"codeVoice","code":"FileManager.copyItem"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which the system maps to "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"type":"text","text":"copy-on-write clone instead of a byte-for-byte copy, making"},{"type":"text","text":" "},{"type":"text","text":"snapshot creation and restoration near-instantaneous regardless"},{"type":"text","text":" "},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}]},{"text":"Snapshot Directory Layout","level":2,"anchor":"Snapshot-Directory-Layout","type":"heading"},{"syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"],"type":"codeListing"},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing"}]}],"abstract":[{"text":"Manages disk-level snapshots for virtual machine bundles.","type":"text"}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"},"seeAlsoSections":[{"title":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"anchor":"Snapshots","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/snapshotmanager"]}],"metadata":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"externalID":"s:15SpooktacularKit15SnapshotManagerO","modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum","navigatorTitle":[{"text":"SnapshotManager","kind":"identifier"}],"role":"symbol","roleHeading":"Enumeration","title":"SnapshotManager"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotInfo":{"navig