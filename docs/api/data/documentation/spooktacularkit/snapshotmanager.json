{"topicSections":[{"generated":true,"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"metadata":{"modules":[{"name":"SpooktacularKit"}],"navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"title":"SnapshotManager","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"externalID":"s:15SpooktacularKit15SnapshotManagerO","symbolKind":"enum","roleHeading":"Enumeration"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"SnapshotManager","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"type":"text","text":" provides save, restore, list, and delete"},{"type":"text","text":" "},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":"), auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"text":"), and machine identifier (","type":"text"},{"code":"machine-identifier.bin","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"stored in a named subdirectory under the bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" "},{"type":"text","text":"directory."}],"type":"paragraph"},{"text":"How Snapshots Work","level":2,"anchor":"How-Snapshots-Work","type":"heading"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"text":"requires the VM to be running in the same process),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The VM ","type":"text"},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Snapshots work across processes and reboots.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Restoring replaces the current disk and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"level":2,"anchor":"APFS-Copy-on-Write","text":"APFS Copy-on-Write","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"type":"codeVoice","code":"FileManager.copyItem"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"text":" ","type":"text"},{"type":"text","text":"consume additional storage."}]},{"type":"heading","level":2,"text":"Snapshot Directory Layout","anchor":"Snapshot-Directory-Layout"},{"syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"],"type":"codeListing"},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"codeListing","syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}],"kind":"content"}],"kind":"symbol","seeAlsoSections":[{"generated":true,"anchor":"Snapshots","title":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/do