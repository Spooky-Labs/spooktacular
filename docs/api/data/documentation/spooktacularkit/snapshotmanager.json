apshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"syntax":"swift"}]}],"topicSections":[{"generated":true,"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"title":"Type Properties"},{"generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"title":"Type Methods"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/infoFileName":{"title":"infoFileName","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","kind":"symbol","url":"\/documentation\/spooktacularkit\/snapshotmanager\/infofilename","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"infoFileName"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}],"type":"topic","abstract":[{"type":"text","text":"The file name for snapshot metadata inside each snapshot directory."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/list(bundle:)":{"kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/snapshotmanager\/list(bundle:)","role":"symbol","abstract":[{"ty