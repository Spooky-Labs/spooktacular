{"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"title":"SnapshotManager","symbolKind":"enum","roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit15SnapshotManagerO"},"topicSections":[{"title":"Type Properties","generated":true,"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"title":"Type Methods","generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/snapshotmanager"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"title":"Snapshots","generated":true,"anchor":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SnapshotManager"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"type":"text","text":" provides save, restore, list, and delete"},{"type":"text","text":" "},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":") and auxiliary storage"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}],"type":"paragraph"},{"anchor":"How-Snapshots-Work","type":"heading","text":"How Snapshots Work","level":2},{"type":"paragraph","inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"text":" before saving or restoring.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Snapshots work across processes and reboots.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"text":" ","type":"text"},{"text":"with the snapshot copies.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"APFS Copy-on-Write","anchor":"APFS-Copy-on-Write","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which the system maps to "},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":". This produces a"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"consume additional storage."}]},{"anchor":"Snapshot-Directory-Layout","type":"heading","text":"Snapshot Directory Layout","level":2},{"type":"codeListing","syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/delet