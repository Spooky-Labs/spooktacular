:"heading","level":2},{"type":"paragraph","inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"text":" ","type":"text"},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":") and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"text":"), stored in a named subdirectory under the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"text":" directory.","type":"text"}]},{"type":"heading","level":2,"anchor":"How-Snapshots-Work","text":"How Snapshots Work"},{"type":"paragraph","inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The VM ","type":"text"},{"inlineContent":[{"type":"text","text":"must be stopped"}],"type":"strong"},{"text":" before saving or restoring.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"level":2,"text":"Snapshot Directory Layout","type":"heading","anchor":"Snapshot-Directory-Layout"},{"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"],"type":"codeListing","syntax":null},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing","syntax":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/save(bundle:label:)":{"kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/snapshotmanager\/save(bundle:label:)","abstract":[{"text":"Saves a disk-level snapshot of the VM bundle.","type":"text"}],"title":"save(bundle:label:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"save"},{"text":"(","kind":"text"},{"text":"bundle","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VirtualMachineBundle","kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV"},{"text":", ","kind":"text"},{"text":"label","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],