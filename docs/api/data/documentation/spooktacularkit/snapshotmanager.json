{"kind":"symbol","abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"type":"codeVoice","code":"disk.img"},{"text":"), auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"auxiliary.bin"},{"text":"), and machine identifier (","type":"text"},{"type":"codeVoice","code":"machine-identifier.bin"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"stored in a named subdirectory under the bundle’s ","type":"text"},{"type":"codeVoice","code":"SavedStates\/"},{"text":" ","type":"text"},{"text":"directory.","type":"text"}]},{"type":"heading","level":2,"text":"How Snapshots Work","anchor":"How-Snapshots-Work"},{"type":"paragraph","inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"inlineContent":[{"type":"text","text":"must be stopped"}],"type":"strong"},{"type":"text","text":" before saving or restoring."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"APFS Copy-on-Write","anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"type":"codeVoice","code":"FileManager.copyItem"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which the system maps to ","type":"text"},{"type":"codeVoice","code":"clonefile(2)"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"type":"heading","level":2,"text":"Snapshot Directory Layout","anchor":"Snapshot-Directory-Layout"},{"type":"codeListing","code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"],"syntax":null},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapsho