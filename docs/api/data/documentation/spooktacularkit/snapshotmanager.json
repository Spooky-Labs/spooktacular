{"metadata":{"roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit15SnapshotManagerO","symbolKind":"enum","title":"SnapshotManager","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"SnapshotManager","kind":"identifier"}],"role":"symbol"},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"anchor":"Type-Properties","title":"Type Properties","generated":true},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"title":"Type Methods","anchor":"Type-Methods"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"title":"Snapshots","anchor":"Snapshots"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":") and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"auxiliary.bin"},{"type":"text","text":"), stored in a named subdirectory under the"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"type":"text","text":" directory."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"How-Snapshots-Work","text":"How Snapshots Work"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"type":"text","text":"must be stopped"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"APFS-Copy-on-Write","text":"APFS Copy-on-Write"},{"inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"type":"codeVoice","code":"FileManager.copyItem"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which the system maps to "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"type":"text","text":"copy-on-write clone instead of a byte-for-byte copy, making"},{"type":"text","text":" "},{"type":"text","text":"snapshot creation and restoration near-instantaneous regardless"},{"type":"text","text":" "},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Snapshot-Directory-Layout","text":"Snapshot Directory Layout"},{"type":"codeListing","syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"codeListing","syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/snapshotmanager"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager":{"ur