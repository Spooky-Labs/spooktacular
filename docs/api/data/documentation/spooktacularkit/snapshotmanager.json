","type":"text"},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}],"type":"paragraph"}]}]},{"type":"heading","text":"APFS Copy-on-Write","level":2,"anchor":"APFS-Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which the system maps to "},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"type":"text","text":" "},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"type":"text","text":" "},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"anchor":"Snapshot-Directory-Layout","level":2,"type":"heading","text":"Snapshot Directory Layout"},{"syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"],"type":"codeListing"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}]}],"topicSections":[{"title":"Type Properties","generated":true,"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"title":"Type Methods","generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"roleHeading":"Enumeration","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"role":"symbol","externalID":"s:15SpooktacularKit15SnapshotManagerO","title":"SnapshotManager","modules":[{"name":"SpooktacularKit"}],"navigatorTitle":[{"text":"SnapshotMana