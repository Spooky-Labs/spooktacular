{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","topicSections":[{"generated":true,"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"]},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"type":"text","text":" provides save, restore, list, and delete"},{"type":"text","text":" "},{"type":"text","text":"operations for VM snapshots. Each snapshot is a full copy of"},{"type":"text","text":" "},{"type":"text","text":"the VM’s disk image ("},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":"), auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"auxiliary.bin","type":"codeVoice"},{"type":"text","text":"), and machine identifier ("},{"code":"machine-identifier.bin","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"stored in a named subdirectory under the bundle’s "},{"code":"SavedStates\/","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"directory."}]},{"anchor":"How-Snapshots-Work","type":"heading","level":2,"text":"How Snapshots Work"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}]},{"anchor":"APFS-Copy-on-Write","type":"heading","level":2,"text":"APFS Copy-on-Write"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"code":"FileManager.copyItem","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which the system maps to "},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"type":"text","text":"copy-on-write clone instead of a byte-for-byte copy, making"},{"type":"text","text":" "},{"type":"text","text":"snapshot creation and restoration near-instantaneous regardless"},{"type":"text","text":" "},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}]},{"anchor":"Snapshot-Directory-Layout","type":"heading","level":2,"text":"Snapshot Directory Layout"},{"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"],"type":"codeListing","syntax":null},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"role":"symbol","symbolKind":"enum","externalID":"s:15SpooktacularKit15SnapshotManagerO","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"roleHeading":"Enumeration","title":"SnapshotManager"},"seeAlsoSections":[{"generated":true,"title":"Snapshots","anchor":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanag