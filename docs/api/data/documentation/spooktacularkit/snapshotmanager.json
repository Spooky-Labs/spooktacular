{"metadata":{"externalID":"s:15SpooktacularKit15SnapshotManagerO","symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}],"modules":[{"name":"SpooktacularKit"}],"role":"symbol","title":"SnapshotManager","roleHeading":"Enumeration","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}]},"seeAlsoSections":[{"generated":true,"anchor":"Snapshots","title":"Snapshots","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"SnapshotManager","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"SnapshotManager"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":"), auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), and machine identifier (","type":"text"},{"code":"machine-identifier.bin","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"stored in a named subdirectory under the bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" ","type":"text"},{"text":"directory.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"How-Snapshots-Work","type":"heading","text":"How Snapshots Work"},{"inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"type":"text","text":"must be stopped"}]},{"type":"text","text":" before saving or restoring."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Restoring replaces the current disk and auxiliary storage","type":"text"},{"type":"text","text":" "},{"text":"with the snapshot copies.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"APFS-Copy-on-Write","level":2,"type":"heading","text":"APFS Copy-on-Write"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On APFS volumes, both save and restore use "},{"type":"codeVoice","code":"FileManager.copyItem"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which the system maps to "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":". This produces a"},{"type":"text","text":" "},{"type":"text","text":"copy-on-write clone instead of a byte-for-byte copy, making"},{"type":"text","text":" "},{"type":"text","text":"snapshot creation and restoration near-instantaneous regardless"},{"type":"text","text":" "},{"type":"text","text":"of disk image size. Only blocks that diverge after the clone"},{"type":"text","text":" "},{"type":"text","text":"consume additional storage."}]},{"anchor":"Snapshot-Directory-Layout","level":2,"type":"heading","text":"Snapshot Directory Layout"},{"syntax":null,"type":"codeListing","code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── machine-identifier.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   ├── machine-identifier.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        ├── machine-identifier.bin","        └── snapshot-info.json"]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"syntax":"swift","type":"codeListing","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"title":"Type Properties","generated":true,"anchor":"Type-Properties"},{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spo