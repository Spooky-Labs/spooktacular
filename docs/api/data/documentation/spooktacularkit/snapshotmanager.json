","kind":"text"},{"kind":"identifier","text":"SnapshotManager"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"type":"text","text":" provides save, restore, list, and delete"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the VM’s disk image ("},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":") and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"auxiliary.bin","type":"codeVoice"},{"type":"text","text":"), stored in a named subdirectory under the"},{"type":"text","text":" "},{"type":"text","text":"bundle’s "},{"type":"codeVoice","code":"SavedStates\/"},{"text":" directory.","type":"text"}]},{"text":"How Snapshots Work","level":2,"anchor":"How-Snapshots-Work","type":"heading"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"text":" before saving or restoring.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}],"type":"unorderedList"},{"text":"Snapshot Directory Layout","level":2,"anchor":"Snapshot-Directory-Layout","type":"heading"},{"type":"codeListing","syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"codeListing","syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"]}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/delete(bundle:label:)":{"abstract":[{"text":"Deletes a snapshot from a VM bundle.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delete","kind":"identifier"},{"text":"(","kind":"text"},{"text":"bundle","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VirtualMachineBundle","kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV"},{"text":", ","kind":"text"},{"text":"label","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","title":"delete(bun