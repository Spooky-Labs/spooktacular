,{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}],"type":"paragraph"},{"text":"How Snapshots Work","level":2,"type":"heading","anchor":"How-Snapshots-Work"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level snapshots copy the on-disk artifacts. This means:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM "},{"type":"strong","inlineContent":[{"text":"must be stopped","type":"text"}]},{"type":"text","text":" before saving or restoring."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Snapshots work across processes and reboots."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring replaces the current disk and auxiliary storage"},{"type":"text","text":" "},{"type":"text","text":"with the snapshot copies."}]}]}]},{"text":"Snapshot Directory Layout","level":2,"type":"heading","anchor":"Snapshot-Directory-Layout"},{"syntax":null,"code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"],"type":"codeListing"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"syntax":"swift","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"anchor":"Snapshots","generated":true,"title":"Snapshots"}],"abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/SnapshotManager/delete(bundle:label:)":{"title":"delete(bundle:label:)","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delete","kind":"identifier"},{"text":"(","kind":"text"},{"text":"bundle","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VirtualMachineBundle","preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"label","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","abstract":[{"type":"text","text":"Deletes a snapshot from a 