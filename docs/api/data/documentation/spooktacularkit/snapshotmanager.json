{"abstract":[{"text":"Manages disk-level snapshots for virtual machine bundles.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"},"variants":[{"paths":["\/documentation\/spooktacularkit\/snapshotmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"title":"Snapshots","generated":true,"anchor":"Snapshots"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SnapshotManager"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":") and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}],"type":"paragraph"},{"anchor":"How-Snapshots-Work","level":2,"text":"How Snapshots Work","type":"heading"},{"inlineContent":[{"type":"text","text":"Unlike VZ state save (which captures in-memory VM state and"},{"type":"text","text":" "},{"type":"text","text":"requires the VM to be running in the same process),"},{"type":"text","text":" "},{"type":"text","text":"disk-level s