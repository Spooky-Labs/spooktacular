{"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/infoFileName","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/savedStatesDirectory"],"generated":true,"title":"Type Properties","anchor":"Type-Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/delete(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/list(bundle:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/restore(bundle:label:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager\/save(bundle:label:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotManager"},"abstract":[{"type":"text","text":"Manages disk-level snapshots for virtual machine bundles."}],"metadata":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"title":"SnapshotManager","role":"symbol","roleHeading":"Enumeration","symbolKind":"enum","externalID":"s:15SpooktacularKit15SnapshotManagerO","navigatorTitle":[{"kind":"identifier","text":"SnapshotManager"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SnapshotManager","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SnapshotManager","type":"codeVoice"},{"text":" provides save, restore, list, and delete","type":"text"},{"text":" ","type":"text"},{"text":"operations for VM snapshots. Each snapshot is a full copy of","type":"text"},{"text":" ","type":"text"},{"text":"the VM’s disk image (","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":") and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":"), stored in a named subdirectory under the","type":"text"},{"text":" ","type":"text"},{"text":"bundle’s ","type":"text"},{"code":"SavedStates\/","type":"codeVoice"},{"text":" directory.","type":"text"}]},{"type":"heading","anchor":"How-Snapshots-Work","level":2,"text":"How Snapshots Work"},{"type":"paragraph","inlineContent":[{"text":"Unlike VZ state save (which captures in-memory VM state and","type":"text"},{"text":" ","type":"text"},{"text":"requires the VM to be running in the same process),","type":"text"},{"text":" ","type":"text"},{"text":"disk-level snapshots copy the on-disk artifacts. This means:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The VM ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be stopped"}]},{"text":" before saving or restoring.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Snapshots work across processes and reboots.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Restoring replaces the current disk and auxiliary storage","type":"text"},{"text":" ","type":"text"},{"text":"with the snapshot copies.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"APFS-Copy-on-Write","level":2,"text":"APFS Copy-on-Write"},{"type":"paragraph","inlineContent":[{"text":"On APFS volumes, both save and restore use ","type":"text"},{"code":"FileManager.copyItem","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which the system maps to ","type":"text"},{"code":"clonefile(2)","type":"codeVoice"},{"text":". This produces a","type":"text"},{"text":" ","type":"text"},{"text":"copy-on-write clone instead of a byte-for-byte copy, making","type":"text"},{"text":" ","type":"text"},{"text":"snapshot creation and restoration near-instantaneous regardless","type":"text"},{"text":" ","type":"text"},{"text":"of disk image size. Only blocks that diverge after the clone","type":"text"},{"text":" ","type":"text"},{"text":"consume additional storage.","type":"text"}]},{"type":"heading","anchor":"Snapshot-Directory-Layout","level":2,"text":"Snapshot Directory Layout"},{"type":"codeListing","code":["my-vm.vm\/","├── disk.img","├── auxiliary.bin","├── ...","└── SavedStates\/","    ├── clean-install\/","    │   ├── disk.img","    │   ├── auxiliary.bin","    │   └── snapshot-info.json","    └── before-xcode\/","        ├── disk.img","        ├── auxiliary.bin","        └── snapshot-info.json"],"syntax":null},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"codeListing","code":["let bundle = try VirtualMachineBundle.load(from: bundleURL)","","\/\/ Save a snapshot","try SnapshotManager.save(bundle: bundle, label: \"clean-install\")","","\/\/ List snapshots","let snapshots = try SnapshotManager.list(bundle: bundle)","for snap in snapshots {","    print(\"\\(snap.label): \\(snap.sizeInBytes) bytes\")","}","","\/\/ Restore a snapshot","try SnapshotManager.restore(bundle: bundle, label: \"clean-install\")","","\/\/ Delete a snapshot","try SnapshotManager.delete(bundle: bundle, label: \"clean-install\")"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotInfo","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SnapshotError"],"generated":true,"title":"Snapshots","anchor":"Snapshots"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/snapshotmanager"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"Spooktacul