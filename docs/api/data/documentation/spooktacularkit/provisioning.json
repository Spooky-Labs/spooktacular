:"Status","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works without setup?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need SSH enabled","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In progress"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need agent installed","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"OCI images (future)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need watcher","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No-disk-modify environments","type":"text"}]}]]]},{"text":"SSH (Working)","anchor":"SSH-Working","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Requires:","type":"text"}]},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}]},{"text":"Disk Inject (In Progress)","anchor":"Disk-Inject-In-Progress","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}]},{"text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"role":"collectionGroup","title":"Running BlueBubbles iMessage Server","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"collectionGroup","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article","title":"Remote Desktop Access","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","role":"symbol","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"url":"\/documentation\/spooktacularkit\/provisioningmode","kind":"symbol","title":"Prov