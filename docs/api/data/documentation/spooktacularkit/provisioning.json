{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning"},"kind":"article","topicSections":[{"anchor":"Provisioning-Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"],"title":"Provisioning Modes"}],"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"provides provisioning modes to bridge this gap. Today, SSH provisioning","type":"text"},{"text":" ","type":"text"},{"text":"is fully working. Disk-inject is in progress, and two more modes (guest","type":"text"},{"text":" ","type":"text"},{"text":"agent and shared-folder watcher) are planned.","type":"text"}]},{"anchor":"Choosing-a-Mode","text":"Choosing a Mode","type":"heading","level":3},{"rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Status","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Works without setup?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Network needed?"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Best for"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Working","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need SSH enabled","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In progress"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need agent installed"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"text":"OCI images (future)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"inlineContent":[{"text":"Need watcher","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]],"type":"table","header":"row"},{"level":3,"text":"SSH (Working)","type":"heading","anchor":"SSH-Working"},{"inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"text":" ","type":"text"},{"type":"text","text":"and executes your script. You get real-time output streaming."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Disk-Inject-In-Progress","text":"Disk Inject (In Progress)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, Spooktacular mounts the guest’s data volume"},{"type":"text","text":" "},{"type":"text","text":"and writes a standard macOS LaunchDaemon that executes your script."},{"type":"text","text":" "},{"type":"text","text":"This is the only mode that will work on a completely vanilla macOS"},{"type":"text","text":" "},{"type":"text","text":"install. This mode is currently being implemented."}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"type":"heading","text":"Guest Agent (Planned)","level":3,"anchor":"Guest-Agent-Planned"},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"type":"text","text":" "},{"text":"is planned for a future release.","type":"text"}]},{"level":3,"text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned","type":"heading"},{"inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"type":"text","text":"daemon in the guest will execute new scripts automatically. This"},{"type":"text","text":" "},{"type":"text","text":"mode is planned for a future release."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Provisioning Virtual Machines","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioning"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/Sp