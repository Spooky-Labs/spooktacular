"type":"text"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","roleHeading":"API Collection","title":"Provisioning Virtual Machines"},"sections":[],"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}],"type":"paragraph"},{"text":"Choosing a Mode","level":3,"anchor":"Choosing-a-Mode","type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Status"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works without setup?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need SSH enabled"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In progress"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fresh IPSW installs, CI runners"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need agent installed"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI images (future)"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need watcher"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]],"type":"table"},{"text":"SSH (Working)","level":3,"anchor":"SSH-Working","type":"heading"},{"inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}],"type":"paragraph"},{"syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"text":"Disk Inject (In Progress)","level":3,"anchor":"Disk-Inject-In-Progress","type":"heading"},{"inlineContent":[{"type":"text","text":"Before the VM boots, Spooktacular mounts the guest’s data volume"},{"type":"text","text":" "},{"type":"text","text":"and writes a standard macOS LaunchDaemon that executes your script."},{"type":"text","text":" "},{"type":"text","text":"This is the only mode that will work on a completely vanilla macOS"},{"type":"text","text":" "},{"type":"text","text":"install. This mode is currently being implemented."}],"type":"paragraph"},{"syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"],"type":"codeListing"},{"text":"Guest Agent (Planned)","level":3,"anchor":"Guest-Agent-Planned","type":"heading"},{"inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}],"type":"paragraph"},{"text":"Shared Folder (Planned)","level":3,"anchor":"Shared-Folder-Planned","type":"heading"},{"inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"type":"text","text":"daemon in the guest will execute new scripts automatically. This"},{"type":"text","text":" "},{"type":"text","text":"mode is planned for a future release."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/d