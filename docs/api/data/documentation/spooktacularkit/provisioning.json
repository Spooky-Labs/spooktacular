t\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"topicSections":[{"anchor":"Provisioning-Modes","title":"Provisioning Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"text":"is fully working. Disk-inject is in progress, and two more modes (guest","type":"text"},{"text":" ","type":"text"},{"text":"agent and shared-folder watcher) are planned.","type":"text"}]},{"anchor":"Choosing-a-Mode","text":"Choosing a Mode","level":3,"type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Status"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works without setup?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}]}],[{"inlineContent":[{"type":"text","text":"Need SSH enabled"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In progress","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need agent installed"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI images (future)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need watcher"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]],"type":"table"},{"anchor":"SSH-Working","text":"SSH (Working)","level":3,"type":"heading"},{"inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}],"type":"paragraph"},{"code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}],"type":"paragraph"},{"anchor":"Disk-Inject-In-Progress","text":"Disk Inject (In Progress)","level":3,"type":"heading"},{"inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}],"type":"paragraph"},{"code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"anchor":"Guest-Agent-Planned","text":"Guest Agent (Planned)","level":3,"type":"heading"},{"inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}],"type":"paragraph"},{"anchor":"Shared-Folder-Planned","text":"Shared Folder (Planned)","level":3,"type":"heading"},{"inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/provisioning"]}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","title":"Running BlueBubbles iMessage Server","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","kind":"article","title":"Configuring GitHub Actions Runners"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineBundle":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineBundle"}],"navigatorTitle":[{"kind":"identifier","text":"VirtualMachineBundle"}],"url":"\/documentation\/spooktacularkit\/virtualmachinebundle","kind":"symbol","type":"topic","title