{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning"},"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioning"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Provisioning Virtual Machines","roleHeading":"API Collection","role":"collectionGroup"},"abstract":[{"text":"Run scripts automatically when a VM boots.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}]},{"text":"Choosing a Mode","type":"heading","anchor":"Choosing-a-Mode","level":3},{"rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Status","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Works without setup?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Network needed?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need SSH enabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"In progress"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Fresh IPSW installs, CI runners"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent"}]}],[{"inlineContent":[{"type":"text","text":"Planned"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need agent installed"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"OCI images (future)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need watcher"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]],"type":"table","header":"row"},{"anchor":"SSH-Working","type":"heading","level":3,"text":"SSH (Working)"},{"inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Requires:","type":"text"}]},{"type":"text","text":" Remote Login enabled in the guest"},{"text":" ","type":"text"},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"text":"Disk Inject (In Progress)","type":"heading","level":3,"anchor":"Disk-Inject-In-Progress"},{"inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"text":"Guest Agent (Planned)","type":"heading","level":3,"anchor":"Guest-Agent-Planned"},{"inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}],"type":"paragraph"},{"text":"Shared Folder (Planned)","type":"heading","level":3,"anchor":"Shared-Folder-Planned"},{"inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"anchor":"Provisioning-Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"],"title":"Provisioning Modes"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/Sp