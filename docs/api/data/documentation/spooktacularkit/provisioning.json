{"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup","title":"Provisioning Virtual Machines"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"provides provisioning modes to bridge this gap. Today, SSH provisioning","type":"text"},{"text":" ","type":"text"},{"text":"is fully working. Disk-inject is in progress, and two more modes (guest","type":"text"},{"text":" ","type":"text"},{"text":"agent and shared-folder watcher) are planned.","type":"text"}]},{"anchor":"Choosing-a-Mode","type":"heading","level":3,"text":"Choosing a Mode"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Status"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Works without setup?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Network needed?"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Working","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need SSH enabled","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In progress","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Fresh IPSW installs, CI runners"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Planned"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need agent installed","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"inlineContent":[{"text":"OCI images (future)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need watcher"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No-disk-modify environments","type":"text"}]}]]]},{"type":"heading","level":3,"text":"SSH (Working)","anchor":"SSH-Working"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}]},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Requires:","type":"text"}]},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}]},{"level":3,"anchor":"Disk-Inject-In-Progress","type":"heading","text":"Disk Inject (In Progress)"},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"install. This mode is currently being implemented."}]},{"syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"],"type":"codeListing"},{"text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}],"type":"paragraph"},{"text":"Shared Folder (Planned)","type":"heading","anchor":"Shared-Folder-Planned","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning"},"kind":"article","abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"title":"Provisioning Modes","anchor":"Provisioning-Modes","identi