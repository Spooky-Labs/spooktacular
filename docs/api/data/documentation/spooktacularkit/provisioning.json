{"sections":[],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}]},{"type":"heading","text":"Choosing a Mode","anchor":"Choosing-a-Mode","level":3},{"type":"table","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Status","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Works without setup?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Network needed?","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Working","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need SSH enabled","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In progress","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need agent installed","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"OCI images (future)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need watcher","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]],"header":"row"},{"type":"heading","text":"SSH (Working)","anchor":"SSH-Working","level":3},{"type":"paragraph","inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}]},{"type":"heading","text":"Disk Inject (In Progress)","anchor":"Disk-Inject-In-Progress","level":3},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"type":"heading","text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned","level":3},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}]},{"type":"heading","text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned","level":3},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/do