{"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}]},{"text":"Choosing a Mode","type":"heading","anchor":"Choosing-a-Mode","level":3},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Status"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works without setup?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"type":"paragraph","inlineContent":[{"text":"Best for","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need SSH enabled"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"In progress","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fresh IPSW installs, CI runners"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need agent installed"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"text":"OCI images (future)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need watcher"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]]},{"text":"SSH (Working)","type":"heading","anchor":"SSH-Working","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}]},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}]},{"text":"Disk Inject (In Progress)","type":"heading","anchor":"Disk-Inject-In-Progress","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, Spooktacular mounts the guest’s data volume"},{"type":"text","text":" "},{"type":"text","text":"and writes a standard macOS LaunchDaemon that executes your script."},{"type":"text","text":" "},{"type":"text","text":"This is the only mode that will work on a completely vanilla macOS"},{"type":"text","text":" "},{"type":"text","text":"install. This mode is currently being implemented."}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"text":"Guest Agent (Planned)","type":"heading","anchor":"Guest-Agent-Planned","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}]},{"text":"Shared Folder (Planned)","type":"heading","anchor":"Shared-Folder-Planned","level":3},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","title":"Provisioning Virtual Machines"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"topicSections":[{"title":"Provisioning Modes","anchor":"Provisioning-Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKi