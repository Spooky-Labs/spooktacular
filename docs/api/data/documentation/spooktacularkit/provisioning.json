text","text":"Planned"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need watcher"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No-disk-modify environments"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"SSH-Working","level":3,"text":"SSH (Working)","type":"heading"},{"inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Disk Inject (In Progress)","anchor":"Disk-Inject-In-Progress"},{"inlineContent":[{"type":"text","text":"Before the VM boots, Spooktacular mounts the guest’s data volume"},{"type":"text","text":" "},{"type":"text","text":"and writes a standard macOS LaunchDaemon that executes your script."},{"type":"text","text":" "},{"type":"text","text":"This is the only mode that will work on a completely vanilla macOS"},{"type":"text","text":" "},{"type":"text","text":"install. This mode is currently being implemented."}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"type":"heading","level":3,"text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned"},{"inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned"},{"inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"type":"text","text":"daemon in the guest will execute new scripts automatically. This"},{"type":"text","text":" "},{"type":"text","text":"mode is planned for a future release."}],"type":"paragraph"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineBundle":{"type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","abstract":[{"type":"text","text":"A virtual machine bundle stored on disk."}],"role":"symbol","navigatorTitle":[{"text":"VirtualMachineBundle","kind":"identifier"}],"title":"VirtualMachineBundle","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineBundle","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinebundle"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","title":"Deploying on EC2 Mac","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","abstract":[{"text":"Understand what version numbers mean and w