acularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}]},{"anchor":"Choosing-a-Mode","type":"heading","level":3,"text":"Choosing a Mode"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Status"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Works without setup?"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Network needed?"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Working","type":"text"}]}]}],[{"inlineContent":[{"text":"Need SSH enabled","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In progress"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need agent installed","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"text":"OCI images (future)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"inlineContent":[{"type":"text","text":"Need watcher"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"No-disk-modify environments","type":"text"}]}]]],"type":"table","header":"row"},{"level":3,"type":"heading","text":"SSH (Working)","anchor":"SSH-Working"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}]},{"syntax":"bash","type":"codeListing","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"type":"heading","text":"Disk Inject (In Progress)","anchor":"Disk-Inject-In-Progress","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, Spooktacular mounts the guest’s data volume"},{"type":"text","text":" "},{"type":"text","text":"and writes a standard macOS LaunchDaemon that executes your script."},{"type":"text","text":" "},{"type":"text","text":"This is the only mode that will work on a completely vanilla macOS"},{"type":"text","text":" "},{"type":"text","text":"install. This mode is currently being implemented."}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"level":3,"type":"heading","text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}]},{"level":3,"type":"heading","text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"type":"text","text":"daemon in the guest will execute new scripts automatically. This"},{"type":"text","text":" "},{"type":"text","text":"mode is planned for a future release."}]}]}],"abstract":[{"text":"Run scripts automatically when a VM boots.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/provisioning"]}],"metadata":{"role":"collectionGroup","title":"Provisioning Virtual Machines","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","title":"Versioning & Release Schedule","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","title":"Kubernetes Integration"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit