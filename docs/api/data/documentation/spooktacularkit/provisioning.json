{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"provides provisioning modes to bridge this gap. Today, SSH provisioning","type":"text"},{"text":" ","type":"text"},{"text":"is fully working. Disk-inject is in progress, and two more modes (guest","type":"text"},{"text":" ","type":"text"},{"text":"agent and shared-folder watcher) are planned.","type":"text"}]},{"level":3,"type":"heading","text":"Choosing a Mode","anchor":"Choosing-a-Mode"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Status"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works without setup?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Network needed?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need SSH enabled"}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In progress"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fresh IPSW installs, CI runners"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Planned"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need agent installed","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI images (future)"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder"}]}],[{"type":"paragraph","inlineContent":[{"text":"Planned","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Need watcher","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No-disk-modify environments"}]}]]]},{"level":3,"anchor":"SSH-Working","text":"SSH (Working)","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}]},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}]},{"level":3,"anchor":"Disk-Inject-In-Progress","text":"Disk Inject (In Progress)","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"level":3,"anchor":"Guest-Agent-Planned","text":"Guest Agent (Planned)","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is planned for a future release."}]},{"type":"heading","anchor":"Shared-Folder-Planned","text":"Shared Folder (Planned)","level":3},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup","title":"Provisioning Virtual Machines"},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning"},"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pro