{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","metadata":{"roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Provisioning Virtual Machines"},"topicSections":[{"anchor":"Provisioning-Modes","title":"Provisioning Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}]},{"type":"heading","level":3,"text":"Choosing a Mode","anchor":"Choosing-a-Mode"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Status","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works without setup?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"type":"paragraph","inlineContent":[{"text":"Best for","type":"text"}]}]],[[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Working","type":"text"}]}]}],[{"inlineContent":[{"type":"text","text":"Need SSH enabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In progress"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],[{"inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need agent installed","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"OCI images (future)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Need watcher","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No-disk-modify environments"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"SSH-Working","level":3,"type":"heading","text":"SSH (Working)"},{"inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Requires:","type":"text"}]},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}],"type":"paragraph"},{"anchor":"Disk-Inject-In-Progress","level":3,"type":"heading","text":"Disk Inject (In Progress)"},{"inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"type":"heading","text":"Guest Agent (Planned)","level":3,"anchor":"Guest-Agent-Planned"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}]},{"type":"heading","text":"Shared Folder (Planned)","level":3,"anchor":"Shared-Folder-Planned"},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}]}],"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioning"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/Sp