,"type":"text"}],"type":"paragraph"}]]]},{"type":"heading","anchor":"SSH-Working","text":"SSH (Working)","level":3},{"type":"paragraph","inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"text":" Remote Login enabled in the guest","type":"text"},{"text":" ","type":"text"},{"text":"(System Settings -> General -> Sharing -> Remote Login).","type":"text"}]},{"type":"heading","anchor":"Disk-Inject-In-Progress","text":"Disk Inject (In Progress)","level":3},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"]},{"type":"heading","anchor":"Guest-Agent-Planned","text":"Guest Agent (Planned)","level":3},{"type":"paragraph","inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}]},{"type":"heading","anchor":"Shared-Folder-Planned","text":"Shared Folder (Planned)","level":3},{"type":"paragraph","inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioning"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup","title":"Provisioning Virtual Machines"},"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}],"kind":"symbol","title":"VirtualMachineSpecification"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"kind":"article","title":"Machine Learning Workloads","url":"\/documentation\/spooktacularkit\/mlworkloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","role":"collectionGroup","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode/diskInject":{"abstract":[{"text":"Injects a LaunchDaemon into the VM’s disk before first boot.","type":"text"}],"url":"\/documentation\/spooktacularkit\/provisioningmode\/diskinject","type"