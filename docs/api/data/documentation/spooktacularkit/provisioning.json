{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/provisioning"]}],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Provisioning Virtual Machines","roleHeading":"API Collection"},"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"],"anchor":"Provisioning-Modes","title":"Provisioning Modes"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"provides provisioning modes to bridge this gap. Today, SSH provisioning","type":"text"},{"text":" ","type":"text"},{"text":"is fully working. Disk-inject is in progress, and two more modes (guest","type":"text"},{"text":" ","type":"text"},{"text":"agent and shared-folder watcher) are planned.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Choosing a Mode","anchor":"Choosing-a-Mode","type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Status","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works without setup?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network needed?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Working"}]}]}],[{"inlineContent":[{"text":"Need SSH enabled","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cloned VMs with SSH","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"In progress"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Planned"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need agent installed"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"OCI images (future)"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need watcher"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No-disk-modify environments"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"text":"SSH (Working)","anchor":"SSH-Working","type":"heading"},{"inlineContent":[{"type":"text","text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,"},{"type":"text","text":" "},{"type":"text","text":"and executes your script. You get real-time output streaming."}],"type":"paragraph"},{"code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"level":3,"text":"Disk Inject (In Progress)","anchor":"Disk-Inject-In-Progress","type":"heading"},{"inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}],"type":"paragraph"},{"code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"type":"heading","level":3,"text":"Guest Agent (Planned)","anchor":"Guest-Agent-Planned"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular guest agent will communicate over VirtIO socket — a"},{"type":"text","text":" "},{"type":"text","text":"direct host-guest channel that works without networking. This mode"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release."}]},{"type":"heading","level":3,"text":"Shared Folder (Planned)","anchor":"Shared-Folder-Planned"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The script will be delivered via a VirtIO shared folder. A watcher"},{"type":"text","text":" "},{"type":"text","text":"daemon in the guest will execute new scripts automatically. This"},{"type":"text","text":" "},{"type":"text","text":"mode is planned for a future release."}]}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/Sp