SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Provisioning Virtual Machines","roleHeading":"API Collection"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Run scripts automatically when a VM boots."}],"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Provisioning","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"],"anchor":"Provisioning-Modes","title":"Provisioning Modes"}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"macOS virtual machines don’t have a cloud-init equivalent. Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"provides provisioning modes to bridge this gap. Today, SSH provisioning"},{"type":"text","text":" "},{"type":"text","text":"is fully working. Disk-inject is in progress, and two more modes (guest"},{"type":"text","text":" "},{"type":"text","text":"agent and shared-folder watcher) are planned."}],"type":"paragraph"},{"anchor":"Choosing-a-Mode","level":3,"type":"heading","text":"Choosing a Mode"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Mode","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Status"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works without setup?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Network needed?","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Working"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need SSH enabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cloned VMs with SSH"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"In progress","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Fresh IPSW installs, CI runners","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Planned","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need agent installed"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"OCI images (future)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Planned"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Need watcher"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No-disk-modify environments","type":"text"}],"type":"paragraph"}]]]},{"anchor":"SSH-Working","level":3,"type":"heading","text":"SSH (Working)"},{"inlineContent":[{"text":"After boot, Spooktacular discovers the VM’s IP, connects via SSH,","type":"text"},{"text":" ","type":"text"},{"text":"and executes your script. You get real-time output streaming.","type":"text"}],"type":"paragraph"},{"code":["spook start my-vm \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"type":"text","text":" Remote Login enabled in the guest"},{"type":"text","text":" "},{"type":"text","text":"(System Settings -> General -> Sharing -> Remote Login)."}],"type":"paragraph"},{"anchor":"Disk-Inject-In-Progress","level":3,"type":"heading","text":"Disk Inject (In Progress)"},{"inlineContent":[{"text":"Before the VM boots, Spooktacular mounts the guest’s data volume","type":"text"},{"text":" ","type":"text"},{"text":"and writes a standard macOS LaunchDaemon that executes your script.","type":"text"},{"text":" ","type":"text"},{"text":"This is the only mode that will work on a completely vanilla macOS","type":"text"},{"text":" ","type":"text"},{"text":"install. This mode is currently being implemented.","type":"text"}],"type":"paragraph"},{"code":["spook create my-vm --from-ipsw latest \\","    --user-data ~\/setup.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"anchor":"Guest-Agent-Planned","level":3,"type":"heading","text":"Guest Agent (Planned)"},{"inlineContent":[{"text":"The Spooktacular guest agent will communicate over VirtIO socket — a","type":"text"},{"text":" ","type":"text"},{"text":"direct host-guest channel that works without networking. This mode","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release.","type":"text"}],"type":"paragraph"},{"anchor":"Shared-Folder-Planned","level":3,"type":"heading","text":"Shared Folder (Planned)"},{"inlineContent":[{"text":"The script will be delivered via a VirtIO shared folder. A watcher","type":"text"},{"text":" ","type":"text"},{"text":"daemon in the guest will execute new scripts automatically. This","type":"text"},{"text":" ","type":"text"},{"text":"mode is planned for a future release.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"role":"collectionGroup","title":"Configuring GitHub Actions Runners","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"kind":"article","url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","title":"Remote Desktop Access"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode/diskInject":{"role":"symbol","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"title":"ProvisioningMode.diskInject","kind":"symbol","abstract":[{"type":"text","text