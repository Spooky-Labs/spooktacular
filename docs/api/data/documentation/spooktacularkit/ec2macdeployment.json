mpatibility","kind":"identifier"}],"type":"topic","title":"Compatibility","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Compatibility","kind":"identifier"}],"abstract":[{"text":"Checks version compatibility between the host macOS","type":"text"},{"text":" ","type":"text"},{"text":"and a macOS restore image (IPSW).","type":"text"}],"url":"\/documentation\/spooktacularkit\/compatibility","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineState/error":{"abstract":[{"text":"The VM encountered an error and stopped.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"error"}],"url":"\/documentation\/spooktacularkit\/virtualmachinestate\/error","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState\/error","title":"VirtualMachineState.error"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineBundle":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","url":"\/documentation\/spooktacularkit\/virtualmachinebundle","abstract":[{"type":"text","text":"A virtual machine bundle stored on disk."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineBundle"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineBundle"}],"title":"VirtualMachineBundle","kind":"symbol","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit","role":"collection"},"doc://Spooktacula