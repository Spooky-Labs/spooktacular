oc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"]}],"topicSections":[{"title":"Related Guides","anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Deploying on EC2 Mac","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Guides","generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the"},{"type":"text","text":" "},{"type":"text","text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but"},{"type":"text","text":" "},{"type":"text","text":"with Spooktacular you can run "},{"inlineContent":[{"type":"text","text":"two"}],"type":"strong"},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}],"type":"paragraph"},{"text":"Prerequisites","anchor":"Prerequisites","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Before you begin, ensure you have:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"AWS account"}],"type":"strong"},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"text":" ","type":"text"},{"text":"quota increase for ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"mac2-m2.metal","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated host"}],"type":"strong"},{"text":" — Mac instances run exclusively on","type":"text"},{"text":" ","type":"text"},{"text":"dedicated hosts (not shared tenancy)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"VPC with a private subnet"}],"type":"strong"},{"text":" — recommended for security","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Security group"}],"type":"strong"},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"SSH key pair","type":"text"}],"type":"strong"},{"type":"text","text":" for EC2 access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac host types: "},{"type":"codeVoice","code":"mac2.metal"},{"type":"text","text":" (M1), "},{"type":"codeVoice","code":"mac2-m2.metal"},{"type":"text","text":" "},{"type":"text","text":"(M2), or "},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":" (M2 Pro)"}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts have a "},{"type":"strong","inlineContent":[{"type":"text","text":"24-hour minimum allocation"},{"type":"text","text":" "},{"type":"text","text":"period"}]},{"type":"text","text":". You are billed for the full 24 hours even if you release the"},{"type":"text","text":" "},{"type":"text","text":"host earlier. Plan your usage accordingly."}],"type":"paragraph"}],"style":"important","name":"Important","type":"aside"},{"text":"Quick Setup","anchor":"Quick-Setup","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,"},{"type":"text","text":" "},{"type":"text","text":"and start runners with SSH provisioning:"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"],"type":"codeListing"},{"text":"Manual Step-by-Step Setup","anchor":"Manual-Step-by-Step-Setup","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If you prefer to configure each step yourself, follow this procedure."}],"type":"paragraph"},{"text":"Step 1: Install Spooktacular","anchor":"Step-1-Install-Spooktacular","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}],"type":"paragraph"},{"syntax":"bash","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Verify the installation:"}],"type":"paragraph"},{"syntax":"bash","code":["spook --version","# spook 1.0.0"],"type":"codeListing"},{"text":"Step 2: Install the LaunchDaemon","anchor":"Step-2-Install-the-LaunchDaemon","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Register Spooktacular as a system service for headless operation:"}],"type":"paragraph"},{"syntax":"bash","code":["spook service install"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":""},{"code":"spook service install","type":"codeVoice"},{"type":"text","text":" creates a LaunchDaemon plist at"},{"type":"text","text":" "},{"code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs via SSH + CLI."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}],"type":"paragraph"},{"text":"LaunchDaemon vs LaunchAgent","anchor":"LaunchDaemon-vs-LaunchAgent","type":"heading","level":3},{"rows":[[[{"inlineContent":[{"type":"text","text":"Service Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runs as"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Starts at"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Best for"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"LaunchDaemon"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"root"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"System boot"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Servers, CI hosts, EC2 Mac"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"LaunchAgent"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"User"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"User login"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Developer workstations"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"For EC2 Mac deployments, always use the LaunchDaemon ("},{"code":"spook service install","type":"codeVoice"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}],"type":"paragraph"},{"syntax":"bash","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"],"type":"codeListing"},{"text":"Security Best Practices","anchor":"Security-Best-Practices","type":"heading","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"VPC private subnet"}],"type":"strong"},{"text":" — Place EC2 Mac hosts in a private subnet","type":"text"},{"text":" ","type":"text"},{"text":"with no public IP. Access via VPN, bastion, or VPC peering.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Security group"}],"type":"strong"},{"text":" — Allow SSH (port 22) only from your bastion","type":"text"},{"text":" ","type":"text"},{"text":"or VPN CIDR.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"IAM"}],"type":"strong"},{"text":" — Use EC2 instance roles for AWS API access. Do not store","type":"text"},{"text":" ","type":"text"},{"text":"long-lived AWS credentials on the host.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote VM management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs by SSH-ing into the host and"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI directly."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"text":"Creating VMs on the EC2 Mac","anchor":"Creating-VMs-on-the-EC2-Mac","type":"heading","level":2},{"text":"From an IPSW (Fresh Install)","anchor":"From-an-IPSW-Fresh-Install","type":"heading","level":3},{"syntax":"bash","code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"IPSW installation takes 10-20 minutes per VM. For faster"},{"type":"text","text":" "},{"type":"text","text":"deployment, create one base VM, configure it, then use"},{"type":"text","text":" "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for instant copies."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"text":"From a Clone (Recommended for Fast Deployment)","anchor":"From-a-Clone-Recommended-for-Fast-Deployment","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}],"type":"paragraph"},{"syntax":"bash","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI image push\/pull is planned for a future release."}]}],"style":"note","name":"Note","type":"aside"},{"text":"Clone from a Base VM","anchor":"Clone-from-a-Base-VM","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}],"type":"paragraph"},{"syntax":"bash","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"CloneManager","type":"codeVoice"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}],"type":"paragraph"},{"text":"Provisioning with User-Data","anchor":"Provisioning-with-User-Data","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}],"type":"paragraph"},{"text":"Monitoring","anchor":"Monitoring","type":"heading","level":2},{"text":"Checking VM Status","anchor":"Checking-VM-Status","type":"heading","level":3},{"syntax":"bash","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"],"type":"codeListing"},{"text":"Logs","anchor":"Logs","type":"heading","level":3},{"syntax":"bash","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"],"type":"codeListing"},{"text":"Disk Usage","anchor":"Disk-Usage","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse"},{"type":"text","text":" "},{"type":"text","text":"but can grow to its configured maximum:"}],"type":"paragraph"},{"syntax":"bash","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"],"type":"codeListing"},{"text":"Cost Optimization","anchor":"Cost-Optimization","type":"heading","level":2},{"text":"The Math","anchor":"The-Math","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts cost approximately "},{"inlineContent":[{"type":"text","text":"$1.083\/hour"}],"type":"strong"},{"type":"text","text":" (M1,"},{"type":"text","text":" "},{"code":"us-east-1","type":"codeVoice"},{"type":"text","text":", on-demand pricing as of 2025). With a 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Scenario"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Hosts"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runners"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Monthly cost"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cost per runner"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Without Spooktacular"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$7,800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$780"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"With Spooktacular"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"20","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$7,800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"With Spooktacular"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$3,900"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"Spooktacular halves the per-runner cost by running 2 VMs per host."}],"type":"paragraph"},{"text":"Hardware Allocation","anchor":"Hardware-Allocation","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Each EC2 Mac "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1) has 8 CPU cores and 16 GB RAM. A"},{"type":"text","text":" "},{"type":"text","text":"recommended split for two VMs:"}],"type":"paragraph"},{"syntax":"bash","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For M2 Pro hosts ("},{"code":"mac2-m2pro.metal","type":"codeVoice"},{"type":"text","text":") with 12 cores and 32 GB RAM:"}],"type":"paragraph"},{"syntax":"bash","code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"],"type":"codeListing"},{"text":"Savings Plans and Reserved Instances","anchor":"Savings-Plans-and-Reserved-Instances","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"type":"text","text":" "},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"type":"text","text":" "},{"type":"text","text":"capacity with a Savings Plan for maximum cost efficiency."}],"type":"paragraph"},{"text":"Auto Scaling Group Integration","anchor":"Auto-Scaling-Group-Integration","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each"},{"type":"text","text":" "},{"type":"text","text":"host runs the setup script via user-data on launch:"}],"type":"paragraph"},{"text":"Launch Template","anchor":"Launch-Template","type":"heading","level":3},{"syntax":"bash","code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"],"type":"codeListing"},{"text":"User-Data Script","anchor":"User-Data-Script","type":"heading","level":3},{"syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing"},{"text":"Terraform Module (Planned)","anchor":"Terraform-Module-Planned","type":"heading","level":2},{"content":[{"inlineContent":[{"type":"text","text":"A Terraform module for declarative EC2 Mac fleet management"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release. For now, use EC2 Launch Templates"},{"type":"text","text":" "},{"type":"text","text":"with user-data scripts to automate host setup."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"text":"Troubleshooting","anchor":"Troubleshooting","type":"heading","level":2},{"text":"IPSW Version Mismatch","anchor":"IPSW-Version-Mismatch","type":"heading","level":3},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" ","type":"text"},{"code":"spook create","type":"codeVoice"},{"text":" fails with “Your macOS (X.Y) cannot","type":"text"},{"text":" ","type":"text"},{"text":"install macOS Z.W.”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"text":" The EC2 Mac host’s macOS is older than the IPSW you are","type":"text"},{"text":" ","type":"text"},{"text":"trying to install. The guest version must be less than or equal to","type":"text"},{"text":" ","type":"text"},{"text":"the host version.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"text":" Update the host macOS to a version that supports the","type":"text"},{"text":" ","type":"text"},{"text":"guest you want to install:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"Compatibility","type":"codeVoice"},{"text":" for details on how version checking works.","type":"text"}],"type":"paragraph"},{"text":"Disk Space Exhausted","anchor":"Disk-Space-Exhausted","type":"heading","level":3},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" VM creation or operation fails with I\/O errors.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"text":" APFS sparse disk images grow as the guest writes data.","type":"text"},{"text":" ","type":"text"},{"text":"Two VMs with 100 GB configured disk can consume up to 200 GB.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"text":" Monitor disk usage and size VMs appropriately:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"],"type":"codeListing"},{"text":"24-Hour Minimum Allocation","anchor":"24-Hour-Minimum-Allocation","type":"heading","level":3},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" You are billed for 24 hours even though you released","type":"text"},{"text":" ","type":"text"},{"text":"the dedicated host after 2 hours.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation period. This is an AWS policy, not a Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"limitation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"text":" Plan your usage in 24-hour blocks. Use Auto Scaling","type":"text"},{"text":" ","type":"text"},{"text":"Groups with scheduled scaling to align host allocation with your","type":"text"},{"text":" ","type":"text"},{"text":"CI load patterns:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"],"type":"codeListing"},{"text":"VM Won’t Start","anchor":"VM-Wont-Start","type":"heading","level":3},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" ","type":"text"},{"code":"spook start","type":"codeVoice"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"code":"VirtualMachineState\/error","type":"codeVoice"},{"text":" state.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"text":" Common causes include insufficient resources (too many","type":"text"},{"text":" ","type":"text"},{"text":"cores allocated across VMs), corrupt disk image, or the Apple","type":"text"},{"text":" ","type":"text"},{"text":"kernel 2-VM limit.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"}],"type":"paragraph"},{"syntax":"bash","code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"Apple’s Virtualization framework enforces a hard limit"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"strong","inlineContent":[{"type":"text","text":"2 concurrent VMs"}]},{"type":"text","text":" per host. Attempting to start a third VM"},{"type":"text","text":" "},{"type":"text","text":"will fail. See "},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"type":"text","text":" for minimum hardware"},{"type":"text","text":" "},{"type":"text","text":"requirements."}],"type":"paragraph"}],"style":"important","name":"Important","type":"aside"}]}],"sections":[],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","type":"topic","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/remotedesktop"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","type":"topic","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","type":"topic","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"title":"Machine Learning Workloads","type":"topic","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"title":"Running BlueBubbles iMessage Server","type":"topic","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","type":"topic","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","kind":"symbol","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","type":"topic","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/openclawguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","type":"topic","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/kubernetesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","type":"topic","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/jenkinsguide"}}}