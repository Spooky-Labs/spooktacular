ation\/spooktacularkit\/virtualmachinespecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"title":"VirtualMachineSpecification","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineBundle":{"role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/virtualmachinebundle","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineBundle"}],"abstract":[{"type":"text","text":"A virtual machine bundle stored on disk."}],"title":"VirtualMachineBundle","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VirtualMachineBundle","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"kind":"article"}}}