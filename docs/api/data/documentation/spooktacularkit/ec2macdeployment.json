ed","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Deploying on EC2 Mac","role":"collectionGroup"},"kind":"article","seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the","type":"text"},{"text":" ","type":"text"},{"text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with Spooktacular you can run "},{"type":"strong","inlineContent":[{"type":"text","text":"two"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}]},{"type":"heading","anchor":"Prerequisites","level":3,"text":"Prerequisites"},{"type":"paragraph","inlineContent":[{"text":"Before you begin, ensure you have:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"AWS account"}]},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"text":" ","type":"text"},{"text":"quota increase for ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"mac2-m2.metal"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"EC2 Mac dedicated host"}]},{"type":"text","text":" — Mac instances run exclusively on"},{"type":"text","text":" "},{"type":"text","text":"dedicated hosts (not shared tenancy)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"VPC with a private subnet","type":"text"}],"type":"strong"},{"type":"text","text":" — recommended for security"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Security group","type":"text"}],"type":"strong"},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"SSH key pair","type":"text"}]},{"text":" for EC2 access","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac host types: "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1), "},{"code":"mac2-m2.metal","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"(M2), or "},{"code":"mac2-m2pro.metal","type":"codeVoice"},{"type":"text","text":" (M2 Pro)"}]}]}]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts have a "},{"inlineContent":[{"text":"24-hour minimum allocation","type":"text"},{"text":" ","type":"text"},{"text":"period","type":"text"}],"type":"strong"},{"type":"text","text":". You are billed for the full 24 hours even if you release the"},{"type":"text","text":" "},{"type":"text","text":"host earlier. Plan your usage accordingly."}]}],"type":"aside","name":"Important"},{"text":"Quick Setup","level":2,"type":"heading","anchor":"Quick-Setup"},{"inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,"},{"type":"text","text":" "},{"type":"text","text":"and start runners with SSH provisioning:"}],"type":"paragraph"},{"code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"text":"Manual Step-by-Step Setup","anchor":"Manual-Step-by-Step-Setup","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you prefer to configure each step yourself, follow this procedure."}],"type":"paragraph"},{"text":"Step 1: Install Spooktacular","anchor":"Step-1-Install-Spooktacular","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}],"type":"paragraph"},{"code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Verify the installation:"}],"type":"paragraph"},{"code":["spook --version","# spook 0.1.0"],"syntax":"bash","type":"codeListing"},{"text":"Step 2: Install the LaunchDaemon","anchor":"Step-2-Install-the-LaunchDaemon","level":3,"type":"heading"},{"inlineContent":[{"text":"Register Spooktacular as a system service for headless operation:","type":"text"}],"type":"paragraph"},{"code":["spook service install"],"syntax":"bash","type":"codeListing"},{"name":"Note","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"spook service install","type":"codeVoice"},{"text":" creates a LaunchDaemon plist at","type":"text"},{"text":" ","type":"text"},{"code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs via SSH + CLI."}],"type":"paragraph"}],"type":"aside","style":"note"},{"inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}],"type":"paragraph"},{"text":"LaunchDaemon vs LaunchAgent","anchor":"LaunchDaemon-vs-LaunchAgent","level":3,"type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Service Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runs as"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts at"}]}],[{"type":"paragraph","inlineContent":[{"text":"Best for","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchDaemon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"root"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"System boot"}]}],[{"type":"paragraph","inlineContent":[{"text":"Servers, CI hosts, EC2 Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"LaunchAgent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User"}]}],[{"type":"paragraph","inlineContent":[{"text":"User login","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Developer workstations"}]}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"For EC2 Mac deployments, always use the LaunchDaemon ("},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}],"type":"paragraph"},{"code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"],"syntax":"bash","type":"codeListing"},{"level":2,"text":"Security Best Practices","anchor":"Security-Best-Practices","type":"heading"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"VPC private subnet"}],"type":"strong"},{"type":"text","text":" — Place EC2 Mac hosts in a private subnet"},{"type":"text","text":" "},{"type":"text","text":"with no public IP. Access via VPN, bastion, or VPC peering."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Security group","type":"text"}],"type":"strong"},{"type":"text","text":" — Allow SSH (port 22) only from your bastion"},{"type":"text","text":" "},{"type":"text","text":"or VPN CIDR."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"IAM","type":"text"}]},{"text":" — Use EC2 instance roles for AWS API access. Do not store","type":"text"},{"text":" ","type":"text"},{"text":"long-lived AWS credentials on the host.","type":"text"}]}]}],"type":"orderedList"},{"content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote VM management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs by SSH-ing into the host and"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI directly."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"text":"Creating VMs on the EC2 Mac","level":2,"anchor":"Creating-VMs-on-the-EC2-Mac","type":"heading"},{"text":"From an IPSW (Fresh Install)","level":3,"anchor":"From-an-IPSW-Fresh-Install","type":"heading"},{"code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"syntax":"bash","type":"codeListing"},{"content":[{"inlineContent":[{"text":"IPSW installation takes 10-20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create one base VM, configure it, then use","type":"text"},{"text":" ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for instant copies.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"text":"From a Clone (Recommended for Fast Deployment)","type":"heading","level":3,"anchor":"From-a-Clone-Recommended-for-Fast-Deployment"},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}],"type":"paragraph"},{"code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"],"syntax":"bash","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"OCI image push\/pull is planned for a future release.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"text":"Clone from a Base VM","type":"heading","level":3,"anchor":"Clone-from-a-Base-VM"},{"inlineContent":[{"text":"Create one base VM, configure it, then clone instantly:","type":"text"}],"type":"paragraph"},{"code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}],"type":"paragraph"},{"text":"Provisioning with User-Data","type":"heading","level":3,"anchor":"Provisioning-with-User-Data"},{"inlineContent":[{"text":"Automate VM setup with a user-data script via SSH provisioning:","type":"text"}],"type":"paragraph"},{"code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}],"type":"paragraph"},{"text":"Monitoring","type":"heading","level":2,"anchor":"Monitoring"},{"text":"Checking VM Status","type":"heading","level":3,"anchor":"Checking-VM-Status"},{"code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"],"syntax":"bash","type":"codeListing"},{"text":"Logs","type":"heading","level":3,"anchor":"Logs"},{"code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"],"syntax":"bash","type":"codeListing"},{"text":"Disk Usage","type":"heading","level":3,"anchor":"Disk-Usage"},{"inlineContent":[{"text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse","type":"text"},{"text":" ","type":"text"},{"text":"but can grow to its configured maximum:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"],"syntax":"bash"},{"level":2,"type":"heading","anchor":"Cost-Optimization","text":"Cost Optimization"},{"level":3,"type":"heading","anchor":"The-Math","text":"The Math"},{"type":"paragraph","inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts cost approximately "},{"type":"strong","inlineContent":[{"text":"$1.083\/hour","type":"text"}]},{"type":"text","text":" (M1,"},{"type":"text","text":" "},{"type":"codeVoice","code":"us-east-1"},{"type":"text","text":", on-demand pricing as of 2025). With a 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Scenario","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Hosts","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runners"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Monthly cost","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cost per runner","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Without Spooktacular"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$7,800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$780","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"With Spooktacular","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"~$7,800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"With Spooktacular","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$3,900"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]]]},{"type":"paragraph","inlineContent":[{"text":"Spooktacular halves the per-runner cost by running 2 VMs per host.","type":"text"}]},{"text":"Hardware Allocation","type":"heading","level":3,"anchor":"Hardware-Allocation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each EC2 Mac "},{"type":"codeVoice","code":"mac2.metal"},{"type":"text","text":" (M1) has 8 CPU cores and 16 GB RAM. A"},{"type":"text","text":" "},{"type":"text","text":"recommended split for two VMs:"}]},{"syntax":"bash","type":"codeListing","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For M2 Pro hosts ("},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":") with 12 cores and 32 GB RAM:"}]},{"syntax":"bash","type":"codeListing","code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"]},{"text":"Savings Plans and Reserved Instances","type":"heading","level":3,"anchor":"Savings-Plans-and-Reserved-Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"type":"text","text":" "},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"type":"text","text":" "},{"type":"text","text":"capacity with a Savings Plan for maximum cost efficiency."}]},{"type":"heading","text":"Auto Scaling Group Integration","anchor":"Auto-Scaling-Group-Integration","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each"},{"type":"text","text":" "},{"type":"text","text":"host runs the setup script via user-data on launch:"}]},{"type":"heading","text":"Launch Template","anchor":"Launch-Template","level":3},{"syntax":"bash","type":"codeListing","code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"]},{"type":"heading","text":"User-Data Script","anchor":"User-Data-Script","level":3},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"]},{"type":"heading","text":"Terraform Module (Planned)","anchor":"Terraform-Module-Planned","level":2},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Terraform module for declarative EC2 Mac fleet management"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release. For now, use EC2 Launch Templates"},{"type":"text","text":" "},{"type":"text","text":"with user-data scripts to automate host setup."}]}]},{"type":"heading","text":"Troubleshooting","anchor":"Troubleshooting","level":2},{"type":"heading","text":"IPSW Version Mismatch","anchor":"IPSW-Version-Mismatch","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"spook create","type":"codeVoice"},{"type":"text","text":" fails with “Your macOS (X.Y) cannot"},{"type":"text","text":" "},{"type":"text","text":"install macOS Z.W.”"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" The EC2 Mac host’s macOS is older than the IPSW you are"},{"type":"text","text":" "},{"type":"text","text":"trying to install. The guest version must be less than or equal to"},{"type":"text","text":" "},{"type":"text","text":"the host version."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"type":"text","text":" Update the host macOS to a version that supports the"},{"type":"text","text":" "},{"type":"text","text":"guest you want to install:"}]},{"type":"codeListing","syntax":"bash","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"Compatibility"},{"text":" for details on how version checking works.","type":"text"}]},{"level":3,"type":"heading","text":"Disk Space Exhausted","anchor":"Disk-Space-Exhausted"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" VM creation or operation fails with I\/O errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" APFS sparse disk images grow as the guest writes data.","type":"text"},{"text":" ","type":"text"},{"text":"Two VMs with 100 GB configured disk can consume up to 200 GB.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]},{"text":" Monitor disk usage and size VMs appropriately:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"]},{"level":3,"type":"heading","text":"24-Hour Minimum Allocation","anchor":"24-Hour-Minimum-Allocation"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"text":" You are billed for 24 hours even though you released","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the dedicated host after 2 hours."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"type":"text","text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation period. This is an AWS policy, not a Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"limitation."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"text":" Plan your usage in 24-hour blocks. Use Auto Scaling","type":"text"},{"text":" ","type":"text"},{"text":"Groups with scheduled scaling to align host allocation with your","type":"text"},{"text":" ","type":"text"},{"text":"CI load patterns:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"]},{"text":"VM Won’t Start","anchor":"VM-Wont-Start","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook start"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VirtualMachineState\/error"},{"text":" state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"text":" Common causes include insufficient resources (too many","type":"text"},{"text":" ","type":"text"},{"text":"cores allocated across VMs), corrupt disk image, or the Apple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"kernel 2-VM limit."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]}]},{"code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"],"syntax":"bash","type":"codeListing"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"text":"Apple’s Virtualization framework enforces a hard limit","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"inlineContent":[{"text":"2 concurrent VMs","type":"text"}],"type":"strong"},{"text":" per host. Attempting to start a third VM","type":"text"},{"text":" ","type":"text"},{"text":"will fail. See ","type":"text"},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"text":" for minimum hardware","type":"text"},{"text":" ","type":"text"},{"text":"requirements.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","role":"collectionGroup","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"title":"Machine Learning Workloads","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"title":"Running BlueBubbles iMessage Server","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","url":"\/documentation\/spooktacularkit\/bluebubblesguide","role":"collectionGroup","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","url":"\/documentation\/spooktacularkit\/jenkinsguide","role":"collectionGroup","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","kind":"article","role":"collectionGroup","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic","title":"Using the spook Command-Line Interface"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"url":"\/documentation\/spooktacularkit\/remotedesktop","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"collectionGroup","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"url":"\/documentation\/spooktacularkit\/versioning","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","role":"collectionGroup","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic","title":"Kubernetes Integration"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","role":"collectionGroup","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup","kind":"article","type":"topic"}}}