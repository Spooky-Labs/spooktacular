{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"kind":"article","metadata":{"roleHeading":"API Collection","role":"collectionGroup","title":"Deploying on EC2 Mac","modules":[{"name":"SpooktacularKit"}]},"sections":[],"seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the","type":"text"},{"text":" ","type":"text"},{"text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but","type":"text"},{"text":" ","type":"text"},{"text":"with Spooktacular you can run ","type":"text"},{"type":"strong","inlineContent":[{"text":"two","type":"text"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}]},{"type":"paragraph","inlineContent":[{"text":"This guide covers the complete setup: from allocating a dedicated host","type":"text"},{"text":" ","type":"text"},{"text":"to running a production GitHub Actions fleet on EC2 Mac.","type":"text"}]},{"level":3,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"type":"paragraph","inlineContent":[{"text":"Before you begin, ensure you have:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"AWS account"}],"type":"strong"},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"type":"text","text":" "},{"text":"quota increase for ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"mac2-m2.metal","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"EC2 Mac dedicated host","type":"text"}],"type":"strong"},{"type":"text","text":" — Mac instances run exclusively on"},{"type":"text","text":" "},{"text":"dedicated hosts (not shared tenancy)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"VPC with a private subnet","type":"text"}]},{"type":"text","text":" — recommended for security"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"SSH key pair"}],"type":"strong"},{"type":"text","text":" for EC2 access"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac host types: "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1), "},{"type":"codeVoice","code":"mac2-m2.metal"},{"type":"text","text":" "},{"type":"text","text":"(M2), or "},{"code":"mac2-m2pro.metal","type":"codeVoice"},{"text":" (M2 Pro)","type":"text"}]}]}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"EC2 Mac dedicated hosts have a ","type":"text"},{"inlineContent":[{"text":"24-hour minimum allocation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"period"}],"type":"strong"},{"text":". You are billed for the full 24 hours even if you release the","type":"text"},{"text":" ","type":"text"},{"text":"host earlier. Plan your usage accordingly.","type":"text"}]}],"style":"important","name":"Important"},{"type":"heading","level":2,"text":"Quick Setup","anchor":"Quick-Setup"},{"type":"paragraph","inlineContent":[{"text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,","type":"text"},{"text":" ","type":"text"},{"text":"and start runners with SSH provisioning:","type":"text"}]},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"],"type":"codeListing"},{"text":"Manual Step-by-Step Setup","level":2,"anchor":"Manual-Step-by-Step-Setup","type":"heading"},{"inlineContent":[{"text":"If you prefer to configure each step yourself, follow this procedure.","type":"text"}],"type":"paragraph"},{"text":"Step 1: Install Spooktacular","type":"heading","level":3,"anchor":"Step-1-Install-Spooktacular"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}]},{"type":"codeListing","syntax":"bash","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"]},{"inlineContent":[{"text":"Verify the installation:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook --version","# spook 0.1.0"]},{"anchor":"Step-2-Install-the-LaunchDaemon","type":"heading","text":"Step 2: Install the LaunchDaemon","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register Spooktacular as a system service for headless operation:"}]},{"type":"codeListing","syntax":"bash","code":["spook service install"]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":" creates a LaunchDaemon plist at"},{"type":"text","text":" "},{"code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist","type":"codeVoice"},{"type":"text","text":"."}]}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs via SSH + CLI."}],"type":"paragraph"}],"name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}]},{"text":"LaunchDaemon vs LaunchAgent","anchor":"LaunchDaemon-vs-LaunchAgent","type":"heading","level":3},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Service Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Runs as"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Starts at","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchDaemon"}]}],[{"type":"paragraph","inlineContent":[{"text":"root","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"System boot"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Servers, CI hosts, EC2 Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchAgent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User login"}]}],[{"inlineContent":[{"type":"text","text":"Developer workstations"}],"type":"paragraph"}]]]},{"inlineContent":[{"text":"For EC2 Mac deployments, always use the LaunchDaemon (","type":"text"},{"code":"spook service install","type":"codeVoice"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}],"type":"paragraph"},{"syntax":"bash","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"],"type":"codeListing"},{"level":2,"anchor":"Security-Best-Practices","text":"Security Best Practices","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VPC private subnet"}]},{"type":"text","text":" — Place EC2 Mac hosts in a private subnet"},{"type":"text","text":" "},{"type":"text","text":"with no public IP. Access via VPN, bastion, or VPC peering."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"text":" — Allow SSH (port 22) only from your bastion","type":"text"},{"text":" ","type":"text"},{"text":"or VPN CIDR.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"IAM","type":"text"}]},{"type":"text","text":" — Use EC2 instance roles for AWS API access. Do not store"},{"text":" ","type":"text"},{"text":"long-lived AWS credentials on the host.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"content":[{"inlineContent":[{"type":"text","text":"An HTTP control API for remote VM management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs by SSH-ing into the host and"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI directly."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"level":2,"text":"Creating VMs on the EC2 Mac","type":"heading","anchor":"Creating-VMs-on-the-EC2-Mac"},{"anchor":"From-an-IPSW-Fresh-Install","level":3,"text":"From an IPSW (Fresh Install)","type":"heading"},{"code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"syntax":"bash","type":"codeListing"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"IPSW installation takes 10-20 minutes per VM. For faster"},{"text":" ","type":"text"},{"type":"text","text":"deployment, create one base VM, configure it, then use"},{"type":"text","text":" "},{"code":"spook clone","type":"codeVoice"},{"text":" for instant copies.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"anchor":"From-a-Clone-Recommended-for-Fast-Deployment","level":3,"text":"From a Clone (Recommended for Fast Deployment)","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}]},{"type":"codeListing","syntax":"bash","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI image push\/pull is planned for a future release."}]}]},{"type":"heading","text":"Clone from a Base VM","anchor":"Clone-from-a-Base-VM","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}]},{"syntax":"bash","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","type":"reference"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Provisioning-with-User-Data","text":"Provisioning with User-Data"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}]},{"code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}]},{"type":"heading","anchor":"Monitoring","text":"Monitoring","level":2},{"anchor":"Checking-VM-Status","text":"Checking VM Status","type":"heading","level":3},{"syntax":"bash","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"],"type":"codeListing"},{"anchor":"Logs","text":"Logs","type":"heading","level":3},{"syntax":"bash","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"],"type":"codeListing"},{"type":"heading","level":3,"anchor":"Disk-Usage","text":"Disk Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse"},{"type":"text","text":" "},{"type":"text","text":"but can grow to its configured maximum:"}]},{"type":"codeListing","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"],"syntax":"bash"},{"type":"heading","level":2,"text":"Cost Optimization","anchor":"Cost-Optimization"},{"type":"heading","level":3,"text":"The Math","anchor":"The-Math"},{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts cost approximately "},{"type":"strong","inlineContent":[{"type":"text","text":"$1.083\/hour"}]},{"text":" (M1,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"us-east-1"},{"text":", on-demand pricing as of 2025). With a 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Scenario"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hosts"}]}],[{"type":"paragraph","inlineContent":[{"text":"Runners","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Monthly cost","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Cost per runner"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Without Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$7,800"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$780","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$7,800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"inlineContent":[{"type":"text","text":"5"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$3,900"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$390","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular halves the per-runner cost by running 2 VMs per host."}]},{"level":3,"type":"heading","anchor":"Hardware-Allocation","text":"Hardware Allocation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each EC2 Mac "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1) has 8 CPU cores and 16 GB RAM. A"},{"type":"text","text":" "},{"text":"recommended split for two VMs:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For M2 Pro hosts ("},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":") with 12 cores and 32 GB RAM:"}]},{"syntax":"bash","type":"codeListing","code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"]},{"level":3,"type":"heading","anchor":"Savings-Plans-and-Reserved-Instances","text":"Savings Plans and Reserved Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"text":" ","type":"text"},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"text":" ","type":"text"},{"text":"capacity with a Savings Plan for maximum cost efficiency.","type":"text"}]},{"level":2,"type":"heading","anchor":"Auto-Scaling-Group-Integration","text":"Auto Scaling Group Integration"},{"inlineContent":[{"text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each","type":"text"},{"text":" ","type":"text"},{"text":"host runs the setup script via user-data on launch:","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Launch-Template","type":"heading","text":"Launch Template"},{"syntax":"bash","code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"],"type":"codeListing"},{"text":"User-Data Script","level":3,"anchor":"User-Data-Script","type":"heading"},{"syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing"},{"text":"Terraform Module (Planned)","level":2,"anchor":"Terraform-Module-Planned","type":"heading"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"A Terraform module for declarative EC2 Mac fleet management","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release. For now, use EC2 Launch Templates","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with user-data scripts to automate host setup."}]}],"style":"note","name":"Note"},{"level":2,"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting"},{"level":3,"type":"heading","anchor":"IPSW-Version-Mismatch","text":"IPSW Version Mismatch"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" "},{"code":"spook create","type":"codeVoice"},{"text":" fails with “Your macOS (X.Y) cannot","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"install macOS Z.W.”"}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"type":"text","text":" The EC2 Mac host’s macOS is older than the IPSW you are"},{"text":" ","type":"text"},{"type":"text","text":"trying to install. The guest version must be less than or equal to"},{"text":" ","type":"text"},{"type":"text","text":"the host version."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"type":"text","text":" Update the host macOS to a version that supports the"},{"type":"text","text":" "},{"type":"text","text":"guest you want to install:"}]},{"type":"codeListing","syntax":"bash","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility","type":"reference","isActive":true},{"text":" for details on how version checking works.","type":"text"}]},{"level":3,"type":"heading","text":"Disk Space Exhausted","anchor":"Disk-Space-Exhausted"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" VM creation or operation fails with I\/O errors.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Cause:","type":"text"}],"type":"strong"},{"text":" APFS sparse disk images grow as the guest writes data.","type":"text"},{"text":" ","type":"text"},{"text":"Two VMs with 100 GB configured disk can consume up to 200 GB.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"type":"text","text":" Monitor disk usage and size VMs appropriately:"}],"type":"paragraph"},{"syntax":"bash","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"],"type":"codeListing"},{"text":"24-Hour Minimum Allocation","level":3,"anchor":"24-Hour-Minimum-Allocation","type":"heading"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"type":"text","text":" You are billed for 24 hours even though you released"},{"text":" ","type":"text"},{"text":"the dedicated host after 2 hours.","type":"text"}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocation period. This is an AWS policy, not a Spooktacular"},{"text":" ","type":"text"},{"type":"text","text":"limitation."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"type":"text","text":" Plan your usage in 24-hour blocks. Use Auto Scaling"},{"type":"text","text":" "},{"type":"text","text":"Groups with scheduled scaling to align host allocation with your"},{"type":"text","text":" "},{"type":"text","text":"CI load patterns:"}]},{"code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"],"type":"codeListing","syntax":"bash"},{"text":"VM Won’t Start","anchor":"VM-Wont-Start","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"spook start"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState\/error"},{"type":"text","text":" state."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"text":" Common causes include insufficient resources (too many","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cores allocated across VMs), corrupt disk image, or the Apple"},{"type":"text","text":" "},{"text":"kernel 2-VM limit.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]}]},{"code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"],"syntax":"bash","type":"codeListing"},{"style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework enforces a hard limit"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"strong","inlineContent":[{"type":"text","text":"2 concurrent VMs"}]},{"type":"text","text":" per host. Attempting to start a third VM"},{"type":"text","text":" "},{"type":"text","text":"will fail. See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","isActive":true},{"text":" for minimum hardware","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requirements."}]}],"name":"Important"}],"kind":"content"}],"topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],"title":"Related Guides"},{"anchor":"Key-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMa