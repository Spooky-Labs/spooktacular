arKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"],"title":"Related Guides"},{"anchor":"Key-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RestoreImageManager","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState"],"title":"Key Types"}],"seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the"},{"type":"text","text":" "},{"type":"text","text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but"},{"type":"text","text":" "},{"type":"text","text":"with Spooktacular you can run "},{"type":"strong","inlineContent":[{"text":"two","type":"text"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}]},{"anchor":"Prerequisites","type":"heading","text":"Prerequisites","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before you begin, ensure you have:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"AWS account","type":"text"}],"type":"strong"},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"text":" ","type":"text"},{"text":"quota increase for ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"mac2-m2.metal","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"EC2 Mac dedicated host","type":"text"}],"type":"strong"},{"text":" — Mac instances run exclusively on","type":"text"},{"text":" ","type":"text"},{"text":"dedicated hosts (not shared tenancy)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"VPC with a private subnet","type":"text"}],"type":"strong"},{"text":" — recommended for security","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"SSH key pair","type":"text"}]},{"text":" for EC2 access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac host types: ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" (M1), ","type":"text"},{"type":"codeVoice","code":"mac2-m2.metal"},{"text":" ","type":"text"},{"text":"(M2), or ","type":"text"},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"text":" (M2 Pro)","type":"text"}]}]}],"type":"unorderedList"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"EC2 Mac dedicated hosts have a ","type":"text"},{"type":"strong","inlineContent":[{"text":"24-hour minimum allocation","type":"text"},{"text":" ","type":"text"},{"text":"period","type":"text"}]},{"text":". You are billed for the full 24 hours even if you release the","type":"text"},{"text":" ","type":"text"},{"text":"host earlier. Plan your usage accordingly.","type":"text"}]}],"type":"aside"},{"anchor":"Quick-Setup","type":"heading","text":"Quick Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,"},{"type":"text","text":" "},{"type":"text","text":"and start runners with SSH provisioning:"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"]},{"anchor":"Manual-Step-by-Step-Setup","type":"heading","text":"Manual Step-by-Step Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you prefer to configure each step yourself, follow this procedure."}]},{"anchor":"Step-1-Install-Spooktacular","type":"heading","text":"Step 1: Install Spooktacular","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}]},{"type":"codeListing","syntax":"bash","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify the installation:"}]},{"type":"codeListing","syntax":"bash","code":["spook --version","# spook 0.1.0"]},{"text":"Step 2: Install the LaunchDaemon","type":"heading","anchor":"Step-2-Install-the-LaunchDaemon","level":3},{"type":"paragraph","inlineContent":[{"text":"Register Spooktacular as a system service for headless operation:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook service install"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"spook service install"},{"text":" creates a LaunchDaemon plist at","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist"},{"type":"text","text":"."}]}],"type":"aside","style":"note","name":"Note"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP control API for remote management is planned for a","type":"text"},{"text":" ","type":"text"},{"text":"future release. For now, manage VMs via SSH + CLI.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}]},{"anchor":"LaunchDaemon-vs-LaunchAgent","type":"heading","text":"LaunchDaemon vs LaunchAgent","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Service Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runs as"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts at"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchDaemon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"root"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"System boot"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Servers, CI hosts, EC2 Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"LaunchAgent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"User","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User login"}]}],[{"type":"paragraph","inlineContent":[{"text":"Developer workstations","type":"text"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"For EC2 Mac deployments, always use the LaunchDaemon ("},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}],"type":"paragraph"},{"syntax":"bash","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"],"type":"codeListing"},{"level":2,"text":"Security Best Practices","anchor":"Security-Best-Practices","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VPC private subnet"}]},{"text":" — Place EC2 Mac hosts in a private subnet","type":"text"},{"text":" ","type":"text"},{"text":"with no public IP. Access via VPN, bastion, or VPC peering.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Security group"}]},{"type":"text","text":" — Allow SSH (port 22) only from your bastion"},{"text":" ","type":"text"},{"type":"text","text":"or VPN CIDR."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"IAM"}]},{"text":" — Use EC2 instance roles for AWS API access. Do not store","type":"text"},{"text":" ","type":"text"},{"text":"long-lived AWS credentials on the host.","type":"text"}]}]}],"type":"orderedList"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP control API for remote VM management is planned for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"future release. For now, manage VMs by SSH-ing into the host and"},{"text":" ","type":"text"},{"type":"text","text":"using the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI directly."}]}]},{"anchor":"Creating-VMs-on-the-EC2-Mac","level":2,"type":"heading","text":"Creating VMs on the EC2 Mac"},{"anchor":"From-an-IPSW-Fresh-Install","level":3,"type":"heading","text":"From an IPSW (Fresh Install)"},{"syntax":"bash","code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10-20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create one base VM, configure it, then use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook clone"},{"text":" for instant copies.","type":"text"}]}],"type":"aside"},{"level":3,"anchor":"From-a-Clone-Recommended-for-Fast-Deployment","text":"From a Clone (Recommended for Fast Deployment)","type":"heading"},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}],"type":"paragraph"},{"syntax":"bash","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"OCI image push\/pull is planned for a future release.","type":"text"}]}],"type":"aside"},{"level":3,"anchor":"Clone-from-a-Base-VM","text":"Clone from a Base VM","type":"heading"},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}],"type":"paragraph"},{"syntax":"bash","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","isActive":true},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}],"type":"paragraph"},{"level":3,"anchor":"Provisioning-with-User-Data","text":"Provisioning with User-Data","type":"heading"},{"inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for available provisioning modes.","type":"text"}]},{"anchor":"Monitoring","level":2,"type":"heading","text":"Monitoring"},{"anchor":"Checking-VM-Status","level":3,"type":"heading","text":"Checking VM Status"},{"type":"codeListing","syntax":"bash","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"]},{"text":"Logs","type":"heading","anchor":"Logs","level":3},{"type":"codeListing","syntax":"bash","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"]},{"text":"Disk Usage","type":"heading","anchor":"Disk-Usage","level":3},{"type":"paragraph","inlineContent":[{"text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but can grow to its configured maximum:"}]},{"code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"],"syntax":"bash","type":"codeListing"},{"anchor":"Cost-Optimization","level":2,"type":"heading","text":"Cost Optimization"},{"anchor":"The-Math","level":3,"type":"heading","text":"The Math"},{"type":"paragraph","inlineContent":[{"text":"EC2 Mac dedicated hosts cost approximately ","type":"text"},{"inlineContent":[{"text":"$1.083\/hour","type":"text"}],"type":"strong"},{"text":" (M1,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"us-east-1"},{"text":", on-demand pricing as of 2025). With a 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Scenario","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Hosts","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Runners","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Monthly cost","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Cost per runner","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Without Spooktacular","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$7,800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$780","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"With Spooktacular","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$7,800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"~$390"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"With Spooktacular","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"~$3,900"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"~$390","type":"text"}]}]]]},{"type":"paragraph","inlineContent":[{"text":"Spooktacular halves the per-runner cost by running 2 VMs per host.","type":"text"}]},{"anchor":"Hardware-Allocation","level":3,"type":"heading","text":"Hardware Allocation"},{"type":"paragraph","inlineContent":[{"text":"Each EC2 Mac ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" (M1) has 8 CPU cores and 16 GB RAM. A","type":"text"},{"text":" ","type":"text"},{"text":"recommended split for two VMs:","type":"text"}]},{"code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For M2 Pro hosts (","type":"text"},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"text":") with 12 cores and 32 GB RAM:","type":"text"}]},{"code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"],"syntax":"bash","type":"codeListing"},{"anchor":"Savings-Plans-and-Reserved-Instances","level":3,"type":"heading","text":"Savings Plans and Reserved Instances"},{"type":"paragraph","inlineContent":[{"text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%","type":"text"},{"text":" ","type":"text"},{"text":"discount for a 1-year commitment. Combine Spooktacular’s 2x","type":"text"},{"text":" ","type":"text"},{"text":"capacity with a Savings Plan for maximum cost efficiency.","type":"text"}]},{"anchor":"Auto-Scaling-Group-Integration","level":2,"type":"heading","text":"Auto Scaling Group Integration"},{"type":"paragraph","inlineContent":[{"text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each","type":"text"},{"text":" ","type":"text"},{"text":"host runs the setup script via user-data on launch:","type":"text"}]},{"anchor":"Launch-Template","level":3,"type":"heading","text":"Launch Template"},{"code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"],"syntax":"bash","type":"codeListing"},{"anchor":"User-Data-Script","level":3,"type":"heading","text":"User-Data Script"},{"code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"anchor":"Terraform-Module-Planned","level":2,"type":"heading","text":"Terraform Module (Planned)"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"A Terraform module for declarative EC2 Mac fleet management","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release. For now, use EC2 Launch Templates","type":"text"},{"text":" ","type":"text"},{"text":"with user-data scripts to automate host setup.","type":"text"}]}]},{"anchor":"Troubleshooting","level":2,"type":"heading","text":"Troubleshooting"},{"anchor":"IPSW-Version-Mismatch","level":3,"type":"heading","text":"IPSW Version Mismatch"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook create"},{"text":" fails with “Your macOS (X.Y) cannot","type":"text"},{"text":" ","type":"text"},{"text":"install macOS Z.W.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" The EC2 Mac host’s macOS is older than the IPSW you are","type":"text"},{"text":" ","type":"text"},{"text":"trying to install. The guest version must be less than or equal to","type":"text"},{"text":" ","type":"text"},{"text":"the host version.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Update the host macOS to a version that supports the","type":"text"},{"text":" ","type":"text"},{"text":"guest you want to install:","type":"text"}]},{"code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility","type":"reference","isActive":true},{"text":" for details on how version checking works.","type":"text"}]},{"anchor":"Disk-Space-Exhausted","level":3,"type":"heading","text":"Disk Space Exhausted"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" VM creation or operation fails with I\/O errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" APFS sparse disk images grow as the guest writes data.","type":"text"},{"text":" ","type":"text"},{"text":"Two VMs with 100 GB configured disk can consume up to 200 GB.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Monitor disk usage and size VMs appropriately:","type":"text"}]},{"code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"],"syntax":"bash","type":"codeListing"},{"anchor":"24-Hour-Minimum-Allocation","level":3,"type":"heading","text":"24-Hour Minimum Allocation"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" You are billed for 24 hours even though you released","type":"text"},{"text":" ","type":"text"},{"text":"the dedicated host after 2 hours.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation period. This is an AWS policy, not a Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"limitation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Plan your usage in 24-hour blocks. Use Auto Scaling","type":"text"},{"text":" ","type":"text"},{"text":"Groups with scheduled scaling to align host allocation with your","type":"text"},{"text":" ","type":"text"},{"text":"CI load patterns:","type":"text"}]},{"code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"],"syntax":"bash","type":"codeListing"},{"anchor":"VM-Wont-Start","level":3,"type":"heading","text":"VM Won’t Start"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook start"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState\/error","type":"reference","isActive":true},{"text":" state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" Common causes include insufficient resources (too many","type":"text"},{"text":" ","type":"text"},{"text":"cores allocated across VMs), corrupt disk image, or the Apple","type":"text"},{"text":" ","type":"text"},{"text":"kernel 2-VM limit.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]}]},{"code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"],"syntax":"bash","type":"codeListing"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Apple’s Virtualization framework enforces a hard limit","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"strong","inlineContent":[{"text":"2 concurrent VMs","type":"text"}]},{"text":" per host. Attempting to start a third VM","type":"text"},{"text":" ","type":"text"},{"text":"will fail. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","isActive":true,"type":"reference"},{"text":" for minimum hardware","type":"text"},{"text":" ","type":"text"},{"text":"requirements.","type":"text"}]}]}],"kind":"content"}],"sections":[],"metadata":{"role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"title":"Deploying on EC2 Mac"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the t