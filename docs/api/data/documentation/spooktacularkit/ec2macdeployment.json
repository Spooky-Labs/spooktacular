rd","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/RestoreImageManager":{"type":"topic","title":"RestoreImageManager","url":"\/documentation\/spooktacularkit\/restoreimagemanager","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RestoreImageManager","navigatorTitle":[{"kind":"identifier","text":"RestoreImageManager"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RestoreImageManager"}],"abstract":[{"type":"text","text":"Manages macOS restore images (IPSWs) for virtual machine installation."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/spooktacularkit\/mlworkloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","type":"topic","url":"\/documentation\/spook