{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the","type":"text"},{"text":" ","type":"text"},{"text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but","type":"text"},{"text":" ","type":"text"},{"text":"with Spooktacular you can run ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"two"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}],"type":"paragraph"},{"level":3,"text":"Prerequisites","type":"heading","anchor":"Prerequisites"},{"inlineContent":[{"type":"text","text":"Before you begin, ensure you have:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"AWS account","type":"text"}]},{"type":"text","text":" with EC2 Mac instance access (may require a service"},{"type":"text","text":" "},{"type":"text","text":"quota increase for "},{"type":"codeVoice","code":"mac2.metal"},{"type":"text","text":" or "},{"type":"codeVoice","code":"mac2-m2.metal"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"EC2 Mac dedicated host","type":"text"}]},{"type":"text","text":" — Mac instances run exclusively on"},{"type":"text","text":" "},{"type":"text","text":"dedicated hosts (not shared tenancy)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"VPC with a private subnet","type":"text"}]},{"type":"text","text":" — recommended for security"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"type":"text","text":" allowing:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"SSH (port 22) from your bastion or VPN"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Spooktacular API (port 9470) from your Kubernetes cluster or"},{"type":"text","text":" "},{"type":"text","text":"management network"}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"SSH key pair","type":"text"}]},{"type":"text","text":" for EC2 access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac host types: "},{"type":"codeVoice","code":"mac2.metal"},{"type":"text","text":" (M1), "},{"type":"codeVoice","code":"mac2-m2.metal"},{"type":"text","text":" "},{"type":"text","text":"(M2), or "},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":" (M2 Pro)"}]}]}],"type":"unorderedList"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts have a "},{"type":"strong","inlineContent":[{"type":"text","text":"24-hour minimum allocation"},{"type":"text","text":" "},{"type":"text","text":"period"}]},{"type":"text","text":". You are billed for the full 24 hours even if you release the"},{"type":"text","text":" "},{"type":"text","text":"host earlier. Plan your usage accordingly."}],"type":"paragraph"}],"type":"aside","style":"important"},{"level":2,"text":"One-Liner Setup","type":"heading","anchor":"One-Liner-Setup"},{"inlineContent":[{"text":"The fastest way to get running on a fresh EC2 Mac instance:","type":"text"}],"type":"paragraph"},{"code":["curl -sSL https:\/\/spooktacular.dev\/ec2-setup.sh | bash -s -- \\","    --github-repo myorg\/myrepo \\","    --github-token ghp_xxxxxxxxxxxx \\","    --xcode 16.2"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This script:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Installs Homebrew (if not present)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Installs Spooktacular via ","type":"text"},{"type":"codeVoice","code":"brew install --cask spooktacular"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Configures the control API to listen on all interfaces","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Generates a secure API bearer token","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Installs and starts the Spooktacular LaunchDaemon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Creates two macOS VMs with Xcode pre-installed"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Registers both VMs as GitHub Actions runners"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"After the script completes you have two self-hosted runners","type":"text"},{"text":" ","type":"text"},{"text":"picking up jobs immediately.","type":"text"}]},{"type":"heading","anchor":"Manual-Step-by-Step-Setup","level":2,"text":"Manual Step-by-Step Setup"},{"type":"paragraph","inlineContent":[{"text":"If you prefer to configure each step yourself, follow this procedure.","type":"text"}]},{"type":"heading","anchor":"Step-1-Install-Spooktacular","level":3,"text":"Step 1: Install Spooktacular"},{"type":"paragraph","inlineContent":[{"text":"SSH into your EC2 Mac instance and install via Homebrew:","type":"text"}]},{"type":"codeListing","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Verify the installation:","type":"text"}]},{"type":"codeListing","code":["spook --version","# spook 0.1.0"],"syntax":"bash"},{"type":"heading","anchor":"Step-2-Configure-the-Control-API","level":3,"text":"Step 2: Configure the Control API"},{"type":"paragraph","inlineContent":[{"text":"By default, Spooktacular’s API listens on ","type":"text"},{"type":"codeVoice","code":"127.0.0.1:9470"},{"text":" (localhost","type":"text"},{"text":" ","type":"text"},{"text":"only). For remote management you need to bind to all interfaces:","type":"text"}]},{"type":"codeListing","code":["# Install the LaunchDaemon with a custom bind address so the K8s","# operator (or other tools) can reach this host over the VPC network.","sudo spook service install --bind 0.0.0.0:9470"],"syntax":"bash"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"spook service install"},{"text":" creates a LaunchDaemon for headless servers.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"content":[{"inlineContent":[{"text":"Never expose port 9470 to the public internet. Use VPC private","type":"text"},{"text":" ","type":"text"},{"text":"subnets and security groups to restrict access. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"reference"},{"type":"text","text":" for operator-to-host connectivity patterns."}],"type":"paragraph"}],"style":"important","type":"aside","name":"Important"},{"level":3,"text":"Step 3: Install the LaunchDaemon","type":"heading","anchor":"Step-3-Install-the-LaunchDaemon"},{"inlineContent":[{"text":"Register Spooktacular as a system service so it starts automatically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on boot and survives SSH session termination:"}],"type":"paragraph"},{"code":["spook service install"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This creates a LaunchDaemon at"},{"type":"text","text":" "},{"code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist","type":"codeVoice"},{"type":"text","text":" that:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Starts on system boot"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Restarts automatically on crash"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Runs the Spooktacular API server"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Manages VM lifecycle (start, stop, health checks)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"text":"LaunchDaemon vs LaunchAgent","type":"heading","anchor":"LaunchDaemon-vs-LaunchAgent"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Service Type"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Runs as","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Starts at","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Best for"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"LaunchDaemon"}],"type":"paragraph"}],[{"inlineContent":[{"text":"root","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"System boot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Servers, CI hosts, EC2 Mac","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"LaunchAgent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"User","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"User login","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Developer workstations"}]}]]]},{"inlineContent":[{"text":"For EC2 Mac deployments, always use the LaunchDaemon (","type":"text"},{"type":"codeVoice","code":"spook service install"},{"text":"). LaunchAgents require an active GUI session and are not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}],"type":"paragraph"},{"code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"],"syntax":"bash","type":"codeListing"},{"level":2,"anchor":"Configuring-the-Control-API-for-Remote-Access","text":"Configuring the Control API for Remote Access","type":"heading"},{"inlineContent":[{"text":"The Spooktacular control API is a JSON-over-HTTP service that accepts","type":"text"},{"text":" ","type":"text"},{"text":"commands for creating, starting, stopping, and managing VMs.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Bind Address","anchor":"Bind-Address","level":3},{"inlineContent":[{"type":"text","text":"The bind address is set when installing the LaunchDaemon:"}],"type":"paragraph"},{"type":"codeListing","code":["# Listen on localhost only (default, for local use)","sudo spook service install --bind 127.0.0.1:9470","","# Listen on all interfaces (required for remote access)","sudo spook service install --bind 0.0.0.0:9470"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"To change the bind address, uninstall and reinstall:"}],"type":"paragraph"},{"code":["sudo spook service uninstall","sudo spook service install --bind 0.0.0.0:9470"],"syntax":"bash","type":"codeListing"},{"type":"heading","level":3,"anchor":"Bearer-Token-Authentication","text":"Bearer Token Authentication"},{"type":"paragraph","inlineContent":[{"text":"Every API request must include a bearer token:","type":"text"}]},{"code":["# Verify connectivity from another machine","curl -s -H \"Authorization: Bearer $(cat ~\/.spooktacular\/api-token)\" \\","    http:\/\/10.0.1.50:9470\/v1\/vms | jq ."],"type":"codeListing","syntax":"bash"},{"text":"Security Best Practices","level":3,"type":"heading","anchor":"Security-Best-Practices"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VPC private subnet"}]},{"type":"text","text":" — Place EC2 Mac hosts in a private subnet"},{"type":"text","text":" "},{"type":"text","text":"with no public IP. Access via VPN, bastion, or VPC peering."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Security group"}]},{"type":"text","text":" — Allow port 9470 only from your Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"cluster’s CIDR or management network."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Token rotation"}]},{"type":"text","text":" — Rotate API tokens periodically. Update the"},{"type":"text","text":" "},{"type":"text","text":"Helm values or ConfigMap in your K8s cluster when you rotate."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"TLS termination"}]},{"type":"text","text":" — Use an NLB or ALB with TLS in front of the"},{"type":"text","text":" "},{"type":"text","text":"API if traversing untrusted networks."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"IAM"}]},{"type":"text","text":" — Use EC2 instance roles for AWS API access. Do not store"},{"type":"text","text":" "},{"type":"text","text":"long-lived AWS credentials on the host."}]}]}]},{"code":["# Update the K8s operator with a new token","kubectl create secret generic spook-node-tokens \\","    --from-literal=mac-01=\"$(ssh ec2-user@10.0.1.50 'cat ~\/.spooktacular\/api-token')\" \\","    --dry-run=client -o yaml | kubectl apply -f -"],"type":"codeListing","syntax":"bash"},{"text":"Creating VMs on the EC2 Mac","level":2,"type":"heading","anchor":"Creating-VMs-on-the-EC2-Mac"},{"text":"From an IPSW (Fresh Install)","level":3,"type":"heading","anchor":"From-an-IPSW-Fresh-Install"},{"code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"IPSW installation takes 10-20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, use OCI images or clone from a base VM.","type":"text"}],"type":"paragraph"}]},{"text":"From a Clone (Recommended for Fast Deployment)","level":3,"type":"heading","anchor":"From-a-Clone-Recommended-for-Fast-Deployment"},{"type":"paragraph","inlineContent":[{"text":"Create one base VM, configure it with Xcode, then clone instantly:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"OCI image pull is on the roadmap. For now, use ","type":"text"},{"code":"--from-ipsw","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"to create VMs, then clone configured bases for fast deployment."}]}],"type":"aside","style":"note"},{"type":"heading","level":3,"anchor":"Clone-from-a-Base-VM","text":"Clone from a Base VM"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}]},{"type":"codeListing","syntax":"bash","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}]},{"type":"heading","level":3,"anchor":"Provisioning-with-User-Data","text":"Provisioning with User-Data"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script:"}]},{"syntax":"bash","type":"codeListing","code":["spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"text":"doc:Provisioning","type":"text"},{"type":"text","text":" for all four provisioning strategies and"},{"text":" ","type":"text"},{"type":"text","text":"when to use each."}]},{"level":2,"anchor":"Monitoring","type":"heading","text":"Monitoring"},{"level":3,"anchor":"Checking-VM-Status","type":"heading","text":"Checking VM Status"},{"type":"codeListing","syntax":"bash","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"]},{"text":"Logs","anchor":"Logs","type":"heading","level":3},{"type":"codeListing","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"],"syntax":"bash"},{"text":"Disk Usage","level":3,"type":"heading","anchor":"Disk-Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse"},{"type":"text","text":" "},{"text":"but can grow to its configured maximum:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"]},{"type":"heading","level":2,"anchor":"Cost-Optimization","text":"Cost Optimization"},{"type":"heading","level":3,"anchor":"The-Math","text":"The Math"},{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts cost approximately "},{"type":"strong","inlineContent":[{"text":"$1.083\/hour","type":"text"}]},{"type":"text","text":" (M1,"},{"type":"text","text":" "},{"type":"codeVoice","code":"us-east-1"},{"type":"text","text":", on-demand pricing as of 2025). With a 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scenario"}]}],[{"inlineContent":[{"text":"Hosts","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runners"}]}],[{"inlineContent":[{"type":"text","text":"Monthly cost"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cost per runner"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Without Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$7,800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$780","type":"text"}]}]],[[{"inlineContent":[{"text":"With Spooktacular","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"text":"~$7,800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"~$390","type":"text"}]}]],[[{"inlineContent":[{"text":"With Spooktacular","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"~$3,900","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"type":"text","text":"Spooktacular halves the per-runner cost by running 2 VMs per host."}],"type":"paragraph"},{"anchor":"Hardware-Allocation","level":3,"type":"heading","text":"Hardware Allocation"},{"type":"paragraph","inlineContent":[{"text":"Each EC2 Mac ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1) has 8 CPU cores and 16 GB RAM. A"},{"type":"text","text":" "},{"text":"recommended split for two VMs:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For M2 Pro hosts ("},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":") with 12 cores and 32 GB RAM:"}]},{"code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"],"type":"codeListing","syntax":"bash"},{"type":"heading","anchor":"Savings-Plans-and-Reserved-Instances","level":3,"text":"Savings Plans and Reserved Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"type":"text","text":" "},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"type":"text","text":" "},{"text":"capacity with a Savings Plan for maximum cost efficiency.","type":"text"}]},{"type":"heading","anchor":"Auto-Scaling-Group-Integration","level":2,"text":"Auto Scaling Group Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each"},{"type":"text","text":" "},{"type":"text","text":"host runs the setup script via user-data on launch:"}]},{"level":3,"type":"heading","text":"Launch Template","anchor":"Launch-Template"},{"code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"],"syntax":"bash","type":"codeListing"},{"level":3,"anchor":"User-Data-Script","type":"heading","text":"User-Data Script"},{"code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install service (listens on all interfaces for remote access)","sudo spook service install --bind 0.0.0.0:9470","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision disk-inject","","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision disk-inject","","spook start runner-01 --headless","spook start runner-02 --headless"],"type":"codeListing","syntax":"bash"},{"level":2,"anchor":"Terraform-Module-Reference","type":"heading","text":"Terraform Module Reference"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Terraform module is available for declarative infrastructure:"}]},{"syntax":"hcl","code":["module \"spooktacular_fleet\" {","  source = \"spooktacular\/ec2-mac\/aws\"","","  host_count       = 5","  instance_type    = \"mac2-m2pro.metal\"","  subnet_ids       = module.vpc.private_subnets","  security_groups  = [aws_security_group.spooktacular.id]","  key_name         = aws_key_pair.deploy.key_name","","  vms_per_host     = 2","  vm_cpu           = 6","  vm_memory_gb     = 16","  vm_disk_gb       = 100","  vm_image         = \"ghcr.io\/spooktacular\/macos-xcode:15.4-16.2\"","","  github_repo      = \"myorg\/myrepo\"","  github_token_ssm = aws_ssm_parameter.github_token.name","","  tags = {","    Environment = \"production\"","    Team        = \"platform\"","  }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Output values:"}],"type":"paragraph"},{"code":["output \"host_ips\" {","  value = module.spooktacular_fleet.host_private_ips","}","","output \"runner_count\" {","  value = module.spooktacular_fleet.total_runners","  # 10 (5 hosts x 2 runners)","}"],"syntax":"hcl","type":"codeListing"},{"anchor":"Troubleshooting","type":"heading","level":2,"text":"Troubleshooting"},{"text":"IPSW Version Mismatch","type":"heading","level":3,"anchor":"IPSW-Version-Mismatch"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" "},{"code":"spook create","type":"codeVoice"},{"text":" fails with “Your macOS (X.Y) cannot","type":"text"},{"type":"text","text":" "},{"type":"text","text":"install macOS Z.W.”"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" The EC2 Mac host’s macOS is older than the IPSW you are","type":"text"},{"type":"text","text":" "},{"text":"trying to install. The guest version must be less than or equal to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the host version."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"},{"type":"text","text":" Update the host macOS to a version that supports the"},{"type":"text","text":" "},{"type":"text","text":"guest you want to install:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility"},{"type":"text","text":" for details on how version checking works."}]},{"text":"Disk Space Exhausted","anchor":"Disk-Space-Exhausted","type":"heading","level":3},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Symptom:"}],"type":"strong"},{"type":"text","text":" VM creation or operation fails with I\/O errors."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"type":"text","text":" APFS sparse disk images grow as the guest writes data."},{"type":"text","text":" "},{"type":"text","text":"Two VMs with 100 GB configured disk can consume up to 200 GB."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"type":"text","text":" Monitor disk usage and size VMs appropriately:"}],"type":"paragraph"},{"syntax":"bash","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"],"type":"codeListing"},{"text":"24-Hour Minimum Allocation","anchor":"24-Hour-Minimum-Allocation","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"type":"text","text":" You are billed for 24 hours even though you released"},{"type":"text","text":" "},{"type":"text","text":"the dedicated host after 2 hours."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"type":"text","text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation period. This is an AWS policy, not a Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"limitation."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"type":"text","text":" Plan your usage in 24-hour blocks. Use Auto Scaling"},{"type":"text","text":" "},{"type":"text","text":"Groups with scheduled scaling to align host allocation with your"},{"type":"text","text":" "},{"type":"text","text":"CI load patterns:"}],"type":"paragraph"},{"syntax":"bash","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"],"type":"codeListing"},{"text":"VM Won’t Start","anchor":"VM-Wont-Start","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"type":"text","text":" "},{"code":"spook start","type":"codeVoice"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMState\/error","isActive":true,"type":"reference"},{"text":" state.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cause:"}],"type":"strong"},{"text":" Common causes include insufficient resources (too many","type":"text"},{"text":" ","type":"text"},{"text":"cores allocated across VMs), corrupt disk image, or the Apple","type":"text"},{"text":" ","type":"text"},{"text":"kernel 2-VM limit.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Solution:"}],"type":"strong"}],"type":"paragraph"},{"syntax":"bash","code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"],"type":"codeListing"},{"style":"important","name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Apple’s Virtualization framework enforces a hard limit","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"inlineContent":[{"type":"text","text":"2 concurrent VMs"}],"type":"strong"},{"type":"text","text":" per host. Attempting to start a third VM"},{"type":"text","text":" "},{"text":"will fail. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/minimumCPUCount","type":"reference"},{"type":"text","text":" for minimum hardware"},{"type":"text","text":" "},{"text":"requirements.","type":"text"}]}]}]}],"abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/docume