larKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true,"anchor":"Guides"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the"},{"type":"text","text":" "},{"type":"text","text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but"},{"type":"text","text":" "},{"type":"text","text":"with Spooktacular you can run "},{"type":"strong","inlineContent":[{"type":"text","text":"two"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}]},{"level":3,"type":"heading","anchor":"Prerequisites","text":"Prerequisites"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before you begin, ensure you have:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"AWS account"}],"type":"strong"},{"type":"text","text":" with EC2 Mac instance access (may require a service"},{"type":"text","text":" "},{"type":"text","text":"quota increase for "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" or "},{"code":"mac2-m2.metal","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"EC2 Mac dedicated host"}],"type":"strong"},{"type":"text","text":" — Mac instances run exclusively on"},{"type":"text","text":" "},{"type":"text","text":"dedicated hosts (not shared tenancy)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"VPC with a private subnet"}],"type":"strong"},{"type":"text","text":" — recommended for security"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Security group"}],"type":"strong"},{"type":"text","text":" allowing SSH (port 22) from your bastion or VPN"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"SSH key pair"}],"type":"strong"},{"type":"text","text":" for EC2 access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac host types: "},{"code":"mac2.metal","type":"codeVoice"},{"type":"text","text":" (M1), "},{"code":"mac2-m2.metal","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"(M2), or "},{"code":"mac2-m2pro.metal","type":"codeVoice"},{"type":"text","text":" (M2 Pro)"}]}]}],"type":"unorderedList"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts have a "},{"type":"strong","inlineContent":[{"type":"text","text":"24-hour minimum allocation"},{"type":"text","text":" "},{"type":"text","text":"period"}]},{"type":"text","text":". You are billed for the full 24 hours even if you release the"},{"type":"text","text":" "},{"type":"text","text":"host earlier. Plan your usage accordingly."}]}],"type":"aside","style":"important","name":"Important"},{"level":2,"type":"heading","anchor":"Quick-Setup","text":"Quick Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,"},{"type":"text","text":" "},{"type":"text","text":"and start runners with SSH provisioning:"}]},{"type":"codeListing","syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"]},{"level":2,"type":"heading","anchor":"Manual-Step-by-Step-Setup","text":"Manual Step-by-Step Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you prefer to configure each step yourself, follow this procedure."}]},{"level":3,"type":"heading","anchor":"Step-1-Install-Spooktacular","text":"Step 1: Install Spooktacular"},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}]},{"type":"codeListing","syntax":"bash","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify the installation:"}]},{"type":"codeListing","syntax":"bash","code":["spook --version","# spook 1.0.0"]},{"level":3,"type":"heading","anchor":"Step-2-Install-the-LaunchDaemon","text":"Step 2: Install the LaunchDaemon"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register Spooktacular as a system service for headless operation:"}]},{"type":"codeListing","syntax":"bash","code":["spook service install"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":" creates a LaunchDaemon plist at"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist"},{"type":"text","text":"."}]}],"type":"aside","style":"note","name":"Note"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An HTTP control API for remote management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs via SSH + CLI."}]}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}]},{"level":3,"type":"heading","anchor":"LaunchDaemon-vs-LaunchAgent","text":"LaunchDaemon vs LaunchAgent"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Service Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runs as"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts at"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchDaemon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"root"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"System boot"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Servers, CI hosts, EC2 Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchAgent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"User login"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Developer workstations"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For EC2 Mac deployments, always use the LaunchDaemon ("},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}]},{"type":"codeListing","syntax":"bash","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"]},{"level":2,"type":"heading","anchor":"Security-Best-Practices","text":"Security Best Practices"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"VPC private subnet"}],"type":"strong"},{"type":"text","text":" — Place EC2 Mac hosts in a private subnet"},{"type":"text","text":" "},{"type":"text","text":"with no public IP. Access via VPN, bastion, or VPC peering."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Security group"}],"type":"strong"},{"type":"text","text":" — Allow SSH (port 22) only from your bastion"},{"type":"text","text":" "},{"type":"text","text":"or VPN CIDR."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"IAM"}],"type":"strong"},{"type":"text","text":" — Use EC2 instance roles for AWS API access. Do not store"},{"type":"text","text":" "},{"type":"text","text":"long-lived AWS credentials on the host."}]}]}],"type":"orderedList"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An HTTP control API for remote VM management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs by SSH-ing into the host and"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI directly."}]}],"type":"aside","style":"note","name":"Note"},{"level":2,"type":"heading","anchor":"Creating-VMs-on-the-EC2-Mac","text":"Creating VMs on the EC2 Mac"},{"level":3,"type":"heading","anchor":"From-an-IPSW-Fresh-Install","text":"From an IPSW (Fresh Install)"},{"type":"codeListing","syntax":"bash","code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"IPSW installation takes 10-20 minutes per VM. For faster"},{"type":"text","text":" "},{"type":"text","text":"deployment, create one base VM, configure it, then use"},{"type":"text","text":" "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for instant copies."}]}],"type":"aside","style":"note","name":"Note"},{"level":3,"type":"heading","anchor":"From-a-Clone-Recommended-for-Fast-Deployment","text":"From a Clone (Recommended for Fast Deployment)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}]},{"type":"codeListing","syntax":"bash","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OCI image push\/pull is planned for a future release."}]}],"type":"aside","style":"note","name":"Note"},{"level":3,"type":"heading","anchor":"Clone-from-a-Base-VM","text":"Clone from a Base VM"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}]},{"type":"codeListing","syntax":"bash","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}]},{"level":3,"type":"heading","anchor":"Provisioning-with-User-Data","text":"Provisioning with User-Data"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}]},{"type":"codeListing","syntax":"bash","code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}]},{"level":2,"type":"heading","anchor":"Monitoring","text":"Monitoring"},{"level":3,"type":"heading","anchor":"Checking-VM-Status","text":"Checking VM Status"},{"type":"codeListing","syntax":"bash","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"]},{"level":3,"type":"heading","anchor":"Logs","text":"Logs"},{"type":"codeListing","syntax":"bash","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"]},{"level":3,"type":"heading","anchor":"Disk-Usage","text":"Disk Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse"},{"type":"text","text":" "},{"type":"text","text":"but can grow to its configured maximum:"}]},{"type":"codeListing","syntax":"bash","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"]},{"level":2,"type":"heading","anchor":"Cost-Optimization","text":"Cost Optimization"},{"level":3,"type":"heading","anchor":"The-Math","text":"The Math"},{"type":"paragraph","inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts cost approximately "},{"type":"strong","inlineContent":[{"type":"text","text":"$1.083\/hour"}]},{"type":"text","text":" (M1,"},{"type":"text","text":" "},{"type":"codeVoice","code":"us-east-1"},{"type":"text","text":", on-demand pricing as of 2025). With a 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scenario"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hosts"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runners"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Monthly cost"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cost per runner"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Without Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$7,800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$780"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"20"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$7,800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$3,900"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular halves the per-runner cost by running 2 VMs per host."}]},{"level":3,"type":"heading","anchor":"Hardware-Allocation","text":"Hardware Allocation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each EC2 Mac "},{"type":"codeVoice","code":"mac2.metal"},{"type":"text","text":" (M1) has 8 CPU cores and 16 GB RAM. A"},{"type":"text","text":" "},{"type":"text","text":"recommended split for two VMs:"}]},{"type":"codeListing","syntax":"bash","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For M2 Pro hosts ("},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"type":"text","text":") with 12 cores and 32 GB RAM:"}]},{"type":"codeListing","syntax":"bash","code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"]},{"level":3,"type":"heading","anchor":"Savings-Plans-and-Reserved-Instances","text":"Savings Plans and Reserved Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"type":"text","text":" "},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"type":"text","text":" "},{"type":"text","text":"capacity with a Savings Plan for maximum cost efficiency."}]},{"level":2,"type":"heading","anchor":"Auto-Scaling-Group-Integration","text":"Auto Scaling Group Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each"},{"type":"text","text":" "},{"type":"text","text":"host runs the setup script via user-data on launch:"}]},{"level":3,"type":"heading","anchor":"Launch-Template","text":"Launch Template"},{"type":"codeListing","syntax":"bash","code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"]},{"level":3,"type":"heading","anchor":"User-Data-Script","text":"User-Data Script"},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"]},{"level":2,"type":"heading","anchor":"Terraform-Module-Planned","text":"Terraform Module (Planned)"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Terraform module for declarative EC2 Mac fleet management"},{"type":"text","text":" "},{"type":"text","text":"is planned for a future release. For now, use EC2 Launch Templates"},{"type":"text","text":" "},{"type":"text","text":"with user-data scripts to automate host setup."}]}],"type":"aside","style":"note","name":"Note"},{"level":2,"type":"heading","anchor":"Troubleshooting","text":"Troubleshooting"},{"level":3,"type":"heading","anchor":"IPSW-Version-Mismatch","text":"IPSW Version Mismatch"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"spook create"},{"type":"text","text":" fails with “Your macOS (X.Y) cannot"},{"type":"text","text":" "},{"type":"text","text":"install macOS Z.W.”"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" The EC2 Mac host’s macOS is older than the IPSW you are"},{"type":"text","text":" "},{"type":"text","text":"trying to install. The guest version must be less than or equal to"},{"type":"text","text":" "},{"type":"text","text":"the host version."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]},{"type":"text","text":" Update the host macOS to a version that supports the"},{"type":"text","text":" "},{"type":"text","text":"guest you want to install:"}]},{"type":"codeListing","syntax":"bash","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"Compatibility"},{"type":"text","text":" for details on how version checking works."}]},{"level":3,"type":"heading","anchor":"Disk-Space-Exhausted","text":"Disk Space Exhausted"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" VM creation or operation fails with I\/O errors."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" APFS sparse disk images grow as the guest writes data."},{"type":"text","text":" "},{"type":"text","text":"Two VMs with 100 GB configured disk can consume up to 200 GB."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]},{"type":"text","text":" Monitor disk usage and size VMs appropriately:"}]},{"type":"codeListing","syntax":"bash","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"]},{"level":3,"type":"heading","anchor":"24-Hour-Minimum-Allocation","text":"24-Hour Minimum Allocation"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" You are billed for 24 hours even though you released"},{"type":"text","text":" "},{"type":"text","text":"the dedicated host after 2 hours."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation period. This is an AWS policy, not a Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"limitation."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]},{"type":"text","text":" Plan your usage in 24-hour blocks. Use Auto Scaling"},{"type":"text","text":" "},{"type":"text","text":"Groups with scheduled scaling to align host allocation with your"},{"type":"text","text":" "},{"type":"text","text":"CI load patterns:"}]},{"type":"codeListing","syntax":"bash","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"]},{"level":3,"type":"heading","anchor":"VM-Wont-Start","text":"VM Won’t Start"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Symptom:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" hangs or the VM enters the"},{"type":"text","text":" "},{"type":"codeVoice","code":"VirtualMachineState\/error"},{"type":"text","text":" state."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"type":"text","text":" Common causes include insufficient resources (too many"},{"type":"text","text":" "},{"type":"text","text":"cores allocated across VMs), corrupt disk image, or the Apple"},{"type":"text","text":" "},{"type":"text","text":"kernel 2-VM limit."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]}]},{"type":"codeListing","syntax":"bash","code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework enforces a hard limit"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"strong","inlineContent":[{"type":"text","text":"2 concurrent VMs"}]},{"type":"text","text":" per host. Attempting to start a third VM"},{"type":"text","text":" "},{"type":"text","text":"will fail. See "},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":" for minimum hardware"},{"type":"text","text":" "},{"type":"text","text":"requirements."}]}],"type":"aside","style":"important","name":"Important"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads","kind":"article","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","title":"Running BlueBubbles iMessage Server","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/bluebubblesguide","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"role":"collection","title":"SpooktacularKit","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","title":"Configuring Jenkins Nodes","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/jenkinsguide","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","title":"Versioning & Release Schedule","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","kind":"article","url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","title":"Kubernetes Integration","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/openclawguide","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","title":"Getting Started with Spooktacular","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","title":"Using the spook Command-Line Interface","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"type":"topic"}}}