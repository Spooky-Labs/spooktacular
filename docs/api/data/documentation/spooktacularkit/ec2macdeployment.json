ion\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"]}],"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the","type":"text"},{"text":" ","type":"text"},{"text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but","type":"text"},{"text":" ","type":"text"},{"text":"with Spooktacular you can run ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"two"}]},{"text":" macOS virtual machines per host —","type":"text"},{"text":" ","type":"text"},{"text":"doubling your CI runner capacity without adding hardware.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This guide covers the complete setup: from allocating a dedicated host","type":"text"},{"text":" ","type":"text"},{"text":"to running a production GitHub Actions fleet on EC2 Mac.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Prerequisites","type":"heading","anchor":"Prerequisites"},{"inlineContent":[{"text":"Before you begin, ensure you have:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"AWS account"}]},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"text":" ","type":"text"},{"text":"quota increase for ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"mac2-m2.metal","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"EC2 Mac dedicated host"}]},{"text":" — Mac instances run exclusively on","type":"text"},{"text":" ","type":"text"},{"text":"dedicated hosts (not shared tenancy)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VPC with a private subnet"}]},{"text":" — recommended for security","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Security group"}]},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"SSH key pair"}]},{"text":" for EC2 access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Apple Silicon Mac host types: ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" (M1), ","type":"text"},{"code":"mac2-m2.metal","type":"codeVoice"},{"text":" ","type":"text"},{"text":"(M2), or ","type":"text"},{"code":"mac2-m2pro.metal","type":"codeVoice"},{"text":" (M2 Pro)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"EC2 Mac dedicated hosts have a "},{"inlineContent":[{"text":"24-hour minimum allocation","type":"text"},{"text":" ","type":"text"},{"text":"period","type":"text"}],"type":"strong"},{"type":"text","text":". You are billed for the full 24 hours even if you release the"},{"type":"text","text":" "},{"type":"text","text":"host earlier. Plan your usage accordingly."}]}]},{"level":2,"text":"Quick Setup","type":"heading","anchor":"Quick-Setup"},{"inlineContent":[{"text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,","type":"text"},{"text":" ","type":"text"},{"text":"and start runners with SSH provisioning:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"],"type":"codeListing"},{"level":2,"text":"Manual Step-by-Step Setup","type":"heading","anchor":"Manual-Step-by-Step-Setup"},{"inlineContent":[{"text":"If you prefer to configure each step yourself, follow this procedure.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Step 1: Install Spooktacular","type":"heading","anchor":"Step-1-Install-Spooktacular"},{"inlineContent":[{"text":"SSH into your EC2 Mac instance and install via Homebrew:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"],"type":"codeListing"},{"inlineContent":[{"text":"Verify the installation:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook --version","# spook 1.0.0"],"type":"codeListing"},{"level":3,"text":"Step 2: Install the LaunchDaemon","type":"heading","anchor":"Step-2-Install-the-LaunchDaemon"},{"inlineContent":[{"text":"Register Spooktacular as a system service for headless operation:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook service install"],"type":"codeListing"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"spook service install","type":"codeVoice"},{"type":"text","text":" creates a LaunchDaemon plist at"},{"type":"text","text":" "},{"code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist","type":"codeVoice"},{"type":"text","text":"."}]}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An HTTP control API for remote management is planned for a"},{"type":"text","text":" "},{"type":"text","text":"future release. For now, manage VMs via SSH + CLI."}]}]},{"inlineContent":[{"text":"The LaunchDaemon starts on system boot, restarts automatically","type":"text"},{"text":" ","type":"text"},{"text":"on crash, and ensures VMs survive SSH session termination.","type":"text"}],"type":"paragraph"},{"level":3,"text":"LaunchDaemon vs LaunchAgent","type":"heading","anchor":"LaunchDaemon-vs-LaunchAgent"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Service Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runs as"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts at"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"LaunchDaemon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"root"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"System boot"}]}],[{"inlineContent":[{"text":"Servers, CI hosts, EC2 Mac","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"LaunchAgent"}],"type":"paragraph"}],[{"inlineContent":[{"text":"User","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"User login"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Developer workstations","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"text":"For EC2 Mac deployments, always use the LaunchDaemon (","type":"text"},{"code":"spook service install","type":"codeVoice"},{"text":"). LaunchAgents require an active GUI session and are not","type":"text"},{"text":" ","type":"text"},{"text":"suitable for headless server operation.","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"]},{"text":"Security Best Practices","anchor":"Security-Best-Practices","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"VPC private subnet","type":"text"}]},{"type":"text","text":" — Place EC2 Mac hosts in a private subnet"},{"type":"text","text":" "},{"type":"text","text":"with no public IP. Access via VPN, bastion, or VPC peering."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"type":"text","text":" — Allow SSH (port 22) only from your bastion"},{"type":"text","text":" "},{"type":"text","text":"or VPN CIDR."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"IAM"}]},{"type":"text","text":" — Use EC2 instance roles for AWS API access. Do not store"},{"type":"text","text":" "},{"type":"text","text":"long-lived AWS credentials on the host."}]}]}],"type":"orderedList"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP control API for remote VM management is planned for a","type":"text"},{"text":" ","type":"text"},{"text":"future release. For now, manage VMs by SSH-ing into the host and","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI directly.","type":"text"}]}],"name":"Note"},{"type":"heading","level":2,"anchor":"Creating-VMs-on-the-EC2-Mac","text":"Creating VMs on the EC2 Mac"},{"type":"heading","level":3,"anchor":"From-an-IPSW-Fresh-Install","text":"From an IPSW (Fresh Install)"},{"code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10-20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create one base VM, configure it, then use","type":"text"},{"text":" ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for instant copies.","type":"text"}]}],"name":"Note"},{"type":"heading","level":3,"anchor":"From-a-Clone-Recommended-for-Fast-Deployment","text":"From a Clone (Recommended for Fast Deployment)"},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}],"type":"paragraph"},{"code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"OCI image push\/pull is planned for a future release.","type":"text"}]}],"name":"Note"},{"type":"heading","level":3,"anchor":"Clone-from-a-Base-VM","text":"Clone from a Base VM"},{"inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}],"type":"paragraph"},{"code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Provisioning-with-User-Data","text":"Provisioning with User-Data"},{"inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}],"type":"paragraph"},{"code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Monitoring","text":"Monitoring"},{"type":"heading","level":3,"anchor":"Checking-VM-Status","text":"Checking VM Status"},{"code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"Logs","text":"Logs"},{"code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"Disk-Usage","text":"Disk Usage"},{"inlineContent":[{"text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse","type":"text"},{"text":" ","type":"text"},{"text":"but can grow to its configured maximum:","type":"text"}],"type":"paragraph"},{"code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":2,"anchor":"Cost-Optimization","text":"Cost Optimization"},{"type":"heading","level":3,"anchor":"The-Math","text":"The Math"},{"inlineContent":[{"text":"EC2 Mac dedicated hosts cost approximately ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"$1.083\/hour"}]},{"text":" (M1,","type":"text"},{"text":" ","type":"text"},{"code":"us-east-1","type":"codeVoice"},{"text":", on-demand pricing as of 2025). With a 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation:","type":"text"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scenario"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hosts"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runners"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Monthly cost"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cost per runner"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Without Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$7,800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$780"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$7,800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"With Spooktacular"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$3,900"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"~$390"}]}]]]},{"inlineContent":[{"text":"Spooktacular halves the per-runner cost by running 2 VMs per host.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Hardware-Allocation","text":"Hardware Allocation"},{"inlineContent":[{"text":"Each EC2 Mac ","type":"text"},{"code":"mac2.metal","type":"codeVoice"},{"text":" (M1) has 8 CPU cores and 16 GB RAM. A","type":"text"},{"text":" ","type":"text"},{"text":"recommended split for two VMs:","type":"text"}],"type":"paragraph"},{"code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"For M2 Pro hosts (","type":"text"},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"text":") with 12 cores and 32 GB RAM:","type":"text"}],"type":"paragraph"},{"code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"Savings-Plans-and-Reserved-Instances","text":"Savings Plans and Reserved Instances"},{"inlineContent":[{"type":"text","text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%"},{"type":"text","text":" "},{"type":"text","text":"discount for a 1-year commitment. Combine Spooktacular’s 2x"},{"type":"text","text":" "},{"type":"text","text":"capacity with a Savings Plan for maximum cost efficiency."}],"type":"paragraph"},{"level":2,"text":"Auto Scaling Group Integration","type":"heading","anchor":"Auto-Scaling-Group-Integration"},{"inlineContent":[{"type":"text","text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each"},{"type":"text","text":" "},{"type":"text","text":"host runs the setup script via user-data on launch:"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Launch-Template","text":"Launch Template"},{"code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"User-Data-Script","text":"User-Data Script"},{"code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":2,"anchor":"Terraform-Module-Planned","text":"Terraform Module (Planned)"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"A Terraform module for declarative EC2 Mac fleet management","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release. For now, use EC2 Launch Templates","type":"text"},{"text":" ","type":"text"},{"text":"with user-data scripts to automate host setup.","type":"text"}]}],"name":"Note"},{"type":"heading","level":2,"anchor":"Troubleshooting","text":"Troubleshooting"},{"type":"heading","level":3,"anchor":"IPSW-Version-Mismatch","text":"IPSW Version Mismatch"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"spook create","type":"codeVoice"},{"type":"text","text":" fails with “Your macOS (X.Y) cannot"},{"type":"text","text":" "},{"type":"text","text":"install macOS Z.W.”"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cause:"}]},{"text":" The EC2 Mac host’s macOS is older than the IPSW you are","type":"text"},{"text":" ","type":"text"},{"text":"trying to install. The guest version must be less than or equal to","type":"text"},{"type":"text","text":" "},{"text":"the host version.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solution:"}]},{"type":"text","text":" Update the host macOS to a version that supports the"},{"type":"text","text":" "},{"type":"text","text":"guest you want to install:"}]},{"syntax":"bash","type":"codeListing","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"Compatibility","type":"codeVoice"},{"type":"text","text":" for details on how version checking works."}]},{"text":"Disk Space Exhausted","anchor":"Disk-Space-Exhausted","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"type":"text","text":" VM creation or operation fails with I\/O errors."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cause:","type":"text"}],"type":"strong"},{"type":"text","text":" APFS sparse disk images grow as the guest writes data."},{"type":"text","text":" "},{"type":"text","text":"Two VMs with 100 GB configured disk can consume up to 200 GB."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Solution:","type":"text"}],"type":"strong"},{"type":"text","text":" Monitor disk usage and size VMs appropriately:"}]},{"syntax":"bash","type":"codeListing","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"]},{"text":"24-Hour Minimum Allocation","anchor":"24-Hour-Minimum-Allocation","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"type":"text","text":" You are billed for 24 hours even though you released"},{"type":"text","text":" "},{"type":"text","text":"the dedicated host after 2 hours."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cause:","type":"text"}],"type":"strong"},{"type":"text","text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum"},{"type":"text","text":" "},{"type":"text","text":"allocation period. This is an AWS policy, not a Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"limitation."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Solution:","type":"text"}],"type":"strong"},{"type":"text","text":" Plan your usage in 24-hour blocks. Use Auto Scaling"},{"type":"text","text":" "},{"type":"text","text":"Groups with scheduled scaling to align host allocation with your"},{"type":"text","text":" "},{"type":"text","text":"CI load patterns:"}]},{"syntax":"bash","type":"codeListing","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"]},{"text":"VM Won’t Start","anchor":"VM-Wont-Start","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Symptom:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"spook start","type":"codeVoice"},{"type":"text","text":" hangs or the VM enters the"},{"type":"text","text":" "},{"code":"VirtualMachineState\/error","type":"codeVoice"},{"type":"text","text":" state."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cause:","type":"text"}],"type":"strong"},{"type":"text","text":" Common causes include insufficient resources (too many"},{"type":"text","text":" "},{"type":"text","text":"cores allocated across VMs), corrupt disk image, or the Apple"},{"type":"text","text":" "},{"type":"text","text":"kernel 2-VM limit."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Solution:","type":"text"}],"type":"strong"}]},{"syntax":"bash","type":"codeListing","code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s Virtualization framework enforces a hard limit"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"strong","inlineContent":[{"text":"2 concurrent VMs","type":"text"}]},{"type":"text","text":" per host. Attempting to start a third VM"},{"type":"text","text":" "},{"type":"text","text":"will fail. See "},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":" for minimum hardware"},{"type":"text","text":" "},{"type":"text","text":"requirements."}]}],"name":"Important","style":"important","type":"aside"}],"kind":"content"}],"abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/jenkinsguide","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"title":"Machine Learning Workloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","title":"SpooktacularKit","kind":"symbol","type":"topic","role":"collection","url":"\/documentation\/spooktacularkit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/githubactionsguide","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"title":"Running BlueBubbles iMessage Server","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/bluebubblesguide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/openclawguide","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}]}}}