c:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]]},"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS EC2 Mac instances provide bare-metal Apple Silicon hardware in the"},{"type":"text","text":" "},{"type":"text","text":"cloud. Each EC2 Mac host can run a single macOS instance natively, but"},{"type":"text","text":" "},{"type":"text","text":"with Spooktacular you can run "},{"type":"strong","inlineContent":[{"text":"two","type":"text"}]},{"type":"text","text":" macOS virtual machines per host —"},{"type":"text","text":" "},{"type":"text","text":"doubling your CI runner capacity without adding hardware."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide covers the complete setup: from allocating a dedicated host"},{"type":"text","text":" "},{"type":"text","text":"to running a production GitHub Actions fleet on EC2 Mac."}]},{"text":"Prerequisites","type":"heading","anchor":"Prerequisites","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before you begin, ensure you have:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"AWS account","type":"text"}]},{"text":" with EC2 Mac instance access (may require a service","type":"text"},{"text":" ","type":"text"},{"text":"quota increase for ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"mac2-m2.metal"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"EC2 Mac dedicated host","type":"text"}]},{"text":" — Mac instances run exclusively on","type":"text"},{"text":" ","type":"text"},{"text":"dedicated hosts (not shared tenancy)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"VPC with a private subnet","type":"text"}]},{"text":" — recommended for security","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"text":" allowing SSH (port 22) from your bastion or VPN","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"SSH key pair","type":"text"}]},{"text":" for EC2 access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Apple Silicon Mac host types: ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" (M1), ","type":"text"},{"type":"codeVoice","code":"mac2-m2.metal"},{"text":" ","type":"text"},{"text":"(M2), or ","type":"text"},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"text":" (M2 Pro)","type":"text"}],"type":"paragraph"}]}]},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"EC2 Mac dedicated hosts have a ","type":"text"},{"inlineContent":[{"text":"24-hour minimum allocation","type":"text"},{"text":" ","type":"text"},{"text":"period","type":"text"}],"type":"strong"},{"text":". You are billed for the full 24 hours even if you release the","type":"text"},{"text":" ","type":"text"},{"text":"host earlier. Plan your usage accordingly.","type":"text"}]}],"type":"aside","style":"important"},{"text":"Quick Setup","type":"heading","anchor":"Quick-Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance, install Spooktacular, create VMs,"},{"type":"text","text":" "},{"type":"text","text":"and start runners with SSH provisioning:"}]},{"syntax":"bash","type":"codeListing","code":["# Install Spooktacular","brew install --cask spooktacular","","# Install the LaunchDaemon for headless operation","spook service install","","# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... install Xcode, enable SSH, configure settings","spook stop base","","# Clone runners and start with provisioning","spook clone base runner-01","spook clone base runner-02","spook start runner-01 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data ~\/github-runner-setup.sh --provision ssh --ssh-user admin"]},{"text":"Manual Step-by-Step Setup","type":"heading","anchor":"Manual-Step-by-Step-Setup","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you prefer to configure each step yourself, follow this procedure."}]},{"text":"Step 1: Install Spooktacular","type":"heading","anchor":"Step-1-Install-Spooktacular","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH into your EC2 Mac instance and install via Homebrew:"}]},{"syntax":"bash","type":"codeListing","code":["ssh -i ~\/.ssh\/my-key.pem ec2-user@<ec2-public-ip>","","# Install Homebrew if not already present","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","","# Install Spooktacular","brew install --cask spooktacular"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify the installation:"}]},{"syntax":"bash","type":"codeListing","code":["spook --version","# spook 1.0.0"]},{"text":"Step 2: Install the LaunchDaemon","type":"heading","anchor":"Step-2-Install-the-LaunchDaemon","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register Spooktacular as a system service for headless operation:"}]},{"syntax":"bash","type":"codeListing","code":["spook service install"]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"spook service install"},{"text":" creates a LaunchDaemon plist at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/dev.spooktacular.daemon.plist"},{"text":".","type":"text"}]}],"type":"aside","style":"note"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP control API for remote management is planned for a","type":"text"},{"text":" ","type":"text"},{"text":"future release. For now, manage VMs via SSH + CLI.","type":"text"}]}],"type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The LaunchDaemon starts on system boot, restarts automatically"},{"type":"text","text":" "},{"type":"text","text":"on crash, and ensures VMs survive SSH session termination."}]},{"text":"LaunchDaemon vs LaunchAgent","type":"heading","anchor":"LaunchDaemon-vs-LaunchAgent","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Service Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Runs as","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Starts at","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Best for","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"LaunchDaemon","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"root","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"System boot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Servers, CI hosts, EC2 Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"LaunchAgent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"User","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"User login","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Developer workstations","type":"text"}]}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For EC2 Mac deployments, always use the LaunchDaemon ("},{"type":"codeVoice","code":"spook service install"},{"type":"text","text":"). LaunchAgents require an active GUI session and are not"},{"type":"text","text":" "},{"type":"text","text":"suitable for headless server operation."}]},{"syntax":"bash","type":"codeListing","code":["# LaunchDaemon (recommended for EC2 Mac)","spook service install","","# LaunchAgent (for developer machines)","spook service install --user"]},{"text":"Security Best Practices","type":"heading","anchor":"Security-Best-Practices","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"VPC private subnet","type":"text"}]},{"text":" — Place EC2 Mac hosts in a private subnet","type":"text"},{"text":" ","type":"text"},{"text":"with no public IP. Access via VPN, bastion, or VPC peering.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Security group","type":"text"}]},{"text":" — Allow SSH (port 22) only from your bastion","type":"text"},{"text":" ","type":"text"},{"text":"or VPN CIDR.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"IAM","type":"text"}]},{"text":" — Use EC2 instance roles for AWS API access. Do not store","type":"text"},{"text":" ","type":"text"},{"text":"long-lived AWS credentials on the host.","type":"text"}],"type":"paragraph"}]}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"An HTTP control API for remote VM management is planned for a","type":"text"},{"text":" ","type":"text"},{"text":"future release. For now, manage VMs by SSH-ing into the host and","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI directly.","type":"text"}]}],"type":"aside","style":"note"},{"text":"Creating VMs on the EC2 Mac","type":"heading","anchor":"Creating-VMs-on-the-EC2-Mac","level":2},{"text":"From an IPSW (Fresh Install)","type":"heading","anchor":"From-an-IPSW-Fresh-Install","level":3},{"syntax":"bash","type":"codeListing","code":["# Download the latest compatible macOS and install","spook create runner-01 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64","","# Create a second VM (2 per host maximum)","spook create runner-02 --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64"]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10-20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create one base VM, configure it, then use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook clone"},{"text":" for instant copies.","type":"text"}]}],"type":"aside","style":"note"},{"text":"From a Clone (Recommended for Fast Deployment)","type":"heading","anchor":"From-a-Clone-Recommended-for-Fast-Deployment","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it with Xcode, then clone instantly:"}]},{"syntax":"bash","type":"codeListing","code":["# Clone from the base for instant deployment","spook clone base runner-01","spook clone base runner-02"]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"OCI image push\/pull is planned for a future release.","type":"text"}]}],"type":"aside","style":"note"},{"text":"Clone from a Base VM","type":"heading","anchor":"Clone-from-a-Base-VM","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create one base VM, configure it, then clone instantly:"}]},{"syntax":"bash","type":"codeListing","code":["# Create and configure a base VM","spook create base --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook start base","# ... manually install Xcode, configure settings, etc.","spook stop base","","# Clone instantly (APFS copy-on-write, milliseconds)","spook clone base runner-01","spook clone base runner-02"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" for details on how APFS copy-on-write cloning"},{"type":"text","text":" "},{"type":"text","text":"works."}]},{"text":"Provisioning with User-Data","type":"heading","anchor":"Provisioning-with-User-Data","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup with a user-data script via SSH provisioning:"}]},{"syntax":"bash","type":"codeListing","code":["spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/setup-runner.sh \\","    --provision ssh --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for available provisioning modes."}]},{"text":"Monitoring","type":"heading","anchor":"Monitoring","level":2},{"text":"Checking VM Status","type":"heading","anchor":"Checking-VM-Status","level":3},{"syntax":"bash","type":"codeListing","code":["# List all VMs with status","spook list","","# JSON output for automation","spook list --json","","# Detailed configuration for a specific VM","spook get runner-01","","# Extract a single field for scripting","spook get runner-01 --field cpu"]},{"text":"Logs","type":"heading","anchor":"Logs","level":3},{"syntax":"bash","type":"codeListing","code":["# Spooktacular service logs (LaunchDaemon)","log show --predicate 'subsystem == \"dev.spooktacular\"' --last 1h","","# System-level VM logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 1h"]},{"text":"Disk Usage","type":"heading","anchor":"Disk-Usage","level":3},{"type":"paragraph","inlineContent":[{"text":"Monitor disk space carefully. Each VM’s disk image is APFS sparse","type":"text"},{"text":" ","type":"text"},{"text":"but can grow to its configured maximum:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Check host disk usage","df -h \/","","# Check actual disk image sizes (sparse files)","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# Check configured vs actual size","spook get runner-01 --field disk"]},{"text":"Cost Optimization","type":"heading","anchor":"Cost-Optimization","level":2},{"text":"The Math","type":"heading","anchor":"The-Math","level":3},{"type":"paragraph","inlineContent":[{"text":"EC2 Mac dedicated hosts cost approximately ","type":"text"},{"inlineContent":[{"text":"$1.083\/hour","type":"text"}],"type":"strong"},{"text":" (M1,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"us-east-1"},{"text":", on-demand pricing as of 2025). With a 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation:","type":"text"}]},{"rows":[[[{"inlineContent":[{"text":"Scenario","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Hosts","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Runners","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Monthly cost","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Cost per runner","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Without Spooktacular","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$7,800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$780","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"With Spooktacular","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"20","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$7,800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$390","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"With Spooktacular","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$3,900","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"~$390","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular halves the per-runner cost by running 2 VMs per host.","type":"text"}]},{"text":"Hardware Allocation","type":"heading","anchor":"Hardware-Allocation","level":3},{"type":"paragraph","inlineContent":[{"text":"Each EC2 Mac ","type":"text"},{"type":"codeVoice","code":"mac2.metal"},{"text":" (M1) has 8 CPU cores and 16 GB RAM. A","type":"text"},{"text":" ","type":"text"},{"text":"recommended split for two VMs:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Runner 1: 4 cores, 8 GB RAM","spook create runner-01 --cpu 4 --memory 8 --disk 64","","# Runner 2: 4 cores, 8 GB RAM","spook create runner-02 --cpu 4 --memory 8 --disk 64"]},{"type":"paragraph","inlineContent":[{"text":"For M2 Pro hosts (","type":"text"},{"type":"codeVoice","code":"mac2-m2pro.metal"},{"text":") with 12 cores and 32 GB RAM:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Runner 1: 6 cores, 16 GB RAM","spook create runner-01 --cpu 6 --memory 16 --disk 100","","# Runner 2: 6 cores, 16 GB RAM","spook create runner-02 --cpu 6 --memory 16 --disk 100"]},{"text":"Savings Plans and Reserved Instances","type":"heading","anchor":"Savings-Plans-and-Reserved-Instances","level":3},{"type":"paragraph","inlineContent":[{"text":"AWS offers Savings Plans for EC2 Mac dedicated hosts with up to 44%","type":"text"},{"text":" ","type":"text"},{"text":"discount for a 1-year commitment. Combine Spooktacular’s 2x","type":"text"},{"text":" ","type":"text"},{"text":"capacity with a Savings Plan for maximum cost efficiency.","type":"text"}]},{"text":"Auto Scaling Group Integration","type":"heading","anchor":"Auto-Scaling-Group-Integration","level":2},{"type":"paragraph","inlineContent":[{"text":"Use an EC2 Auto Scaling Group to manage a fleet of Mac hosts. Each","type":"text"},{"text":" ","type":"text"},{"text":"host runs the setup script via user-data on launch:","type":"text"}]},{"text":"Launch Template","type":"heading","anchor":"Launch-Template","level":3},{"syntax":"bash","type":"codeListing","code":["aws ec2 create-launch-template \\","    --launch-template-name spooktacular-mac \\","    --launch-template-data '{","        \"ImageId\": \"ami-0xxxxxxxxxxxx\",","        \"InstanceType\": \"mac2.metal\",","        \"KeyName\": \"my-key\",","        \"SecurityGroupIds\": [\"sg-0xxxxxxxxxxxx\"],","        \"UserData\": \"'$(base64 -w0 ec2-setup.sh)'\"","    }'"]},{"text":"User-Data Script","type":"heading","anchor":"User-Data-Script","level":3},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Install Spooktacular","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","brew install --cask spooktacular","","# Install the LaunchDaemon","sudo spook service install","","# Create two runners from IPSW","spook create runner-01 --from-ipsw latest --cpu 4 --memory 8 --disk 64","spook create runner-02 --from-ipsw latest --cpu 4 --memory 8 --disk 64","","# Start with SSH provisioning","spook start runner-01 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin","spook start runner-02 --headless \\","    --user-data \/opt\/spooktacular\/github-runner.sh \\","    --provision ssh --ssh-user admin"]},{"text":"Terraform Module (Planned)","type":"heading","anchor":"Terraform-Module-Planned","level":2},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"A Terraform module for declarative EC2 Mac fleet management","type":"text"},{"text":" ","type":"text"},{"text":"is planned for a future release. For now, use EC2 Launch Templates","type":"text"},{"text":" ","type":"text"},{"text":"with user-data scripts to automate host setup.","type":"text"}]}],"type":"aside","style":"note"},{"text":"Troubleshooting","type":"heading","anchor":"Troubleshooting","level":2},{"text":"IPSW Version Mismatch","type":"heading","anchor":"IPSW-Version-Mismatch","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook create"},{"text":" fails with “Your macOS (X.Y) cannot","type":"text"},{"text":" ","type":"text"},{"text":"install macOS Z.W.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" The EC2 Mac host’s macOS is older than the IPSW you are","type":"text"},{"text":" ","type":"text"},{"text":"trying to install. The guest version must be less than or equal to","type":"text"},{"text":" ","type":"text"},{"text":"the host version.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Update the host macOS to a version that supports the","type":"text"},{"text":" ","type":"text"},{"text":"guest you want to install:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Check host version","sw_vers --productVersion","","# Use --from-ipsw with a compatible version","spook create runner --from-ipsw latest"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"Compatibility"},{"text":" for details on how version checking works.","type":"text"}]},{"text":"Disk Space Exhausted","type":"heading","anchor":"Disk-Space-Exhausted","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" VM creation or operation fails with I\/O errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" APFS sparse disk images grow as the guest writes data.","type":"text"},{"text":" ","type":"text"},{"text":"Two VMs with 100 GB configured disk can consume up to 200 GB.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Monitor disk usage and size VMs appropriately:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Check actual disk usage","du -sh ~\/.spooktacular\/vms\/*\/disk.img","","# EC2 Mac root volume is typically 200 GB — resize if needed","aws ec2 modify-volume --volume-id vol-0xxxx --size 500","# Then resize the filesystem inside the instance","sudo diskutil apfs resizeContainer disk1 0"]},{"text":"24-Hour Minimum Allocation","type":"heading","anchor":"24-Hour-Minimum-Allocation","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" You are billed for 24 hours even though you released","type":"text"},{"text":" ","type":"text"},{"text":"the dedicated host after 2 hours.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" EC2 Mac dedicated hosts have a mandatory 24-hour minimum","type":"text"},{"text":" ","type":"text"},{"text":"allocation period. This is an AWS policy, not a Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"limitation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]},{"text":" Plan your usage in 24-hour blocks. Use Auto Scaling","type":"text"},{"text":" ","type":"text"},{"text":"Groups with scheduled scaling to align host allocation with your","type":"text"},{"text":" ","type":"text"},{"text":"CI load patterns:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Scale up at 8 AM UTC (start of business)","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-up \\","    --recurrence \"0 8 * * MON-FRI\" \\","    --desired-capacity 10","","# Scale down at 8 PM UTC (end of business)","# Hosts won't actually release until 24hr mark","aws autoscaling put-scheduled-action \\","    --auto-scaling-group-name spooktacular-fleet \\","    --scheduled-action-name scale-down \\","    --recurrence \"0 20 * * MON-FRI\" \\","    --desired-capacity 2"]},{"text":"VM Won’t Start","type":"heading","anchor":"VM-Wont-Start","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Symptom:","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"spook start"},{"text":" hangs or the VM enters the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VirtualMachineState\/error"},{"text":" state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Cause:","type":"text"}]},{"text":" Common causes include insufficient resources (too many","type":"text"},{"text":" ","type":"text"},{"text":"cores allocated across VMs), corrupt disk image, or the Apple","type":"text"},{"text":" ","type":"text"},{"text":"kernel 2-VM limit.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Solution:","type":"text"}]}]},{"syntax":"bash","type":"codeListing","code":["# Check how many VMs are running (max 2)","spook list","","# Verify resource allocation","spook get runner-01","","# Check system logs","log show --predicate 'subsystem == \"com.apple.Virtualization\"' --last 5m"]},{"name":"Important","content":[{"inlineContent":[{"text":"Apple’s Virtualization framework enforces a hard limit","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"inlineContent":[{"text":"2 concurrent VMs","type":"text"}],"type":"strong"},{"text":" per host. Attempting to start a third VM","type":"text"},{"text":" ","type":"text"},{"text":"will fail. See ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"text":" for minimum hardware","type":"text"},{"text":" ","type":"text"},{"text":"requirements.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important"}]}],"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Deploying on EC2 Mac","role":"collectionGroup"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/ec2macdeployment"]}],"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface","url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","title":"Running BlueBubbles iMessage Server","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","title":"Versioning & Release Schedule","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration","url":"\/documentation\/spooktacularkit\/kubernetesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","url":"\/documentation\/spooktacularkit\/openclawguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes","url":"\/documentation\/spooktacularkit\/jenkinsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","url":"\/documentation\/spooktacularkit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","url":"\/documentation\/spooktacularkit\/githubactionsguide"}}}