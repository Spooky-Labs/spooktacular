":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/Compatibility":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Compatibility","kind":"identifier"}],"navigatorTitle":[{"text":"Compatibility","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/compatibility","title":"Compatibility","abstract":[{"type":"text","text":"Checks version compatibility between the host macOS"},{"text":" ","type":"text"},{"text":"and a macOS restore image (IPSW).","type":"text"}],"kind":"symbol","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","kind":"symbol","title":"minimumCPUCount","type":"topic","abstract":[{"type":"text","text":"The minimum number of CPU cores required for a macOS VM"},{"type":"text","text":" "},{"type":"text","text":"to boot without freezing."}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"minimumCPUCount","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount"}}}