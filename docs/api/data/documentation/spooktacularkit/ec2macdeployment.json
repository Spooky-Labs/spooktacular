ager","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","type":"topic","url":"\/documentation\/spooktacularkit\/clonemanager","role":"symbol","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"title":"CloneManager","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","url":"\/documentation\/spooktacularkit\/virtualmachinespecification","title":"VirtualMachineSpecification","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Compatibility":{"navigatorTitle":[{"kind":"identifier","text":"Compatibility"}],"abstract":[{"text":"Checks version compatibility between the host macOS","type":"text"},{"text":" ","type":"text"},{"text":"and a macOS restore image (IPSW).","type":"text"}],"title":"Compatibility","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Compatibility"}],"role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/compatibility","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Compatibility"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"abstract":[{"type":"text","text":"The minimum number of CPU cores required for a macOS VM"},{"type":"text","text":" "},{"type":"text","text":"to boot without freezing."}],"title":"minimumCPUCount","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let