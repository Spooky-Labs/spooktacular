{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CapacityCheck","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The macOS Virtualization framework on Apple Silicon supports"},{"type":"text","text":" "},{"type":"text","text":"at most 2 concurrent virtual machines per host. Attempting to"},{"type":"text","text":" "},{"type":"text","text":"start a third VM causes a kernel-level failure that is"},{"type":"text","text":" "},{"type":"text","text":"difficult to diagnose. This module checks the limit proactively"},{"type":"text","text":" "},{"type":"text","text":"and provides a clear error message."}],"type":"paragraph"},{"text":"How It Works","level":2,"anchor":"How-It-Works","type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},{"type":"text","text":" scans all "},{"type":"codeVoice","code":".vm"},{"type":"text","text":" bundles in a given directory"},{"type":"text","text":" "},{"type":"text","text":"for active PID files (see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile"},{"type":"text","text":"). A bundle counts as"},{"type":"text","text":" "},{"type":"text","text":"“running” if it has a PID file whose recorded process is still"},{"type":"text","text":" "},{"type":"text","text":"alive."}],"type":"paragraph"},{"code":["try CapacityCheck.ensureCapacity(in: vmDirectory)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"If 2 or more VMs are already running, the method throws a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError\/limitReached(running:)"},{"type":"text","text":" error."}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/capacitycheck"]}],"topicSections":[{"title":"Type Properties","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/maxConcurrentVMs"],"anchor":"Type-Properties"},{"title":"Type Methods","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/ensureCapacity(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningCount(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningVMs(in:)"],"anchor":"Type-Methods"}],"abstract":[{"text":"Enforces the Apple Silicon concurrent VM limit.","type":"text"}],"metadata":{"role":"symbol","title":"CapacityCheck","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CapacityCheck","kind":"identifier"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit13CapacityCheckO","navigatorTitle":[{"text":"CapacityCheck","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"title":"Capacity","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError"],"anchor":"Capacity"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CapacityCheck/runningCount(in:)":{"role":"symbol","url":"\/documentation\/spooktacularkit\/capacitycheck\/runningcount(in:)","title":"runningCount(in:)","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","