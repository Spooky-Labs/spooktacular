{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CapacityCheck"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The macOS Virtualization framework on Apple Silicon supports"},{"type":"text","text":" "},{"type":"text","text":"at most 2 concurrent virtual machines per host. Attempting to"},{"type":"text","text":" "},{"type":"text","text":"start a third VM causes a kernel-level failure that is"},{"type":"text","text":" "},{"type":"text","text":"difficult to diagnose. This module checks the limit proactively"},{"type":"text","text":" "},{"type":"text","text":"and provides a clear error message."}]},{"type":"heading","text":"How It Works","level":2,"anchor":"How-It-Works"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},{"type":"text","text":" scans all "},{"type":"codeVoice","code":".vm"},{"type":"text","text":" bundles in a given directory"},{"type":"text","text":" "},{"type":"text","text":"for active PID files (see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile"},{"type":"text","text":"). A bundle counts as"},{"type":"text","text":" "},{"type":"text","text":"“running” if it has a PID file whose recorded process is still"},{"type":"text","text":" "},{"type":"text","text":"alive."}]},{"type":"codeListing","code":["try CapacityCheck.ensureCapacity(in: vmDirectory)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If 2 or more VMs are already running, the method throws a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError\/limitReached(running:)"},{"type":"text","text":" error."}]}]}],"seeAlsoSections":[{"title":"Capacity","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError"],"anchor":"Capacity","generated":true}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/spooktacularkit\/capacitycheck"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Enforces the Apple Silicon concurrent VM limit."}],"metadata":{"title":"CapacityCheck","role":"symbol","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit13CapacityCheckO","roleHeading":"Enumeration","navigatorTitle":[{"kind":"identifier","text":"CapacityCheck"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CapacityCheck"}],"symbolKind":"enum"},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/maxConcurrentVMs"],"anchor":"Type-Properties","generated":true},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/ensureCapacity(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningCount(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningVMs(in:)"],"generated":true,"anchor":"Type-Methods"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CapacityCheck/runningVMs(in:)":{"title":"runningVMs(in:)","role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"Returns the names of all currently running VMs in the","type":"text"},{"text":" ","type":"text"},{"text":"given directory.","type":"text