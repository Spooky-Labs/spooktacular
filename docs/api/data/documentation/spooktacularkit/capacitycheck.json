{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CapacityCheck"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The macOS Virtualization framework on Apple Silicon supports"},{"type":"text","text":" "},{"type":"text","text":"at most 2 concurrent virtual machines per host. Attempting to"},{"type":"text","text":" "},{"type":"text","text":"start a third VM causes a kernel-level failure that is"},{"type":"text","text":" "},{"type":"text","text":"difficult to diagnose. This module checks the limit proactively"},{"type":"text","text":" "},{"type":"text","text":"and provides a clear error message."}],"type":"paragraph"},{"anchor":"How-It-Works","level":2,"text":"How It Works","type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck","type":"reference","isActive":true},{"type":"text","text":" scans all "},{"code":".vm","type":"codeVoice"},{"type":"text","text":" bundles in a given directory"},{"type":"text","text":" "},{"type":"text","text":"for active PID files (see "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","type":"reference","isActive":true},{"type":"text","text":"). A bundle counts as"},{"type":"text","text":" "},{"type":"text","text":"“running” if it has a PID file whose recorded process is still"},{"type":"text","text":" "},{"type":"text","text":"alive."}],"type":"paragraph"},{"code":["try CapacityCheck.ensureCapacity(in: vmDirectory)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"If 2 or more VMs are already running, the method throws a"},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError\/limitReached(running:)","typ