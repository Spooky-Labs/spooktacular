.vm"},{"type":"text","text":" bundles in a given directory"},{"type":"text","text":" "},{"type":"text","text":"for active PID files (see "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","isActive":true},{"type":"text","text":"). A bundle counts as"},{"type":"text","text":" "},{"type":"text","text":"“running” if it has a PID file whose recorded process is still"},{"type":"text","text":" "},{"type":"text","text":"alive."}],"type":"paragraph"},{"syntax":"swift","code":["try CapacityCheck.ensureCapacity(in: vmDirectory)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If 2 or more VMs are already running, the method throws a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError\/limitReached(running:)","isActive":true},{"type":"text","text":" error."}],"type":"paragraph"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/maxConcurrentVMs"],"generated":true,"title":"Type Properties","anchor":"Type-Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/ensureCapacity(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningCount(in:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningVMs(in:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","type":"topic","title":"SpooktacularKit","kind":"symbol","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CapacityCheck/maxConcurrentVMs":{"url":"\/documentation\/spooktacularkit\/capacitycheck