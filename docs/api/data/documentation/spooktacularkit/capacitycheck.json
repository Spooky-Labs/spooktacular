ference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError\/limitReached(running:)"},{"type":"text","text":" error."}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CapacityCheck"}],"title":"CapacityCheck","modules":[{"name":"SpooktacularKit"}],"navigatorTitle":[{"kind":"identifier","text":"CapacityCheck"}],"symbolKind":"enum","externalID":"s:15SpooktacularKit13CapacityCheckO","roleHeading":"Enumeration","role":"symbol"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityError"],"generated":true,"anchor":"Capacity","title":"Capacity"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/capacitycheck"]}],"topicSections":[{"generated":true,"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/maxConcurrentVMs"],"title":"Type Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/ensureCapacity(in:log:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningCount(in:log:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck\/runningVMs(in:log:)"],"generated":true,"anchor":"Type-Methods","title":"Type Methods"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CapacityCheck/ensureCapacity(in:log:)":{"abstract":[{"type":"text","text":"Throws if the concurrent VM limit has been reached."}],"url":"\/documentation\/spooktacularkit\/capacitycheck\/ensurecapacity(in:log:)","title":"ensureCapacity(in:log:)","type