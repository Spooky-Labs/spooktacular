r":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","kind":"article","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"title":"Machine Learning Workloads"},"https://bluebubbles.app":{"identifier":"https:\/\/bluebubbles.app","title":"BlueBubbles","url":"https:\/\/bluebubbles.app","type":"link","titleInlineContent":[{"type":"text","text":"BlueBubbles"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}]},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","title":"BlueBubbles VMware guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"link","titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"title":"Versioning & Release Schedule"},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","title":"Using iCloud with macOS virtual machines","url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"link","titleInlineContent":[{"type":"text","text":"Using iCloud with macOS virtual machines"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"title":"Getting Started with Spooktacular"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/ec2macdeployment","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"title":"Remote Desktop Access"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"type":"topic","url":"\/documentation\/spooktacularkit\/provisioningmode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","title":"ProvisioningMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}]},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","title":"BlueBubbles VMware guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","type":"link","titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}]}}}