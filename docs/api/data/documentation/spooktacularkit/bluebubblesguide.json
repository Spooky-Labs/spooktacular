acular","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","title":"BlueBubbles VMware guide","type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","title":"SpooktacularKit","url":"\/documentation\/spooktacularkit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"kind":"symbol","type":"topic","role":"collection"},"https://bluebubbles.app":{"url":"https:\/\/bluebubbles.app","title":"BlueBubbles","type":"link","identifier":"https:\/