{"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"text":" is an open-source app that brings","type":"text"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"text":"image conversion, Auto-Unlocker patches, and manual VMX editing","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}],"type":"strong"},{"text":" On an Apple Silicon Mac, you run","type":"text"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s official Virtualization framework, no Hackintosh tools required.","type":"text"}],"type":"paragraph"},{"anchor":"Why-a-VM-instead-of-bare-metal","level":3,"text":"Why a VM instead of bare metal?","type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Dedicated environment"}],"type":"strong"},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}]},{"text":"Quick Start","anchor":"Quick-Start","level":2,"type":"heading"},{"text":"1. Create a VM","anchor":"1-Create-a-VM","level":3,"type":"heading"},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"]},{"inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}],"type":"paragraph"},{"text":"2. The setup script","anchor":"2-The-setup-script","level":3,"type":"heading"},{"inlineContent":[{"text":"Create ","type":"text"},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"text":"3. Start and configure","anchor":"3-Start-and-configure","level":3,"type":"heading"},{"type":"codeListing","syntax":"bash","code":["spook start bluebubbles"]},{"inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}],"type":"strong"},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Open Messages.app"}],"type":"strong"},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}],"type":"strong"},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Grant Full Disk Access"}],"type":"strong"},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}]},{"text":"4. Run headless 24\/7","anchor":"4-Run-headless-247","level":3,"type":"heading"},{"inlineContent":[{"text":"Once configured, restart headless:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"]},{"inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"]},{"text":"Two BlueBubbles Instances","anchor":"Two-BlueBubbles-Instances","level":2,"type":"heading"},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"]},{"type":"aside","name":"Important","content":[{"inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}],"type":"paragraph"}],"style":"important"},{"text":"Comparison: Spooktacular vs VMware-on-Windows","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","level":2,"type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware on Windows","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Spooktacular"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Steps to working VM","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"20+ manual steps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1 command"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS installation"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"OpenCore + Recovery","type":"text"}]}],[{"inlineContent":[{"text":"Apple’s official IPSW","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"text":"Any x86 PC","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac","type":"text"}]}]],[[{"inlineContent":[{"text":"Apple EULA","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Compliant","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iMessage activation","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Requires fake serial numbers","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Emulated, slow","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"inlineContent":[{"text":"GPU acceleration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"None","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Maintenance","type":"text"}]}],[{"inlineContent":[{"text":"Manual patching per update","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware snapshots","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook snapshot","type":"codeVoice"},{"text":" (APFS)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"24\/7 headless","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Complex configuration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook start --headless","type":"codeVoice"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"iCloud and iMessage in VMs","anchor":"iCloud-and-iMessage-in-VMs","level":2,"type":"heading"},{"inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"iCloud support requires macOS 15+ on both the host and","type":"text"},{"text":" ","type":"text"},{"text":"the guest. Earlier macOS versions may have issues with iMessage","type":"text"},{"text":" ","type":"text"},{"text":"activation in VMs. See Apple’s documentation:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"text":".","type":"text"}],"type":"paragraph"}],"style":"note"},{"text":"Networking for BlueBubbles","anchor":"Networking-for-BlueBubbles","level":2,"type":"heading"},{"inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"]},{"inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing"},{"level":2,"text":"Monitoring","anchor":"Monitoring","type":"heading"},{"syntax":"bash","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing"}]}],"topicSections":[{"anchor":"Related","title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/Spooktacu