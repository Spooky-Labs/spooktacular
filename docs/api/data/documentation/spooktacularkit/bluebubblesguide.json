{"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"anchor":"Guides","title":"Guides"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"],"anchor":"Related","title":"Related"}],"metadata":{"title":"Running BlueBubbles iMessage Server","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/bluebubbles.app","isActive":true},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}]},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}],"type":"paragraph"},{"anchor":"Why-a-VM-instead-of-bare-metal","text":"Why a VM instead of bare metal?","level":3,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Two servers"}]},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Quick-Start","text":"Quick Start","level":2,"type":"heading"},{"anchor":"1-Create-a-VM","text":"1. Create a VM","level":3,"type":"heading"},{"syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}],"type":"paragraph"},{"anchor":"2-The-setup-script","text":"2. The setup script","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"type":"codeListing"},{"anchor":"3-Start-and-configure","text":"3. Start and configure","level":3,"type":"heading"},{"syntax":"bash","code":["spook start bluebubbles"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}]},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Messages.app"}]},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Grant Full Disk Access"}]},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"4-Run-headless-247","text":"4. Run headless 24\/7","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Once configured, restart headless:"}],"type":"paragraph"},{"syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The BlueBubbles server runs in the background. Access it"},{"type":"text","text":" "},{"type":"text","text":"remotely via VNC if you need to make changes:"}],"type":"paragraph"},{"syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"type":"codeListing"},{"anchor":"Two-BlueBubbles-Instances","text":"Two BlueBubbles Instances","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Run two iMessage servers on one Mac — one for each Apple ID:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}]}],"style":"important","type":"aside"},{"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","text":"Comparison: Spooktacular vs VMware-on-Windows","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true},{"type":"text","text":" "},{"type":"text","text":"requires 20+ steps including BIOS configuration, Python\/QEMU"},{"type":"text","text":" "},{"type":"text","text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"type":"text","text":" "},{"type":"text","text":"by Apple, may violate the EULA)."}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"text":"VMware on Windows","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Spooktacular","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Steps to working VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"20+ manual steps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 command","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS installation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"OpenCore + Recovery","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple’s official IPSW","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Hardware","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Any x86 PC","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Apple EULA","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iMessage activation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Requires fake serial numbers","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works natively","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Performance","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Emulated, slow","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Near-native (VirtIO)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"GPU acceleration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"None","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Metal via VZ framework","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Maintenance","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Manual patching per update","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Snapshots","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"VMware snapshots","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook snapshot","type":"codeVoice"},{"text":" (APFS)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"24\/7 headless","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Complex configuration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook start --headless","type":"codeVoice"}]}]]],"header":"row","type":"table"},{"anchor":"iCloud-and-iMessage-in-VMs","text":"iCloud and iMessage in VMs","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"type":"text","text":" "},{"type":"text","text":"inside macOS VMs created with the Virtualization framework. This"},{"type":"text","text":" "},{"type":"text","text":"means iMessage activation works natively — no fake serial numbers"},{"type":"text","text":" "},{"type":"text","text":"or Clover Configurator needed."}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"iCloud support requires macOS 15+ on both the host and","type":"text"},{"text":" ","type":"text"},{"text":"the guest. Earlier macOS versions may have issues with iMessage","type":"text"},{"text":" ","type":"text"},{"text":"activation in VMs. See Apple’s documentation:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"reference","isActive":true},{"text":".","type":"text"}]}],"style":"note","type":"aside"},{"anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare."},{"type":"text","text":" "},{"type":"text","text":"NAT networking (the default) provides this without any additional"},{"type":"text","text":" "},{"type":"text","text":"configuration:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For advanced setups where other devices on your LAN need to reach"},{"type":"text","text":" "},{"type":"text","text":"the BlueBubbles server directly:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing"},{"anchor":"Monitoring","text":"Monitoring","level":2,"type":"heading"},{"syntax":"bash","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing"}],"kind":"content"}],"references":{"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"type":"link","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","title":"BlueBubbles VMware guide","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmwar