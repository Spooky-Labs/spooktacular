{"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"title":"Guides","generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","title":"Running BlueBubbles iMessage Server","role":"collectionGroup"},"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/bluebubbles.app","type":"reference","isActive":true},{"text":" is an open-source app that brings","type":"text"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"text":"image conversion, Auto-Unlocker patches, and manual VMX editing","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","type":"reference","isActive":true},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}],"type":"strong"},{"text":" On an Apple Silicon Mac, you run","type":"text"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s official Virtualization framework, no Hackintosh tools required.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Why a VM instead of bare metal?","type":"heading","anchor":"Why-a-VM-instead-of-bare-metal"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Isolation"}],"type":"strong"},{"type":"text","text":" — BlueBubbles needs Full Disk Access to read iMessage’s"},{"text":" ","type":"text"},{"type":"text","text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"strong"},{"type":"text","text":" — save a working iMessage configuration before macOS"},{"type":"text","text":" "},{"type":"text","text":"updates, roll back if something breaks."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Dedicated environment"}],"type":"strong"},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"type":"text","text":" "},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}]}]}]},{"text":"Quick Start","level":2,"anchor":"Quick-Start","type":"heading"},{"level":3,"type":"heading","anchor":"1-Create-a-VM","text":"1. Create a VM"},{"type":"codeListing","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"syntax":"bash"},{"inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}],"type":"paragraph"},{"level":3,"text":"2. The setup script","type":"heading","anchor":"2-The-setup-script"},{"inlineContent":[{"text":"Create ","type":"text"},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"type":"codeListing","syntax":"bash"},{"level":3,"text":"3. Start and configure","type":"heading","anchor":"3-Start-and-configure"},{"code":["spook start bluebubbles"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}]},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Open Messages.app","type":"text"}]},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":3,"text":"4. Run headless 24\/7","type":"heading","anchor":"4-Run-headless-247"},{"inlineContent":[{"text":"Once configured, restart headless:","type":"text"}],"type":"paragraph"},{"code":["spook stop bluebubbles","spook start bluebubbles --headless"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}],"type":"paragraph"},{"code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"type":"codeListing","syntax":"bash"},{"level":2,"text":"Two BlueBubbles Instances","type":"heading","anchor":"Two-BlueBubbles-Instances"},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing","syntax":"bash"},{"style":"important","content":[{"inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important"},{"level":2,"text":"Comparison: Spooktacular vs VMware-on-Windows","type":"heading","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"reference"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware on Windows","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Spooktacular","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Steps to working VM","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"20+ manual steps","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1 command","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS installation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"OpenCore + Recovery","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Apple’s official IPSW","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Hardware","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Any x86 PC","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Apple Silicon Mac","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Apple EULA","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Compliant","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iMessage activation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Requires fake serial numbers","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Works natively","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Emulated, slow","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Near-native (VirtIO)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"GPU acceleration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"None","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Metal via VZ framework","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Maintenance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Manual patching per update",