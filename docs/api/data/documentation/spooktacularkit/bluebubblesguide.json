n\/spooktacularkit\/ec2macdeployment","title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"titleInlineContent":[{"type":"text","text":"Using iCloud with macOS virtual machines"}],"url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"link","title":"Using iCloud with macOS virtual machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/jenkinsguide","title":"Configuring Jenkins Nodes","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"}}}