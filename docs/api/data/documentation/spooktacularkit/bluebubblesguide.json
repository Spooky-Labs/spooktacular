"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"title":"ProvisioningMode","kind":"symbol","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit","role":"collection"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"link","title":"BlueBubbles VMware guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"}}}