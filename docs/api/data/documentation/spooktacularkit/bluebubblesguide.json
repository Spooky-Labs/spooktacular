ding","level":2,"text":"Quick Start"},{"anchor":"1-Create-a-VM","type":"heading","level":3,"text":"1. Create a VM"},{"syntax":"bash","type":"codeListing","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}]},{"anchor":"2-The-setup-script","type":"heading","level":3,"text":"2. The setup script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create "},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"anchor":"3-Start-and-configure","type":"heading","level":3,"text":"3. Start and configure"},{"syntax":"bash","type":"codeListing","code":["spook start bluebubbles"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}],"type":"strong"},{"type":"text","text":" — required for iMessage"}],"type":"paragraph"}]},{"con