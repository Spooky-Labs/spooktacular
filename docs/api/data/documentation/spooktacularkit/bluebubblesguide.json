{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],"anchor":"Related"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"text":" is an open-source app that brings","type":"text"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"text":"image conversion, Auto-Unlocker patches, and manual VMX editing","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Spooktacular eliminates all of that."}]},{"text":" On an Apple Silicon Mac, you run","type":"text"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s official Virtualization framework, no Hackintosh tools required.","type":"text"}],"type":"paragraph"},{"anchor":"Why-a-VM-instead-of-bare-metal","text":"Why a VM instead of bare metal?","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Snapshots","type":"text"}]},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Dedicated environment","type":"text"}]},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Two servers","type":"text"}]},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Quick-Start","text":"Quick Start","type":"heading","level":2},{"anchor":"1-Create-a-VM","text":"1. Create a VM","type":"heading","level":3},{"syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}],"type":"paragraph"},{"anchor":"2-The-setup-script","text":"2. The setup script","type":"heading","level":3},{"inlineContent":[{"text":"Create ","type":"text"},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"type":"codeListing"},{"anchor":"3-Start-and-configure","text":"3. Start and configure","type":"heading","level":3},{"syntax":"bash","code":["spook start bluebubbles"],"type":"codeListing"},{"inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}]},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Open Messages.app","type":"text"}]},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}]},{"anchor":"4-Run-headless-247","text":"4. Run headless 24\/7","type":"heading","level":3},{"inlineContent":[{"text":"Once configured, restart headless:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"],"type":"codeListing"},{"inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"type":"codeListing"},{"anchor":"Two-BlueBubbles-Instances","text":"Two BlueBubbles Instances","type":"heading","level":2},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}]}],"type":"aside","style":"important"},{"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","text":"Comparison: Spooktacular vs VMware-on-Windows","type":"heading","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware on Windows"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Steps to working VM"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"20+ manual steps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 command"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS installation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s official IPSW"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple EULA"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Compliant"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works natively"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Performance"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Emulated, slow"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GPU acceleration"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Metal via VZ framework"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maintenance"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual patching per update"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook snapshot","type":"codeVoice"},{"type":"text","text":" (APFS)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"24\/7 headless"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex configuration"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook start --headless","type":"codeVoice"}]}]]],"header":"row","type":"table"},{"anchor":"iCloud-and-iMessage-in-VMs","text":"iCloud and iMessage in VMs","type":"heading","level":2},{"inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","isActive":true,"type":"reference"},{"type":"text","text":"."}]}],"type":"aside","style":"note"},{"anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles","type":"heading","level":2},{"inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"],"type":"codeListing"},{"inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing"},{"anchor":"Monitoring","text":"Monitoring","type":"heading","level":2},{"syntax":"bash","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"role":"collectionGroup","title":"Running BlueBubbles iMessage Server","modules":[{"name":"SpooktacularKit"}]},"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"article","seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","title":"Getting Started with Spooktacular"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","kind":"symbol","role":"collection","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"type":"topic","ident