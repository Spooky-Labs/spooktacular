ines","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"type":"link","title":"BlueBubbles VMware guide","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","title":"Kubernetes Integration","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"title":"Versioning & Release Schedule","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","kind":"symbol","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"role":"collectionGroup","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","title":"Deploying on EC2 Mac","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article","title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"role":"collectionGroup"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"type":"link","title":"BlueBubbles VMware guide","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"}}}