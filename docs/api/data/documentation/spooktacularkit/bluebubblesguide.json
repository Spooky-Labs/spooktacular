{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/bluebubbles.app","type":"reference"},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Spooktacular eliminates all of that."}],"type":"strong"},{"text":" On an Apple Silicon Mac, you run","type":"text"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s official Virtualization framework, no Hackintosh tools required.","type":"text"}]},{"type":"heading","text":"Why a VM instead of bare metal?","anchor":"Why-a-VM-instead-of-bare-metal","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"type":"text","text":" — BlueBubbles needs Full Disk Access to read iMessage’s"},{"type":"text","text":" "},{"type":"text","text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Snapshots","type":"text"}]},{"type":"text","text":" — save a working iMessage configuration before macOS"},{"type":"text","text":" "},{"type":"text","text":"updates, roll back if something breaks."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Dedicated environment"}],"type":"strong"},{"type":"text","text":" — the VM can run 24\/7 headless while you"},{"text":" ","type":"text"},{"type":"text","text":"use your Mac normally."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"type":"text","text":" "},{"type":"text","text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support."}]}]}],"type":"unorderedList"},{"level":2,"text":"Quick Start","type":"heading","anchor":"Quick-Start"},{"anchor":"1-Create-a-VM","level":3,"type":"heading","text":"1. Create a VM"},{"code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}],"type":"paragraph"},{"level":3,"text":"2. The setup script","type":"heading","anchor":"2-The-setup-script"},{"inlineContent":[{"text":"Create ","type":"text"},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"type":"codeListing"},{"type":"heading","text":"3. Start and configure","anchor":"3-Start-and-configure","level":3},{"code":["spook start bluebubbles"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}],"type":"strong"},{"text":" — required for iMessage","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Open Messages.app"}],"type":"strong"},{"type":"text","text":" — verify iMessage activates"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}],"type":"strong"},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"type":"text","text":" — System Settings → Privacy &"},{"type":"text","text":" "},{"type":"text","text":"Security → Full Disk Access → add BlueBubbles"}],"type":"paragraph"}]}]},{"text":"4. Run headless 24\/7","level":3,"type":"heading","anchor":"4-Run-headless-247"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once configured, restart headless:"}]},{"syntax":"bash","type":"codeListing","code":["spook stop bluebubbles","spook start bluebubbles --headless"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The BlueBubbles server runs in the background. Access it"},{"type":"text","text":" "},{"type":"text","text":"remotely via VNC if you need to make changes:"}]},{"syntax":"bash","type":"codeListing","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"]},{"text":"Two BlueBubbles Instances","level":2,"type":"heading","anchor":"Two-BlueBubbles-Instances"},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing","syntax":"bash"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}]}],"style":"important","type":"aside","name":"Important"},{"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","level":2,"type":"heading","text":"Comparison: Spooktacular vs VMware-on-Windows"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware on Windows"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Steps to working VM"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"20+ manual steps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 command"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS installation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s official IPSW"}]}]],[[{"inlineContent":[{"type":"text","text":"Hardware"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Any x86 PC"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Apple EULA"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}]}],[{"inlineContent":[{"type":"text","text":"Compliant"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iMessage activation"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works natively"}]}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Near-native (VirtIO)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Metal via VZ framework","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Manual patching per update"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"text":" (APFS)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"24\/7 headless"}]}],[{"type":"paragraph","inlineContent":[{"text":"Complex configuration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start --headless"}]}]]],"type":"table"},{"anchor":"iCloud-and-iMessage-in-VMs","level":2,"type":"heading","text":"iCloud and iMessage in VMs"},{"inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"type":"text","text":" "},{"type":"text","text":"inside macOS VMs created with the Virtualization framework. This"},{"type":"text","text":" "},{"type":"text","text":"means iMessage activation works natively — no fake serial numbers"},{"type":"text","text":" "},{"type":"text","text":"or Clover Configurator needed."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","isActive":true},{"type":"text","text":"."}]}],"style":"note","type":"aside","name":"Note"},{"anchor":"Networking-for-BlueBubbles","level":2,"type":"heading","text":"Networking for BlueBubbles"},{"inlineContent":[{"type":"text","text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare."},{"type":"text","text":" "},{"type":"text","text":"NAT networking (the default) provides this without any additional"},{"type":"text","text":" "},{"type":"text","text":"configuration:"}],"type":"paragraph"},{"code":["spook create bluebubbles --network nat   # default, works out of the box"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"For advanced setups where other devices on your LAN need to reach"},{"type":"text","text":" "},{"type":"text","text":"the BlueBubbles server directly:"}],"type":"paragraph"},{"code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing","syntax":"bash"},{"anchor":"Monitoring","level":2,"type":"heading","text":"Monitoring"},{"code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing","syntax":"bash"}]}],"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup","title":"Running BlueBubbles iMessage Server"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"title":"ProvisioningMode","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"url":"\/documentation\/spooktacularkit\/provisioningmode","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","type":"topic","title":"SpooktacularKit","kind":"symbol","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"title":"BlueBubbles VMware guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}],"type":"link"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"kind":"symbol","role":"symbol","title":"NetworkMode","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode"},"https://bluebubbles.app":{"title":"BlueBubbles","url":"https:\/\/bluebubbles.app","identifier":"https:\/\/bluebubbles.app","titleInlineContent":[{"type":"text","text":"BlueBubbles"}],"type":"link"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","role":"collectionGroup","title":"Getting Started with Spooktacular","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}],"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","title":"BlueBubbles VMware guide","type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"kind":"article","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"role":"collectionGroup"},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"titleInlineContent":[{"text":"Using iCloud with macOS virtual machines","type":"text"}],"url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","title":"Using iCloud with macOS virtual machines","type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"}}}