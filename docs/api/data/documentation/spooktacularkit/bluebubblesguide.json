tleInlineContent":[{"text":"BlueBubbles","type":"text"}],"url":"https:\/\/bluebubbles.app","type":"link","identifier":"https:\/\/bluebubbles.app"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"title":"Versioning & Release Schedule"}}}