/SpooktacularKit\/KubernetesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/clireference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"kind":"article","title":"Remote Desktop Access","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop","type":"topic","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"title":"BlueBubbles VMware guide","type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"kind":"article","title":"Getting Started with Spooktacular","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"title":"Configuring Jenkins Nodes","kind":"article","url":"\/documentation\/spooktacularkit\/jenkinsguide","type":"topic"},"https://bluebubbles.app":{"identifier":"https:\/\/bluebubbles.app","title":"BlueBubbles","url":"https:\/\/bluebubbles.app","type":"link","titleInlineContent":[{"text":"BlueBubbles","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"kind":"article","title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"}}}