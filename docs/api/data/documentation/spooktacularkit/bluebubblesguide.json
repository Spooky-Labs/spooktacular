ws","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Spooktacular","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Steps to working VM","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"20+ manual steps"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1 command","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS installation"}]}],[{"type":"paragraph","inlineContent":[{"text":"OpenCore + Recovery","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s official IPSW"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Hardware","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Apple EULA","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}]}],[{"inlineContent":[{"text":"Compliant","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works natively"}]}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Near-native (VirtIO)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GPU acceleration"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Metal via VZ framework"}]}]],[[{"inlineContent":[{"text":"Maintenance","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Manua