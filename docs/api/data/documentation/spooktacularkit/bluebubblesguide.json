","title":"BlueBubbles","titleInlineContent":[{"text":"BlueBubbles","type":"text"}],"identifier":"https:\/\/bluebubbles.app"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"role":"collectionGroup","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"title":"Kubernetes Integration","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article"}}}