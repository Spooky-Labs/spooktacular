":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","type":"topic"}}}