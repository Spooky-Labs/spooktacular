r","text":"NetworkMode"}],"kind":"symbol","title":"NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"type":"topic","title":"ProvisioningMode","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","url":"\/documentation\/spooktacularkit\/provisioningmode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"kind":"symbol","role":"symbol"}}}