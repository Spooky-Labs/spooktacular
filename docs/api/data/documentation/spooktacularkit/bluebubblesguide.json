al-machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"title":"NetworkMode","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"type":"topic","url":"\/documentation\/spooktacularkit\/networkmode","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"role":"symbol"}}}