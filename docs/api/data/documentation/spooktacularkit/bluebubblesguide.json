oper.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"kind":"article"}}}