acularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"type":"topic","title":"Deploying on EC2 Mac","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/ec2macdeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"type":"topic","title":"NetworkMode","role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","title":"BlueBubbles VMware guide"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"title":"ProvisioningMode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","url":"\/documentation\/spooktacularkit\/provisioningmode","kind":"symbol","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"type":"topic","role":"symbol","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}]},"https://bluebubbles.app":{"titleInlineContent":[{"type":"text","text":"BlueBubbles"}],"url":"https:\/\/bluebubbles.app","type":"link","identifier":"https:\/\/bluebubbles.app","title":"BlueBubbles"}}}