{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"text":" is an open-source app that brings","type":"text"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"text":"image conversion, Auto-Unlocker patches, and manual VMX editing","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}]},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}]},{"level":3,"anchor":"Why-a-VM-instead-of-bare-metal","type":"heading","text":"Why a VM instead of bare metal?"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"type":"text","text":" — BlueBubbles needs Full Disk Access to read iMessage’s"},{"type":"text","text":" "},{"type":"text","text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"type":"text","text":" — the VM can run 24\/7 headless while you"},{"type":"text","text":" "},{"type":"text","text":"use your Mac normally."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"type":"text","text":" — run two BlueBubbles instances (e.g., personal +"},{"type":"text","text":" "},{"type":"text","text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Quick-Start","type":"heading","text":"Quick Start"},{"level":3,"anchor":"1-Create-a-VM","type":"heading","text":"1. Create a VM"},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}]},{"type":"heading","anchor":"2-The-setup-script","text":"2. The setup script","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"type":"heading","anchor":"3-Start-and-configure","text":"3. Start and configure","level":3},{"type":"codeListing","syntax":"bash","code":["spook start bluebubbles"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}]},{"type":"text","text":" — required for iMessage"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Open Messages.app","type":"text"}],"type":"strong"},{"type":"text","text":" — verify iMessage activates"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Grant Full Disk Access"}]},{"text":" — System Settings → Privacy &","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Security → Full Disk Access → add BlueBubbles"}]}]}]},{"type":"heading","level":3,"anchor":"4-Run-headless-247","text":"4. Run headless 24\/7"},{"type":"paragraph","inlineContent":[{"text":"Once configured, restart headless:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"]},{"type":"paragraph","inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"]},{"type":"heading","level":2,"anchor":"Two-BlueBubbles-Instances","text":"Two BlueBubbles Instances"},{"type":"paragraph","inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}],"type":"paragraph"}]},{"type":"heading","level":2,"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","text":"Comparison: Spooktacular vs VMware-on-Windows"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware on Windows"}]}],[{"type":"paragraph","inlineContent":[{"text":"Spooktacular","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Steps to working VM"}]}],[{"type":"paragraph","inlineContent":[{"text":"20+ manual steps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 command"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS installation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple’s official IPSW","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Apple EULA","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Performance"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Emulated, slow","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Near-native (VirtIO)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"GPU acceleration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Manual patching per update","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VMware snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook snapshot","type":"codeVoice"},{"type":"text","text":" (APFS)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"24\/7 headless"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Complex configuration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook start --headless"}],"type":"paragraph"}]]]},{"text":"iCloud and iMessage in VMs","level":2,"type":"heading","anchor":"iCloud-and-iMessage-in-VMs"},{"inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"type":"text","text":"."}]}],"style":"note","type":"aside","name":"Note"},{"anchor":"Networking-for-BlueBubbles","type":"heading","text":"Networking for BlueBubbles","level":2},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"]},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"]},{"anchor":"Monitoring","type":"heading","text":"Monitoring","level":2},{"type":"codeListing","syntax":"bash","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebu