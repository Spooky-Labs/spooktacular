 GitHub Actions Runners","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"https://bluebubbles.app":{"identifier":"https:\/\/bluebubbles.app","titleInlineContent":[{"type":"text","text":"BlueBubbles"}],"url":"https:\/\/bluebubbles.app","title":"BlueBubbles","type":"link"}}}