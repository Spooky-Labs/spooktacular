{"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],"title":"Related"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides"}],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"text":" is an open-source app that brings","type":"text"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}]},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}]},{"text":"Why a VM instead of bare metal?","level":3,"type":"heading","anchor":"Why-a-VM-instead-of-bare-metal"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}]}]}]},{"text":"Quick Start","level":2,"type":"heading","anchor":"Quick-Start"},{"text":"1. Create a VM","level":3,"type":"heading","anchor":"1-Create-a-VM"},{"code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}]},{"text":"2. The setup script","level":3,"type":"heading","anchor":"2-The-setup-script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}]},{"code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"syntax":"bash","type":"codeListing"},{"text":"3. Start and configure","level":3,"type":"heading","anchor":"3-Start-and-configure"},{"code":["spook start bluebubbles"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}]},{"text":" — required for iMessage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Open Messages.app","type":"text"}]},{"text":" — verify iMessage activates","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}]}]}]},{"text":"4. Run headless 24\/7","level":3,"type":"heading","anchor":"4-Run-headless-247"},{"type":"paragraph","inlineContent":[{"text":"Once configured, restart headless:","type":"text"}]},{"code":["spook stop bluebubbles","spook start bluebubbles --headless"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}]},{"code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"syntax":"bash","type":"codeListing"},{"text":"Two BlueBubbles Instances","level":2,"type":"heading","anchor":"Two-BlueBubbles-Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Run two iMessage servers on one Mac — one for each Apple ID:"}]},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"syntax":"bash","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}]}],"style":"important","type":"aside","name":"Important"},{"text":"Comparison: Spooktacular vs VMware-on-Windows","level":2,"type":"heading","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true},{"type":"text","text":" "},{"type":"text","text":"requires 20+ steps including BIOS configuration, Python\/QEMU"},{"type":"text","text":" "},{"type":"text","text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"type":"text","text":" "},{"type":"text","text":"by Apple, may violate the EULA)."}]},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware on Windows","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Spooktacular","type":"text"}]}]],[[{"inlineContent":[{"text":"Steps to working VM","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"20+ manual steps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1 command"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS installation"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple’s official IPSW","type":"text"}]}]],[[{"inlineContent":[{"text":"Hardware","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Any x86 PC","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac"}]}]],[[{"inlineContent":[{"type":"text","text":"Apple EULA"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"iMessage activation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Requires fake serial numbers"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Performance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Manual patching per update"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VMware snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"type":"text","text":" (APFS)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"24\/7 headless"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Complex configuration"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook start --headless"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"iCloud and iMessage in VMs","level":2,"type":"heading","anchor":"iCloud-and-iMessage-in-VMs"},{"type":"paragraph","inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"text":"Networking for BlueBubbles","level":2,"type":"heading","anchor":"Networking-for-BlueBubbles"},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"code":["spook create bluebubbles --network nat   # default, works out of the box"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}]},{"code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"syntax":"bash","type":"codeListing"},{"text":"Monitoring","level":2,"type":"heading","anchor":"Monitoring"},{"code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"syntax":"bash","type":"codeListing"}],"kind":"content"}],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Running BlueBubbles iMessage Server"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","url":"\/documentation\/spooktacularkit","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","title":"SpooktacularKit","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","title":"Versioning & Release Schedule","kind":"article"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}],"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"link","title":"BlueBubbles VMware guide"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","title":"Configuring Jenkins Nodes","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"type":"topic","role":"collectionGroup"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}],"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","type":"link","title":"BlueBubbles VMware guide"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","kind":"article"},"https://bluebubbles.app":{"identifier":"https:\/\/bluebubbles.app","titleInlineContent":[{"text":"BlueBubbles","type":"text"}],"url":"https:\/\/bluebubbles.app","type":"link","title":"BlueBubbles"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","url":"\/documentation\/spooktacularkit\/githubactionsguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"title":"Machine Learning Workloads","url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"type":"topic","role":"collectionGroup"},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","titleInlineContent":[{"text":"Using iCloud with macOS virtual machines","type":"text"}],"url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"link","title":"Using iCloud with macOS virtual machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"type":"topic","url":"\/documentation\/spooktacularkit\/clireference","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"type":"topic","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"url":"\/documentation\/spooktacularkit\/kubernetesguide","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration","kind":"article"}}}