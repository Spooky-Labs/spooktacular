{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/bluebubbles.app","isActive":true},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}]},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}],"type":"paragraph"},{"anchor":"Why-a-VM-instead-of-bare-metal","type":"heading","level":3,"text":"Why a VM instead of bare metal?"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Dedicated environment","type":"text"}],"type":"strong"},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Two servers","type":"text"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Quick-Start","type":"heading","level":2,"text":"Quick Start"},{"anchor":"1-Create-a-VM","type":"heading","level":3,"text":"1. Create a VM"},{"code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}],"type":"paragraph"},{"anchor":"2-The-setup-script","type":"heading","level":3,"text":"2. The setup script"},{"inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"syntax":"bash","type":"codeListing"},{"anchor":"3-Start-and-configure","type":"heading","level":3,"text":"3. Start and configure"},{"code":["spook start bluebubbles"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}],"type":"strong"},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Open Messages.app","type":"text"}],"type":"strong"},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}],"type":"strong"},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Grant Full Disk Access","type":"text"}],"type":"strong"},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}]},{"anchor":"4-Run-headless-247","type":"heading","level":3,"text":"4. Run headless 24\/7"},{"inlineContent":[{"type":"text","text":"Once configured, restart headless:"}],"type":"paragraph"},{"code":["spook stop bluebubbles","spook start bluebubbles --headless"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The BlueBubbles server runs in the background. Access it"},{"type":"text","text":" "},{"type":"text","text":"remotely via VNC if you need to make changes:"}],"type":"paragraph"},{"code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"syntax":"bash","type":"codeListing"},{"anchor":"Two-BlueBubbles-Instances","type":"heading","level":2,"text":"Two BlueBubbles Instances"},{"inlineContent":[{"type":"text","text":"Run two iMessage servers on one Mac — one for each Apple ID:"}],"type":"paragraph"},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"syntax":"bash","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","type":"heading","level":2,"text":"Comparison: Spooktacular vs VMware-on-Windows"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true},{"type":"text","text":" "},{"type":"text","text":"requires 20+ steps including BIOS configuration, Python\/QEMU"},{"type":"text","text":" "},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware on Windows","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Spooktacular","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Steps to working VM","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"20+ manual steps","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1 command","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS installation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"OpenCore + Recovery","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Apple’s official IPSW","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Hardware","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Any x86 PC","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Apple Silicon Mac","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Apple EULA","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Compliant","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iMessage activation"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Requires fake serial numbers","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Performance","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Emulated, slow","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Metal via VZ framework"}]}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Manual patching per update","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Snapshots","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"type":"text","text":" (APFS)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"24\/7 headless","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Complex configuration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start --headless"}]}]]],"type":"table","header":"row"},{"anchor":"iCloud-and-iMessage-in-VMs","type":"heading","level":2,"text":"iCloud and iMessage in VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"type":"text","text":" "},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"type":"text","text":" "},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"iCloud support requires macOS 15+ on both the host and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"text":" ","type":"text"},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"text":".","type":"text"}],"type":"paragraph"}]},{"anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"configuration:"}]},{"syntax":"bash","type":"codeListing","code":["spook create bluebubbles --network nat   # default, works out of the box"]},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"]},{"anchor":"Monitoring","type":"heading","text":"Monitoring","level":2},{"syntax":"bash","type":"codeListing","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"]}]}],"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","generated":true}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"kind":"article","variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","title":"Running BlueBubbles iMessage Server"},"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"],"anchor":"Related"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","kind":"article","role":"collectionGroup","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"},"https://docs.bluebubbles.app/server/advanced/macos-vir