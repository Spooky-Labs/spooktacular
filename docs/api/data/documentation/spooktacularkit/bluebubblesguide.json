:[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"url":"\/documentation\/spooktacularkit\/clireference","kind":"article","title":"Using the spook Command-Line Interface","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"role":"collectionGroup","kind":"article","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","role":"collectionGroup","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}]},"doc://SpooktacularKit/documenta