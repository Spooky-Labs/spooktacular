ing Started with Spooktacular","role":"collectionGroup","type":"topic"},"https://bluebubbles.app":{"identifier":"https:\/\/bluebubbles.app","title":"BlueBubbles","type":"link","titleInlineContent":[{"type":"text","text":"BlueBubbles"}],"url":"https:\/\/bluebubbles.app"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","role":"collection","type":"topic"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","title":"BlueBubbles VMware guide","type":"link","titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"kind":"article","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"url":"\/documentation\/spooktacularkit\/versioning","title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"kind":"article","type":"topic","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"