de","kind":"identifier"}],"navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","title":"ProvisioningMode","type":"topic"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","titleInlineContent":[{"type":"text","text":"BlueBubbles VMware guide"}],"type":"link","title":"BlueBubbles VMware guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"kind":"article","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","kind":"article","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","role":"collectionGroup","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"kind":"article","title":"Machine Learning Workloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","type":"topic"},"http