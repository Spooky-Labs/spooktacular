d-with-macos-virtual-machines":{"type":"link","title":"Using iCloud with macOS virtual machines","url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","titleInlineContent":[{"type":"text","text":"Using iCloud with macOS virtual machines"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","url":"\/documentation\/spooktacularkit\/openclawguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","kind":"article","role":"collectionGroup","title":"Machine Learning Workloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","title":"Using the spook Command-Line Interface","url":"\/documentation\/spooktacularkit\/clireference","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","kind":"article","role":"collectionGroup","title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spoo