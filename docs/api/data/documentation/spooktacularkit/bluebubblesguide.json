{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"seeAlsoSections":[{"generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides"}],"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"]}],"metadata":{"role":"collectionGroup","title":"Running BlueBubbles iMessage Server","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection"},"sections":[],"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"],"anchor":"Related"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"type":"text","text":" is an open-source app that brings"},{"text":" ","type":"text"},{"text":"iMessage to Android, Windows, and Linux. It requires a macOS server running","type":"text"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"text":"image conversion, Auto-Unlocker patches, and manual VMX editing","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true,"type":"reference"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Spooktacular eliminates all of that."}],"type":"strong"},{"text":" On an Apple Silicon Mac, you run","type":"text"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}]},{"type":"heading","level":3,"text":"Why a VM instead of bare metal?","anchor":"Why-a-VM-instead-of-bare-metal"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Dedicated environment"}],"type":"strong"},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Two servers"}]},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}]}]}]},{"text":"Quick Start","type":"heading","anchor":"Quick-Start","level":2},{"text":"1. Create a VM","anchor":"1-Create-a-VM","type":"heading","level":3},{"syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}]},{"text":"2. The setup script","anchor":"2-The-setup-script","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"level":3,"type":"heading","anchor":"3-Start-and-configure","text":"3. Start and configure"},{"type":"codeListing","code":["spook start bluebubbles"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}],"type":"strong"},{"text":" — required for iMessage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Messages.app"}]},{"type":"text","text":" — verify iMessage activates"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Launch BlueBubbles Server","type":"text"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"type":"text","text":" — System Settings → Privacy &"},{"type":"text","text":" "},{"type":"text","text":"Security → Full Disk Access → add BlueBubbles"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":3,"anchor":"4-Run-headless-247","text":"4. Run headless 24\/7","type":"heading"},{"inlineContent":[{"type":"text","text":"Once configured, restart headless:"}],"type":"paragraph"},{"syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"],"type":"codeListing"},{"inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"]},{"anchor":"Two-BlueBubbles-Instances","type":"heading","level":2,"text":"Two BlueBubbles Instances"},{"type":"paragraph","inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}]},{"type":"codeListing","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"syntax":"bash"},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}],"type":"paragraph"}]},{"type":"heading","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","text":"Comparison: Spooktacular vs VMware-on-Windows","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"type":"text","text":" "},{"text":"by Apple, may violate the EULA).","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware on Windows","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Spooktacular"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Steps to working VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"20+ manual steps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 command","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS installation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple’s official IPSW","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Apple EULA","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iMessage activation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Requires fake serial numbers","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Works natively","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Performance","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Emulated, slow","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"GPU acceleration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Manual patching per update"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VMware snapshots"}],"type":"paragraph"}],[{"inlineContent":[{"code":"spook snapshot","type":"codeVoice"},{"text":" (APFS)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"24\/7 headless"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Complex configuration","type":"text"}]}],[{"inlineContent":[{"type":"codeVoice","code":"spook start --headless"}],"type":"paragraph"}]]]},{"anchor":"iCloud-and-iMessage-in-VMs","type":"heading","text":"iCloud and iMessage in VMs","level":2},{"inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"text":" ","type":"text"},{"type":"text","text":"inside macOS VMs created with the Virtualization framework. This"},{"type":"text","text":" "},{"type":"text","text":"means iMessage activation works natively — no fake serial numbers"},{"type":"text","text":" "},{"type":"text","text":"or Clover Configurator needed."}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"text":"activation in VMs. See Apple’s documentation:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"level":2,"type":"heading","anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles"},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For advanced setups where other devices on your LAN need to reach"},{"type":"text","text":" "},{"type":"text","text":"the BlueBubbles server directly:"}]},{"syntax":"bash","type":"codeListing","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"]},{"anchor":"Monitoring","type":"heading","text":"Monitoring","level":2},{"code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing","syntax":"bash"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"url":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","kind":"article","title":"Kubernetes Integration","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Sched