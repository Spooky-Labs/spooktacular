{"kind":"article","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Related","title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"]}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","title":"Guides","generated":true}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/bluebubbles.app","isActive":true},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}]},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}]},{"type":"heading","anchor":"Why-a-VM-instead-of-bare-metal","level":3,"text":"Why a VM instead of bare metal?"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"type":"text","text":" — BlueBubbles needs Full Disk Access to read iMessage’s"},{"type":"text","text":" "},{"type":"text","text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updates, roll back if something breaks."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use your Mac normally."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Two servers"}]},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}]},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"level":3,"text":"1. Create a VM","anchor":"1-Create-a-VM","type":"heading"},{"syntax":"bash","type":"codeListing","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"]},{"inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}],"type":"paragraph"},{"level":3,"text":"2. The setup script","type":"heading","anchor":"2-The-setup-script"},{"type":"paragraph","inlineContent":[{"text":"Create ","type":"text"},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"text":":","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"anchor":"3-Start-and-configure","text":"3. Start and configure","type":"heading","level":3},{"type":"codeListing","syntax":"bash","code":["spook start bluebubbles"]},{"type":"paragraph","inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sign in to your Apple ID","type":"text"}]},{"type":"text","text":" — required for iMessage"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Messages.app"}]},{"type":"text","text":" — verify iMessage activates"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}]},{"type":"text","text":" — configure your connection"},{"text":" ","type":"text"},{"type":"text","text":"(Firebase, Cloudflare tunnel, or Tailscale)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Grant Full Disk Access","type":"text"}]},{"text":" — System Settings → Privacy &","type":"text"},{"type":"text","text":" "},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}]}]}]},{"level":3,"text":"4. Run headless 24\/7","anchor":"4-Run-headless-247","type":"heading"},{"inlineContent":[{"text":"Once configured, restart headless:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook stop bluebubbles","spook start bluebubbles --headless"]},{"type":"paragraph","inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}]},{"syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"type":"codeListing"},{"level":2,"text":"Two BlueBubbles Instances","anchor":"Two-BlueBubbles-Instances","type":"heading"},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing"},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","text":"Comparison: Spooktacular vs VMware-on-Windows","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"type":"text","text":" "},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"type":"text","text":" "},{"type":"text","text":"by Apple, may violate the EULA)."}]},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"text":"VMware on Windows","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Spooktacular","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Steps to working VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"20+ manual steps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 command"}]}]],[[{"inlineContent":[{"type":"text","text":"macOS installation"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenCore + Recovery"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s official IPSW"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple EULA"}]}],[{"inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Compliant"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"inlineContent":[{"type":"text","text":"Requires fake serial numbers"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Works natively","type":"text"}]}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"None","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Manual patching per update","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"spook create --from-ipsw latest","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Snapshots","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"VMware snapshots","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"text":" (APFS)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"24\/7 headless","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex configuration"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start --headless"}]}]]],"header":"row","type":"table"},{"anchor":"iCloud-and-iMessage-in-VMs","text":"iCloud and iMessage in VMs","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"type":"text","text":" "},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"text":"the guest. Earlier macOS versions may have issues with iMessage","type":"text"},{"text":" ","type":"text"},{"text":"activation in VMs. See Apple’s documentation:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","name":"Note"},{"anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare."},{"type":"text","text":" "},{"type":"text","text":"NAT networking (the default) provides this without any additional"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"]},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"]},{"type":"heading","anchor":"Monitoring","level":2,"text":"Monitoring"},{"type":"codeListing","syntax":"bash","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"]}]}],"metadata":{"title":"Running BlueBubbles iMessage Server","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawG