arKit/documentation/SpooktacularKit/ProvisioningMode":{"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"type":"topic","url":"\/documentation\/spooktacularkit\/provisioningmode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"title":"ProvisioningMode","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"}}}