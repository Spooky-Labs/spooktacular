es from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"kind":"article","type":"topic","role":"collectionGroup","title":"Deploying on EC2 Mac","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"kind":"article","role":"collectionGroup","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic","title":"Versioning & Release Schedule","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"kind":"article","type":"topic","role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","url":"\/documentation\/spooktacularkit\/openclawguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","type":"topic","title":"ProvisioningMode","url":"\/documentation\/spooktacularkit\/provisioningmode","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"kind":"article","type":"topic","role":"collectionGroup","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"kind":"article","type":"topic","title":"Remote Desktop Access","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop"}}}