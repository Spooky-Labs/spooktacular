":[{"type":"text","text":"Apple’s official IPSW"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hardware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any x86 PC"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple EULA"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Compliant"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works natively"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Performance"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Emulated, slow"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GPU acceleration"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Metal via VZ framework"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maintenance"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual patching per update"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"type":"text","text":" (APFS)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"24\/7 headless"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex configuration"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start --headless"}]}]]],"header":"row"},{"level":2,"type":"heading","anchor":"iCloud-and-iMessage-in-VMs","text":"iCloud and iMessage in VMs"},{"type":"paragraph","inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"type":"text","text":"."}]}],"type":"aside","style":"note","name":"Note"},{"level":2,"type":"heading","anchor":"Networking-for-BlueBubbles","text":"Networking for BlueBubbles"},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"type":"codeListing","code":["spook create bluebubbles --network nat   # default, works out of the box"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the