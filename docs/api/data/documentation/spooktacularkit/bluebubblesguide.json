ord"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"type":"topic","url":"\/documentation\/spooktacularkit\/networkmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic"}}}