moteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"role":"collectionGroup","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","type":"topic"},"https://bluebubbles.app":{"title":"BlueBubbles","url":"https:\/\/bluebubbles.app","type":"link","identifier":"https:\/\/bluebubbles.app","titleInlineContent":[{"text":"BlueBubbles","type":"text"}]},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"title":"Using iCloud with macOS virtual machines","url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"link","identifier":"https:\/\/de