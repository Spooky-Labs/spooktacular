{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"roleHeading":"API Collection","title":"Running BlueBubbles iMessage Server","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides","anchor":"Guides"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"],"title":"Related"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/bluebubbles.app"},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"text":" ","type":"text"},{"text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac","type":"text"},{"text":" ","type":"text"},{"text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"text":"(","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}],"type":"strong"},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"text":" ","type":"text"},{"text":"one command and get an isolated macOS VM ready for BlueBubbles — using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s official Virtualization framework, no Hackintosh tools required.","type":"text"}],"type":"paragraph"},{"text":"Why a VM instead of bare metal?","anchor":"Why-a-VM-instead-of-bare-metal","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Two servers"}]},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Quick Start","anchor":"Quick-Start","type":"heading","level":2},{"text":"1. Create a VM","anchor":"1-Create-a-VM","type":"heading","level":3},{"code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty.","type":"text"}],"type":"paragraph"},{"text":"2. The setup script","anchor":"2-The-setup-script","type":"heading","level":3},{"inlineContent":[{"text":"Create ","type":"text"},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"syntax":"bash","type":"codeListing"},{"text":"3. Start and configure","anchor":"3-Start-and-configure","type":"heading","level":3},{"code":["spook start bluebubbles"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"The VM opens with a display window. Complete these one-time steps:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}]},{"text":" — required for iMessage","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Messages.app"}]},{"text":" — verify iMessage activates","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}]},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Grant Full Disk Access"}]},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"4. Run headless 24\/7","anchor":"4-Run-headless-247","type":"heading","level":3},{"inlineContent":[{"text":"Once configured, restart headless:","type":"text"}],"type":"paragraph"},{"code":["spook stop bluebubbles","spook start bluebubbles --headless"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"The BlueBubbles server runs in the background. Access it","type":"text"},{"text":" ","type":"text"},{"text":"remotely via VNC if you need to make changes:","type":"text"}],"type":"paragraph"},{"code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"syntax":"bash","type":"codeListing"},{"text":"Two BlueBubbles Instances","anchor":"Two-BlueBubbles-Instances","type":"heading","level":2},{"inlineContent":[{"text":"Run two iMessage servers on one Mac — one for each Apple ID:","type":"text"}],"type":"paragraph"},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"syntax":"bash","type":"codeListing"},{"style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}],"type":"paragraph"}],"type":"aside"},{"text":"Comparison: Spooktacular vs VMware-on-Windows","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","type":"heading","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","type":"reference"},{"text":" ","type":"text"},{"text":"requires 20+ steps including BIOS configuration, Python\/QEMU","type":"text"},{"text":" ","type":"text"},{"text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,","type":"text"},{"text":" ","type":"text"},{"text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator","type":"text"},{"text":" ","type":"text"},{"text":"for iServices. It runs macOS on non-Apple hardware (unsupported","type":"text"},{"text":" ","type":"text"},{"text":"by Apple, may violate the EULA).","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VMware on Windows"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Spooktacular"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Steps to working VM"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"20+ manual steps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1 command"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS installation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"OpenCore + Recovery"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Apple’s official IPSW"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Hardware"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Any x86 PC"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Apple EULA"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Compliant"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iMessage activation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Requires fake serial numbers"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Performance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"None"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Maintenance"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Manual patching per update","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"VMware snapshots","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"text":" (APFS)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"24\/7 headless","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Complex configuration","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"spook start --headless"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"iCloud and iMessage in VMs","anchor":"iCloud-and-iMessage-in-VMs","type":"heading","level":2},{"inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"iCloud support requires macOS 15+ on both the host and","type":"text"},{"text":" ","type":"text"},{"text":"the guest. Earlier macOS versions may have issues with iMessage","type":"text"},{"text":" ","type":"text"},{"text":"activation in VMs. See Apple’s documentation:","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}],"type":"aside"},{"text":"Networking for BlueBubbles","anchor":"Networking-for-BlueBubbles","type":"heading","level":2},{"inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}],"type":"paragraph"},{"code":["spook create bluebubbles --network nat   # default, works out of the box"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}],"type":"paragraph"},{"code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"syntax":"bash","type":"codeListing"},{"text":"Monitoring","anchor":"Monitoring","type":"heading","level":2},{"code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"syntax":"bash","type":"codeListing"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode","title":"ProvisioningMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/versioning","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/gettingstarted","title":"Getting Started with Spooktacular"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","type":"topic","role":"collection","url":"\/documentation\/spooktacularkit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm":{"type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","title":"BlueBubbles VMware guide","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}]},"https://bluebubbles.app":{"type":"link","identifier":"https:\/\/bluebubbles.app","url":"https:\/\/bluebubbles.app","title":"BlueBubbles","titleInlineContent":[{"text":"BlueBubbles","type":"text"}]},"https://developer.apple.com/documentation/virtualization/using-icloud-with-macos-virtual-machines":{"type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","url":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","title":"Using iCloud with macOS virtual machines","titleInlineContent":[{"text":"Using iCloud with macOS virtual machines","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","title":"NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/ec2macdeployment","title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"role":"collectionGroup","title":"Kubernetes Integration","kind":"article","url":"\/documentation\/spooktacularkit\/kubernetesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/openclawguide","title":"Running OpenClaw in Virtual Machines"},"https://docs.bluebubbles.app/server/advanced/macos-virtualization/running-a-macos-vm/deploying-macos-in-vmware-on-windows-full-guide":{"type":"link","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","url":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","title":"BlueBubbles VMware guide","titleInlineContent":[{"text":"BlueBubbles VMware guide","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface"}}}