arKit/CLIReference":{"abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","kind":"article"}}}