{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"reference","identifier":"https:\/\/bluebubbles.app","isActive":true},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Spooktacular eliminates all of that."}],"type":"strong"},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}],"type":"paragraph"},{"text":"Why a VM instead of bare metal?","anchor":"Why-a-VM-instead-of-bare-metal","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Isolation"}],"type":"strong"},{"text":" — BlueBubbles needs Full Disk Access to read iMessage’s","type":"text"},{"text":" ","type":"text"},{"text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"strong"},{"text":" — save a working iMessage configuration before macOS","type":"text"},{"text":" ","type":"text"},{"text":"updates, roll back if something breaks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Dedicated environment"}],"type":"strong"},{"text":" — the VM can run 24\/7 headless while you","type":"text"},{"text":" ","type":"text"},{"text":"use your Mac normally.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Two servers"}],"type":"strong"},{"text":" — run two BlueBubbles instances (e.g., personal +","type":"text"},{"text":" ","type":"text"},{"text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support.","type":"text"}]}]}]},{"text":"Quick Start","anchor":"Quick-Start","type":"heading","level":2},{"text":"1. Create a VM","anchor":"1-Create-a-VM","type":"heading","level":3},{"syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}],"type":"paragraph"},{"text":"2. The setup script","anchor":"2-The-setup-script","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Create "},{"code":"setup-bluebubbles.sh","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""],"type":"codeListing"},{"text":"3. Start and configure","anchor":"3-Start-and-configure","type":"heading","level":3},{"syntax":"bash","code":["spook start bluebubbles"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}],"type":"strong"},{"text":" — required for iMessage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Open Messages.app"}],"type":"strong"},{"text":" — verify iMessage activates","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}],"type":"strong"},{"text":" — configure your connection","type":"text"},{"text":" ","type":"text"},{"text":"(Firebase, Cloudflare tunnel, or Tailscale)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Grant Full Disk Access"}],"type":"strong"},{"text":" — System Settings → Privacy &","type":"text"},{"text":" ","type":"text"},{"text":"Security → Full Disk Access → add BlueBubbles","type":"text"}]}]}]},{"text":"4. Run headless 24\/7","anchor":"4-Run-headless-247","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Once configured, restart headless:"}],"type":"paragraph"},{"syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The BlueBubbles server runs in the background. Access it"},{"type":"text","text":" "},{"type":"text","text":"remotely via VNC if you need to make changes:"}],"type":"paragraph"},{"syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"],"type":"codeListing"},{"text":"Two BlueBubbles Instances","anchor":"Two-BlueBubbles-Instances","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Run two iMessage servers on one Mac — one for each Apple ID:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Each VM gets a unique ","type":"text"},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"iMessage activation is per-machine-identifier. Cloning creates","type":"text"},{"text":" ","type":"text"},{"text":"a new identity, so you must re-activate iMessage on the clone.","type":"text"}]}]},{"text":"Comparison: Spooktacular vs VMware-on-Windows","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true},{"type":"text","text":" "},{"type":"text","text":"requires 20+ steps including BIOS configuration, Python\/QEMU"},{"type":"text","text":" "},{"type":"text","text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"type":"text","text":" "},{"type":"text","text":"by Apple, may violate the EULA)."}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[{"text":"VMware on Windows","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Spooktacular","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Steps to working VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"20+ manual steps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 command","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS installation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"OpenCore + Recovery","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple’s official IPSW","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Hardware","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Any x86 PC","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Apple EULA","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Violates (non-Apple HW)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"iMessage activation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Requires fake serial numbers"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Works natively"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Performance"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Emulated, slow"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"GPU acceleration"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"None"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Metal via VZ framework"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maintenance"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual patching per update"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"type":"text","text":" (APFS)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"24\/7 headless"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex configuration"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start --headless"}]}]]],"type":"table","header":"row"},{"text":"iCloud and iMessage in VMs","anchor":"iCloud-and-iMessage-in-VMs","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in"},{"type":"text","text":" "},{"type":"text","text":"inside macOS VMs created with the Virtualization framework. This"},{"type":"text","text":" "},{"type":"text","text":"means iMessage activation works natively — no fake serial numbers"},{"type":"text","text":" "},{"type":"text","text":"or Clover Configurator needed."}],"type":"paragraph"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines"},{"type":"text","text":"."}]}]},{"text":"Networking for BlueBubbles","anchor":"Networking-for-BlueBubbles","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare."},{"type":"text","text":" "},{"type":"text","text":"NAT networking (the default) provides this without any additional"},{"type":"text","text":" "},{"type":"text","text":"configuration:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network nat   # default, works out of the box"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For advanced setups where other devices on your LAN need to reach"},{"type":"text","text":" "},{"type":"text","text":"the BlueBubbles server directly:"}],"type":"paragraph"},{"syntax":"bash","code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing"},{"text":"Monitoring","anchor":"Monitoring","type":"heading","level":2},{"type":"codeListing","code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"syntax":"bash"}]}],"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"]}],"seeAlsoSe