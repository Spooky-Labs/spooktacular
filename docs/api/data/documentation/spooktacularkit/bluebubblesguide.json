{"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","generated":true}],"sections":[],"metadata":{"title":"Running BlueBubbles iMessage Server","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/bluebubbles.app","isActive":true,"type":"reference"},{"type":"text","text":" is an open-source app that brings"},{"type":"text","text":" "},{"type":"text","text":"iMessage to Android, Windows, and Linux. It requires a macOS server running"},{"type":"text","text":" "},{"type":"text","text":"24\/7 to relay messages. Traditionally, users set this up on a dedicated Mac"},{"type":"text","text":" "},{"type":"text","text":"or through a complex VMware-on-Windows process involving OpenCore, QEMU"},{"type":"text","text":" "},{"type":"text","text":"image conversion, Auto-Unlocker patches, and manual VMX editing"},{"type":"text","text":" "},{"type":"text","text":"("},{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm","isActive":true,"type":"reference"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Spooktacular eliminates all of that.","type":"text"}],"type":"strong"},{"type":"text","text":" On an Apple Silicon Mac, you run"},{"type":"text","text":" "},{"type":"text","text":"one command and get an isolated macOS VM ready for BlueBubbles — using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s official Virtualization framework, no Hackintosh tools required."}]},{"type":"heading","level":3,"anchor":"Why-a-VM-instead-of-bare-metal","text":"Why a VM instead of bare metal?"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"type":"text","text":" — BlueBubbles needs Full Disk Access to read iMessage’s"},{"type":"text","text":" "},{"type":"text","text":"chat database. Running it in a VM keeps it sandboxed from your daily Mac."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"type":"text","text":" — save a working iMessage configuration before macOS"},{"type":"text","text":" "},{"type":"text","text":"updates, roll back if something breaks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dedicated environment"}]},{"type":"text","text":" — the VM can run 24\/7 headless while you"},{"type":"text","text":" "},{"type":"text","text":"use your Mac normally."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Two servers"}]},{"type":"text","text":" — run two BlueBubbles instances (e.g., personal +"},{"type":"text","text":" "},{"type":"text","text":"family Apple IDs) on one Mac using Spooktacular’s 2-VM support."}]}]}]},{"type":"heading","level":2,"anchor":"Quick-Start","text":"Quick Start"},{"type":"heading","level":3,"anchor":"1-Create-a-VM","text":"1. Create a VM"},{"type":"codeListing","syntax":"bash","code":["spook create bluebubbles --from-ipsw latest \\","    --cpu 4 --memory 4 --disk 32 \\","    --network nat \\","    --user-data .\/setup-bluebubbles.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"BlueBubbles is lightweight — 4 CPU cores and 4 GB RAM is plenty."}]},{"type":"heading","level":3,"anchor":"2-The-setup-script","text":"2. The setup script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create "},{"type":"codeVoice","code":"setup-bluebubbles.sh"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# setup-bluebubbles.sh — installs BlueBubbles server in a macOS VM","","set -euo pipefail","","# Install Homebrew","\/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","","# Install BlueBubbles server","brew install --cask bluebubbles-server","","# Enable Screen Sharing for remote management","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate -configure -access -on -restart -agent -privs -all","","echo \"BlueBubbles server installed.\"","echo \"Connect via VNC to complete Apple ID sign-in and BlueBubbles setup.\""]},{"type":"heading","level":3,"anchor":"3-Start-and-configure","text":"3. Start and configure"},{"type":"codeListing","syntax":"bash","code":["spook start bluebubbles"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM opens with a display window. Complete these one-time steps:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sign in to your Apple ID"}]},{"type":"text","text":" — required for iMessage"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Messages.app"}]},{"type":"text","text":" — verify iMessage activates"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Launch BlueBubbles Server"}]},{"type":"text","text":" — configure your connection"},{"type":"text","text":" "},{"type":"text","text":"(Firebase, Cloudflare tunnel, or Tailscale)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Grant Full Disk Access"}]},{"type":"text","text":" — System Settings → Privacy &"},{"type":"text","text":" "},{"type":"text","text":"Security → Full Disk Access → add BlueBubbles"}]}]}]},{"type":"heading","level":3,"anchor":"4-Run-headless-247","text":"4. Run headless 24\/7"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once configured, restart headless:"}]},{"type":"codeListing","syntax":"bash","code":["spook stop bluebubbles","spook start bluebubbles --headless"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The BlueBubbles server runs in the background. Access it"},{"type":"text","text":" "},{"type":"text","text":"remotely via VNC if you need to make changes:"}]},{"type":"codeListing","syntax":"bash","code":["spook ip bluebubbles","# Connect via Screen Sharing to the reported IP"]},{"type":"heading","level":2,"anchor":"Two-BlueBubbles-Instances","text":"Two BlueBubbles Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Run two iMessage servers on one Mac — one for each Apple ID:"}]},{"code":["spook create bb-personal --from-ipsw latest --cpu 4 --memory 4","spook create bb-family --from-ipsw latest --cpu 4 --memory 4","","# Or clone from a configured base:","spook create bb-personal --from-ipsw latest --user-data .\/setup-bluebubbles.sh","# Configure Apple ID #1...","spook stop bb-personal","","spook clone bb-personal bb-family","# Start bb-family and sign in with Apple ID #2","spook start bb-family","# Configure Apple ID #2...","","# Run both headless","spook start bb-personal --headless","spook start bb-family --headless"],"type":"codeListing","syntax":"bash"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"Each VM gets a unique "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"iMessage activation is per-machine-identifier. Cloning creates"},{"type":"text","text":" "},{"type":"text","text":"a new identity, so you must re-activate iMessage on the clone."}],"type":"paragraph"}],"type":"aside","style":"important"},{"level":2,"text":"Comparison: Spooktacular vs VMware-on-Windows","type":"heading","anchor":"Comparison-Spooktacular-vs-VMware-on-Windows"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"https:\/\/docs.bluebubbles.app\/server\/advanced\/macos-virtualization\/running-a-macos-vm\/deploying-macos-in-vmware-on-windows-full-guide","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"requires 20+ steps including BIOS configuration, Python\/QEMU"},{"type":"text","text":" "},{"type":"text","text":"installation, OpenCore recovery download, DMG-to-VMDK conversion,"},{"type":"text","text":" "},{"type":"text","text":"Auto-Unlocker patching, VMX file editing, and Clover Configurator"},{"type":"text","text":" "},{"type":"text","text":"for iServices. It runs macOS on non-Apple hardware (unsupported"},{"type":"text","text":" "},{"type":"text","text":"by Apple, may violate the EULA)."}]},{"type":"table","rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VMware on Windows"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Spooktacular"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Steps to working VM"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"20+ manual steps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1 command"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS installation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"OpenCore + Recovery"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Apple’s official IPSW"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Hardware"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Any x86 PC"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Apple EULA"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Violates (non-Apple HW)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Compliant","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iMessage activation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires fake serial numbers"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works natively"}]}]],[[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Emulated, slow"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Near-native (VirtIO)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GPU acceleration"}]}],[{"inlineContent":[{"text":"None","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Metal via VZ framework"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Maintenance","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual patching per update"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook create --from-ipsw latest"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VMware snapshots"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook snapshot"},{"text":" (APFS)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"24\/7 headless"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex configuration"}]}],[{"type":"paragraph","inlineContent":[{"code":"spook start --headless","type":"codeVoice"}]}]]],"header":"row"},{"level":2,"text":"iCloud and iMessage in VMs","type":"heading","anchor":"iCloud-and-iMessage-in-VMs"},{"type":"paragraph","inlineContent":[{"text":"As of macOS 15 (Sequoia), Apple officially supports iCloud sign-in","type":"text"},{"text":" ","type":"text"},{"text":"inside macOS VMs created with the Virtualization framework. This","type":"text"},{"text":" ","type":"text"},{"text":"means iMessage activation works natively — no fake serial numbers","type":"text"},{"text":" ","type":"text"},{"text":"or Clover Configurator needed.","type":"text"}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iCloud support requires macOS 15+ on both the host and"},{"type":"text","text":" "},{"type":"text","text":"the guest. Earlier macOS versions may have issues with iMessage"},{"type":"text","text":" "},{"type":"text","text":"activation in VMs. See Apple’s documentation:"},{"type":"text","text":" "},{"identifier":"https:\/\/developer.apple.com\/documentation\/virtualization\/using-icloud-with-macos-virtual-machines","type":"reference","isActive":true},{"type":"text","text":"."}]}],"type":"aside","style":"note"},{"level":2,"text":"Networking for BlueBubbles","type":"heading","anchor":"Networking-for-BlueBubbles"},{"type":"paragraph","inlineContent":[{"text":"BlueBubbles needs outbound internet access to reach Firebase\/Cloudflare.","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking (the default) provides this without any additional","type":"text"},{"text":" ","type":"text"},{"text":"configuration:","type":"text"}]},{"code":["spook create bluebubbles --network nat   # default, works out of the box"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"For advanced setups where other devices on your LAN need to reach","type":"text"},{"text":" ","type":"text"},{"text":"the BlueBubbles server directly:","type":"text"}]},{"code":["spook create bluebubbles --network bridged:en0  # own IP on LAN"],"type":"codeListing","syntax":"bash"},{"level":2,"text":"Monitoring","type":"heading","anchor":"Monitoring"},{"code":["# Check VM status","spook list","","# Get the VM's IP (for VNC access)","spook ip bluebubbles","","# View configuration","spook get bluebubbles"],"type":"codeListing","syntax":"bash"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","interfaceLanguage":"swift"},"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"],"anchor":"Related"}],"kind":"article","variants":[{"paths":["\/documentation\/spooktacularkit\/bluebubblesguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"type":"topic","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","title":"ProvisioningMode","kind":"symbol","role":"symbol","url":"\/documenta