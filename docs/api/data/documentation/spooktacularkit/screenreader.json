{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ScreenReader"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScreenReader"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP","text":"Sendable"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"Implement this protocol to provide screen capture and OCR"},{"type":"text","text":" "},{"type":"text","text":"for screen-aware Setup Assistant automation. The screen reader"},{"type":"text","text":" "},{"type":"text","text":"enables the automation executor to wait for specific text to"},{"type":"text","text":" "},{"type":"text","text":"appear on the VM display before proceeding, replacing fixed"},{"type":"text","text":" "},{"type":"text","text":"timing delays with deterministic screen state checks."}],"type":"paragraph"},{"text":"Design","type":"heading","level":2,"anchor":"Design"},{"inlineContent":[{"type":"text","text":"This follows the approach used by"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/cirruslabs\/tart","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which uses Apple’s Vision framework to recognize text on the"},{"type":"text","text":" "},{"type":"text","text":"VM screen and drive Setup Assistant navigation based on what"},{"type":"text","text":" "},{"type":"text","text":"is actually visible rather than elapsed time."}],"type":"paragraph"},{"text":"Architecture","type":"heading","level":2,"anchor":"Architecture"},{"inlineContent":[{"