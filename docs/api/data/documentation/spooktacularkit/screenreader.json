{"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Reads text from a virtual machine’s display."}],"topicSections":[{"title":"Instance Methods","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ScreenReader\/recognizeText()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ScreenReader\/waitForText(_:timeout:)"],"anchor":"Instance-Methods"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ScreenReader","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"kind":"relationships"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ScreenReader","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s8SendableP","text":"Sendable","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this protocol to provide screen capture and OCR"},{"type":"text","text":" "},{"type":"text","text":"for screen-aware Setup Assistant automation. The screen reader"},{"type":"text","text":" "},{"type":"text","text":"enables the automation executor to wait for specific text to"},{"type":"text","text":" "},{"type":"text","text":"appear on the VM display before proceeding, replacing fixed"},{"type":"text","text":" "},{"type":"text","text":"timing delays with deterministic screen state checks."}]},{"type":"heading","text":"Design","level":2,"anchor":"Design"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This follows the approach us