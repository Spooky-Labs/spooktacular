{"kind":"symbol","abstract":[{"type":"text","text":"Reads text from a virtual machine’s display."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScreenReader"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP","text":"Sendable"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this protocol to provide screen capture and OCR"},{"type":"text","text":" "},{"type":"text","text":"for screen-aware Setup Assistant automation. The screen reader"},{"type":"text","text":" "},{"type":"text","text":"enables the automation executor to wait for specific text to"},{"type":"text","text":" "},{"type":"text","text":"appear on the VM display before proceeding, replacing fixed"},{"type":"text","text":" "},{"type":"text","text":"timing delays with deterministic screen state checks."}]},{"type":"heading","level":2,"text":"Design","anchor":"Design"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This follows the approach used by"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which uses Apple’s Vision framework to recognize text on the"},{"type":"text","text":" "},{"type":"text","text":"VM screen and drive Setup Assistant navigation based on what"},{"type":"text","text":" "},{"type":"text","text":"is actually visible rather than elapsed time."}]},{"type":"heading","level":2,"text":"Architecture","anchor":"Architecture"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The protocol lives in SpooktacularKit (no AppKit or Vision"},{"type":"text","text":" "},{"type":"text","text":"imports) so it can be referenced fro