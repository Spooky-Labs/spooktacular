{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Executes the script over SSH after the VM boots."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssh","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular waits for the VM to boot, resolves its IP","type":"text"},{"text":" ","type":"text"},{"text":"address, connects via SSH, and runs your script remotely.","type":"text"},{"text":" ","type":"text"},{"text":"This is the most flexible mode — you get real-time output","type":"text"},{"text":" ","type":"text"},{"text":"streaming and an interactive connection.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Best for:","type":"text"}],"type":"strong"},{"text":" Cloned VMs where the base image has SSH","type":"text"},{"text":" ","type":"text"},{"text":"(Remote Login) enabled. Development workflows where you","type":"text"},{"text":" ","type":"text"},{"text":"want to see output as it runs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Requires:","type":"text"}],"type":"strong"},{"text":" Remote Login (SSH) enabled in the guest.","type":"text"},{"text":" ","type":"text"},{"text":"The base image must have an SSH user and either password","type":"text"},{"text":" ","type":"text"},{"text":"or key-based authentication configured.","type":"text"}]}]}],"seeAlsoSections":[{"title":"Provisioning Modes","anchor":"Provisioning-Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInj