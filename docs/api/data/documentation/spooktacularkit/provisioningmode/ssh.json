{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssh","kind":"identifier"}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Spooktacular waits for the VM to boot, resolves its IP"},{"type":"text","text":" "},{"type":"text","text":"address, connects via SSH, and runs your script remotely."},{"type":"text","text":" "},{"type":"text","text":"This is the most flexible mode — you get real-time output"},{"type":"text","text":" "},{"type":"text","text":"streaming and an interactive connection."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Best for:"}],"type":"strong"},{"type":"text","text":" Cloned VMs where the base image has SSH"},{"type":"text","text":" "},{"type":"text","text":"(Remote Login) enabled. Development workflows where you"},{"type":"text","text":" "},{"type":"text","text":"want to see output as it runs."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"type":"text","text":" Remote Login (SSH) enabled in the guest."},{"type":"text","text":" "},{"type":"text","text":"The base image must have an SSH user and either password"},{"type":"text","text":" "},{"type":"text","text":"or key-based authentication configured."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/spooktacularkit\/provisioningmode\/ssh"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadat