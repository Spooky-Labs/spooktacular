{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","abstract":[{"text":"Executes the script over SSH after the VM boots.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ssh","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"Spooktacular waits for the VM to boot, resolves its IP","type":"text"},{"text":" ","type":"text"},{"text":"address, connects via SSH, and runs your script remotely.","type":"text"},{"text":" ","type":"text"},{"text":"This is the most flexible mode — you get real-time output","type":"text"},{"text":" ","type":"text"},{"text":"streaming and an interactive connection.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Best for:"}],"type":"strong"},{"text":" Cloned VMs where the base image has SSH","type":"text"},{"text":" ","type":"text"},{"text":"(Remote Login) enabled. Development workflows where you","type":"text"},{"text":" ","type":"text"},{"text":"want to see output as it runs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"text":" Remote Login (SSH) enabled in the guest.","type":"text"},{"text":" ","type":"text"},{"text":"The base image must have an SSH user and either password","type":"text"},{"text":" ","type":"text"},{"text":"or key-based authentication configured.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]]},"variants":[{"traits":[{"interfaceLanguage":"