{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"agent"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Spooktacular guest agent runs inside the VM and"},{"type":"text","text":" "},{"type":"text","text":"communicates with the host over a VirtIO socket (vsock) —"},{"text":" ","type":"text"},{"text":"a direct channel that works without networking. The host","type":"text"},{"text":" ","type":"text"},{"text":"pushes the script to the agent, which executes it and","type":"text"},{"text":" ","type":"text"},{"text":"streams output back.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Best for:"}]},{"type":"text","text":" VMs created from Spooktacular’s official OCI"},{"type":"text","text":" "},{"type":"text","text":"images, which include the agent pre-installed. Fastest"},{"type":"text","text":" "},{"type":"text","text":"provisioning, works with isolated (no-network) VMs."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" The Spooktacular guest agent installed in"},{"type":"text","text":" "},{"type":"text","text":"the VM. Included in all "},{"type":"codeVoice","code":"ghcr.io\/spooktacular\/"},{"type":"text","text":" images."}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Uses a pre-installed guest agent communicating over VirtIO socket."}]