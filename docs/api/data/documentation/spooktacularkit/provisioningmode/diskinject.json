{"abstract":[{"type":"text","text":"Injects a LaunchDaemon into the VM’s disk before first boot."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"diskInject"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The script runs automatically when macOS starts — no SSH,"},{"type":"text","text":" "},{"type":"text","text":"no agent, no network, and no manual setup required. This is"},{"type":"text","text":" "},{"type":"text","text":"the only provisioning mode that works on a completely vanilla"},{"type":"text","text":" "},{"type":"text","text":"macOS installation from an IPSW."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"How it works:"}],"type":"strong"},{"type":"text","text":" Before the VM boots, Spooktacular mounts"},{"type":"text","text":" "},{"type":"text","text":"the guest’s data volume on the host and writes a standard"},{"type":"text","text":" "},{"type":"text","text":"macOS LaunchDaemon that executes your script at boot time."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Best for:"}],"type":"strong"},{"type":"text","text":" Fresh VMs created from IPSW where you need"},{"type":"text","text":" "},{"type":"text","text":"zero-touch automation — CI runners, test environments,"},{"type":"text","text":" "},{"type":"text","text":"automated fleet provisioning."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"type":"text","text":" Nothing in the guest. Works with any macOS."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/provisioningmode\/diskinject"]}],"seeAlsoSections":[{"anchor":"Provisioning-Modes","title"