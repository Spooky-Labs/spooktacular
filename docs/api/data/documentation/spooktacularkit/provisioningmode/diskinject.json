{"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Injects a LaunchDaemon into the VM’s disk before first boot."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"diskInject"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The script runs automatically when macOS starts — no SSH,","type":"text"},{"text":" ","type":"text"},{"text":"no agent, no network, and no manual setup required. This is","type":"text"},{"text":" ","type":"text"},{"text":"the only provisioning mode that works on a completely vanilla","type":"text"},{"text":" ","type":"text"},{"text":"macOS installation from an IPSW.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"How it works:"}],"type":"strong"},{"text":" Before the VM boots, Spooktacular mounts","type":"text"},{"text":" ","type":"text"},{"text":"the guest’s data volume on the host and writes a standard","type":"text"},{"text":" ","type":"text"},{"text":"macOS LaunchDaemon that executes your script at boot time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Best for:"}],"type":"strong"},{"text":" Fresh VMs created from IPSW where you need","type":"text"},{"text":" ","type":"text"},{"text":"zero-touch automation — CI runners, test environments,","type":"text"},{"text":" ","type":"text"},{"text":"automated fleet provisioning.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"text":" Nothing in the guest. Works with any macOS.","type":"text"}]}]}],"seeAlsoSections":[{"