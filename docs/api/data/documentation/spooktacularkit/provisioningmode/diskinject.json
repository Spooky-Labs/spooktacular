{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The script runs automatically when macOS starts — no SSH,"},{"type":"text","text":" "},{"type":"text","text":"no agent, no network, and no manual setup required. This is"},{"type":"text","text":" "},{"type":"text","text":"the only provisioning mode that works on a completely vanilla"},{"type":"text","text":" "},{"type":"text","text":"macOS installation from an IPSW."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"How it works:"}]},{"type":"text","text":" Before the VM boots, Spooktacular mounts"},{"type":"text","text":" "},{"type":"text","text":"the guest’s data volume on the host and writes a standard"},{"type":"text","text":" "},{"type":"text","text":"macOS LaunchDaemon that executes your script at boot time."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Best for:"}]},{"type":"text","text":" Fresh VMs created from IPSW where you need"},{"type":"text","text":" "},{"type":"text","text":"zero-touch automation — CI runners, test environments,"},{"type":"text","text":" "},{"type":"text","text":"automated fleet provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" Nothing in the guest. Works with any macOS."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","d