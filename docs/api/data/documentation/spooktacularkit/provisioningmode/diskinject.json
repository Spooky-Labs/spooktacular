{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"},"abstract":[{"text":"Injects a LaunchDaemon into the VM’s disk before first boot.","type":"text"}],"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"title":"ProvisioningMode.diskInject","role":"symbol","roleHeading":"Case","symbolKind":"case","externalID":"s:15SpooktacularKit16ProvisioningModeO10diskInjectyA2CmF"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The script runs automatically when macOS starts — no SSH,"},{"type":"text","text":" "},{"type":"text","text":"no agent, no network, and no manual setup required. This is"},{"type":"text","text":" "},{"type":"text","text":"the only provisioning mode that works on a completely vanilla"},{"type":"text","text":" "},{"type":"text","text":"macOS installation from an IPSW."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"How it works:"}]},{"type":"text","text":" Before the VM boots, Spooktacular mounts"},{"type":"text","text":" "},{"type":"text","text":"the guest’s data volume on the host and writes a standard"},{"type":"text","text":" "},{"type":"text","text":"macOS LaunchDaemon that executes your script at boot time."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Best for:"}]},{"type":"text","text":" Fresh VMs created from IPSW where you need"},{"type":"text","text":" "},{"type":"text","text":"zero-touch automation — CI runners, test environments,"},{"type":"text","text":" "},{"type":"text","text":"automated fleet provisioning."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requires:"}]},{"type":"text","text":" Nothing in the guest. Works with any macOS."}]}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]]},"seeAlsoSections":[{"title":"Provisioning Modes","generated":true,"anchor":"Provisioning-Modes","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/ssh","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/agent","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioningmode\/diskinject"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol","url":"\/documentation\/spooktacularkit","role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","title":"VirtualMachineSpecification","abstract":[{"type":"tex