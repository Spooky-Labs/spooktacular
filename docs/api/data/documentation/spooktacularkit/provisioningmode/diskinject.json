":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Best for:"}],"type":"strong"},{"text":" Fresh VMs created from IPSW where you need","type":"text"},{"text":" ","type":"text"},{"text":"zero-touch automation — CI runners, test environments,","type":"text"},{"text":" ","type":"text"},{"text":"automated fleet provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"text":" Nothing in the guest. Works with any macOS.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/spooktacularkit\/provisioningmode\/diskinject"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/diskInject"},"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit16ProvisioningModeO10diskInjectyA2CmF","symbolKind":"case","roleHeading":"Case","role":"symbol","title":"ProvisioningMode.diskInject"},"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode/sharedFolder":{"role":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode\/sharedfolder","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"sharedFolder"}],"kind":"symbol","title":"ProvisioningMode.sharedFolder","abstract":[{"text":"Delivers the script via a VirtIO shared folder.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"role":"collectio