unts"},{"type":"text","text":" "},{"type":"text","text":"the guest’s data volume on the host and writes a standard"},{"type":"text","text":" "},{"type":"text","text":"macOS LaunchDaemon that executes your script at boot time."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Best for:"}]},{"type":"text","text":" Fresh VMs created from IPSW where you need"},{"type":"text","text":" "},{"type":"text","text":"zero-touch automation — CI runners, test environments,"},{"type":"text","text":" "},{"type":"text","text":"automated fleet provisioning."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Requires:"}],"type":"strong"},{"type":"text","text":" Nothing in the guest. Works with any macOS."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/provisioningmode\/diskinject"]}],"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"diskInject","kind":"identifier"}],"role":"symbol","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit16ProvisioningModeO10diskInjectyA2CmF","symbolKind":"case","roleHeading":"Case","title":"ProvisioningMode.diskInject"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode/sharedFolder":{"role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sharedFolder","kind":"identifier"}],"title":"ProvisioningMode.sharedFolder","kind":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode\/sharedfolder","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode\/sharedFolder","abstract":[{"type":"text","text":"Delivers the script via a VirtIO shared folder."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMod