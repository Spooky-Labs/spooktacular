{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookCore"}]},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Virtualization"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookApplication"}]},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}]},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSPasteboard"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSWorkspace"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Security.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Network.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Foundation Models"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Views stay thin: they observe ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" state objects and","type":"text"},{"text":" ","type":"text"},{"text":"call through to these libraries. Keeping logic out of views is","type":"text"},{"text":" ","type":"text"},{"text":"what makes the same codebase ship a CLI, a Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"controller, and an App Store binary from one package.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"article","metadata":{"title":"Building a macOS VM Manager","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"text":"Compose the Spooktacular libraries into a first-class Mac app.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation","anchor":"Related-Documentation"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","kind":"article","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"title":"Getting Started with Spooktacular","identifier":"doc:\/\/SpooktacularKit\/documen