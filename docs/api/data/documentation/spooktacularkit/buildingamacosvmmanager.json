{"metadata":{"title":"Building a macOS VM Manager","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation"}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This article walks through the layered structure of the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular SwiftUI app so you can build something comparable"},{"type":"text","text":" "},{"type":"text","text":"without repeating the architectural decisions we already settled."}]},{"type":"paragraph","inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"SpookCore","type":"codeVoice"}]},{"type":"text","text":" — pure Swift domain types. No AppKit, no"},{"type":"text","text":" "},{"type":"codeVoice","code":"Virtualization"},{"type":"text","text":", no networking. Use it for models, enums,"},{"type":"text","text":" "},{"type":"text","text":"and protocol “ports” that describe what the app needs without"},{"type":"text","text":" "},{"type":"text","text":"committing to a concrete transport."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"SpookApplication","type":"codeVoice"}]},{"type":"text","text":" — use cases and services that combine"},{"type":"text","text":" "},{"type":"text","text":"domain types into workflows (RBAC evaluation, tenant"},{"type":"text","text":" "},{"type":"text","text":"isolation, runner-pool orchestration)."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"co