{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"title":"Building a macOS VM Manager","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"kind":"article","abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"SpookCore","type":"codeVoice"}]},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"SpookApplication","type":"codeVoice"}]},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"SpookInfrastructureApple","type":"codeVoice"}]},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSPasteboard","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSWorkspace","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"Security.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Network.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Views stay thin: they observe ","type":"text"},{"code":"@Observable","type":"codeVoice"},{"text":" state objects and","type":"text"},{"text":" ","type":"text"},{"text":"call through to these libraries. Keeping logic out of views is","type":"text"},{"text":" ","type":"text"},{"text":"what makes the same codebase ship a CLI, a Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"controller, and an App Store binary from one package.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","role":"collection","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article"}}}