{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"kind":"article","abstract":[{"text":"Compose the Spooktacular libraries into a first-class Mac app.","type":"text"}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"anchor":"Related-Documentation","title":"Related Documentation"}],"metadata":{"title":"Building a macOS VM Manager","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager"},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This article walks through the layered structure of the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular SwiftUI app so you can build something comparable"},{"type":"text","text":" "},{"type":"text","text":"without repeating the architectural decisions we already settled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app target depends on three Swift packages in this repo:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookCore"}]},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookApplication"}]},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}]},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSPasteboard","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSWorkspace","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"Security.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Network.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","url":"\/documentation\/spooktacularkit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted"}}}