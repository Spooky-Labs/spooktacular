{"abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookCore"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Virtualization"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookApplication"}],"type":"strong"},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSPasteboard"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSWorkspace"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Security.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Network.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Foundation Models"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Views stay thin: they observe ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" state objects and","type":"text"},{"text":" ","type":"text"},{"text":"call through to these libraries. Keeping logic out of views is","type":"text"},{"text":" ","type":"text"},{"text":"what makes the same codebase ship a CLI, a Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"controller, and an App Store binary from one package.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"anchor":"Related-Documentation","title":"Related Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"article","metadata":{"role":"collectionGroup","title":"Building a macOS VM Manager","modules":[{"name":"SpooktacularKit"}]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","type":"topic","kind":"symbol","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","type":"topic","title":"Getting Started with Spooktacular","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article"}}}