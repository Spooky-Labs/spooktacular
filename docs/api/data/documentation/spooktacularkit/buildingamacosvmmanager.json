{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookCore","type":"codeVoice"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookApplication"}],"type":"strong"},{"type":"text","text":" — use cases and services that combine"},{"type":"text","text":" "},{"type":"text","text":"domain types into workflows (RBAC evaluation, tenant"},{"type":"text","text":" "},{"type":"text","text":"isolation, runner-pool orchestration)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookInfrastructureApple","type":"codeVoice"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSPasteboard","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSWorkspace","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"Security.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Network.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"abstract":[{"text":"Compose the Spooktacular libraries into a first-class Mac app.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation","anchor":"Related-Documentation"}],"sections":[],"kind":"article","metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Building a macOS VM Manager"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","role":"collection","type":"topic","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://SpooktacularKit