{"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookCore"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookApplication"}],"type":"strong"},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSPasteboard","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSWorkspace","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"Security.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Network.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Views stay thin: they observe ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" state objects and","type":"text"},{"text":" ","type":"text"},{"text":"call through to these libraries. Keeping logic out of views is","type":"text"},{"text":" ","type":"text"},{"text":"what makes the same codebase ship a CLI, a Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"controller, and an App Store binary from one package.","type":"text"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager"},"metadata":{"title":"Building a macOS VM Manager","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"kind":"article","abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"seeAlsoSections":[{"anchor":"Related-Documentation","title":"Related Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","kind":"article","abstract":[{"text":"Create your first macOS virtual machine in 