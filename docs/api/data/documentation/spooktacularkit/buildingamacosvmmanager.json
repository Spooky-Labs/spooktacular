{"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation","anchor":"Related-Documentation"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Building a macOS VM Manager"},"abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This article walks through the layered structure of the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular SwiftUI app so you can build something comparable"},{"type":"text","text":" "},{"type":"text","text":"without repeating the architectural decisions we already settled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The app target depends on three Swift packages in this repo:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookCore","type":"codeVoice"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookApplication","type":"codeVoice"}],"type":"strong"},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookInfrastructureApple","type":"codeVoice"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSPasteboard","type":"codeVoice"},{"text":", ","type":"text"},{"code":"NSWorkspace","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"Security.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Network.framework","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager"},"kind":"article","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","kind":"symbol","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","kind":"article"}}}