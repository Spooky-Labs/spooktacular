eVoice","code":"NSPasteboard"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSWorkspace"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"Security.framework"},{"type":"text","text":", "},{"type":"codeVoice","code":"Network.framework"},{"type":"text","text":", "},{"type":"codeVoice","code":"Foundation Models"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Views stay thin: they observe ","type":"text"},{"code":"@Observable","type":"codeVoice"},{"text":" state objects and","type":"text"},{"text":" ","type":"text"},{"text":"call through to these libraries. Keeping logic out of views is","type":"text"},{"text":" ","type":"text"},{"text":"what makes the same codebase ship a CLI, a Kubernetes","type":"text"},{"text":" ","type":"text"},{"text":"controller, and an App Store binary from one package.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"anchor":"Related-Documentation"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"sections":[],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Building a macOS VM Manager"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","role":"collectionGroup","ti