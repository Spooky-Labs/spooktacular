{"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This article walks through the layered structure of the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular SwiftUI app so you can build something comparable"},{"type":"text","text":" "},{"type":"text","text":"without repeating the architectural decisions we already settled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The app target depends on three Swift packages in this repo:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookCore","type":"codeVoice"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Virtualization"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookApplication","type":"codeVoice"}],"type":"strong"},{"text":" — use cases and services that combine","type":"text"},{"text":" ","type":"text"},{"text":"domain types into workflows (RBAC evaluation, tenant","type":"text"},{"text":" ","type":"text"},{"text":"isolation, runner-pool orchestration).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookInfrastructureApple","type":"codeVoice"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSPasteboard"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSWorkspace"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Security.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Network.framework"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Foundation Models"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"variants":[{"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation","anchor":"Related-Documentation"}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Building a macOS VM Manager"},"abstract":[{"type":"text","text":"Compose the Spooktacular libraries into a first-class Mac app."}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"kind":"article","type":"topic","role":"collectionGroup","title":"Getting Started with Spooktacular","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}]}}}