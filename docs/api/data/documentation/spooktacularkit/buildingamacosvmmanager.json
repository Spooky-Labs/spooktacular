{"sections":[],"kind":"article","primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"inlineContent":[{"text":"This article walks through the layered structure of the","type":"text"},{"text":" ","type":"text"},{"text":"Spooktacular SwiftUI app so you can build something comparable","type":"text"},{"text":" ","type":"text"},{"text":"without repeating the architectural decisions we already settled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The app target depends on three Swift packages in this repo:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":"SpookCore","type":"codeVoice"}],"type":"strong"},{"text":" — pure Swift domain types. No AppKit, no","type":"text"},{"text":" ","type":"text"},{"code":"Virtualization","type":"codeVoice"},{"text":", no networking. Use it for models, enums,","type":"text"},{"text":" ","type":"text"},{"text":"and protocol “ports” that describe what the app needs without","type":"text"},{"text":" ","type":"text"},{"text":"committing to a concrete transport.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookApplication"}],"type":"strong"},{"type":"text","text":" — use cases and services that combine"},{"type":"text","text":" "},{"type":"text","text":"domain types into workflows (RBAC evaluation, tenant"},{"type":"text","text":" "},{"type":"text","text":"isolation, runner-pool orchestration)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}],"type":"strong"},{"text":" — Apple-framework adapters.","type":"text"},{"text":" ","type":"text"},{"text":"Wraps ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachine"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSPasteboard"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NSWorkspace"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Security.framework"},{"type":"text","text":", "},{"type":"codeVoice","code":"Network.framework"},{"type":"text","text":", "},{"type":"codeVoice","code":"Foundation Models"},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"abstract":[{"text":"Compose the Spooktacular libraries into a first-class Mac app.","type":"text"}],"metadata":{"role":"collectionGroup","title":"Building a macOS VM Manager","modules":[{"name":"SpooktacularKit"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"title":"Related Documentation"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","title":"SpooktacularKit","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol"},"doc://SpooktacularKit