{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BuildingAMacOSVMManager","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This article walks through the layered structure of the"},{"type":"text","text":" "},{"type":"text","text":"Spooktacular SwiftUI app so you can build something comparable"},{"type":"text","text":" "},{"type":"text","text":"without repeating the architectural decisions we already settled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app target depends on three Swift packages in this repo:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookCore"}],"type":"strong"},{"type":"text","text":" — pure Swift domain types. No AppKit, no"},{"type":"text","text":" "},{"code":"Virtualization","type":"codeVoice"},{"type":"text","text":", no networking. Use it for models, enums,"},{"type":"text","text":" "},{"type":"text","text":"and protocol “ports” that describe what the app needs without"},{"type":"text","text":" "},{"type":"text","text":"committing to a concrete transport."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookApplication"}],"type":"strong"},{"type":"text","text":" — use cases and services that combine"},{"type":"text","text":" "},{"type":"text","text":"domain types into workflows (RBAC evaluation, tenant"},{"type":"text","text":" "},{"type":"text","text":"isolation, runner-pool orchestration)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"SpookInfrastructureApple"}],"type":"strong"},{"type":"text","text":" — Apple-framework adapters."},{"type":"text","text":" "},{"type":"text","text":"Wraps "},{"code":"VZVirtualMachine","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSPasteboard","type":"codeVoice"},{"type":"text","text":", "},{"code":"NSWorkspace","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"Security.framework","type":"codeVoice"},{"type":"text","text":", "},{"code":"Network.framework","type":"codeVoice"},{"type":"text","text":", "},{"code":"Foundation Models","type":"codeVoice"},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views stay thin: they observe "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" state objects and"},{"type":"text","text":" "},{"type":"text","text":"call through to these libraries. Keeping logic out of views is"},{"type":"text","text":" "},{"type":"text","text":"what makes the same codebase ship a CLI, a Kubernetes"},{"type":"text","text":" "},{"type":"text","text":"controller, and an App Store binary from one package."}]}],"kind":"content"}],"sections":[],"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Building a macOS VM Manager"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Compose the Spooktacular libraries into a first-class Mac app.","type":"text"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/buildingamacosvmmanager"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"],"anchor":"Related-Documentation"}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","title":"SpooktacularKit","kind":"symbol","type":"topic","role":"collection","url":"\/documentation\/spooktacularkit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}]}}}