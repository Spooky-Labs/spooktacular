{"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GUI app or the "},{"code":"spook","type":"codeVoice"},{"text":" CLI — both backed by the same","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"reference"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"text":" ","type":"text"},{"text":"a future release.","type":"text"}],"type":"paragraph"},{"name":"Important","content":[{"inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","type":"reference"},{"text":").","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important"},{"level":3,"type":"heading","anchor":"Creating-a-VM-with-the-CLI","text":"Creating a VM with the CLI"},{"inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"]},{"name":"Note","content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"level":3,"type":"heading","anchor":"Creating-a-VM-with-the-GUI","text":"Creating a VM with the GUI"},{"items":[{"content":[{"inlineContent":[{"text":"Open Spooktacular.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Click the ","type":"text"},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"text":" button or press ","type":"text"},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Managing-VMs","text":"Managing VMs"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI for day-to-day VM management:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},{"type":"text","text":" for details."}],"type":"paragraph"}],"type":"aside"},{"level":3,"anchor":"Provisioning-with-User-Data-Scripts","text":"Provisioning with User-Data Scripts","type":"heading"},{"inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}],"type":"paragraph"},{"code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ssh"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","type":"reference","isActive":true},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}],"type":"paragraph"},{"level":3,"anchor":"EC2-Mac-Setup","text":"EC2 Mac Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text",