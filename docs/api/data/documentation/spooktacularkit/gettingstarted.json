{"topicSections":[{"title":"Core Types","anchor":"Core-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachine"]},{"title":"Configuration","anchor":"Configuration","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]},{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]]},"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"text":" ","type":"text"},{"text":"GUI app or the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI — both backed by the same","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","isActive":true,"type":"reference"},{"text":" library. A Kubernetes operator is planned for","type":"text"},{"text":" ","type":"text"},{"text":"a future release.","type":"text"}]},{"style":"important","name":"Important","content":[{"inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","isActive":true,"type":"reference"},{"text":").","type":"text"}],"type":"paragraph"}],"type":"aside"},{"anchor":"Creating-a-VM-with-the-CLI","level":3,"text":"Creating a VM with the CLI","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}]},{"syntax":"bash","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"anchor":"Creating-a-VM-with-the-GUI","level":3,"text":"Creating a VM with the GUI","type":"heading"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Open Spooktacular.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Click the ","type":"text"},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"text":" button or press ","type":"text"},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}]},{"anchor":"Managing-VMs","level":3,"text":"Managing VMs","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI for day-to-day VM management:","type":"text"}]},{"syntax":"bash","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"type":"codeListing"},{"style":"important","name":"Important","content":[{"inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck","isActive":true,"type":"reference"},{"text":" for details.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"anchor":"Provisioning-with-User-Data-Scripts","level":3,"type":"heading","text":"Provisioning with User-Data Scripts"},{"type":"paragraph","inlineContent":[{"text":"Automate VM setup by running a shell script after boot via SSH:","type":"text"}]},{"code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ssh","type":"codeVoice"},{"text":" mode waits for the VM to boot, discovers its IP, connects","type":"text"},{"text":" ","type":"text"},{"text":"via SSH, and executes your script with real-time output streaming.","type":"text"},{"text":" ","type":"text"},{"text":"Disk-inject provisioning (zero-touch, no SSH required) is in","type":"text"},{"text":" ","type":"text"},{"text":"progress. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","isActive":true,"type":"reference"},{"text":" for provisioning strategies and","type":"text"},{"text":" ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for detailed guidance.","type":"text"}]},{"anchor":"EC2-Mac-Setup","level":3,"type":"heading","text":"EC2 Mac Setup"},{"inlineContent":[{"text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"text":" ","type":"text"},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"reference","isActive":true},{"text":" for detailed EC2 Mac configuration.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"text":" ","type":"text"},{"text":"release. See ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},{"type":"text","text":" for the planned architecture."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/gettingstarted"]}],"sections":[],"seeAlsoSections":[{"title":"Guides","generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","title":"Getting Started with Spooktacular","role":"collectionGroup"},"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","kind":"article","type":"topic","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit"