{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"reference","isActive":true},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need an Apple Silicon Mac (M1 or later) running"},{"type":"text","text":" "},{"type":"text","text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of"},{"type":"text","text":" "},{"type":"text","text":"free disk space and 4 CPU cores (see"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount"},{"text":").","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"text":"Creating a VM with the CLI","level":3,"type":"heading","anchor":"Creating-a-VM-with-the-CLI"},{"inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"syntax":"bash"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"type":"text","text":" "},{"type":"text","text":"deployment, create a base VM once, then use "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"instant copies."}],"type":"paragraph"}]},{"type":"heading","level":3,"text":"Creating a VM with the GUI","anchor":"Creating-a-VM-with-the-GUI"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Spooktacular.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"+"}]},{"text":" button or press ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Cmd+N"}]},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Create"}]},{"text":".","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}]},{"type":"heading","level":3,"text":"Managing VMs","anchor":"Managing-VMs"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI for day-to-day VM management:","type":"text"}]},{"type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"syntax":"bash"},{"name":"Important","type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck","type":"reference","isActive":true},{"type":"text","text":" for details."}],"type":"paragraph"}]},{"type":"heading","level":3,"text":"Provisioning with User-Data Scripts","anchor":"Provisioning-with-User-Data-Scripts"},{"type":"paragraph","inlineContent":[{"text":"Automate VM setup by running a shell script after boot via SSH:","type":"text"}]},{"type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ssh","type":"codeVoice"},{"text":" mode waits for the VM to boot, discovers its IP, connects","type":"text"},{"text":" ","type":"text"},{"text":"via SSH, and executes your script with real-time output streaming.","type":"text"},{"text":" ","type":"text"},{"text":"Disk-inject provisioning (zero-touch, no SSH required) is in","type":"text"},{"text":" ","type":"text"},{"text":"progress. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","isActive":true,"type":"reference"},{"text":" for provisioning strategies and","type":"text"},{"text":" ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for detailed guidance.","type":"text"}]},{"type":"heading","level":3,"text":"EC2 Mac Setup","anchor":"EC2-Mac-Setup"},{"type":"paragraph","inlineContent":[{"text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI","type":"text"},{"text":" ","type":"text"},{"text":"capacity. Install Spooktacular, create VMs from IPSW, clone","type":"text"},{"text":" ","type":"text"},{"text":"configured bases, and start runners with SSH provisioning.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","isActive":true,"type":"reference"},{"text":" for detailed EC2 Mac configuration.","type":"text"}]},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"reference","isActive":true},{"type":"text","text":" for the planned architecture."}],"type":"paragraph"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"},"kind":"article","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"topicSections":[{"title":"Core Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineBundle","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachine"],"anchor":"Core-Types"},{"title":"Configuration","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"],"anchor":"Configuration"},{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Kubernetes