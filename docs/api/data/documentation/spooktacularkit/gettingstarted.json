guration","anchor":"Configuration","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"]},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"title":"Guides","anchor":"Guides"}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"text":" ","type":"text"},{"text":"GUI app or the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI — both backed by the same","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},{"text":" library. A Kubernetes operator is planned for","type":"text"},{"text":" ","type":"text"},{"text":"a future release.","type":"text"}],"type":"paragraph"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","type":"reference","isActive":true},{"text":").","type":"text"}],"type":"paragraph"}]},{"level":3,"anchor":"Creating-a-VM-with-the-CLI","type":"heading","text":"Creating a VM with the CLI"},{"inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}],"type":"paragraph"},{"code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"type":"codeListing","syntax":"bash"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}],"type":"paragraph"}]},{"level":3,"text":"Creating a VM with the GUI","type":"heading","anchor":"Creating-a-VM-with-the-GUI"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Spooktacular."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click the "},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"type":"text","text":" button or press "},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}]},{"level":3,"text":"Managing VMs","type":"heading","anchor":"Managing-VMs"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI for day-to-day VM management:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},{"text":" for details.","type":"text"}]}]},{"level":3,"text":"Provisioning with User-Data Scripts","type":"heading","anchor":"Provisioning-with-User-Data-Scripts"},{"type":"paragraph","inlineContent":[{"text":"Automate VM setup by running a shell script after boot via SSH:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ssh"},{"text":" mode waits for the VM to boot, discovers its IP, connects","type":"text"},{"text":" ","type":"text"},{"text":"via SSH, and executes your script with real-time output streaming.","type":"text"},{"text":" ","type":"text"},{"text":"Disk-inject provisioning (zero-touch, no SSH required) is in","type":"text"},{"text":" ","type":"text"},{"text":"progress. See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","isActive":true},{"text":" for provisioning strategies and","type":"text"},{"text":" ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for detailed guidance.","type":"text"}]},{"level":3,"text":"EC2 Mac Setup","type":"heading","anchor":"EC2-Mac-Setup"},{"type":"paragraph","inlineContent":[{"text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI","type":"text"},{"text":" ","type":"text"},{"text":"capacity. Install Spooktacular, create VMs from IPSW, clone","type":"text"},{"text":" ","type":"text"},{"text":"configured bases, and start runners with SSH provisioning.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},{"text":" for detailed EC2 Mac configuration.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"reference","isActive":true},{"type":"text","text":" for the planned architecture."}]}]}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"doc://SpooktacularKit/documentation/Spookt