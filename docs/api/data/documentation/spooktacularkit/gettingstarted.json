{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"metadata":{"role":"collectionGroup","title":"Getting Started with Spooktacular","modules":[{"name":"SpooktacularKit"}]},"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"anchor":"Guides","title":"Guides"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","title":"Guides","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/gettingstarted"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","isActive":true,"type":"reference"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"text":").","type":"text"}]}],"style":"important","name":"Important"},{"type":"heading","level":3,"text":"Creating a VM with the CLI","anchor":"Creating-a-VM-with-the-CLI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}]},{"type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"syntax":"bash"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}]}],"style":"note","name":"Note"},{"type":"heading","level":3,"text":"Creating a VM with the GUI","anchor":"Creating-a-VM-with-the-GUI"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Spooktacular.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click the ","type":"text"},{"type":"strong","inlineContent":[{"text":"+","type":"text"}]},{"text":" button or press ","type":"text"},{"type":"strong","inlineContent":[{"text":"Cmd+N","type":"text"}]},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"text":"Create","type":"text"}]},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"type":"heading","level":3,"text":"Managing VMs","anchor":"Managing-VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI for day-to-day VM management:"}]},{"type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"syntax":"bash"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"CapacityCheck"},{"type":"text","text":" for details."}]}],"style":"important","name":"Important"},{"type":"heading","level":3,"text":"Provisioning with User-Data Scripts","anchor":"Provisioning-with-User-Data-Scripts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}]},{"type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"ssh","type":"codeVoice"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"code":"ProvisioningMode","type":"codeVoice"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}]},{"type":"heading","level":3,"text":"EC2 Mac Setup","anchor":"EC2-Mac-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","isActive":true,"type":"reference"},{"type":"text","text":" for detailed EC2 Mac configuration."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},{"type":"text","text":" for the planned architecture."}]}],"style":"note","name":"Note"}]}],"sections":[],"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"kind":"article","role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup",