{"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"content":[{"inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"text":").","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"level":3,"anchor":"Creating-a-VM-with-the-CLI","text":"Creating a VM with the CLI","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}]},{"syntax":"bash","type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"]},{"content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"type":"codeVoice","code":"spook clone"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"level":3,"anchor":"Creating-a-VM-with-the-GUI","text":"Creating a VM with the GUI","type":"heading"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Spooktacular."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click the "},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"type":"text","text":" button or press "},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"level":3,"anchor":"Managing-VMs","text":"Managing VMs","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI for day-to-day VM management:"}]},{"syntax":"bash","type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"content":[{"inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CapacityCheck"},{"text":" for details.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"level":3,"anchor":"Provisioning-with-User-Data-Scripts","text":"Provisioning with User-Data Scripts","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}]},{"syntax":"bash","type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"ssh","type":"codeVoice"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"code":"ProvisioningMode","type":"codeVoice"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}]},{"level":3,"anchor":"EC2-Mac-Setup","text":"EC2 Mac Setup","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},{"type":"text","text":" for detailed EC2 Mac configuration."}]},{"content":[{"inlineContent":[{"text":"A Kubernetes operator (MacOSVM CRD) is planned for a future","type":"text"},{"text":" ","type":"text"},{"text":"release. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"reference"},{"text":" for the planned architecture.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/Spooktacu