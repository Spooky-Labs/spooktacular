blesGuide":{"title":"Running BlueBubbles iMessage Server","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"kind":"article","role":"collectionGroup","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","title":"Remote Desktop Access"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"kind":"article","type":"topic","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","url":"\/documentation\/spooktacularkit\/ec2macdeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"kind":"article","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"title":"Versioning & Release Schedule","role":"collectionGroup