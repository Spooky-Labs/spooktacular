{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/gettingstarted"]}],"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"collectionGroup","title":"Getting Started with Spooktacular","modules":[{"name":"SpooktacularKit"}]},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"topicSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]}],"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides"}],"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"text":" ","type":"text"},{"text":"GUI app or the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI — both backed by the same","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"reference"},{"text":" library. A Kubernetes operator is planned for","type":"text"},{"text":" ","type":"text"},{"text":"a future release.","type":"text"}],"type":"paragraph"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"text":").","type":"text"}]}],"type":"aside","name":"Important"},{"text":"Creating a VM with the CLI","type":"heading","level":3,"anchor":"Creating-a-VM-with-the-CLI"},{"inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}]}],"type":"aside","name":"Note"},{"text":"Creating a VM with the GUI","type":"heading","level":3,"anchor":"Creating-a-VM-with-the-GUI"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Spooktacular."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click the "},{"type":"strong","inlineContent":[{"type":"text","text":"+"}]},{"type":"text","text":" button or press "},{"type":"strong","inlineContent":[{"type":"text","text":"Cmd+N"}]},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"type":"text","text":"Create"}]},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}],"type":"paragraph"},{"text":"Managing VMs","type":"heading","level":3,"anchor":"Managing-VMs"},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI for day-to-day VM management:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"code":"CapacityCheck","type":"codeVoice"},{"text":" for details.","type":"text"}]}],"type":"aside","name":"Important"},{"text":"Provisioning with User-Data Scripts","type":"heading","level":3,"anchor":"Provisioning-with-User-Data-Scripts"},{"inlineContent":[{"text":"Automate VM setup by running a shell script after boot via SSH:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ssh"},{"text":" mode waits for the VM to boot, discovers its IP, connects","type":"text"},{"text":" ","type":"text"},{"text":"via SSH, and executes your script with real-time output streaming.","type":"text"},{"text":" ","type":"text"},{"text":"Disk-inject provisioning (zero-touch, no SSH required) is in","type":"text"},{"text":" ","type":"text"},{"text":"progress. See ","type":"text"},{"type":"codeVoice","code":"ProvisioningMode"},{"text":" for provisioning strategies and","type":"text"},{"text":" ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for detailed guidance.","type":"text"}],"type":"paragraph"},{"text":"EC2 Mac Setup","type":"heading","level":3,"anchor":"EC2-Mac-Setup"},{"inlineContent":[{"text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI","type":"text"},{"text":" ","type":"text"},{"text":"capacity. Install Spooktacular, create VMs from IPSW, clone","type":"text"},{"text":" ","type":"text"},{"text":"configured bases, and start runners with SSH provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"reference"},{"text":" for detailed EC2 Mac configuration.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"A Kubernetes operator (MacOSVM CRD) is planned for a future","type":"text"},{"text":" ","type":"text"},{"text":"release. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","isActive":true,"type":"reference"},{"text":" for the planned architecture.","type":"text"}]}],"type":"aside","name":"Note"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/remotedesktop","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","title":"Remote Desktop Access","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"role":"collectionGroup","url":"\/do