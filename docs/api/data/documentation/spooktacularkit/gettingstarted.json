{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"kind":"article","metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Getting Started with Spooktacular"},"sections":[],"topicSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]}],"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"reference"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}],"type":"paragraph"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need an Apple Silicon Mac (M1 or later) running"},{"type":"text","text":" "},{"type":"text","text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of"},{"type":"text","text":" "},{"type":"text","text":"free disk space and 4 CPU cores (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":")."}]}],"type":"aside","name":"Important"},{"anchor":"Creating-a-VM-with-the-CLI","text":"Creating a VM with the CLI","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}],"type":"paragraph"},{"syntax":"bash","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"IPSW installation takes 10–20 minutes per VM. For faster"},{"type":"text","text":" "},{"type":"text","text":"deployment, create a base VM once, then use "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"instant copies."}]}],"type":"aside","name":"Note"},{"anchor":"Creating-a-VM-with-the-GUI","text":"Creating a VM with the GUI","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Spooktacular.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click the ","type":"text"},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"text":" button or press ","type":"text"},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"text":".","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}],"type":"paragraph"},{"anchor":"Managing-VMs","text":"Managing VMs","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Use the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI for day-to-day VM management:"}],"type":"paragraph"},{"syntax":"bash","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"type":"codeListing"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"CapacityCheck"},{"type":"text","text":" for details."}]}],"type":"aside","name":"Important"},{"anchor":"Provisioning-with-User-Data-Scripts","text":"Provisioning with User-Data Scripts","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"code":"ssh","type":"codeVoice"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"code":"ProvisioningMode","type":"codeVoice"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}],"type":"paragraph"},{"anchor":"EC2-Mac-Setup","text":"EC2 Mac Setup","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"reference"},{"type":"text","text":" for detailed EC2 Mac configuration."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","isActive":true},{"type":"text","text":" for the planned architecture."}]}],"type":"aside","name":"Note"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"type":"topic","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","kind":"article","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"title":"Machine Learning Workloads","kind":"article","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","kind":"article","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","kind":"article","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","url":"\/documentation\/spooktacularkit\/jenkinsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"role":"collectionGroup","kind":"article","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","url":"\/documentation\/spooktacularkit\/openclawguide","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","kind":"article","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","kind":"article","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"title":"Deploying on EC2 Mac","kind":"article","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"title":"Running BlueBubbles iMessage Server","kind":"article","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","url":"\/documentation\/spooktacularkit\/bluebubblesguide"}}}