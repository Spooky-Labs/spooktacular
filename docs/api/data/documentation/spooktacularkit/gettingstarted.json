:{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"Spooktacular runs macOS virtual machines on Apple Silicon using","type":"text"},{"text":" ","type":"text"},{"text":"Apple’s Virtualization framework. You interact with it through the","type":"text"},{"text":" ","type":"text"},{"text":"GUI app or the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI — both backed by the same","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},{"text":" library. A Kubernetes operator is planned for","type":"text"},{"text":" ","type":"text"},{"text":"a future release.","type":"text"}],"type":"paragraph"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"You need an Apple Silicon Mac (M1 or later) running"},{"type":"text","text":" "},{"type":"text","text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of"},{"type":"text","text":" "},{"type":"text","text":"free disk space and 4 CPU cores (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":")."}],"type":"paragraph"}],"type":"aside","style":"important"},{"anchor":"Creating-a-VM-with-the-CLI","level":3,"type":"heading","text":"Creating a VM with the CLI"},{"inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"type":"codeListing"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"IPSW installation takes 10–20 minutes per VM. For faster"},{"type":"text","text":" "},{"type":"text","text":"deployment, create a base VM once, then use "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"instant copies."}],"type":"paragraph"}],"type":"aside","style":"note"},{"anchor":"Creating-a-VM-with-the-GUI","level":3,"type":"heading","text":"Creating a VM with the GUI"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Spooktacular."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click the "},{"type":"strong","inlineContent":[{"text":"+","type":"text"}]},{"type":"text","text":" button or press "},{"type":"strong","inlineContent":[{"text":"Cmd+N","type":"text"}]},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"text":"Create","type":"text"}]},{"type":"text","text":"."}]}]}],"type":"orderedList"},{"inlineContent":[{"text":"The app downloads the latest compatible macOS IPSW and installs it","type":"text"},{"text":" ","type":"text"},{"text":"into a new VM bundle.","type":"text"}],"type":"paragraph"},{"anchor":"Managing-VMs","level":3,"type":"heading","text":"Managing VMs"},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI for day-to-day VM management:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"type":"codeListing"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"CapacityCheck"},{"type":"text","text":" for details."}],"type":"paragraph"}],"type":"aside","style":"important"},{"anchor":"Provisioning-with-User-Data-Scripts","level":3,"type":"heading","text":"Provisioning with User-Data Scripts"},{"inlineContent":[{"text":"Automate VM setup by running a shell script after boot via SSH:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ssh"},{"text":" mode waits for the VM to boot, discovers its IP, connects","type":"text"},{"text":" ","type":"text"},{"text":"via SSH, and executes your script with real-time output streaming.","type":"text"},{"text":" ","type":"text"},{"text":"Disk-inject provisioning (zero-touch, no SSH required) is in","type":"text"},{"text":" ","type":"text"},{"text":"progress. See ","type":"text"},{"type":"codeVoice","code":"ProvisioningMode"},{"text":" for provisioning strategies and","type":"text"},{"text":" ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for detailed guidance.","type":"text"}],"type":"paragraph"},{"anchor":"EC2-Mac-Setup","level":3,"type":"heading","text":"EC2 Mac Setup"},{"inlineContent":[{"text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI","type":"text"},{"text":" ","type":"text"},{"text":"capacity. Install Spooktacular, create VMs from IPSW, clone","type":"text"},{"text":" ","type":"text"},{"text":"configured bases, and start runners with SSH provisioning.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},{"text":" for detailed EC2 Mac configuration.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},{"type":"text","text":" for the planned architecture."}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"metadata":{"role":"collectionGroup","title":"Getting Started with Spooktacular","modules":[{"name":"SpooktacularKit"}]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"title":"Guides","anchor":"Guides"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, cha