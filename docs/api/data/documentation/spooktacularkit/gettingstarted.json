spooktacularkit","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol","title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","title":"Remote Desktop Access","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"kind":"article","url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","role":"collectionGroup","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"kind":"article","title":"Running BlueBubbles iMessage Server"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"kind":"article","title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic","url":"\/documentation\/spooktacularkit\/clireference","role":"collectionGroup","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"kind":"article","title":"Using the spook Command-Line Interface"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","role":"collectionGroup","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"kind":"article","title":"Configuring Jenkins Nodes"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","role":"collectionGroup","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"kind":"article","title":"Running OpenClaw in Virtual Machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic","title":"Versioning & Release Schedule","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"kind":"article","url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","type":"topic","url":"\/documentation\/spooktacularkit\/mlworkloads","role":"collectionGroup","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"kind":"article","title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic","url":"\/documentation\/spooktacularkit\/kubernetesguide","role":"collectionGroup","abstract":[{"type":"text","text":"