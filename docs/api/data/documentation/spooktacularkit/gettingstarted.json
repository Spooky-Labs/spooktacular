is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount"},{"text":").","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Creating a VM with the CLI","level":3,"anchor":"Creating-a-VM-with-the-CLI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}]},{"type":"codeListing","syntax":"bash","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Creating a VM with the GUI","level":3,"anchor":"Creating-a-VM-with-the-GUI"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Spooktacular."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click the "},{"type":"strong","inlineContent":[{"text":"+","type":"text"}]},{"type":"text","text":" button or press "},{"type":"strong","inlineContent":[{"text":"Cmd+N","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"text":"Create","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"type":"heading","text":"Managing VMs","level":3,"anchor":"Managing-VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI for day-to-day VM management:"}]},{"type":"codeListing","syntax":"bash","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CapacityCheck"},{"text":" for details.","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Provisioning with User-Data Scripts","level":3,"anchor":"Provisioning-with-User-Data-Scripts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup by running a 