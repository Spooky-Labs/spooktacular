{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"},"metadata":{"title":"Getting Started with Spooktacular","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"seeAlsoSections":[{"anchor":"Guides","generated":true,"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"topicSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","isActive":true},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need an Apple Silicon Mac (M1 or later) running"},{"type":"text","text":" "},{"type":"text","text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of"},{"type":"text","text":" "},{"type":"text","text":"free disk space and 4 CPU cores (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":")."}]}],"style":"important"},{"text":"Creating a VM with the CLI","type":"heading","anchor":"Creating-a-VM-with-the-CLI","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}]},{"type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"syntax":"bash"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"IPSW installation takes 10–20 minutes per VM. For faster"},{"type":"text","text":" "},{"type":"text","text":"deployment, create a base VM once, then use "},{"type":"codeVoice","code":"spook clone"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"instant copies."}]}],"style":"note"},{"text":"Creating a VM with the GUI","type":"heading","anchor":"Creating-a-VM-with-the-GUI","level":3},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Spooktacular.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click the ","type":"text"},{"inlineContent":[{"type":"text","text":"+"}],"type":"strong"},{"text":" button or press ","type":"text"},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"Create"}],"type":"strong"},{"text":".","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"text":"Managing VMs","type":"heading","anchor":"Managing-VMs","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI for day-to-day VM management:"}]},{"type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"syntax":"bash"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"CapacityCheck"},{"type":"text","text":" for details."}]}],"style":"important"},{"text":"Provisioning with User-Data Scripts","type":"heading","anchor":"Provisioning-with-User-Data-Scripts","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}]},{"type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ssh"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"type":"codeVoice","code":"ProvisioningMode"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}]},{"text":"EC2 Mac Setup","type":"heading","anchor":"EC2-Mac-Setup","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","isActive":true},{"type":"text","text":" for detailed EC2 Mac configuration."}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","isActive":true,"type":"reference"},{"type":"text","text":" for the planned architectu