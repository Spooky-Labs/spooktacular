{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted"},"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"topicSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Getting Started with Spooktacular"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"You need an Apple Silicon Mac (M1 or later) running"},{"type":"text","text":" "},{"type":"text","text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of"},{"type":"text","text":" "},{"type":"text","text":"free disk space and 4 CPU cores (see"},{"type":"text","text":" "},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}],"type":"aside"},{"level":3,"anchor":"Creating-a-VM-with-the-CLI","text":"Creating a VM with the CLI","type":"heading"},{"inlineContent":[{"text":"Install Spooktacular and create a VM from the latest compatible IPSW:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"],"type":"codeListing"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"type":"codeVoice","code":"spook clone"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}]}],"type":"aside"},{"level":3,"anchor":"Creating-a-VM-with-the-GUI","text":"Creating a VM with the GUI","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Spooktacular."}]}]},{"content":[{"inlineContent":[{"text":"Click the ","type":"text"},{"inlineContent":[{"text":"+","type":"text"}],"type":"strong"},{"text":" button or press ","type":"text"},{"inlineContent":[{"type":"text","text":"Cmd+N"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enter a name and adjust hardware settings.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"text":"Create","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"type":"heading","anchor":"Managing-VMs","level":3,"text":"Managing VMs"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI for day-to-day VM management:","type":"text"}]},{"type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"],"syntax":"bash"},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Apple Silicon supports a maximum of 2 concurrent VMs"},{"type":"text","text":" "},{"type":"text","text":"per host. Attempting to start a third VM fails. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"CapacityCheck"},{"text":" for details.","type":"text"}],"type":"paragraph"}]},{"type":"heading","anchor":"Provisioning-with-User-Data-Scripts","level":3,"text":"Provisioning with User-Data Scripts"},{"inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ssh"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"type":"codeVoice","code":"ProvisioningMode"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}],"type":"paragraph"},{"anchor":"EC2-Mac-Setup","text":"EC2 Mac Setup","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","isActive":true},{"text":" for detailed EC2 Mac configuration.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"A Kubernetes operator (MacOSVM CRD) is planned for a future"},{"type":"text","text":" "},{"type":"text","text":"release. See "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"reference"},{"type":"text","text":" for the planned architecture."}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","role":"collectionGroup","title":"Configuring Jenkins Nodes","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads","role":"collectionGroup","type":"topic","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"title":"Machine Learning Workloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","role":"collectionGroup","title":"Running BlueBubbles iMessage Server","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"kind":"article","url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup","title":"Configuring GitHub Actions Runners","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","kind":"article","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"kind":"article","url":"\/documentation\/spooktacularkit\/kubernetesguide","role":"collectionGroup","type":"topic","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"title":"Kubernetes Integration","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","url":"\/documentation\/spooktacularkit\/clireference","role":"collectionGroup","title":"Using the spook Command-Line Interface","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}]}}}