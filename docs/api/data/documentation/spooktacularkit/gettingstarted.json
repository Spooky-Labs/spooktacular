{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"title":"Guides","anchor":"Guides"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Getting Started with Spooktacular","role":"collectionGroup"},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides","anchor":"Guides"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular runs macOS virtual machines on Apple Silicon using"},{"type":"text","text":" "},{"type":"text","text":"Apple’s Virtualization framework. You interact with it through the"},{"type":"text","text":" "},{"type":"text","text":"GUI app or the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI — both backed by the same"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},{"type":"text","text":" library. A Kubernetes operator is planned for"},{"type":"text","text":" "},{"type":"text","text":"a future release."}]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"You need an Apple Silicon Mac (M1 or later) running","type":"text"},{"text":" ","type":"text"},{"text":"macOS 14.0 (Sonoma) or later. Each VM requires at least 20 GB of","type":"text"},{"text":" ","type":"text"},{"text":"free disk space and 4 CPU cores (see","type":"text"},{"text":" ","type":"text"},{"code":"VirtualMachineSpecification\/minimumCPUCount","type":"codeVoice"},{"text":").","type":"text"}]}],"name":"Important"},{"level":3,"type":"heading","text":"Creating a VM with the CLI","anchor":"Creating-a-VM-with-the-CLI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Install Spooktacular and create a VM from the latest compatible IPSW:"}]},{"syntax":"bash","type":"codeListing","code":["# Install via Homebrew","brew install --cask spooktacular","","# Create from the latest compatible IPSW","spook create my-vm --from-ipsw latest","","# Or specify custom hardware resources","spook create runner --cpu 8 --memory 16 --disk 100"]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"IPSW installation takes 10–20 minutes per VM. For faster","type":"text"},{"text":" ","type":"text"},{"text":"deployment, create a base VM once, then use ","type":"text"},{"code":"spook clone","type":"codeVoice"},{"text":" for","type":"text"},{"text":" ","type":"text"},{"text":"instant copies.","type":"text"}]}],"name":"Note"},{"level":3,"type":"heading","text":"Creating a VM with the GUI","anchor":"Creating-a-VM-with-the-GUI"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Spooktacular."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click the "},{"type":"strong","inlineContent":[{"text":"+","type":"text"}]},{"type":"text","text":" button or press "},{"type":"strong","inlineContent":[{"text":"Cmd+N","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enter a name and adjust hardware settings."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"text":"Create","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app downloads the latest compatible macOS IPSW and installs it"},{"type":"text","text":" "},{"type":"text","text":"into a new VM bundle."}]},{"level":3,"type":"heading","text":"Managing VMs","anchor":"Managing-VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI for day-to-day VM management:"}]},{"syntax":"bash","type":"codeListing","code":["# List all VMs","spook list","","# Start a VM (opens display window)","spook start my-vm","","# Start headless (for CI runners and servers)","spook start my-vm --headless","","# Clone instantly using APFS copy-on-write","spook clone my-vm runner-01","","# Show VM configuration","spook get my-vm","","# Delete a VM permanently","spook delete my-vm --force"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon supports a maximum of 2 concurrent VMs","type":"text"},{"text":" ","type":"text"},{"text":"per host. Attempting to start a third VM fails. See","type":"text"},{"text":" ","type":"text"},{"code":"CapacityCheck","type":"codeVoice"},{"text":" for details.","type":"text"}]}],"name":"Important"},{"level":3,"type":"heading","text":"Provisioning with User-Data Scripts","anchor":"Provisioning-with-User-Data-Scripts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automate VM setup by running a shell script after boot via SSH:"}]},{"syntax":"bash","type":"codeListing","code":["spook start runner --headless \\","    --user-data ~\/setup.sh \\","    --provision ssh \\","    --ssh-user admin"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ssh"},{"type":"text","text":" mode waits for the VM to boot, discovers its IP, connects"},{"type":"text","text":" "},{"type":"text","text":"via SSH, and executes your script with real-time output streaming."},{"type":"text","text":" "},{"type":"text","text":"Disk-inject provisioning (zero-touch, no SSH required) is in"},{"type":"text","text":" "},{"type":"text","text":"progress. See "},{"type":"codeVoice","code":"ProvisioningMode"},{"type":"text","text":" for provisioning strategies and"},{"type":"text","text":" "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for detailed guidance."}]},{"level":3,"type":"heading","text":"EC2 Mac Setup","anchor":"EC2-Mac-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy Spooktacular on AWS EC2 Mac instances to double your CI"},{"type":"text","text":" "},{"type":"text","text":"capacity. Install Spooktacular, create VMs from IPSW, clone"},{"type":"text","text":" "},{"type":"text","text":"configured bases, and start runners with SSH provisioning."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},{"type":"text","text":" for detailed EC2 Mac configuration."}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"A Kubernetes operator (MacOSVM CRD) is planned for a future","type":"text"},{"text":" ","type":"text"},{"text":"release. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","isActive":true,"type":"reference"},{"text":" for the planned architecture.","type":"text"}]}],"name":"Note"}]}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"title":"Versioning & Release Schedule","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/