"},{"type":"text","text":" "},{"type":"text","text":"controlled, reproducible VM environment"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Design review","type":"text"}]},{"type":"text","text":" — Share a running app with designers and"},{"type":"text","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Training and demos"}],"type":"strong"},{"type":"text","text":" — Provide ephemeral macOS desktops for"},{"type":"text","text":" "},{"type":"text","text":"workshops or customer demos"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Help desk","type":"text"}]},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Enabling-Screen-Sharing-via-Provisioning","text":"Enabling Screen Sharing via Provisioning","type":"heading"},{"inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Using-disk-inject-Zero-Touch","text":"Using disk-inject (Zero-Touch)","type":"heading"},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load 