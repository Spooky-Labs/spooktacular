orkspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/displayCount":{"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/displaycount","kind":"symbol","title":"displayCount","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","abstract":[{"type":"text","text":"The number of virtual displays attached to the VM."}],"role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"displayCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktopTemplate":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RemoteDesktopTemplate","kind":"identifier"}],"title":"RemoteDesktopTemplate","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate","url":"\/documentation\/spooktacularkit\/remotedesktoptemplate","type":"topic","abstract":[{"type":"text","text":"Generates user-data scripts for remote desktop (Screen Sharing) VMs."}],"navigatorTitle":[{"text":"RemoteDesktopTemplate","kind":"identifier"}],"role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","title":