},{"text":" ","kind":"text"},{"kind":"identifier","text":"bridged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"interface"},{"kind":"text","text":": "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":")","kind":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"title":"Configuring Jenkins Nodes","type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","role":"collectionGroup","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/clipboardSharingEnabled":{"role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/clipboardsharingenabled","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"clipboardSharingEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Whether the host and guest share a common clipboard."}],"title":"clipboardSharingEnabled"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"url":"\/documentation\/spooktacularkit\/clireference","kind":"article","title":"Using the spook Command-Line Interface","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","title":"Kubernetes Integration","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/autoResizeDisplay":{"abstract":[{"type":"text","text":"Whether the guest display automatically resizes to match"},{"type":"text","text":" "},{"type":"text","text":"the host window."}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/autoresizedisplay","kind":"symbol","title":"autoResizeDisplay","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"autoResizeDisplay","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"role":"collectionGroup","kind":"article","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/microphoneEnabled":{"role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/microphoneenabled","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"microphoneEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"type":"text","text":"Whether the VM has a microphone input device attached."}],"title":"microphoneEnabled"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"type":"topic","title":"ProvisioningMode","url":"\/documentation\/spooktacularkit\/provisioningmode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","type":"topic","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/isolated":{"title":"NetworkMode.isolated","type":"topic","url":"\/documentation\/spooktacularkit\/networkmode\/isolated","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isolated","kind":"identifier"}],"abstract":[{"text":"No network connectivity.","type":"text"}]}}}