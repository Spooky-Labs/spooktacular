{"sections":[],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"title":"Related Guides","anchor":"Related-Guides"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true,"anchor":"Guides"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"metadata":{"title":"Remote Desktop Access","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include full macOS display output backed by a"},{"type":"text","text":" "},{"type":"text","text":"virtual GPU ("},{"type":"codeVoice","code":"VZMacGraphicsDeviceConfiguration"},{"type":"text","text":"). Combined with"},{"type":"text","text":" "},{"type":"text","text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote"},{"type":"text","text":" "},{"type":"text","text":"graphical access to any VM from anywhere on your network."}],"type":"paragraph"},{"text":"Use Cases","anchor":"Use-Cases","level":3,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Remote development","type":"text"}],"type":"strong"},{"text":" — Full macOS desktop for Xcode, Interface","type":"text"},{"text":" ","type":"text"},{"text":"Builder, and Simulator from any machine","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"QA testing","type":"text"}],"type":"strong"},{"text":" — Manual testing of macOS and iOS apps in a","type":"text"},{"text":" ","type":"text"},{"text":"controlled, reproducible VM environment","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Design review","type":"text"}],"type":"strong"},{"text":" — Share a running app with designers and","type":"text"},{"text":" ","type":"text"},{"text":"stakeholders without giving them SSH access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Training and demos","type":"text"}],"type":"strong"},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Help desk","type":"text"}],"type":"strong"},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}]}]}],"type":"unorderedList"},{"text":"Enabling Screen Sharing via Provisioning","anchor":"Enabling-Screen-Sharing-via-Provisioning","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The most reliable way to enable VNC access is through a provisioning"},{"type":"text","text":" "},{"type":"text","text":"script that runs automatically when the VM boots."}],"type":"paragraph"},{"text":"Using disk-inject (Zero-Touch)","anchor":"Using-disk-inject-Zero-Touch","level":3,"type":"heading"},{"syntax":"bash","type":"codeListing","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"]},{"inlineContent":[{"type":"text","text":"Where "},{"type":"codeVoice","code":"enable-screensharing.sh"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""]},{"text":"Using the Kubernetes CRD","anchor":"Using-the-Kubernetes-CRD","level":3,"type":"heading"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for details on all four "},{"type":"codeVoice","code":"ProvisioningMode"},{"type":"text","text":" "},{"type":"text","text":"strategies."}],"type":"paragraph"},{"text":"Connecting via VNC","anchor":"Connecting-via-VNC","level":2,"type":"heading"},{"text":"macOS Screen Sharing App (Built-in)","anchor":"macOS-Screen-Sharing-App-Built-in","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The simplest way to connect from another Mac:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}]}]}],"type":"orderedList"},{"syntax":"bash","type":"codeListing","code":["spook ip desktop-vm","# 192.168.64.3"]},{"start":2,"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}]}]}],"type":"orderedList"},{"syntax":"bash","type":"codeListing","code":["open vnc:\/\/192.168.64.3"]},{"start":3,"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}]}]}],"type":"orderedList"},{"text":"From Any VNC Client","anchor":"From-Any-VNC-Client","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Server:","type":"text"}],"type":"strong"},{"text":" The VM’s IP address (from ","type":"text"},{"type":"codeVoice","code":"spook ip"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"text":" 5900 (default VNC port)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"text":" macOS user credentials or VNC password","type":"text"}]}]}],"type":"unorderedList"},{"syntax":"bash","type":"codeListing","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"text":"Network Mode Considerations","anchor":"Network-Mode-Considerations","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connection method"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/bridged(interface:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"type":"text","text":"For remote desktop scenarios, "},{"type":"strong","inlineContent":[{"type":"text","text":"bridged"}]},{"type":"text","text":" mode is recommended because"},{"type":"text","text":" "},{"type":"text","text":"it gives the VM its own IP address on the LAN, allowing direct"},{"type":"text","text":" "},{"type":"text","text":"connections from any machine."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":" for the entitlement details."}]}],"name":"Note","type":"aside","style":"note"},{"text":"Display Configuration","anchor":"Display-Configuration","level":2,"type":"heading"},{"text":"Resolution and DPI","anchor":"Resolution-and-DPI","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"type":"text","text":". This is set by "},{"type":"codeVoice","code":"VirtualMachineConfiguration"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"applying the "},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"]},{"text":"Dual Monitors","anchor":"Dual-Monitors","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"]},{"inlineContent":[{"type":"text","text":"Each display gets its own VNC session. Connect to the second"},{"type":"text","text":" "},{"type":"text","text":"display on port 5901."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VirtualMachineSpecification\/displayCount"},{"type":"text","text":" property controls the number of"},{"type":"text","text":" "},{"type":"text","text":"displays (valid range: 1-2)."}],"type":"paragraph"},{"text":"Auto-Resize Display","anchor":"Auto-Resize-Display","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"VirtualMachineSpecification\/autoResizeDisplay"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (the default), the"},{"type":"text","text":" "},{"type":"text","text":"guest display resolution adjusts to match the Spooktacular window"},{"type":"text","text":" "},{"type":"text","text":"size on the host. This is useful when viewing the VM display"},{"type":"text","text":" "},{"type":"text","text":"locally:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}]}],"name":"Note","type":"aside","style":"note"},{"text":"Performance Considerations","anchor":"Performance-Considerations","level":2,"type":"heading"},{"text":"LAN vs WAN","anchor":"LAN-vs-WAN","level":3,"type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Factor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full 1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider 1280x800"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Color depth"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32-bit"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16-bit for better performance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Frame rate"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"30-60 fps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 fps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Responsiveness"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Excellent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Usable for most tasks"}]}]]],"type":"table","header":"row"},{"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Quality"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bandwidth"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1280x800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Low (16-bit)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"2-5 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Medium"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5-15 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (32-bit)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3840x2400"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (Retina)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"40-80 Mbps"}]}]]],"type":"table","header":"row"},{"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"For WAN or high-latency connections:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a lower resolution display","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"type":"codeVoice","code":"ssh -C"},{"text":")","type":"text"}]}]}],"type":"orderedList"},{"syntax":"bash","type":"codeListing","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"]},{"text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Spooktacular’s roadmap includes high-performance display streaming"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"4K @ 60fps","type":"text"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sub-frame latency","type":"text"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Adaptive bitrate","type":"text"}],"type":"strong"},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"WebRTC transport","type":"text"}],"type":"strong"},{"text":" — Browser-based access without a VNC client","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}],"type":"paragraph"},{"text":"Audio Forwarding","anchor":"Audio-Forwarding","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"type":"text","text":") by default. Audio from the guest"},{"type":"text","text":" "},{"type":"text","text":"macOS is forwarded to the host’s speakers."}],"type":"paragraph"},{"text":"Enabling Audio","anchor":"Enabling-Audio","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":". To explicitly control it:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"VirtualMachineSpecification\/audioEnabled"},{"type":"text","text":" and "},{"type":"codeVoice","code":"VirtualMachineSpecification\/microphoneEnabled"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}],"type":"paragraph"},{"text":"Audio over VNC","anchor":"Audio-over-VNC","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}],"type":"orderedList"},{"text":"Clipboard Sharing","anchor":"Clipboard-Sharing","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VirtualMachineSpecification\/clipboardSharingEnabled"},{"type":"text","text":" field"},{"type":"text","text":" "},{"type":"text","text":"exists for forward compatibility, but clipboard sharing through the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework is "},{"type":"strong","inlineContent":[{"type":"text","text":"only supported for Linux guests"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"type":"codeVoice","code":"spice-vdagent"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"type":"text","text":" "},{"type":"text","text":"logged at configuration time and no console device is attached."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There is currently no Virtualization framework API for"},{"type":"text","text":" "},{"type":"text","text":"clipboard synchronization between the host and a macOS guest. If"},{"type":"text","text":" "},{"type":"text","text":"Apple adds this capability in a future release, Spooktacular will"},{"type":"text","text":" "},{"type":"text","text":"wire it up automatically via this existing field."}]}],"name":"Important","type":"aside","style":"important"},{"text":"Security","anchor":"Security","level":2,"type":"heading"},{"text":"VNC over SSH Tunnel","anchor":"VNC-over-SSH-Tunnel","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"]},{"text":"VPC-Only Access","anchor":"VPC-Only-Access","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"]},{"text":"Per-VM Authentication","anchor":"Per-VM-Authentication","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Each VM has its own macOS user accounts and passwords. You can"},{"type":"text","text":" "},{"type":"text","text":"create dedicated accounts for different users:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"]},{"text":"Isolated Desktops","anchor":"Isolated-Desktops","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"For maximum security, use "},{"type":"codeVoice","code":"NetworkMode\/isolated"},{"type":"text","text":" networking"},{"type":"text","text":" "},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"type":"text","text":" "},{"type":"text","text":"communication is still possible via the VirtIO socket device,"},{"type":"text","text":" "},{"type":"text","text":"which is always attached regardless of network mode."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Isolated mode removes the network interface entirely."},{"type":"text","text":" "},{"type":"text","text":"VNC requires a network connection, so isolated VMs can only"},{"type":"text","text":" "},{"type":"text","text":"be accessed through the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"NetworkMode\/nat"},{"type":"text","text":" if you need VNC access with limited"},{"type":"text","text":" "},{"type":"text","text":"exposure."}]}],"name":"Note","type":"aside","style":"note"},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Each VM runs independently with its own display, network identity,"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}],"type":"paragraph"},{"text":"Shared Development Environment","anchor":"Shared-Development-Environment","level":3,"type":"heading"},{"syntax":"bash","type":"codeListing","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"]},{"text":"QA Test Lab","anchor":"QA-Test-Lab","level":3,"type":"heading"},{"syntax":"bash","type":"codeListing","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"]},{"text":"Kubernetes-Managed Desktops","anchor":"Kubernetes-Managed-Desktops","level":3,"type":"heading"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"]},{"syntax":"bash","type":"codeListing","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"]}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","url":"\/documentation\/spooktacularkit\/mlworkloads","title":"Machine Learning Workloads","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","kind":"article","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/bluebubblesguide","title":"Running BlueBubbles iMessage Server","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","title":"Configuring Jenkins Nodes","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","kind":"article","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","kind":"article","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/kubernetesguide","title":"Kubernetes Integration","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","kind":"article","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"type":"topic","url":"\/documentation\/spooktacularkit\/gettingstarted","title":"Getting Started with Spooktacular","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","url":"\/documentation\/spooktacularkit\/versioning","title":"Versioning & Release Schedule","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}]}}}