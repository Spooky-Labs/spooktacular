"content":[{"inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}],"type":"paragraph"}]}],"start":3},{"text":"From Any VNC Client","type":"heading","level":3,"anchor":"From-Any-VNC-Client"},{"type":"paragraph","inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Server:","type":"text"}]},{"type":"text","text":" The VM’s IP address (from "},{"code":"spook ip","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"text":" 5900 (default VNC port)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"text":" macOS user credentials or VNC password","type":"text"}]}]}]},{"type":"codeListing","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"syntax":"bash"},{"text":"Network Mode Considerations","type":"heading","level":3,"anchor":"Network-Mode-Considerations"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},{"text":" you choose affects how you connect:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connection method"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"bridged"}]},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},{"type":"text","text":" for the entitlement details."}]}],"type":"aside","style":"note"},{"text":"Display Configuration","type":"heading","level":2,"anchor":"Display-Configuration"},{"level":3,"anchor":"Resolution-and-DPI","text":"Resolution and DPI","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}]},{"type":"text","text":". This is set by "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","isActive":true},{"text":" when","type":"text"},{"type":"text","text":" "},{"text":"applying the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"]},{"text":"Dual Monitors","type":"heading","level":3,"anchor":"Dual-Monitors"},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"type":"codeListing","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"syntax":"bash"},{"inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"type":"text","text":" "},{"text":"display on port 5901.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","isActive":true},{"type":"text","text":" property controls the number of"},{"type":"text","text":" "},{"type":"text","text":"displays (valid range: 1-2)."}]},{"level":3,"type":"heading","text":"Auto-Resize Display","anchor":"Auto-Resize-Display"},{"inlineContent":[{"text":"When ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"syntax":"bash"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Auto-resize affects the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"VNC clients negotiate their own display size with the Screen","type":"text"},{"text":" ","type":"text"},{"text":"Sharing server.","type":"text"}]}],"name":"Note"},{"text":"Performance Considerations","type":"heading","level":2,"anchor":"Performance-Considerations"},{"text":"LAN vs WAN","type":"heading","level":3,"anchor":"LAN-vs-WAN"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Factor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"LAN (< 1ms latency)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Full 1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Consider 1280x800","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Color depth","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32-bit","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16-bit for better performance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Frame rate","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"30-60 fps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 fps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Responsiveness","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Excellent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Usable for most tasks","type":"text"}]}]]],"header":"row"},{"text":"Bandwidth Requirements","type":"heading","level":3,"anchor":"Bandwidth-Requirements"},{"type":"paragraph","inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Quality","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bandwidth","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Low (16-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"2-5 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Medium","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5-15 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (32-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (Retina)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"40-80 Mbps","type":"text"}]}]]],"header":"row"},{"text":"Optimizing for Slow Connections","type":"heading","level":3,"anchor":"Optimizing-for-Slow-Connections"},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a lower resolution display","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}]}]}]},{"type":"codeListing","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"syntax":"bash"},{"text":"Future: High-Performance Streaming","type":"heading","level":2,"anchor":"Future-High-Performance-Streaming"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"4K @ 60fps","type":"text"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sub-frame latency","type":"text"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Adaptive bitrate","type":"text"}],"type":"strong"},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"WebRTC transport","type":"text"}],"type":"strong"},{"text":" — Browser-based access without a VNC client","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"text":"Audio Forwarding","type":"heading","level":2,"anchor":"Audio-Forwarding"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"text":"Enabling Audio","type":"heading","level":3,"anchor":"Enabling-Audio"},{"type":"paragraph","inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"text":". To explicitly control it:","type":"text"}]},{"type":"codeListing","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}]},{"text":"Audio over VNC","type":"heading","level":3,"anchor":"Audio-over-VNC"},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}]},{"text":"Clipboard Sharing","type":"heading","level":2,"anchor":"Clipboard-Sharing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","isActive":true},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"type":"strong","inlineContent":[{"text":"only supported for Linux guests","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spice-vdagent"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}]},{"type":"codeListing","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"syntax":"bash"},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}]}],"name":"Important"},{"text":"Security","type":"heading","level":2,"anchor":"Security"},{"text":"VNC over SSH Tunnel","type":"heading","level":3,"anchor":"VNC-over-SSH-Tunnel"},{"type":"paragraph","inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}]},{"type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"syntax":"bash"},{"text":"VPC-Only Access","type":"heading","level":3,"anchor":"VPC-Only-Access"},{"type":"paragraph","inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}]},{"type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"syntax":"bash"},{"text":"Per-VM Authentication","type":"heading","level":3,"anchor":"Per-VM-Authentication"},{"type":"paragraph","inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}]},{"type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"syntax":"bash"},{"text":"Isolated Desktops","type":"heading","level":3,"anchor":"Isolated-Desktops"},{"type":"paragraph","inlineContent":[{"text":"For maximum security, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"syntax":"bash"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"text":"Multiple Users Accessing Different VMs","type":"heading","level":2,"anchor":"Multiple-Users-Accessing-Different-VMs"},{"type":"paragraph","inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}]},{"level":3,"anchor":"Shared-Development-Environment","text":"Shared Development Environment","type":"heading"},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing","syntax":"bash"},{"text":"QA Test Lab","type":"heading","level":3,"anchor":"QA-Test-Lab"},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"text":"Kubernetes-Managed Desktops","type":"heading","level":3,"anchor":"Kubernetes-Managed-Desktops"},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"syntax":"yaml"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"syntax":"bash","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","interfaceLanguage":"swift"},"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article","title":"Getting Started with Spooktacular","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/autoResizeDisplay":{"