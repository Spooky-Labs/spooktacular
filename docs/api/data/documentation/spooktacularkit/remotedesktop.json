{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Remote Desktop Access","role":"collectionGroup"},"kind":"article","variants":[{"paths":["\/documentation\/spooktacularkit\/remotedesktop"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","interfaceLanguage":"swift"},"sections":[],"seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true}],"topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"title":"Related Guides"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include full macOS display output backed by a","type":"text"},{"text":" ","type":"text"},{"text":"virtual GPU (","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":"). Combined with","type":"text"},{"text":" ","type":"text"},{"text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote","type":"text"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}]},{"anchor":"Use-Cases","type":"heading","level":3,"text":"Use Cases"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Remote development","type":"text"}]},{"text":" — Full macOS desktop for Xcode, Interface","type":"text"},{"text":" ","type":"text"},{"text":"Builder, and Simulator from any machine","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"QA testing","type":"text"}]},{"text":" — Manual testing of macOS and iOS apps in a","type":"text"},{"text":" ","type":"text"},{"text":"controlled, reproducible VM environment","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Design review","type":"text"}]},{"text":" — Share a running app with designers and","type":"text"},{"text":" ","type":"text"},{"text":"stakeholders without giving them SSH access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Training and demos","type":"text"}]},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Help desk","type":"text"}]},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Enabling-Screen-Sharing-via-Provisioning","type":"heading","level":2,"text":"Enabling Screen Sharing via Provisioning"},{"type":"paragraph","inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}]},{"anchor":"Using-disk-inject-Zero-Touch","type":"heading","level":3,"text":"Using disk-inject (Zero-Touch)"},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing","syntax":"bash"},{"anchor":"Using-the-Kubernetes-CRD","type":"heading","level":3,"text":"Using the Kubernetes CRD"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"code":"ProvisioningMode","type":"codeVoice"},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}]},{"anchor":"Connecting-via-VNC","type":"heading","level":2,"text":"Connecting via VNC"},{"anchor":"macOS-Screen-Sharing-App-Built-in","type":"heading","level":3,"text":"macOS Screen Sharing App (Built-in)"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}],"type":"paragraph"}]}]},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"start":2,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}],"type":"paragraph"}]}]},{"code":["open vnc:\/\/192.168.64.3"],"type":"codeListing","syntax":"bash"},{"start":3,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"From-Any-VNC-Client","type":"heading","level":3,"text":"From Any VNC Client"},{"type":"paragraph","inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Server:","type":"text"}]},{"text":" The VM’s IP address (from ","type":"text"},{"code":"spook ip","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Port:","type":"text"}]},{"text":" 5900 (default VNC port)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Authentication:","type":"text"}]},{"text":" macOS user credentials or VNC password","type":"text"}],"type":"paragraph"}]}]},{"code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"type":"codeListing","syntax":"bash"},{"anchor":"Network-Mode-Considerations","type":"heading","level":3,"text":"Network Mode Considerations"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"NetworkMode","type":"codeVoice"},{"text":" you choose affects how you connect:","type":"text"}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Network Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VM IP reachable from"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Connection method"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"NetworkMode\/nat","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Host only"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"NetworkMode\/bridged(interface:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entire LAN"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Direct VNC connection"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"NetworkMode\/isolated","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Nowhere"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Not suitable for VNC"}],"type":"paragraph"}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"inlineContent":[{"type":"text","text":"bridged"}],"type":"strong"},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":" for the entitlement details."}],"type":"paragraph"}],"name":"Note"},{"anchor":"Display-Configuration","type":"heading","level":2,"text":"Display Configuration"},{"anchor":"Resolution-and-DPI","type":"heading","level":3,"text":"Resolution and DPI"},{"type":"paragraph","inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}],"type":"strong"},{"text":". This is set by ","type":"text"},{"code":"VirtualMachineConfiguration","type":"codeVoice"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"type":"codeListing","syntax":"swift"},{"anchor":"Dual-Monitors","type":"heading","level":3,"text":"Dual Monitors"},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/displayCount","type":"codeVoice"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}]},{"anchor":"Auto-Resize-Display","type":"heading","level":3,"text":"Auto-Resize Display"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"VirtualMachineSpecification\/autoResizeDisplay","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}],"name":"Note"},{"anchor":"Performance-Considerations","type":"heading","level":2,"text":"Performance Considerations"},{"anchor":"LAN-vs-WAN","type":"heading","level":3,"text":"LAN vs WAN"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Factor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Full 1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Consider 1280x800"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Frame rate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"30-60 fps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15-30 fps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Responsiveness"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Excellent"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Usable for most tasks"}],"type":"paragraph"}]]],"header":"row"},{"anchor":"Bandwidth-Requirements","type":"heading","level":3,"text":"Bandwidth Requirements"},{"type":"paragraph","inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Quality"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bandwidth"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1280x800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-5 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Medium"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5-15 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (32-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15-30 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3840x2400"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (Retina)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"40-80 Mbps"}],"type":"paragraph"}]]],"header":"row"},{"anchor":"Optimizing-for-Slow-Connections","type":"heading","level":3,"text":"Optimizing for Slow Connections"},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use a lower resolution display","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"anchor":"Future-High-Performance-Streaming","type":"heading","level":2,"text":"Future: High-Performance Streaming"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"4K @ 60fps","type":"text"}]},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sub-frame latency","type":"text"}]},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Adaptive bitrate","type":"text"}]},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"WebRTC transport","type":"text"}]},{"text":" — Browser-based access without a VNC client","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}]},{"anchor":"Audio-Forwarding","type":"heading","level":2,"text":"Audio Forwarding"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"VZVirtioSoundDeviceConfiguration","type":"codeVoice"},{"type":"text","text":") by default. Audio from the guest"},{"type":"text","text":" "},{"type":"text","text":"macOS is forwarded to the host’s speakers."}]},{"anchor":"Enabling-Audio","type":"heading","level":3,"text":"Enabling Audio"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"type":"text","text":". To explicitly control it:"}]},{"code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"VirtualMachineSpecification\/audioEnabled","type":"codeVoice"},{"type":"text","text":" and "},{"code":"VirtualMachineSpecification\/microphoneEnabled","type":"codeVoice"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}]},{"anchor":"Audio-over-VNC","type":"heading","level":3,"text":"Audio over VNC"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Clipboard-Sharing","type":"heading","level":2,"text":"Clipboard Sharing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"VirtualMachineSpecification\/clipboardSharingEnabled","type":"codeVoice"},{"type":"text","text":" field"},{"type":"text","text":" "},{"type":"text","text":"exists for forward compatibility, but clipboard sharing through the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework is "},{"inlineContent":[{"text":"only supported for Linux guests","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"code":"VZSpiceAgentPortAttachment","type":"codeVoice"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"code":"spice-vdagent","type":"codeVoice"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"type":"text","text":" "},{"type":"text","text":"logged at configuration time and no console device is attached."}]},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"important","content":[{"inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}],"type":"paragraph"}],"name":"Important"},{"anchor":"Security","type":"heading","level":2,"text":"Security"},{"anchor":"VNC-over-SSH-Tunnel","type":"heading","level":3,"text":"VNC over SSH Tunnel"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}]},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"type":"codeListing","syntax":"bash"},{"anchor":"VPC-Only-Access","type":"heading","level":3,"text":"VPC-Only Access"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}]},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"type":"codeListing","syntax":"bash"},{"anchor":"Per-VM-Authentication","type":"heading","level":3,"text":"Per-VM Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM has its own macOS user accounts and passwords. You can"},{"type":"text","text":" "},{"type":"text","text":"create dedicated accounts for different users:"}]},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"type":"codeListing","syntax":"bash"},{"anchor":"Isolated-Desktops","type":"heading","level":3,"text":"Isolated Desktops"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For maximum security, use "},{"code":"NetworkMode\/isolated","type":"codeVoice"},{"type":"text","text":" networking"},{"type":"text","text":" "},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"type":"text","text":" "},{"type":"text","text":"communication is still possible via the VirtIO socket device,"},{"type":"text","text":" "},{"type":"text","text":"which is always attached regardless of network mode."}]},{"code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"code":"NetworkMode\/nat","type":"codeVoice"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"anchor":"Multiple-Users-Accessing-Different-VMs","type":"heading","level":2,"text":"Multiple Users Accessing Different VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM runs independently with its own display, network identity,"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}]},{"anchor":"Shared-Development-Environment","type":"heading","level":3,"text":"Shared Development Environment"},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing","syntax":"bash"},{"anchor":"QA-Test-Lab","type":"heading","level":3,"text":"QA Test Lab"},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"anchor":"Kubernetes-Managed-Desktops","type":"heading","level":3,"text":"Kubernetes-Managed Desktops"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing","syntax":"yaml"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing","syntax":"bash"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"type":"topic","kind":"article","title":"Versioning & Release Schedule","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","kind":"symbol","title":"SpooktacularKit","role":"collection","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface","role":"collectionGroup","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","role":"collectionGroup","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration","role":"collectionGroup","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"type":"topic","kind":"article","title":"Running BlueBubbles iMessage Server","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/jenkinsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","role":"collectionGroup","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","role":"collectionGroup","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"type":"topic"}}}