{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular VMs include full macOS display output backed by a"},{"type":"text","text":" "},{"type":"text","text":"virtual GPU ("},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"type":"text","text":"). Combined with"},{"type":"text","text":" "},{"type":"text","text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}]},{"level":3,"anchor":"Use-Cases","type":"heading","text":"Use Cases"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Remote development"}],"type":"strong"},{"type":"text","text":" — Full macOS desktop for Xcode, Interface"},{"type":"text","text":" "},{"type":"text","text":"Builder, and Simulator from any machine"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"QA testing","type":"text"}]},{"type":"text","text":" — Manual testing of macOS and iOS apps in a"},{"type":"text","text":" "},{"type":"text","text":"controlled, reproducible VM environment"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Design review","type":"text"}],"type":"strong"},{"text":" — Share a running app with designers and","type":"text"},{"text":" ","type":"text"},{"text":"stakeholders without giving them SSH access","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Training and demos"}]},{"type":"text","text":" — Provide ephemeral macOS desktops for"},{"type":"text","text":" "},{"type":"text","text":"workshops or customer demos"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Help desk"}]},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}]}]}]},{"level":2,"text":"Enabling Screen Sharing via Provisioning","type":"heading","anchor":"Enabling-Screen-Sharing-via-Provisioning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most reliable way to enable VNC access is through a provisioning"},{"type":"text","text":" "},{"type":"text","text":"script that runs automatically when the VM boots."}]},{"level":3,"text":"Using disk-inject (Zero-Touch)","type":"heading","anchor":"Using-disk-inject-Zero-Touch"},{"syntax":"bash","type":"codeListing","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""]},{"level":3,"text":"Using the Kubernetes CRD","type":"heading","anchor":"Using-the-Kubernetes-CRD"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for details on all four "},{"type":"codeVoice","code":"ProvisioningMode"},{"type":"text","text":" "},{"type":"text","text":"strategies."}]},{"level":2,"text":"Connecting via VNC","type":"heading","anchor":"Connecting-via-VNC"},{"level":3,"text":"macOS Screen Sharing App (Built-in)","type":"heading","anchor":"macOS-Screen-Sharing-App-Built-in"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest way to connect from another Mac:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Find the VM’s IP address:"}],"type":"paragraph"}]}],"type":"orderedList"},{"syntax":"bash","type":"codeListing","code":["spook ip desktop-vm","# 192.168.64.3"]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}],"type":"paragraph"}]}],"type":"orderedList","start":2},{"type":"codeListing","code":["open vnc:\/\/192.168.64.3"],"syntax":"bash"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}],"type":"paragraph"}]}],"type":"orderedList","start":3},{"level":3,"type":"heading","text":"From Any VNC Client","anchor":"From-Any-VNC-Client"},{"inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Server:"}],"type":"strong"},{"text":" The VM’s IP address (from ","type":"text"},{"code":"spook ip","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Port:"}],"type":"strong"},{"text":" 5900 (default VNC port)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"text":" macOS user credentials or VNC password","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"syntax":"bash"},{"level":3,"type":"heading","text":"Network Mode Considerations","anchor":"Network-Mode-Considerations"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Network Mode","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connection method"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"text":"Connect from host, or SSH tunnel","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"NetworkMode\/bridged(interface:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Entire LAN","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"text":"Nowhere","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"header":"row","type":"table"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For remote desktop scenarios, "},{"inlineContent":[{"type":"text","text":"bridged"}],"type":"strong"},{"type":"text","text":" mode is recommended because"},{"type":"text","text":" "},{"type":"text","text":"it gives the VM its own IP address on the LAN, allowing direct"},{"type":"text","text":" "},{"type":"text","text":"connections from any machine."}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":" for the entitlement details."}],"type":"paragraph"}]},{"text":"Display Configuration","level":2,"type":"heading","anchor":"Display-Configuration"},{"text":"Resolution and DPI","level":3,"type":"heading","anchor":"Resolution-and-DPI"},{"inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"type":"text","text":". This is set by "},{"type":"codeVoice","code":"VirtualMachineConfiguration"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"applying the "},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"type":"codeListing","syntax":"swift"},{"text":"Dual Monitors","level":3,"type":"heading","anchor":"Dual-Monitors"},{"inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}],"type":"paragraph"},{"code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"Each display gets its own VNC session. Connect to the second"},{"type":"text","text":" "},{"type":"text","text":"display on port 5901."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VirtualMachineSpecification\/displayCount"},{"type":"text","text":" property controls the number of"},{"type":"text","text":" "},{"type":"text","text":"displays (valid range: 1-2)."}],"type":"paragraph"},{"type":"heading","anchor":"Auto-Resize-Display","level":3,"text":"Auto-Resize Display"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/autoResizeDisplay"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"heading","anchor":"Performance-Considerations","level":2,"text":"Performance Considerations"},{"type":"heading","anchor":"LAN-vs-WAN","level":3,"text":"LAN vs WAN"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Factor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"LAN (< 1ms latency)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full 1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider 1280x800"}]}]],[[{"inlineContent":[{"text":"Color depth","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Frame rate","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"30-60 fps"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 fps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Responsiveness"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Excellent","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Usable for most tasks","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"level":3,"anchor":"Bandwidth-Requirements","text":"Bandwidth Requirements","type":"heading"},{"inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Quality","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Bandwidth","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1280x800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-5 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"5-15 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (32-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3840x2400"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (Retina)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"40-80 Mbps"}],"type":"paragraph"}]]],"type":"table"},{"type":"heading","text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","level":3},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a lower resolution display"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable compression (most clients support ZRLE or Tight encoding)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Consider an SSH tunnel with compression ("},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"]},{"type":"heading","text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming","level":2},{"inlineContent":[{"type":"text","text":"Spooktacular’s roadmap includes high-performance display streaming"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"4K @ 60fps","type":"text"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sub-frame latency","type":"text"}]},{"type":"text","text":" — Direct Metal capture to hardware encoder"},{"type":"text","text":" "},{"type":"text","text":"pipeline"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Adaptive bitrate","type":"text"}]},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"WebRTC transport"}],"type":"strong"},{"type":"text","text":" — Browser-based access without a VNC client"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}],"type":"paragraph"},{"level":2,"text":"Audio Forwarding","anchor":"Audio-Forwarding","type":"heading"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"type":"text","text":") by default. Audio from the guest"},{"type":"text","text":" "},{"type":"text","text":"macOS is forwarded to the host’s speakers."}],"type":"paragraph"},{"level":3,"text":"Enabling Audio","type":"heading","anchor":"Enabling-Audio"},{"inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"type":"text","text":". To explicitly control it:"}],"type":"paragraph"},{"syntax":"bash","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"code":"VirtualMachineSpecification\/audioEnabled","type":"codeVoice"},{"type":"text","text":" and "},{"code":"VirtualMachineSpecification\/microphoneEnabled","type":"codeVoice"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}],"type":"paragraph"},{"level":3,"text":"Audio over VNC","type":"heading","anchor":"Audio-over-VNC"},{"inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a third-party solution like PulseAudio over network"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}],"type":"orderedList"},{"level":2,"anchor":"Clipboard-Sharing","text":"Clipboard Sharing","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/clipboardSharingEnabled"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"inlineContent":[{"text":"only supported for Linux guests","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"type":"codeVoice","code":"spice-vdagent"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}],"type":"paragraph"},{"inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}],"type":"paragraph"},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"syntax":"bash","type":"codeListing"},{"name":"Important","style":"important","content":[{"inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"level":2,"text":"Security","type":"heading","anchor":"Security"},{"level":3,"text":"VNC over SSH Tunnel","type":"heading","anchor":"VNC-over-SSH-Tunnel"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}]},{"syntax":"bash","type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"]},{"level":3,"text":"VPC-Only Access","type":"heading","anchor":"VPC-Only-Access"},{"type":"paragraph","inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"]},{"level":3,"text":"Per-VM Authentication","type":"heading","anchor":"Per-VM-Authentication"},{"type":"paragraph","inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"]},{"level":3,"text":"Isolated Desktops","type":"heading","anchor":"Isolated-Desktops"},{"type":"paragraph","inlineContent":[{"text":"For maximum security, use ","type":"text"},{"code":"NetworkMode\/isolated","type":"codeVoice"},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Isolated mode removes the network interface entirely."},{"type":"text","text":" "},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"NetworkMode\/nat"},{"type":"text","text":" if you need VNC access with limited"},{"type":"text","text":" "},{"type":"text","text":"exposure."}],"type":"paragraph"}],"name":"Note"},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","type":"heading","level":2},{"inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}],"type":"paragraph"},{"text":"Shared Development Environment","anchor":"Shared-Development-Environment","type":"heading","level":3},{"syntax":"bash","type":"codeListing","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"]},{"text":"QA Test Lab","anchor":"QA-Test-Lab","type":"heading","level":3},{"syntax":"bash","type":"codeListing","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"]},{"text":"Kubernetes-Managed Desktops","anchor":"Kubernetes-Managed-Desktops","type":"heading","level":3},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"]},{"syntax":"bash","type":"codeListing","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"]}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/do