ext","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Training and demos","type":"text"}],"type":"strong"},{"type":"text","text":" — Provide ephemeral macOS desktops for"},{"type":"text","text":" "},{"type":"text","text":"workshops or customer demos"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Help desk","type":"text"}],"type":"strong"},{"type":"text","text":" — Remote access to user-like macOS environments"},{"type":"text","text":" "},{"type":"text","text":"for support and troubleshooting"}]}]}],"type":"unorderedList"},{"anchor":"Enabling-Screen-Sharing-via-Provisioning","type":"heading","text":"Enabling Screen Sharing via Provisioning","level":2},{"type":"paragraph","inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}]},{"anchor":"Using-disk-inject-Zero-Touch","type":"heading","text":"Using disk-inject (Zero-Touch)","level":3},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"type":"codeVoice","code":"enable-screensharing.sh"},{"text":":","type":"text"}]},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing","syntax":"bash"},{"anchor":"Using-the-Kubernetes-CRD","type":"heading","text":"Using the Kubernetes CRD","level":3},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","isActive":true},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}]},{"anchor":"Connecting-via-VNC","type":"heading","text":"Connecting via VNC","level":2},{"anchor":"macOS-Screen-Sharing-App-Built-in","type":"heading","text":"macOS Screen Sharing App (Built-in)","level":3},{"type":"paragraph","inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Find the VM’s IP address:"}]}]}],"type":"orderedList"},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}]}]}],"type":"orderedList","start":2},{"code":["open vnc:\/\/192.168.64.3"],"type":"codeListing","syntax":"bash"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}]}]}],"type":"orderedList","start":3},{"anchor":"From-Any-VNC-Client","type":"heading","text":"From Any VNC Client","level":3},{"type":"paragraph","inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Server:","type":"text"}],"type":"strong"},{"type":"text","text":" The VM’s IP address (from "},{"code":"spook ip","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"type":"text","text":" 5900 (default VNC port)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"type":"text","text":" macOS user credentials or VNC password"}]}]}],"type":"unorderedList"},{"code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"type":"codeListing","syntax":"bash"},{"anchor":"Network-Mode-Considerations","type":"heading","text":"Network Mode Considerations","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true},{"text":" you choose affects how you connect:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connection method"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"bridged"}]},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true},{"type":"text","text":" for the entitlement details."}]}],"style":"note"},{"anchor":"Display-Configuration","type":"heading","text":"Display Configuration","level":2},{"anchor":"Resolution-and-DPI","type":"heading","text":"Resolution and DPI","level":3},{"type":"paragraph","inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"text":". This is set by ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","isActive":true},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"text":":","type":"text"}]},{"code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"type":"codeListing","syntax":"swift"},{"anchor":"Dual-Monitors","type":"heading","text":"Dual Monitors","level":3},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each display gets its own VNC session. Connect to the second"},{"type":"text","text":" "},{"type":"text","text":"display on port 5901."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","isActive":true},{"type":"text","text":" property controls the number of"},{"type":"text","text":" "},{"type":"text","text":"displays (valid range: 1-2)."}]},{"anchor":"Auto-Resize-Display","type":"heading","text":"Auto-Resize Display","level":3},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay","type":"reference"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"guest display resolution adjusts to match the Spooktacular window"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Auto-resize affects the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"VNC clients negotiate their own display size with the Screen","type":"text"},{"text":" ","type":"text"},{"text":"Sharing server.","type":"text"}]}],"style":"note"},{"type":"heading","level":2,"text":"Performance Considerations","anchor":"Performance-Considerations"},{"anchor":"LAN-vs-WAN","type":"heading","text":"LAN vs WAN","level":3},{"rows":[[[{"inlineContent":[{"text":"Factor","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}]}],[{"type":"paragraph","inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Full 1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Consider 1280x800","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Color depth","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32-bit","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16-bit for better performance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Frame rate","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"30-60 fps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 fps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Responsiveness","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Excellent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Usable for most tasks","type":"text"}]}]]],"type":"table","header":"row"},{"anchor":"Bandwidth-Requirements","type":"heading","text":"Bandwidth Requirements","level":3},{"type":"paragraph","inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Quality","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bandwidth","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Low (16-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"2-5 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Medium","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5-15 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (32-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (Retina)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"40-80 Mbps","type":"text"}]}]]],"type":"table","header":"row"},{"anchor":"Optimizing-for-Slow-Connections","type":"heading","text":"Optimizing for Slow Connections","level":3},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use a lower resolution display"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable compression (most clients support ZRLE or Tight encoding)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Consider an SSH tunnel with compression ("},{"type":"codeVoice","code":"ssh -C"},{"type":"text","text":")"}],"type":"paragraph"}]}],"type":"orderedList"},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"anchor":"Future-High-Performance-Streaming","type":"heading","text":"Future: High-Performance Streaming","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"4K @ 60fps"}]},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"type":"text","text":" "},{"type":"text","text":"host’s hardware encoder"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sub-frame latency"}]},{"type":"text","text":" — Direct Metal capture to hardware encoder"},{"type":"text","text":" "},{"type":"text","text":"pipeline"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Adaptive bitrate"}]},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"WebRTC transport"}]},{"type":"text","text":" — Browser-based access without a VNC client"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"anchor":"Audio-Forwarding","type":"heading","text":"Audio Forwarding","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"anchor":"Enabling-Audio","type":"heading","text":"Enabling Audio","level":3},{"type":"paragraph","inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"text":". To explicitly control it:","type":"text"}]},{"code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}]},{"anchor":"Audio-over-VNC","type":"heading","text":"Audio over VNC","level":3},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use Apple Remote Desktop (ARD) which supports audio forwarding"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Use a third-party solution like PulseAudio over network"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For simple cases, forward audio via the Spooktacular host’s"},{"type":"text","text":" "},{"type":"text","text":"speakers (if you are physically near the host)"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Clipboard-Sharing","type":"heading","text":"Clipboard Sharing","level":2},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","isActive":true},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"type":"strong","inlineContent":[{"text":"only supported for Linux guests","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spice-vdagent"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}]},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"type":"codeListing","syntax":"bash"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}]}],"style":"important"},{"anchor":"Security","type":"heading","text":"Security","level":2},{"anchor":"VNC-over-SSH-Tunnel","type":"heading","text":"VNC over SSH Tunnel","level":3},{"type":"paragraph","inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}]},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"text":"VPC-Only Access","anchor":"VPC-Only-Access"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}]},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"type":"codeListing","syntax":"bash"},{"anchor":"Per-VM-Authentication","type":"heading","text":"Per-VM Authentication","level":3},{"type":"paragraph","inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"type":"text","text":" "},{"text":"create dedicated accounts for different users:","type":"text"}]},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"text":"Isolated Desktops","anchor":"Isolated-Desktops"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For maximum security, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Isolated mode removes the network interface entirely."},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}],"type":"paragraph"}],"style":"note"},{"anchor":"Multiple-Users-Accessing-Different-VMs","type":"heading","text":"Multiple Users Accessing Different VMs","level":2},{"type":"paragraph","inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}]},{"anchor":"Shared-Development-Environment","type":"heading","text":"Shared Development Environment","level":3},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing","syntax":"bash"},{"anchor":"QA-Test-Lab","type":"heading","text":"QA Test Lab","level":3},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"anchor":"Kubernetes-Managed-Desktops","type":"heading","text":"Kubernetes-Managed Desktops","level":3},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing","syntax":"yaml"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing","syntax":"bash"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit