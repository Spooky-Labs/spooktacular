g Jenkins Nodes","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/clipboardSharingEnabled":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","kind":"symbol","title":"clipboardSharingEnabled","type":"topic","abstract":[{"type":"text","text":"Whether the host and guest share a common clipboard."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"clipboardSharingEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/clipboardsharingenabled"}}}