ubernetesGuide","title":"Kubernetes Integration","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/audioEnabled":{"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/audioenabled","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"audioEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","kind":"symbol","title":"audioEnabled","abstract":[{"type":"text","text":"Whether the VM has an audio output device attached."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktopTemplate":{"type":"topic","url":"\/documentation\/spooktacularkit\/remotedesktoptemplate","navigatorTitle":[{"text":"RemoteDesktopTemplate","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate","title":"RemoteDesktopTemplate","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RemoteDesktopTemplate","kind":"identifier"}],"abstract":[{"type":"text","text":"Generates user-data scripts for remote desktop (Screen Sharing) VMs."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","url":"\/documen