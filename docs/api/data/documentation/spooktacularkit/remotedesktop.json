{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Remote Desktop Access"},"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"topicSections":[{"title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"anchor":"Related-Guides"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/remotedesktop"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include full macOS display output backed by a","type":"text"},{"text":" ","type":"text"},{"text":"virtual GPU (","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":"). Combined with","type":"text"},{"text":" ","type":"text"},{"text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote","type":"text"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}]},{"text":"Use Cases","anchor":"Use-Cases","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Remote development"}],"type":"strong"},{"text":" — Full macOS desktop for Xcode, Interface","type":"text"},{"text":" ","type":"text"},{"text":"Builder, and Simulator from any machine","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"QA testing"}],"type":"strong"},{"text":" — Manual testing of macOS and iOS apps in a","type":"text"},{"text":" ","type":"text"},{"text":"controlled, reproducible VM environment","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Design review"}],"type":"strong"},{"text":" — Share a running app with designers and","type":"text"},{"text":" ","type":"text"},{"text":"stakeholders without giving them SSH access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Training and demos"}],"type":"strong"},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Help desk"}],"type":"strong"},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}],"type":"paragraph"}]}]},{"text":"Enabling Screen Sharing via Provisioning","anchor":"Enabling-Screen-Sharing-via-Provisioning","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}]},{"text":"Using disk-inject (Zero-Touch)","anchor":"Using-disk-inject-Zero-Touch","type":"heading","level":3},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing","syntax":"bash"},{"text":"Using the Kubernetes CRD","anchor":"Using-the-Kubernetes-CRD","type":"heading","level":3},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"code":"ProvisioningMode","type":"codeVoice"},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}]},{"text":"Connecting via VNC","anchor":"Connecting-via-VNC","type":"heading","level":2},{"text":"macOS Screen Sharing App (Built-in)","anchor":"macOS-Screen-Sharing-App-Built-in","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}],"type":"paragraph"}]}]},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"start":2,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}],"type":"paragraph"}]}]},{"code":["open vnc:\/\/192.168.64.3"],"type":"codeListing","syntax":"bash"},{"start":3,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}],"type":"paragraph"}]}]},{"text":"From Any VNC Client","anchor":"From-Any-VNC-Client","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Server:"}],"type":"strong"},{"text":" The VM’s IP address (from ","type":"text"},{"code":"spook ip","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Port:"}],"type":"strong"},{"text":" 5900 (default VNC port)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Authentication:"}],"type":"strong"},{"text":" macOS user credentials or VNC password","type":"text"}],"type":"paragraph"}]}]},{"code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"type":"codeListing","syntax":"bash"},{"text":"Network Mode Considerations","anchor":"Network-Mode-Considerations","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"NetworkMode","type":"codeVoice"},{"text":" you choose affects how you connect:","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connection method"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/bridged(interface:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]]},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"bridged"}]},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":" for the entitlement details."}]}],"name":"Note","style":"note"},{"text":"Display Configuration","anchor":"Display-Configuration","type":"heading","level":2},{"text":"Resolution and DPI","anchor":"Resolution-and-DPI","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"text":". This is set by ","type":"text"},{"code":"VirtualMachineConfiguration","type":"codeVoice"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"type":"codeListing","syntax":"swift"},{"text":"Dual Monitors","anchor":"Dual-Monitors","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/displayCount","type":"codeVoice"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}]},{"text":"Auto-Resize Display","anchor":"Auto-Resize-Display","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"VirtualMachineSpecification\/autoResizeDisplay","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}]}],"name":"Note","style":"note"},{"text":"Performance Considerations","anchor":"Performance-Considerations","type":"heading","level":2},{"text":"LAN vs WAN","anchor":"LAN-vs-WAN","type":"heading","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Factor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full 1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider 1280x800"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Color depth"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32-bit"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16-bit for better performance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Frame rate"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"30-60 fps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 fps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Responsiveness"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Excellent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Usable for most tasks"}]}]]]},{"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Quality"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bandwidth"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1280x800"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Low (16-bit)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"2-5 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Medium"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5-15 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (32-bit)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3840x2400"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (Retina)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"40-80 Mbps"}]}]]]},{"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use a lower resolution display","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"4K @ 60fps"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Adaptive bitrate"}],"type":"strong"},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"WebRTC transport"}],"type":"strong"},{"text":" — Browser-based access without a VNC client","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"text":"Audio Forwarding","anchor":"Audio-Forwarding","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"VZVirtioSoundDeviceConfiguration","type":"codeVoice"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"text":"Enabling Audio","anchor":"Enabling-Audio","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":". To explicitly control it:","type":"text"}]},{"code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"VirtualMachineSpecification\/audioEnabled","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"VirtualMachineSpecification\/microphoneEnabled","type":"codeVoice"},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}]},{"text":"Audio over VNC","anchor":"Audio-over-VNC","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}],"type":"paragraph"}]}]},{"text":"Clipboard Sharing","anchor":"Clipboard-Sharing","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/clipboardSharingEnabled","type":"codeVoice"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"only supported for Linux guests"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"code":"VZSpiceAgentPortAttachment","type":"codeVoice"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"code":"spice-vdagent","type":"codeVoice"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}]},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"type":"codeListing","syntax":"bash"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There is currently no Virtualization framework API for"},{"type":"text","text":" "},{"type":"text","text":"clipboard synchronization between the host and a macOS guest. If"},{"type":"text","text":" "},{"type":"text","text":"Apple adds this capability in a future release, Spooktacular will"},{"type":"text","text":" "},{"type":"text","text":"wire it up automatically via this existing field."}]}],"name":"Important","style":"important"},{"text":"Security","anchor":"Security","type":"heading","level":2},{"text":"VNC over SSH Tunnel","anchor":"VNC-over-SSH-Tunnel","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}]},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"type":"codeListing","syntax":"bash"},{"text":"VPC-Only Access","anchor":"VPC-Only-Access","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}]},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"type":"codeListing","syntax":"bash"},{"text":"Per-VM Authentication","anchor":"Per-VM-Authentication","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}]},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"type":"codeListing","syntax":"bash"},{"text":"Isolated Desktops","anchor":"Isolated-Desktops","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"For maximum security, use ","type":"text"},{"code":"NetworkMode\/isolated","type":"codeVoice"},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"type":"codeListing","syntax":"bash"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Isolated mode removes the network interface entirely."},{"type":"text","text":" "},{"type":"text","text":"VNC requires a network connection, so isolated VMs can only"},{"type":"text","text":" "},{"type":"text","text":"be accessed through the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"codeVoice","code":"NetworkMode\/nat"},{"type":"text","text":" if you need VNC access with limited"},{"type":"text","text":" "},{"type":"text","text":"exposure."}]}],"name":"Note","style":"note"},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}]},{"text":"Shared Development Environment","anchor":"Shared-Development-Environment","type":"heading","level":3},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing","syntax":"bash"},{"text":"QA Test Lab","anchor":"QA-Test-Lab","type":"heading","level":3},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"text":"Kubernetes-Managed Desktops","anchor":"Kubernetes-Managed-Desktops","type":"heading","level":3},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing","syntax":"yaml"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing","syntax":"bash"}]}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","kind":"symbol","role":"collection","title":"SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","kind":"article","role":"collectionGroup","title":"Deploying on EC2 Mac","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"type":"topic","kind":"article","role":"collectionGroup","title":"Machine Learning Workloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"type":"topic","kind":"article","role":"collectionGroup","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","role":"collectionGroup","title":"Configuring Jenkins Nodes","url":"\/documentation\/spooktacularkit\/jenkinsguide","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"code":"spook","type":"codeVoice"},{"type":"text","text":" CLI."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","title":"Using the spook Command-Line Interface","url":"\/documentation\/spooktacularkit\/clireference","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","url":"\/documentation\/spooktacularkit\/openclawguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","title":"Versioning & Release Schedule","url":"\/documentation\/spooktacularkit\/versioning","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Kubernetes Integration","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"type":"topic","kind":"article","role":"collectionGroup","title":"Running BlueBubbles iMessage Server","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","url":"\/documentation\/spooktacularkit\/bluebubblesguide"}}}