pe":"text","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Training and demos","type":"text"}]},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Help desk"}]},{"type":"text","text":" — Remote access to user-like macOS environments"},{"text":" ","type":"text"},{"type":"text","text":"for support and troubleshooting"}]}]}],"type":"unorderedList"},{"text":"Enabling Screen Sharing via Provisioning","type":"heading","level":2,"anchor":"Enabling-Screen-Sharing-via-Provisioning"},{"type":"paragraph","inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"type":"text","text":" "},{"type":"text","text":"script that runs automatically when the VM boots."}]},{"anchor":"Using-disk-inject-Zero-Touch","type":"heading","level":3,"text":"Using disk-inject (Zero-Touch)"},{"type":"codeListing","syntax":"bash","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where "},{"type":"codeVoice","code":"enable-screensharing.sh"},{"text":":","type":"text"}]},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement