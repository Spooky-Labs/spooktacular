{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true,"anchor":"Guides"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include full macOS display output backed by a"},{"text":" ","type":"text"},{"type":"text","text":"virtual GPU ("},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"type":"text","text":"). Combined with"},{"text":" ","type":"text"},{"type":"text","text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote"},{"type":"text","text":" "},{"type":"text","text":"graphical access to any VM from anywhere on your network."}],"type":"paragraph"},{"text":"Use Cases","type":"heading","level":3,"anchor":"Use-Cases"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remote development"}]},{"text":" — Full macOS desktop for Xcode, Interface","type":"text"},{"text":" ","type":"text"},{"text":"Builder, and Simulator from any machine","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"QA testing"}]},{"text":" — Manual testing of macOS and iOS apps in a","type":"text"},{"text":" ","type":"text"},{"text":"controlled, reproducible VM environment","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Design review"}]},{"text":" — Share a running app with designers and","type":"text"},{"text":" ","type":"text"},{"text":"stakeholders without giving them SSH access","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Training and demos"}]},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Help desk"}]},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}],"type":"paragraph"}]}]},{"text":"Enabling Screen Sharing via Provisioning","type":"heading","level":2,"anchor":"Enabling-Screen-Sharing-via-Provisioning"},{"inlineContent":[{"type":"text","text":"The most reliable way to enable VNC access is through a provisioning"},{"type":"text","text":" "},{"type":"text","text":"script that runs automatically when the VM boots."}],"type":"paragraph"},{"text":"Using disk-inject (Zero-Touch)","type":"heading","level":3,"anchor":"Using-disk-inject-Zero-Touch"},{"syntax":"bash","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Where "},{"code":"enable-screensharing.sh","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing"},{"text":"Using the Kubernetes CRD","type":"heading","level":3,"anchor":"Using-the-Kubernetes-CRD"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"text","text":"doc:Provisioning"},{"type":"text","text":" for details on all four "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"strategies."}],"type":"paragraph"},{"text":"Connecting via VNC","type":"heading","level":2,"anchor":"Connecting-via-VNC"},{"text":"macOS Screen Sharing App (Built-in)","type":"heading","level":3,"anchor":"macOS-Screen-Sharing-App-Built-in"},{"inlineContent":[{"type":"text","text":"The simplest way to connect from another Mac:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}],"type":"paragraph"}]}]},{"syntax":"bash","code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing"},{"start":2,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}],"type":"paragraph"}]}]},{"syntax":"bash","code":["open vnc:\/\/192.168.64.3"],"type":"codeListing"},{"start":3,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}],"type":"paragraph"}]}]},{"text":"From Any VNC Client","type":"heading","level":3,"anchor":"From-Any-VNC-Client"},{"inlineContent":[{"type":"text","text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Server:"}]},{"text":" The VM’s IP address (from ","type":"text"},{"type":"codeVoice","code":"spook ip"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Port:"}]},{"text":" 5900 (default VNC port)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Authentication:"}]},{"text":" macOS user credentials or VNC password","type":"text"}],"type":"paragraph"}]}]},{"syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"type":"codeListing"},{"text":"Network Mode Considerations","type":"heading","level":3,"anchor":"Network-Mode-Considerations"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true,"type":"reference"},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Network Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"VM IP reachable from","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Connection method","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Host only","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Connect from host, or SSH tunnel","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Entire LAN","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Direct VNC connection","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Nowhere","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Not suitable for VNC","type":"text"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"For remote desktop scenarios, "},{"inlineContent":[{"text":"bridged","type":"text"}],"type":"strong"},{"type":"text","text":" mode is recommended because"},{"type":"text","text":" "},{"type":"text","text":"it gives the VM its own IP address on the LAN, allowing direct"},{"type":"text","text":" "},{"type":"text","text":"connections from any machine."}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"text":"Bridged networking requires the ","type":"text"},{"code":"com.apple.vm.networking","type":"codeVoice"},{"text":" ","type":"text"},{"text":"entitlement. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"reference"},{"text":" for the entitlement details.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"text":"Display Configuration","type":"heading","level":2,"anchor":"Display-Configuration"},{"text":"Resolution and DPI","type":"heading","level":3,"anchor":"Resolution-and-DPI"},{"inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"type":"text","text":" "},{"inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}],"type":"strong"},{"type":"text","text":". This is set by "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"applying the "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true,"type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"type":"codeListing"},{"text":"Dual Monitors","type":"heading","level":3,"anchor":"Dual-Monitors"},{"inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}],"type":"paragraph"},{"syntax":"bash","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing"},{"inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}],"type":"paragraph"},{"level":3,"text":"Auto-Resize Display","anchor":"Auto-Resize-Display","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay","type":"reference"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" (the default), the"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}]}]},{"text":"Performance Considerations","anchor":"Performance-Considerations","type":"heading","level":2},{"text":"LAN vs WAN","type":"heading","level":3,"anchor":"LAN-vs-WAN"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Factor","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Full 1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Consider 1280x800","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Color depth","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"32-bit","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16-bit for better performance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Frame rate","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"30-60 fps","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 fps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Responsiveness","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Excellent","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Usable for most tasks","type":"text"}],"type":"paragraph"}]]]},{"text":"Bandwidth Requirements","type":"heading","level":3,"anchor":"Bandwidth-Requirements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Quality","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Bandwidth","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1280x800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Low (16-bit)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"2-5 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"5-15 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"High (32-bit)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3840x2400","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"High (Retina)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"40-80 Mbps","type":"text"}],"type":"paragraph"}]]]},{"text":"Optimizing for Slow Connections","type":"heading","level":3,"anchor":"Optimizing-for-Slow-Connections"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For WAN or high-latency connections:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use a lower resolution display","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"]},{"text":"Future: High-Performance Streaming","type":"heading","level":2,"anchor":"Future-High-Performance-Streaming"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular’s roadmap includes high-performance display streaming"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"4K @ 60fps"}]},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Adaptive bitrate"}],"type":"strong"},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"text":"network conditions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"WebRTC transport"}],"type":"strong"},{"type":"text","text":" — Browser-based access without a VNC client"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"text":"Audio Forwarding","type":"heading","level":2,"anchor":"Audio-Forwarding"},{"inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}],"type":"paragraph"},{"text":"Enabling Audio","anchor":"Enabling-Audio","level":3,"type":"heading"},{"inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference"},{"type":"text","text":". To explicitly control it:"}],"type":"paragraph"},{"syntax":"bash","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","type":"reference"},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"type":"text","text":" for the"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}],"type":"paragraph"},{"text":"Audio over VNC","type":"heading","level":3,"anchor":"Audio-over-VNC"},{"inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}]},{"text":"Clipboard Sharing","type":"heading","level":2,"anchor":"Clipboard-Sharing"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","type":"reference"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"inlineContent":[{"type":"text","text":"only supported for Linux guests"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"code":"VZSpiceAgentPortAttachment","type":"codeVoice"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"code":"spice-vdagent","type":"codeVoice"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"type":"codeListing"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}]}],"type":"aside","name":"Important"},{"type":"heading","level":2,"text":"Security","anchor":"Security"},{"type":"heading","level":3,"text":"VNC over SSH Tunnel","anchor":"VNC-over-SSH-Tunnel"},{"inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"text":" ","type":"text"},{"type":"text","text":"an SSH tunnel:"}],"type":"paragraph"},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"syntax":"bash","type":"codeListing"},{"text":"VPC-Only Access","anchor":"VPC-Only-Access","level":3,"type":"heading"},{"inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}],"type":"paragraph"},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"syntax":"bash","type":"codeListing"},{"text":"Per-VM Authentication","anchor":"Per-VM-Authentication","level":3,"type":"heading"},{"inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}],"type":"paragraph"},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"syntax":"bash","type":"codeListing"},{"text":"Isolated Desktops","anchor":"Isolated-Desktops","level":3,"type":"heading"},{"inlineContent":[{"text":"For maximum security, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}],"type":"paragraph"},{"code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"syntax":"bash","type":"codeListing"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}]}],"type":"aside"},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","level":2,"type":"heading"},{"inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}],"type":"paragraph"},{"text":"Shared Development Environment","anchor":"Shared-Development-Environment","level":3,"type":"heading"},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"syntax":"bash","type":"codeListing"},{"text":"QA Test Lab","anchor":"QA-Test-Lab","level":3,"type":"heading"},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"syntax":"bash","type":"codeListing"},{"text":"Kubernetes-Managed Desktops","anchor":"Kubernetes-Managed-Desktops","level":3,"type":"heading"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"syntax":"yaml","type":"codeListing"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"syntax":"bash","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"sections":[],"metadata":{"roleHeading":"API Collection","title":"Remote Desktop Access","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"title":"Related Guides","anchor":"Related-Guides"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate"],"title":"Key Types","anchor":"Key-Types"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/githubactionsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/docum