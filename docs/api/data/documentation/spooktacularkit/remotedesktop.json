nnect from another Mac:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}],"type":"paragraph"}]}]},{"syntax":"bash","type":"codeListing","code":["spook ip desktop-vm","# 192.168.64.3"]},{"start":2,"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}]}]}]},{"syntax":"bash","type":"codeListing","code":["open vnc:\/\/192.168.64.3"]},{"start":3,"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}]}]}]},{"anchor":"From-Any-VNC-Client","level":3,"type":"heading","text":"From Any VNC Client"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Server:"}],"type":"strong"},{"type":"text","text":" The VM’s IP address (from "},{"code":"spook ip","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"text":" 5900 (default VNC port)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Authentication:","type":"text"}]},{"type":"text","text":" macOS user credentials or VNC password"}]}]}]},{"type":"codeListing","syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"level":3,"anchor":"Network-Mode-Considerations","type":"heading","text":"Network Mode Considerations"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"NetworkMode"},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"text":"VM IP reachable from","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Connection method","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"NetworkMode\/nat","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"NetworkMode\/bridged(interface:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"text":"Direct VNC connection","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"text":"Not suitable for VNC","type":"text"}]}]]]},{"inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"inlineContent":[{"text":"bridged","type":"text"}],"type":"strong"},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":" for the entitlement details."}]}]},{"level":2,"type":"heading","text":"Display Configuration","anchor":"Display-Configuration"},{"level":3,"type":"heading","text":"Resolution and DPI","anchor":"Resolution-and-DPI"},{"inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"text":". This is set by ","type":"text"},{"type":"codeVoice","code":"VirtualMachineConfiguration"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"]},{"level":3,"type":"heading","text":"Dual Monitors","anchor":"Dual-Monitors"},{"inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"]},{"inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/displayCount"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Auto-Resize Display","anchor":"Auto-Resize-Display"},{"inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/autoResizeDisplay"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"locally:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"]},{"type":"aside","content":[{"inlineContent":[{"text":"Auto-resize affects the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"VNC clients negotiate their own display size with the Screen","type":"text"},{"text":" ","type":"text"},{"text":"Sharing server.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"text":"Performance Considerations","level":2,"type":"heading","anchor":"Performance-Considerations"},{"text":"LAN vs WAN","level":3,"type":"heading","anchor":"LAN-vs-WAN"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Factor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Full 1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Consider 1280x800"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Frame rate","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"30-60 fps","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 fps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Responsiveness","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Excellent"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Usable for most tasks","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","level":3,"anchor":"Bandwidth-Requirements","text":"Bandwidth Requirements"},{"inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Quality"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Bandwidth","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1280x800"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Low (16-bit)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"2-5 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Medium"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5-15 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"High (32-bit)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 Mbps","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"inlineContent":[{"text":"High (Retina)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"40-80 Mbps"}],"type":"paragraph"}]]],"header":"row"},{"level":3,"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","type":"heading"},{"inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use a lower resolution display"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing"},{"level":2,"text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming","type":"heading"},{"inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"4K @ 60fps"}]},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Adaptive bitrate"}]},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"WebRTC transport","type":"text"}]},{"type":"text","text":" — Browser-based access without a VNC client"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"level":2,"text":"Audio Forwarding","type":"heading","anchor":"Audio-Forwarding"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"VZVirtioSoundDeviceConfiguration","type":"codeVoice"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"text":"Enabling Audio","type":"heading","anchor":"Enabling-Audio","level":3},{"inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification"},{"text":". To explicitly control it:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"VirtualMachineSpecification\/audioEnabled"},{"type":"text","text":" and "},{"type":"codeVoice","code":"VirtualMachineSpecification\/microphoneEnabled"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}]},{"type":"heading","anchor":"Audio-over-VNC","level":3,"text":"Audio over VNC"},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}]},{"type":"heading","anchor":"Clipboard-Sharing","level":2,"text":"Clipboard Sharing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VirtualMachineSpecification\/clipboardSharingEnabled"},{"type":"text","text":" field"},{"type":"text","text":" "},{"type":"text","text":"exists for forward compatibility, but clipboard sharing through the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework is "},{"inlineContent":[{"text":"only supported for Linux guests","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"code":"VZSpiceAgentPortAttachment","type":"codeVoice"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"code":"spice-vdagent","type":"codeVoice"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"type":"text","text":" "},{"type":"text","text":"logged at configuration time and no console device is attached."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"]},{"content":[{"inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}],"type":"paragraph"}],"name":"Important","type":"aside","style":"important"},{"anchor":"Security","type":"heading","text":"Security","level":2},{"anchor":"VNC-over-SSH-Tunnel","type":"heading","text":"VNC over SSH Tunnel","level":3},{"inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"]},{"anchor":"VPC-Only-Access","type":"heading","text":"VPC-Only Access","level":3},{"inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"]},{"anchor":"Per-VM-Authentication","type":"heading","text":"Per-VM Authentication","level":3},{"type":"paragraph","inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"]},{"type":"heading","level":3,"anchor":"Isolated-Desktops","text":"Isolated Desktops"},{"type":"paragraph","inlineContent":[{"text":"For maximum security, use ","type":"text"},{"code":"NetworkMode\/isolated","type":"codeVoice"},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"code":"NetworkMode\/nat","type":"codeVoice"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}]}]},{"type":"heading","level":2,"anchor":"Multiple-Users-Accessing-Different-VMs","text":"Multiple Users Accessing Different VMs"},{"type":"paragraph","inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}]},{"type":"heading","level":3,"anchor":"Shared-Development-Environment","text":"Shared Development Environment"},{"syntax":"bash","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing"},{"text":"QA Test Lab","level":3,"anchor":"QA-Test-Lab","type":"heading"},{"syntax":"bash","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing"},{"text":"Kubernetes-Managed Desktops","level":3,"anchor":"Kubernetes-Managed-Desktops","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing"},{"syntax":"bash","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/remotedesktop"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Remote Desktop Access"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"anchor":"Related-Guides","title":"Related Guides"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","role":"