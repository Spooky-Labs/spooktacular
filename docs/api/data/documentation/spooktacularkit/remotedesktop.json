"text"},{"type":"codeVoice","code":"true"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}]},{"type":"heading","level":2,"anchor":"Performance-Considerations","text":"Performance Considerations"},{"type":"heading","level":3,"anchor":"LAN-vs-WAN","text":"LAN vs WAN"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Factor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Full 1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Consider 1280x800"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Frame rate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"30-60 fps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15-30 fps"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Responsiveness","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Excellent"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Usable for most tasks","type":"text"}]}]]],"type":"table"},{"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Quality"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bandwidth"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-5 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Medium"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5-15 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (32-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15-30 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3840x2400","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (Retina)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"40-80 Mbps","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For WAN or high-latency connections:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Use a lower resolution display","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"code":"ssh -C","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"codeListing","syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"]},{"anchor":"Future-High-Performance-Streaming","type":"heading","text":"Future: High-Performance Streaming","level":2},{"inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"4K @ 60fps","type":"text"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"host’s hardware encoder"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sub-frame latency"}]},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Adaptive bitrate"}]},{"type":"text","text":" — Automatic quality adjustment based on"},{"text":" ","type":"text"},{"type":"text","text":"network conditions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"WebRTC transport"}]},{"type":"text","text":" — Browser-based access without a VNC client"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reliable access for most use cases."}],"type":"paragraph"},{"anchor":"Audio-Forwarding","level":2,"type":"heading","text":"Audio Forwarding"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Enabling-Audio","text":"Enabling Audio","type":"heading"},{"inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec"},{"text":". To explicitly control it:","type":"text"}],"type":"paragraph"},{"code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/audioEnabled"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/microphoneEnabled","type":"reference","isActive":true},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}]},{"type":"heading","level":3,"anchor":"Audio-over-VNC","text":"Audio over VNC"},{"inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use Apple Remote Desktop (ARD) which supports audio forwarding"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For simple cases, forward audio via the Spooktacular host’s"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Clipboard-Sharing","level":2,"type":"heading","text":"Clipboard Sharing"},{"inlineContent":[{"text":"Spooktacular supports bidirectional clipboard sharing between the","type":"text"},{"text":" ","type":"text"},{"text":"host and guest macOS. Copy text or images on the host, paste in","type":"text"},{"text":" ","type":"text"},{"text":"the VM, and vice versa.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Configuration","text":"Configuration","type":"heading"},{"inlineContent":[{"type":"text","text":"Clipboard sharing is enabled by default via"},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/clipboardSharingEnabled","isActive":true,"type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["# Clipboard sharing on (default)","spook create my-vm","","# Clipboard sharing off (for security-sensitive VMs)","spook create secure-vm --disable-clipboard"],"syntax":"bash"},{"level":3,"anchor":"How-It-Works","text":"How It Works","type":"heading"},{"inlineContent":[{"type":"text","text":"The Virtualization framework’s "},{"code":"Spice","type":"codeVoice"},{"type":"text","text":" channel handles clipboard"},{"type":"text","text":" "},{"type":"text","text":"synchronization transparently. Both the local Spooktacular display"},{"type":"text","text":" "},{"type":"text","text":"window and VNC sessions benefit from this feature."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Clipboard sharing works between the host and guest. If you"},{"type":"text","text":" "},{"type":"text","text":"are connecting via VNC from a third machine, clipboard operations"},{"type":"text","text":" "},{"text":"go: your machine -> VNC -> guest -> Virtualization -> host.","type":"text"}],"type":"paragraph"}]},{"level":2,"anchor":"Security","text":"Security","type":"heading"},{"level":3,"anchor":"VNC-over-SSH-Tunnel","text":"VNC over SSH Tunnel","type":"heading"},{"inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"syntax":"bash"},{"level":3,"anchor":"VPC-Only-Access","text":"VPC-Only Access","type":"heading"},{"inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"syntax":"bash"},{"level":3,"anchor":"Per-VM-Authentication","text":"Per-VM Authentication","type":"heading"},{"inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"syntax":"bash"},{"level":3,"anchor":"Isolated-Desktops","text":"Isolated Desktops","type":"heading"},{"inlineContent":[{"text":"For maximum security, use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","type":"reference","isActive":true},{"text":" networking and","type":"text"},{"text":" ","type":"text"},{"text":"connect only from the host:","type":"text"}],"type":"paragraph"},{"name":"Important","type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"Host-only networking currently falls back to NAT mode."},{"type":"text","text":" "},{"text":"VMs will have internet access until a future release adds true","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"host-only isolation. Plan your network security accordingly."}],"type":"paragraph"}]},{"type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network host-only \\","    --disable-audio","","# Connect only from the host machine","open vnc:\/\/$(spook ip secure-desktop)"],"syntax":"bash"},{"level":2,"anchor":"Multiple-Users-Accessing-Different-VMs","text":"Multiple Users Accessing Different VMs","type":"heading"},{"inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Shared-Development-Environment","text":"Shared Development Environment","type":"heading"},{"type":"codeListing","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"syntax":"bash"},{"level":3,"anchor":"QA-Test-Lab","text":"QA Test Lab","type":"heading"},{"type":"codeListing","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"syntax":"bash"},{"level":3,"anchor":"Kubernetes-Managed-Desktops","text":"Kubernetes-Managed Desktops","type":"heading"},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"syntax":"yaml"},{"type":"codeListing","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"syntax":"bash"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/VMSpec/displayCount":{"url":"\/documentation\/spooktacularkit\/vmspec\/displaycount","type":"topic","title":"displayCount","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"displayCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/displayCount","abstract":[{"type":"text","text":"The number of virtual displays attached to the VM."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VMSpec/clipboardSharingEnabled":{"type":"topic","abstract":[{"type":"text","text":"Whether the host and guest share a common clipboard."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"clipboardSharingEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/clipboardSharingEnabled","title":"clipboardSharingEnabled","url":"\/documentation\/spooktacularkit\/vmspec\/clipboardsharingenabled","kind":"symbol","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"type":"topic","title":"Kubernetes Integration","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/VMConfig