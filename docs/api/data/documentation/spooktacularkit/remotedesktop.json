tion\/SpooktacularKit\/ProvisioningMode","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"type":"topic","title":"ProvisioningMode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/nat":{"abstract":[{"type":"text","text":"Network address translation through the host."}],"title":"NetworkMode.nat","url":"\/documentation\/spooktacularkit\/networkmode\/nat","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"nat","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"topic","abstract":[{"text":"Bridged directly to a physical network interface.","type":"text"}],"title":"NetworkMode.bridged(interface:)","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"bridged","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"interface"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"title":"VirtualMachineConfiguration","abstract":[{"text":"Builds ","type":"text"},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":" objects from a ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference","isActive":true},{"text":".","type":"text"}],"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","navigatorTitle":[{"text":"VirtualMachineConfiguration","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineConfiguration","kind":"identifier"}]}}}