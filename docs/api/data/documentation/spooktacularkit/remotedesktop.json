"s:Sb"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","kind":"symbol","title":"microphoneEnabled","abstract":[{"type":"text","text":"Whether the VM has a microphone input device attached."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/clipboardSharingEnabled":{"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/clipboardsharingenabled","title":"clipboardSharingEnabled","type":"topic","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"clipboardSharingEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"abstract":[{"type":"text","text":"Whether the host and guest share a common clipboard."}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"type":"topic","url":"\/documentation\/spooktacularkit\/provisioningmode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","title":"ProvisioningMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/jenkinsguide","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","title":"Configuring Jenkins Nodes","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}]},"doc://S