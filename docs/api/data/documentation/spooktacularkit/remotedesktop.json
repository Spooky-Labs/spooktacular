{"kind":"article","topicSections":[{"title":"Related Guides","anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]},{"title":"Key Types","anchor":"Key-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"API Collection","role":"collectionGroup","title":"Remote Desktop Access","modules":[{"name":"SpooktacularKit"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"Spooktacular VMs include full macOS display output backed by a","type":"text"},{"text":" ","type":"text"},{"text":"virtual GPU (","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":"). Combined with","type":"text"},{"text":" ","type":"text"},{"text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote","type":"text"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Use Cases","anchor":"Use-Cases","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Remote development","type":"text"}]},{"type":"text","text":" — Full macOS desktop for Xcode, Interface"},{"type":"text","text":" "},{"type":"text","text":"Builder, and Simulator from any machine"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"QA testing","type":"text"}]},{"type":"text","text":" — Manual testing of macOS and iOS apps in a"},{"type":"text","text":" "},{"type":"text","text":"controlled, reproducible VM environment"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Design review","type":"text"}]},{"type":"text","text":" — Share a running app with designers and"},{"type":"text","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Training and demos","type":"text"}]},{"type":"text","text":" — Provide ephemeral macOS desktops for"},{"type":"text","text":" "},{"type":"text","text":"workshops or customer demos"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Help desk","type":"text"}]},{"type":"text","text":" — Remote access to user-like macOS environments"},{"type":"text","text":" "},{"type":"text","text":"for support and troubleshooting"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Enabling Screen Sharing via Provisioning","anchor":"Enabling-Screen-Sharing-via-Provisioning","type":"heading"},{"inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Using disk-inject (Zero-Touch)","anchor":"Using-disk-inject-Zero-Touch","type":"heading"},{"syntax":"bash","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing"},{"level":3,"text":"Using the Kubernetes CRD","anchor":"Using-the-Kubernetes-CRD","type":"heading"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing"},{"inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","type":"reference"},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Connecting via VNC","anchor":"Connecting-via-VNC","type":"heading"},{"level":3,"text":"macOS Screen Sharing App (Built-in)","anchor":"macOS-Screen-Sharing-App-Built-in","type":"heading"},{"inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Find the VM’s IP address:"}],"type":"paragraph"}]}],"type":"orderedList"},{"syntax":"bash","code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}],"type":"paragraph"}]}],"type":"orderedList","start":2},{"syntax":"bash","code":["open vnc:\/\/192.168.64.3"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}],"type":"paragraph"}]}],"type":"orderedList","start":3},{"level":3,"text":"From Any VNC Client","anchor":"From-Any-VNC-Client","type":"heading"},{"inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Server:","type":"text"}]},{"type":"text","text":" The VM’s IP address (from "},{"type":"codeVoice","code":"spook ip"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Port:","type":"text"}]},{"type":"text","text":" 5900 (default VNC port)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Authentication:","type":"text"}]},{"type":"text","text":" macOS user credentials or VNC password"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"type":"codeListing"},{"level":3,"text":"Network Mode Considerations","anchor":"Network-Mode-Considerations","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"reference"},{"text":" you choose affects how you connect:","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Network Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"VM IP reachable from","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Connection method","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","type":"reference","isActive":true}]}],[{"inlineContent":[{"type":"text","text":"Host only"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Connect from host, or SSH tunnel","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Entire LAN"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Direct VNC connection","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"}]}],[{"inlineContent":[{"type":"text","text":"Nowhere"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Not suitable for VNC","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"inlineContent":[{"type":"text","text":"bridged"}],"type":"strong"},{"type":"text","text":" mode is recommended because"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true},{"text":" for the entitlement details.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"heading","level":2,"text":"Display Configuration","anchor":"Display-Configuration"},{"type":"heading","level":3,"text":"Resolution and DPI","anchor":"Resolution-and-DPI"},{"type":"paragraph","inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}],"type":"strong"},{"text":". This is set by ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","type":"reference","isActive":true},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"syntax":"swift"},{"type":"heading","level":3,"text":"Dual Monitors","anchor":"Dual-Monitors"},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"type":"codeListing","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"syntax":"bash"},{"inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"type":"text","text":" "},{"text":"display on port 5901.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","isActive":true,"type":"reference"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}],"type":"paragraph"},{"level":3,"text":"Auto-Resize Display","anchor":"Auto-Resize-Display","type":"heading"},{"inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay","isActive":true,"type":"reference"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"level":2,"text":"Performance Considerations","anchor":"Performance-Considerations","type":"heading"},{"level":3,"text":"LAN vs WAN","anchor":"LAN-vs-WAN","type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Factor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Full 1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Consider 1280x800"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Frame rate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"30-60 fps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15-30 fps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Responsiveness"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Excellent"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Usable for most tasks"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","type":"heading"},{"inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Resolution"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Quality"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bandwidth"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1280x800"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-5 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"5-15 Mbps","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (32-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"inlineContent":[{"text":"High (Retina)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"40-80 Mbps","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections","type":"heading"},{"inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use a lower resolution display"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"type":"codeVoice","code":"ssh -C"},{"text":")","type":"text"}]}]}],"type":"orderedList"},{"syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing"},{"type":"heading","level":2,"text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"4K @ 60fps","type":"text"}],"type":"strong"},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Adaptive bitrate","type":"text"}],"type":"strong"},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"WebRTC transport","type":"text"}],"type":"strong"},{"text":" — Browser-based access without a VNC client","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Audio Forwarding","anchor":"Audio-Forwarding","type":"heading"},{"inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"VZVirtioSoundDeviceConfiguration","type":"codeVoice"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Enabling Audio","anchor":"Enabling-Audio","type":"heading"},{"inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification"},{"text":". To explicitly control it:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"text":" for the","type":"text"},{"type":"text","text":" "},{"text":"API details.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Audio over VNC","anchor":"Audio-over-VNC"},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","level":2,"text":"Clipboard Sharing","anchor":"Clipboard-Sharing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","type":"reference"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"inlineContent":[{"text":"only supported for Linux guests","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"code":"VZSpiceAgentPortAttachment","type":"codeVoice"},{"text":") requires the","type":"text"},{"text":" ","type":"text"},{"code":"spice-vdagent","type":"codeVoice"},{"text":" package running inside the guest, which is not","type":"text"},{"text":" ","type":"text"},{"text":"available on macOS.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}],"type":"paragraph"},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"syntax":"bash","type":"codeListing"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"wire it up automatically via this existing field."}],"type":"paragraph"}]},{"anchor":"Security","text":"Security","level":2,"type":"heading"},{"anchor":"VNC-over-SSH-Tunnel","text":"VNC over SSH Tunnel","level":3,"type":"heading"},{"inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}],"type":"paragraph"},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"syntax":"bash","type":"codeListing"},{"anchor":"VPC-Only-Access","text":"VPC-Only Access","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}],"type":"paragraph"},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"syntax":"bash","type":"codeListing"},{"anchor":"Per-VM-Authentication","text":"Per-VM Authentication","level":3,"type":"heading"},{"inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}],"type":"paragraph"},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"syntax":"bash","type":"codeListing"},{"anchor":"Isolated-Desktops","level":3,"type":"heading","text":"Isolated Desktops"},{"type":"paragraph","inlineContent":[{"text":"For maximum security, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"text":" networking","type":"text"},{"text":" ","type":"text"},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"syntax":"bash"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}],"type":"paragraph"}]},{"type":"heading","level":2,"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs"},{"type":"paragraph","inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"text":" ","type":"text"},{"text":"and user accounts. This enables multi-user scenarios:","type":"text"}]},{"type":"heading","level":3,"text":"Shared Development Environment","anchor":"Shared-Development-Environment"},{"type":"codeListing","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"syntax":"bash"},{"type":"heading","level":3,"text":"QA Test Lab","anchor":"QA-Test-Lab"},{"type":"codeListing","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"syntax":"bash"},{"type":"heading","level":3,"text":"Kubernetes-Managed Desktops","anchor":"Kubernetes-Managed-Desktops"},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"syntax":"yaml"},{"type":"codeListing","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"syntax":"bash"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/remotedesktop"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Guides","generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/nat":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"nat","kind":"identifier"}],"role":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/networkmode\/nat","title":"NetworkMode.nat","kind":"symbol","abstract":[{"text":"Network address translation through the host.","type":"text"}]},"doc://SpooktacularKit