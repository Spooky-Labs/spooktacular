{"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Remote Desktop Access"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"]]},"sections":[],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"title":"Related Guides","anchor":"Related-Guides"}],"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include full macOS display output backed by a","type":"text"},{"text":" ","type":"text"},{"text":"virtual GPU (","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":"). Combined with","type":"text"},{"text":" ","type":"text"},{"text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote","type":"text"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}]},{"level":3,"type":"heading","text":"Use Cases","anchor":"Use-Cases"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Remote development","type":"text"}],"type":"strong"},{"text":" — Full macOS desktop for Xcode, Interface","type":"text"},{"text":" ","type":"text"},{"text":"Builder, and Simulator from any machine","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"QA testing","type":"text"}]},{"type":"text","text":" — Manual testing of macOS and iOS apps in a"},{"type":"text","text":" "},{"type":"text","text":"controlled, reproducible VM environment"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Design review"}]},{"type":"text","text":" — Share a running app with designers and"},{"type":"text","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Training and demos","type":"text"}],"type":"strong"},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"text":" ","type":"text"},{"text":"workshops or customer demos","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Help desk","type":"text"}],"type":"strong"},{"text":" — Remote access to user-like macOS environments","type":"text"},{"text":" ","type":"text"},{"text":"for support and troubleshooting","type":"text"}]}]}]},{"level":2,"text":"Enabling Screen Sharing via Provisioning","type":"heading","anchor":"Enabling-Screen-Sharing-via-Provisioning"},{"inlineContent":[{"type":"text","text":"The most reliable way to enable VNC access is through a provisioning"},{"type":"text","text":" "},{"type":"text","text":"script that runs automatically when the VM boots."}],"type":"paragraph"},{"level":3,"text":"Using disk-inject (Zero-Touch)","type":"heading","anchor":"Using-disk-inject-Zero-Touch"},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"Where "},{"type":"codeVoice","code":"enable-screensharing.sh"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing","syntax":"bash"},{"type":"heading","level":3,"anchor":"Using-the-Kubernetes-CRD","text":"Using the Kubernetes CRD"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing","syntax":"yaml"},{"inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"code":"ProvisioningMode","type":"codeVoice"},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Connecting-via-VNC","text":"Connecting via VNC"},{"type":"heading","level":3,"anchor":"macOS-Screen-Sharing-App-Built-in","text":"macOS Screen Sharing App (Built-in)"},{"inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Find the VM’s IP address:","type":"text"}]}]}]},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"type":"orderedList","start":2,"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing","type":"text"},{"text":" ","type":"text"},{"text":"app directly):","type":"text"}]}]}]},{"code":["open vnc:\/\/192.168.64.3"],"type":"codeListing","syntax":"bash"},{"type":"orderedList","start":3,"items":[{"content":[{"inlineContent":[{"type":"text","text":"Authenticate with the guest macOS user credentials."}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"From-Any-VNC-Client","text":"From Any VNC Client"},{"inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Server:","type":"text"}],"type":"strong"},{"text":" The VM’s IP address (from ","type":"text"},{"type":"codeVoice","code":"spook ip"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Port:"}]},{"type":"text","text":" 5900 (default VNC port)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"type":"text","text":" macOS user credentials or VNC password"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"level":3,"type":"heading","text":"Network Mode Considerations","anchor":"Network-Mode-Considerations"},{"inlineContent":[{"type":"text","text":"The "},{"code":"NetworkMode","type":"codeVoice"},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Network Mode"}],"type":"paragraph"}],[{"inlineContent":[{"text":"VM IP reachable from","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Connection method","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"NetworkMode\/nat"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Host only","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Connect from host, or SSH tunnel","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"NetworkMode\/bridged(interface:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entire LAN"}]}],[{"type":"paragraph","inlineContent":[{"text":"Direct VNC connection","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"type":"table"},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"bridged"}]},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Bridged networking requires the ","type":"text"},{"code":"com.apple.vm.networking","type":"codeVoice"},{"text":" ","type":"text"},{"text":"entitlement. See ","type":"text"},{"code":"NetworkMode","type":"codeVoice"},{"text":" for the entitlement details.","type":"text"}]}]},{"type":"heading","level":2,"text":"Display Configuration","anchor":"Display-Configuration"},{"type":"heading","level":3,"text":"Resolution and DPI","anchor":"Resolution-and-DPI"},{"inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"text":" ","type":"text"},{"inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}],"type":"strong"},{"text":". This is set by ","type":"text"},{"code":"VirtualMachineConfiguration","type":"codeVoice"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"]},{"type":"heading","text":"Dual Monitors","level":3,"anchor":"Dual-Monitors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}]},{"type":"codeListing","syntax":"bash","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each display gets its own VNC session. Connect to the second"},{"type":"text","text":" "},{"type":"text","text":"display on port 5901."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/displayCount","type":"codeVoice"},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}]},{"type":"heading","text":"Auto-Resize Display","level":3,"anchor":"Auto-Resize-Display"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"VirtualMachineSpecification\/autoResizeDisplay"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (the default), the"},{"type":"text","text":" "},{"type":"text","text":"guest display resolution adjusts to match the Spooktacular window"},{"type":"text","text":" "},{"type":"text","text":"size on the host. This is useful when viewing the VM display"},{"type":"text","text":" "},{"type":"text","text":"locally:"}]},{"syntax":"bash","type":"codeListing","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"]},{"content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"level":2,"type":"heading","anchor":"Performance-Considerations","text":"Performance Considerations"},{"level":3,"type":"heading","anchor":"LAN-vs-WAN","text":"LAN vs WAN"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Factor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"LAN (< 1ms latency)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Full 1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Consider 1280x800","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"text":"32-bit","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16-bit for better performance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Frame rate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"30-60 fps"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 fps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Responsiveness"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Excellent"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Usable for most tasks","type":"text"}],"type":"paragraph"}]]]},{"anchor":"Bandwidth-Requirements","type":"heading","text":"Bandwidth Requirements","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Quality","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bandwidth"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Low (16-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"2-5 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"text":"Medium","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5-15 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (32-bit)"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (Retina)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"40-80 Mbps","type":"text"}]}]]],"header":"row"},{"type":"heading","text":"Optimizing for Slow Connections","level":3,"anchor":"Optimizing-for-Slow-Connections"},{"type":"paragraph","inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a lower resolution display","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable compression (most clients support ZRLE or Tight encoding)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Consider an SSH tunnel with compression ("},{"code":"ssh -C","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"type":"heading","text":"Future: High-Performance Streaming","level":2,"anchor":"Future-High-Performance-Streaming"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"4K @ 60fps","type":"text"}]},{"text":" — HEVC (H.265) encoding via VideoToolbox on the","type":"text"},{"text":" ","type":"text"},{"text":"host’s hardware encoder","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Sub-frame latency","type":"text"}]},{"type":"text","text":" — Direct Metal capture to hardware encoder"},{"type":"text","text":" "},{"type":"text","text":"pipeline"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Adaptive bitrate"}]},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"WebRTC transport","type":"text"}]},{"type":"text","text":" — Browser-based access without a VNC client"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}]},{"level":2,"text":"Audio Forwarding","type":"heading","anchor":"Audio-Forwarding"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"type":"text","text":") by default. Audio from the guest"},{"type":"text","text":" "},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"level":3,"text":"Enabling Audio","type":"heading","anchor":"Enabling-Audio"},{"inlineContent":[{"text":"Audio is enabled by default in ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":". To explicitly control it:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"]},{"inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/audioEnabled"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"VirtualMachineSpecification\/microphoneEnabled"},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Audio over VNC","anchor":"Audio-over-VNC"},{"inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use Apple Remote Desktop (ARD) which supports audio forwarding"}]}]},{"content":[{"inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For simple cases, forward audio via the Spooktacular host’s","type":"text"},{"text":" ","type":"text"},{"text":"speakers (if you are physically near the host)","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Clipboard Sharing","anchor":"Clipboard-Sharing"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/clipboardSharingEnabled","type":"codeVoice"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Virtualization framework is "},{"type":"strong","inlineContent":[{"type":"text","text":"only supported for Linux guests"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"type":"codeVoice","code":"spice-vdagent"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"type":"text","text":" "},{"type":"text","text":"logged at configuration time and no console device is attached."}]},{"type":"codeListing","syntax":"bash","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"]},{"content":[{"inlineContent":[{"type":"text","text":"There is currently no Virtualization framework API for"},{"type":"text","text":" "},{"type":"text","text":"clipboard synchronization between the host and a macOS guest. If"},{"type":"text","text":" "},{"type":"text","text":"Apple adds this capability in a future release, Spooktacular will"},{"type":"text","text":" "},{"type":"text","text":"wire it up automatically via this existing field."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"heading","level":2,"anchor":"Security","text":"Security"},{"type":"heading","level":3,"anchor":"VNC-over-SSH-Tunnel","text":"VNC over SSH Tunnel"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}]},{"type":"codeListing","syntax":"bash","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"]},{"anchor":"VPC-Only-Access","text":"VPC-Only Access","type":"heading","level":3},{"inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"]},{"text":"Per-VM Authentication","anchor":"Per-VM-Authentication","type":"heading","level":3},{"inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"]},{"text":"Isolated Desktops","anchor":"Isolated-Desktops","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"For maximum security, use "},{"type":"codeVoice","code":"NetworkMode\/isolated"},{"type":"text","text":" networking"},{"type":"text","text":" "},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"type":"text","text":" "},{"type":"text","text":"communication is still possible via the VirtIO socket device,"},{"type":"text","text":" "},{"type":"text","text":"which is always attached regardless of network mode."}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"code":"NetworkMode\/nat","type":"codeVoice"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","type":"heading","level":2},{"inlineContent":[{"text":"Each VM runs independently with its own display, network identity,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}],"type":"paragraph"},{"level":3,"text":"Shared Development Environment","type":"heading","anchor":"Shared-Development-Environment"},{"syntax":"bash","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing"},{"level":3,"text":"QA Test Lab","type":"heading","anchor":"QA-Test-Lab"},{"syntax":"bash","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing"},{"level":3,"text":"Kubernetes-Managed Desktops","type":"heading","anchor":"Kubernetes-Managed-Desktops"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing"},{"syntax":"bash","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true,"anchor":"Guides"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","url":"\/documentation\/spooktacula