pe":"text"}]},{"type":"text","text":" The VM’s IP address (from "},{"type":"codeVoice","code":"spook ip"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"type":"text","text":" 5900 (default VNC port)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Authentication:"}],"type":"strong"},{"type":"text","text":" macOS user credentials or VNC password"}],"type":"paragraph"}]}]},{"syntax":"bash","type":"codeListing","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"type":"heading","level":3,"text":"Network Mode Considerations","anchor":"Network-Mode-Considerations"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},{"text":" you choose affects how you connect:","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Network Mode"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VM IP reachable from"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Connection method","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Host only","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"text":"Entire LAN","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Direct VNC connection"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Nowhere"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Not suitable for VNC"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"For remote desktop scenarios, ","type":"text"},{"inlineContent":[{"type":"text","text":"bridged"}],"type":"strong"},{"text":" mode is recommended because","type":"text"},{"text":" ","type":"text"},{"text":"it gives the VM its own IP address on the LAN, allowing direct","type":"text"},{"text":" ","type":"text"},{"text":"connections from any machine.","type":"text"}]},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"text":" ","type":"text"},{"text":"entitlement. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"reference"},{"text":" for the entitlement details.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"level":2,"type":"heading","anchor":"Display-Configuration","text":"Display Configuration"},{"level":3,"type":"heading","anchor":"Resolution-and-DPI","text":"Resolution and DPI"},{"inlineContent":[{"type":"text","text":"By default, each virtual display is configured at"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"1920 x 1200 @ 80 PPI"}]},{"type":"text","text":". This is set by "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","isActive":true},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"applying the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"]},{"anchor":"Dual-Monitors","type":"heading","level":3,"text":"Dual Monitors"},{"inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}],"type":"paragraph"},{"syntax":"bash","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing"},{"inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","isActive":true},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}],"type":"paragraph"},{"level":3,"text":"Auto-Resize Display","anchor":"Auto-Resize-Display","type":"heading"},{"inlineContent":[{"type":"text","text":"When "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (the default), the"},{"type":"text","text":" "},{"type":"text","text":"guest display resolution adjusts to match the Spooktacular window"},{"type":"text","text":" "},{"type":"text","text":"size on the host. This is useful when viewing the VM display"},{"type":"text","text":" "},{"type":"text","text":"locally:"}],"type":"paragraph"},{"syntax":"bash","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"Auto-resize affects the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"VNC clients negotiate their own display size with the Screen","type":"text"},{"text":" ","type":"text"},{"text":"Sharing server.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"level":2,"text":"Performance Considerations","anchor":"Performance-Considerations","type":"heading"},{"anchor":"LAN-vs-WAN","text":"LAN vs WAN","level":3,"type":"heading"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Factor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"LAN (< 1ms latency)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"WAN (50-200ms latency)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolution"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Full 1920x1200"}]}],[{"type":"paragraph","inlineContent":[{"text":"Consider 1280x800","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32-bit"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16-bit for better performance"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Frame rate"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"30-60 fps"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 fps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Responsiveness"}]}],[{"inlineContent":[{"text":"Excellent","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Usable for most tasks","type":"text"}]}]]]},{"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Quality"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bandwidth"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1280x800","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-5 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5-15 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"High (32-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"15-30 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3840x2400"}],"type":"paragraph"}],[{"inlineContent":[{"text":"High (Retina)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"40-80 Mbps","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Optimizing for Slow Connections","type":"heading","anchor":"Optimizing-for-Slow-Connections","level":3},{"inlineContent":[{"type":"text","text":"For WAN or high-latency connections:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Use a lower resolution display"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable compression (most clients support ZRLE or Tight encoding)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Consider an SSH tunnel with compression (","type":"text"},{"type":"codeVoice","code":"ssh -C"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"text":"Future: High-Performance Streaming","type":"heading","level":2,"anchor":"Future-High-Performance-Streaming"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular’s roadmap includes high-performance display streaming"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"4K @ 60fps"}]},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"type":"text","text":" "},{"type":"text","text":"host’s hardware encoder"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sub-frame latency","type":"text"}],"type":"strong"},{"text":" — Direct Metal capture to hardware encoder","type":"text"},{"text":" ","type":"text"},{"text":"pipeline","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Adaptive bitrate"}]},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"WebRTC transport","type":"text"}],"type":"strong"},{"type":"text","text":" — Browser-based access without a VNC client"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Until then, the macOS built-in Screen Sharing (VNC) server provides","type":"text"},{"text":" ","type":"text"},{"text":"reliable access for most use cases.","type":"text"}]},{"text":"Audio Forwarding","anchor":"Audio-Forwarding","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"text":" ","type":"text"},{"text":"macOS is forwarded to the host’s speakers.","type":"text"}]},{"text":"Enabling Audio","anchor":"Enabling-Audio","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"type":"text","text":". To explicitly control it:"}]},{"syntax":"bash","type":"codeListing","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}]},{"text":"Audio over VNC","anchor":"Audio-over-VNC","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Use a third-party solution like PulseAudio over network"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For simple cases, forward audio via the Spooktacular host’s"},{"type":"text","text":" "},{"type":"text","text":"speakers (if you are physically near the host)"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"text":"Clipboard Sharing","type":"heading","anchor":"Clipboard-Sharing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","isActive":true,"type":"reference"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Virtualization framework is "},{"type":"strong","inlineContent":[{"type":"text","text":"only supported for Linux guests"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"text":") requires the","type":"text"},{"type":"text","text":" "},{"code":"spice-vdagent","type":"codeVoice"},{"text":" package running inside the guest, which is not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"There is currently no Virtualization framework API for"},{"type":"text","text":" "},{"type":"text","text":"clipboard synchronization between the host and a macOS guest. If"},{"type":"text","text":" "},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}],"type":"paragraph"}]},{"level":2,"type":"heading","anchor":"Security","text":"Security"},{"level":3,"type":"heading","anchor":"VNC-over-SSH-Tunnel","text":"VNC over SSH Tunnel"},{"type":"paragraph","inlineContent":[{"text":"Never expose VNC (port 5900) directly to the internet. Always use","type":"text"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"]},{"level":3,"type":"heading","anchor":"VPC-Only-Access","text":"VPC-Only Access"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}]},{"syntax":"bash","type":"codeListing","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"]},{"level":3,"type":"heading","anchor":"Per-VM-Authentication","text":"Per-VM Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM has its own macOS user accounts and passwords. You can"},{"type":"text","text":" "},{"type":"text","text":"create dedicated accounts for different users:"}]},{"syntax":"bash","type":"codeListing","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"]},{"type":"heading","level":3,"text":"Isolated Desktops","anchor":"Isolated-Desktops"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For maximum security, use "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"type":"text","text":" networking"},{"type":"text","text":" "},{"text":"to remove all network interfaces from the VM. Host-guest","type":"text"},{"text":" ","type":"text"},{"text":"communication is still possible via the VirtIO socket device,","type":"text"},{"text":" ","type":"text"},{"text":"which is always attached regardless of network mode.","type":"text"}]},{"type":"codeListing","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"syntax":"bash"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true,"type":"reference"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}]}]},{"text":"Multiple Users Accessing Different VMs","anchor":"Multiple-Users-Accessing-Different-VMs","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Each VM runs independently with its own display, network identity,"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}],"type":"paragraph"},{"text":"Shared Development Environment","anchor":"Shared-Development-Environment","level":3,"type":"heading"},{"syntax":"bash","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing"},{"text":"QA Test Lab","anchor":"QA-Test-Lab","level":3,"type":"heading"},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"text":"Kubernetes-Managed Desktops","level":3,"anchor":"Kubernetes-Managed-Desktops","type":"heading"},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"syntax":"yaml"},{"syntax":"bash","type":"codeListing","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"]}]}],"abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"topicSections":[{"title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"],"anchor":"Related-Guides"},{"anchor":"Key-Types","title":"Key Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"kind":"article","role":"collectionGroup","title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","kind