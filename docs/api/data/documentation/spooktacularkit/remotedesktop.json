{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"},"variants":[{"paths":["\/documentation\/spooktacularkit\/remotedesktop"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"topicSections":[{"title":"Related Guides","anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference"]},{"title":"Key Types","anchor":"Key-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktopTemplate"]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include full macOS display output backed by a","type":"text"},{"text":" ","type":"text"},{"text":"virtual GPU (","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":"). Combined with","type":"text"},{"text":" ","type":"text"},{"text":"macOS’s built-in Screen Sharing (VNC) server, this enables remote","type":"text"},{"text":" ","type":"text"},{"text":"graphical access to any VM from anywhere on your network.","type":"text"}]},{"type":"heading","level":3,"text":"Use Cases","anchor":"Use-Cases"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Remote development"}],"type":"strong"},{"type":"text","text":" — Full macOS desktop for Xcode, Interface"},{"type":"text","text":" "},{"type":"text","text":"Builder, and Simulator from any machine"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"QA testing"}],"type":"strong"},{"type":"text","text":" — Manual testing of macOS and iOS apps in a"},{"type":"text","text":" "},{"type":"text","text":"controlled, reproducible VM environment"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Design review"}],"type":"strong"},{"type":"text","text":" — Share a running app with designers and"},{"type":"text","text":" "},{"type":"text","text":"stakeholders without giving them SSH access"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Training and demos"}]},{"text":" — Provide ephemeral macOS desktops for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"workshops or customer demos"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Help desk","type":"text"}]},{"type":"text","text":" — Remote access to user-like macOS environments"},{"type":"text","text":" "},{"type":"text","text":"for support and troubleshooting"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Enabling Screen Sharing via Provisioning","anchor":"Enabling-Screen-Sharing-via-Provisioning"},{"type":"paragraph","inlineContent":[{"text":"The most reliable way to enable VNC access is through a provisioning","type":"text"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}]},{"type":"heading","level":3,"text":"Using disk-inject (Zero-Touch)","anchor":"Using-disk-inject-Zero-Touch"},{"syntax":"bash","type":"codeListing","code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"code":"enable-screensharing.sh","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""]},{"type":"heading","level":3,"text":"Using the Kubernetes CRD","anchor":"Using-the-Kubernetes-CRD"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}]},{"type":"heading","level":2,"text":"Connecting via VNC","anchor":"Connecting-via-VNC"},{"type":"heading","level":3,"text":"macOS Screen Sharing App (Built-in)","anchor":"macOS-Screen-Sharing-App-Built-in"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Find the VM’s IP address:"}]}]}],"type":"orderedList"},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"start":2,"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}],"type":"paragraph"}]}]},{"syntax":"bash","type":"codeListing","code":["open vnc:\/\/192.168.64.3"]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}]}]}],"start":3},{"type":"heading","level":3,"text":"From Any VNC Client","anchor":"From-Any-VNC-Client"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Server:","type":"text"}]},{"type":"text","text":" The VM’s IP address (from "},{"type":"codeVoice","code":"spook ip"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Port:","type":"text"}]},{"type":"text","text":" 5900 (default VNC port)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Authentication:","type":"text"}]},{"type":"text","text":" macOS user credentials or VNC password"}]}]}]},{"type":"codeListing","syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"type":"heading","anchor":"Network-Mode-Considerations","level":3,"text":"Network Mode Considerations"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true},{"type":"text","text":" you choose affects how you connect:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"VM IP reachable from"}]}],[{"type":"paragraph","inlineContent":[{"text":"Connection method","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Host only"}]}],[{"type":"paragraph","inlineContent":[{"text":"Connect from host, or SSH tunnel","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Entire LAN","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Direct VNC connection","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"type":"text","text":"For remote desktop scenarios, "},{"type":"strong","inlineContent":[{"text":"bridged","type":"text"}]},{"type":"text","text":" mode is recommended because"},{"type":"text","text":" "},{"type":"text","text":"it gives the VM its own IP address on the LAN, allowing direct"},{"text":" ","type":"text"},{"type":"text","text":"connections from any machine."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Bridged networking requires the ","type":"text"},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"text":"entitlement. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true,"type":"reference"},{"text":" for the entitlement details.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"anchor":"Display-Configuration","type":"heading","level":2,"text":"Display Configuration"},{"type":"heading","anchor":"Resolution-and-DPI","level":3,"text":"Resolution and DPI"},{"inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}]},{"type":"text","text":". This is set by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration"},{"text":" when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applying the "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"syntax":"swift"},{"text":"Dual Monitors","level":3,"type":"heading","anchor":"Dual-Monitors"},{"inlineContent":[{"type":"text","text":"Configure two virtual displays for workflows that benefit from"},{"type":"text","text":" "},{"type":"text","text":"extra screen space:"}],"type":"paragraph"},{"syntax":"bash","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Each display gets its own VNC session. Connect to the second","type":"text"},{"text":" ","type":"text"},{"text":"display on port 5901.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/displayCount","type":"reference","isActive":true},{"text":" property controls the number of","type":"text"},{"text":" ","type":"text"},{"text":"displays (valid range: 1-2).","type":"text"}]},{"anchor":"Auto-Resize-Display","text":"Auto-Resize Display","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/autoResizeDisplay","type":"reference","isActive":true},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"type":"text","text":" "},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"type":"text","text":" "},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"type":"text","text":" "},{"type":"text","text":"locally:"}]},{"code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"],"type":"codeListing","syntax":"bash"},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"Auto-resize affects the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"VNC clients negotiate their own display size with the Screen"},{"type":"text","text":" "},{"type":"text","text":"Sharing server."}],"type":"paragraph"}],"type":"aside"},{"text":"Performance Considerations","level":2,"type":"heading","anchor":"Performance-Considerations"},{"anchor":"LAN-vs-WAN","text":"LAN vs WAN","type":"heading","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Factor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"LAN (< 1ms latency)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Full 1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Consider 1280x800","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Color depth","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32-bit","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16-bit for better performance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Frame rate","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"30-60 fps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 fps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Responsiveness","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Excellent","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Usable for most tasks","type":"text"}]}]]],"type":"table","header":"row"},{"text":"Bandwidth Requirements","level":3,"type":"heading","anchor":"Bandwidth-Requirements"},{"inlineContent":[{"type":"text","text":"Approximate bandwidth for VNC at different quality levels:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Resolution","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Quality","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bandwidth","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Low (16-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"2-5 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Medium","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"5-15 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1920x1200","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (32-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"15-30 Mbps","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"High (Retina)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"40-80 Mbps","type":"text"}]}]]],"type":"table","header":"row"},{"text":"Optimizing for Slow Connections","level":3,"type":"heading","anchor":"Optimizing-for-Slow-Connections"},{"inlineContent":[{"type":"text","text":"For WAN or high-latency connections:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a lower resolution display"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reduce color depth in your VNC client settings"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable compression (most clients support ZRLE or Tight encoding)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider an SSH tunnel with compression ("},{"type":"codeVoice","code":"ssh -C"},{"type":"text","text":")"}]}]}],"type":"orderedList"},{"code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"],"type":"codeListing","syntax":"bash"},{"text":"Future: High-Performance Streaming","level":2,"type":"heading","anchor":"Future-High-Performance-Streaming"},{"inlineContent":[{"type":"text","text":"Spooktacular’s roadmap includes high-performance display streaming"},{"type":"text","text":" "},{"type":"text","text":"using hardware video encoding:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"4K @ 60fps"}],"type":"strong"},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"type":"text","text":" "},{"type":"text","text":"host’s hardware encoder"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"type":"text","text":" — Direct Metal capture to hardware encoder"},{"type":"text","text":" "},{"type":"text","text":"pipeline"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Adaptive bitrate"}],"type":"strong"},{"type":"text","text":" — Automatic quality adjustment based on"},{"type":"text","text":" "},{"type":"text","text":"network conditions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"WebRTC transport"}],"type":"strong"},{"type":"text","text":" — Browser-based access without a VNC client"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}],"type":"paragraph"},{"text":"Audio Forwarding","level":2,"type":"heading","anchor":"Audio-Forwarding"},{"inlineContent":[{"type":"text","text":"Spooktacular VMs include a virtual audio device"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"type":"text","text":") by default. Audio from the guest"},{"type":"text","text":" "},{"type":"text","text":"macOS is forwarded to the host’s speakers."}],"type":"paragraph"},{"text":"Enabling Audio","level":3,"type":"heading","anchor":"Enabling-Audio"},{"inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"type":"text","text":". To explicitly control it:"}],"type":"paragraph"},{"code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/audioEnabled","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/microphoneEnabled","isActive":true},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"API details."}],"type":"paragraph"},{"text":"Audio over VNC","level":3,"type":"heading","anchor":"Audio-over-VNC"},{"inlineContent":[{"type":"text","text":"Standard VNC does not support audio. For remote audio:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use Apple Remote Desktop (ARD) which supports audio forwarding"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a third-party solution like PulseAudio over network"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For simple cases, forward audio via the Spooktacular host’s"},{"type":"text","text":" "},{"type":"text","text":"speakers (if you are physically near the host)"}]}]}],"type":"orderedList"},{"text":"Clipboard Sharing","level":2,"type":"heading","anchor":"Clipboard-Sharing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/clipboardSharingEnabled","isActive":true},{"type":"text","text":" field"},{"type":"text","text":" "},{"type":"text","text":"exists for forward compatibility, but clipboard sharing through the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework is "},{"type":"strong","inlineContent":[{"text":"only supported for Linux guests","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The underlying mechanism ("},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"type":"codeVoice","code":"spice-vdagent"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For macOS guests, enabling this setting is a no-op — a warning is"},{"type":"text","text":" "},{"type":"text","text":"logged at configuration time and no console device is attached."}],"type":"paragraph"},{"code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"type":"codeListing","syntax":"bash"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"There is currently no Virtualization framework API for","type":"text"},{"text":" ","type":"text"},{"text":"clipboard synchronization between the host and a macOS guest. If","type":"text"},{"text":" ","type":"text"},{"text":"Apple adds this capability in a future release, Spooktacular will","type":"text"},{"text":" ","type":"text"},{"text":"wire it up automatically via this existing field.","type":"text"}]}],"type":"aside"},{"text":"Security","level":2,"type":"heading","anchor":"Security"},{"text":"VNC over SSH Tunnel","level":3,"type":"heading","anchor":"VNC-over-SSH-Tunnel"},{"inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"type":"text","text":" "},{"type":"text","text":"an SSH tunnel:"}],"type":"paragraph"},{"code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"type":"codeListing","syntax":"bash"},{"text":"VPC-Only Access","level":3,"type":"heading","anchor":"VPC-Only-Access"},{"inlineContent":[{"type":"text","text":"On EC2 Mac deployments, restrict VNC access to the VPC:"}],"type":"paragraph"},{"code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"type":"codeListing","syntax":"bash"},{"text":"Per-VM Authentication","level":3,"type":"heading","anchor":"Per-VM-Authentication"},{"inlineContent":[{"type":"text","text":"Each VM has its own macOS user accounts and passwords. You can"},{"type":"text","text":" "},{"type":"text","text":"create dedicated accounts for different users:"}],"type":"paragraph"},{"code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"type":"codeListing","syntax":"bash"},{"text":"Isolated Desktops","level":3,"type":"heading","anchor":"Isolated-Desktops"},{"inlineContent":[{"type":"text","text":"For maximum security, use "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"type":"text","text":" networking"},{"type":"text","text":" "},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"type":"text","text":" "},{"type":"text","text":"communication is still possible via the VirtIO socket device,"},{"type":"text","text":" "},{"type":"text","text":"which is always attached regardless of network mode."}],"type":"paragraph"},{"code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"type":"codeListing","syntax":"bash"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Isolated mode removes the network interface entirely.","type":"text"},{"text":" ","type":"text"},{"text":"VNC requires a network connection, so isolated VMs can only","type":"text"},{"text":" ","type":"text"},{"text":"be accessed through the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/nat"},{"text":" if you need VNC access with limited","type":"text"},{"text":" ","type":"text"},{"text":"exposure.","type":"text"}]}],"type":"aside"},{"text":"Multiple Users Accessing Different VMs","level":2,"type":"heading","anchor":"Multiple-Users-Accessing-Different-VMs"},{"inlineContent":[{"type":"text","text":"Each VM runs independently with its own display, network identity,"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}],"type":"paragraph"},{"text":"Shared Development Environment","level":3,"type":"heading","anchor":"Shared-Development-Environment"},{"code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing","syntax":"bash"},{"text":"QA Test Lab","level":3,"type":"heading","anchor":"QA-Test-Lab"},{"code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing","syntax":"bash"},{"text":"Kubernetes-Managed Desktops","level":3,"type":"heading","anchor":"Kubernetes-Managed-Desktops"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing","syntax":"yaml"},{"code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing","syntax":"bash"}],"kind":"content"}],"schemaVersion":{"patch":0,"major"