nchor":"Enabling-Screen-Sharing-via-Provisioning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most reliable way to enable VNC access is through a provisioning"},{"text":" ","type":"text"},{"text":"script that runs automatically when the VM boots.","type":"text"}]},{"type":"heading","text":"Using disk-inject (Zero-Touch)","anchor":"Using-disk-inject-Zero-Touch","level":3},{"code":["spook create desktop-vm --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --displays 1 \\","    --user-data ~\/enable-screensharing.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Where "},{"type":"codeVoice","code":"enable-screensharing.sh"},{"text":":","type":"text"}]},{"code":["#!\/bin\/bash","set -euo pipefail","","# Enable Screen Sharing (VNC server)","sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","","# Set the VNC password (for VNC-only clients)","sudo defaults write \/Library\/Preferences\/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true","","# Enable Remote Management for full control","sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","    -activate \\","    -configure -access -on \\","    -configure -allowAccessFor -allUsers \\","    -configure -restart -agent -privs -all","","echo \"Screen Sharing enabled\""],"type":"codeListing","syntax":"bash"},{"type":"heading","text":"Using the Kubernetes CRD","anchor":"Using-the-Kubernetes-CRD","level":3},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: remote-desktop","  namespace: desktops","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","      sudo \/System\/Library\/CoreServices\/RemoteManagement\/ARDAgent.app\/Contents\/Resources\/kickstart \\","          -activate -configure -access -on \\","          -configure -allowAccessFor -allUsers \\","          -configure -restart -agent -privs -all"],"type":"codeListing","syntax":"yaml"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"text":"doc:Provisioning","type":"text"},{"text":" for details on all four ","type":"text"},{"code":"ProvisioningMode","type":"codeVoice"},{"text":" ","type":"text"},{"text":"strategies.","type":"text"}]},{"type":"heading","text":"Connecting via VNC","anchor":"Connecting-via-VNC","level":2},{"type":"heading","text":"macOS Screen Sharing App (Built-in)","anchor":"macOS-Screen-Sharing-App-Built-in","level":3},{"type":"paragraph","inlineContent":[{"text":"The simplest way to connect from another Mac:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Find the VM’s IP address:"}]}]}],"type":"orderedList"},{"code":["spook ip desktop-vm","# 192.168.64.3"],"type":"codeListing","syntax":"bash"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}]}]}],"type":"orderedList","start":2},{"code":["open vnc:\/\/192.168.64.3"],"type":"codeListing","syntax":"bash"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}],"type":"paragraph"}]}],"start":3},{"text":"From Any VNC Client","anchor":"From-Any-VNC-Client","type":"heading","level":3},{"inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Server:","type":"text"}]},{"type":"text","text":" The VM’s IP address (from "},{"type":"codeVoice","code":"spook ip"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Port:"}],"type":"strong"},{"type":"text","text":" 5900 (default VNC port)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Authentication:","type":"text"}],"type":"strong"},{"type":"text","text":" macOS user credentials or VNC password"}]}]}],"type":"unorderedList"},{"code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"],"syntax":"bash","type":"codeListing"},{"text":"Network Mode Considerations","anchor":"Network-Mode-Considerations","type":"heading","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"NetworkMode"},{"text":" you choose affects how you connect:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Network Mode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"VM IP reachable from"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Connection method"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/nat"}]}],[{"type":"paragraph","inlineContent":[{"text":"Host only","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Connect from host, or SSH tunnel"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/bridged(interface:)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Entire LAN","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct VNC connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NetworkMode\/isolated"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Nowhere"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Not suitable for VNC"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"For remote desktop scenarios, "},{"type":"strong","inlineContent":[{"text":"bridged","type":"text"}]},{"type":"text","text":" mode is recommended because"},{"type":"text","text":" "},{"type":"text","text":"it gives the VM its own IP address on the LAN, allowing direct"},{"type":"text","text":" "},{"type":"text","text":"connections from any machine."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"code":"NetworkMode","type":"codeVoice"},{"text":" for the entitlement details.","type":"text"}]}],"name":"Note"},{"text":"Display Configuration","type":"heading","level":2,"anchor":"Display-Configuration"},{"type":"heading","anchor":"Resolution-and-DPI","level":3,"text":"Resolution and DPI"},{"type":"paragraph","inlineContent":[{"text":"By default, each virtual display is configured at","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"1920 x 1200 @ 80 PPI","type":"text"}],"type":"strong"},{"text":". This is set by ","type":"text"},{"code":"VirtualMachineConfiguration","type":"codeVoice"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"text":"applying the ","type":"text"},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["VZMacGraphicsDisplayConfiguration(","    widthInPixels: 1920,","    heightInPixels: 1200,","    pixelsPerInch: 80",")"],"syntax":"swift"},{"type":"heading","anchor":"Dual-Monitors","level":3,"text":"Dual Monitors"},{"type":"paragraph","inlineContent":[{"text":"Configure two virtual displays for workflows that benefit from","type":"text"},{"text":" ","type":"text"},{"text":"extra screen space:","type":"text"}]},{"type":"codeListing","code":["# Create a VM with 2 displays","spook create design-vm --cpu 4 --memory 8 --displays 2","","# Or update an existing VM","spook set design-vm --displays 2"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each display gets its own VNC session. Connect to the second"},{"type":"text","text":" "},{"type":"text","text":"display on port 5901."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VirtualMachineSpecification\/displayCount"},{"type":"text","text":" property controls the number of"},{"type":"text","text":" "},{"type":"text","text":"displays (valid range: 1-2)."}]},{"type":"heading","anchor":"Auto-Resize-Display","level":3,"text":"Auto-Resize Display"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"VirtualMachineSpecification\/autoResizeDisplay","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" (the default), the","type":"text"},{"text":" ","type":"text"},{"text":"guest display resolution adjusts to match the Spooktacular window","type":"text"},{"text":" ","type":"text"},{"text":"size on the host. This is useful when viewing the VM display","type":"text"},{"text":" ","type":"text"},{"text":"locally:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Enable auto-resize (default)","spook set my-vm --enable-auto-resize","","# Disable for a fixed resolution","spook set my-vm --disable-auto-resize"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Auto-resize affects the local Spooktacular display window.","type":"text"},{"text":" ","type":"text"},{"text":"VNC clients negotiate their own display size with the Screen","type":"text"},{"text":" ","type":"text"},{"text":"Sharing server.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"level":2,"type":"heading","anchor":"Performance-Considerations","text":"Performance Considerations"},{"level":3,"type":"heading","anchor":"LAN-vs-WAN","text":"LAN vs WAN"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Factor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"LAN (< 1ms latency)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"WAN (50-200ms latency)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Full 1920x1200","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Consider 1280x800","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Color depth"}],"type":"paragraph"}],[{"inlineContent":[{"text":"32-bit","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16-bit for better performance","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Frame rate"}]}],[{"type":"paragraph","inlineContent":[{"text":"30-60 fps","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 fps"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Responsiveness"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Excellent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Usable for most tasks"}]}]]]},{"level":3,"text":"Bandwidth Requirements","anchor":"Bandwidth-Requirements","type":"heading"},{"inlineContent":[{"text":"Approximate bandwidth for VNC at different quality levels:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Resolution","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Quality"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Bandwidth","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"1280x800","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Low (16-bit)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"2-5 Mbps","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1920x1200"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Medium","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5-15 Mbps"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1920x1200","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"High (32-bit)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"15-30 Mbps"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3840x2400","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"High (Retina)"}]}],[{"type":"paragraph","inlineContent":[{"text":"40-80 Mbps","type":"text"}]}]]],"header":"row","type":"table"},{"type":"heading","level":3,"text":"Optimizing for Slow Connections","anchor":"Optimizing-for-Slow-Connections"},{"inlineContent":[{"text":"For WAN or high-latency connections:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Use a lower resolution display"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Reduce color depth in your VNC client settings","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable compression (most clients support ZRLE or Tight encoding)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Consider an SSH tunnel with compression ("},{"type":"codeVoice","code":"ssh -C"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"bash","code":["# SSH tunnel with compression for slow links","ssh -C -L 5900:192.168.64.3:5900 user@bastion"]},{"type":"heading","level":2,"text":"Future: High-Performance Streaming","anchor":"Future-High-Performance-Streaming"},{"inlineContent":[{"text":"Spooktacular’s roadmap includes high-performance display streaming","type":"text"},{"text":" ","type":"text"},{"text":"using hardware video encoding:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"4K @ 60fps","type":"text"}]},{"type":"text","text":" — HEVC (H.265) encoding via VideoToolbox on the"},{"type":"text","text":" "},{"type":"text","text":"host’s hardware encoder"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Sub-frame latency"}],"type":"strong"},{"type":"text","text":" — Direct Metal capture to hardware encoder"},{"type":"text","text":" "},{"type":"text","text":"pipeline"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Adaptive bitrate","type":"text"}],"type":"strong"},{"text":" — Automatic quality adjustment based on","type":"text"},{"text":" ","type":"text"},{"text":"network conditions","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"WebRTC transport","type":"text"}],"type":"strong"},{"type":"text","text":" — Browser-based access without a VNC client"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Until then, the macOS built-in Screen Sharing (VNC) server provides"},{"type":"text","text":" "},{"type":"text","text":"reliable access for most use cases."}]},{"anchor":"Audio-Forwarding","type":"heading","level":2,"text":"Audio Forwarding"},{"type":"paragraph","inlineContent":[{"text":"Spooktacular VMs include a virtual audio device","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"VZVirtioSoundDeviceConfiguration"},{"text":") by default. Audio from the guest","type":"text"},{"type":"text","text":" "},{"type":"text","text":"macOS is forwarded to the host’s speakers."}]},{"type":"heading","level":3,"anchor":"Enabling-Audio","text":"Enabling Audio"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Audio is enabled by default in "},{"code":"VirtualMachineSpecification","type":"codeVoice"},{"type":"text","text":". To explicitly control it:"}]},{"type":"codeListing","syntax":"bash","code":["# Audio enabled (default)","spook create my-vm --enable-audio","","# Audio disabled (saves resources for headless CI)","spook create my-vm --disable-audio","","# Enable microphone passthrough (for voice\/video calls in the VM)","spook create my-vm --enable-microphone"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"VirtualMachineSpecification\/audioEnabled","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"VirtualMachineSpecification\/microphoneEnabled","type":"codeVoice"},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"API details.","type":"text"}]},{"type":"heading","level":3,"anchor":"Audio-over-VNC","text":"Audio over VNC"},{"type":"paragraph","inlineContent":[{"text":"Standard VNC does not support audio. For remote audio:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Use Apple Remote Desktop (ARD) which supports audio forwarding","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a third-party solution like PulseAudio over network","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For simple cases, forward audio via the Spooktacular host’s"},{"type":"text","text":" "},{"type":"text","text":"speakers (if you are physically near the host)"}]}]}]},{"type":"heading","level":2,"anchor":"Clipboard-Sharing","text":"Clipboard Sharing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"VirtualMachineSpecification\/clipboardSharingEnabled","type":"codeVoice"},{"text":" field","type":"text"},{"text":" ","type":"text"},{"text":"exists for forward compatibility, but clipboard sharing through the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework is ","type":"text"},{"inlineContent":[{"text":"only supported for Linux guests","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The underlying mechanism (","type":"text"},{"type":"codeVoice","code":"VZSpiceAgentPortAttachment"},{"type":"text","text":") requires the"},{"type":"text","text":" "},{"code":"spice-vdagent","type":"codeVoice"},{"type":"text","text":" package running inside the guest, which is not"},{"type":"text","text":" "},{"type":"text","text":"available on macOS."}]},{"type":"paragraph","inlineContent":[{"text":"For macOS guests, enabling this setting is a no-op — a warning is","type":"text"},{"text":" ","type":"text"},{"text":"logged at configuration time and no console device is attached.","type":"text"}]},{"type":"codeListing","code":["# The flag is accepted but has no effect for macOS guests","spook create my-vm","","# Disable to suppress the warning","spook create secure-vm --disable-clipboard"],"syntax":"bash"},{"type":"aside","name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There is currently no Virtualization framework API for"},{"type":"text","text":" "},{"type":"text","text":"clipboard synchronization between the host and a macOS guest. If"},{"type":"text","text":" "},{"type":"text","text":"Apple adds this capability in a future release, Spooktacular will"},{"type":"text","text":" "},{"type":"text","text":"wire it up automatically via this existing field."}]}]},{"type":"heading","anchor":"Security","level":2,"text":"Security"},{"type":"heading","anchor":"VNC-over-SSH-Tunnel","level":3,"text":"VNC over SSH Tunnel"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Never expose VNC (port 5900) directly to the internet. Always use"},{"text":" ","type":"text"},{"text":"an SSH tunnel:","type":"text"}]},{"syntax":"bash","code":["# From your local machine, through a bastion host","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion-host","","# Then connect your VNC client to localhost:5900","open vnc:\/\/localhost"],"type":"codeListing"},{"anchor":"VPC-Only-Access","level":3,"type":"heading","text":"VPC-Only Access"},{"inlineContent":[{"text":"On EC2 Mac deployments, restrict VNC access to the VPC:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Security group rule: allow VNC only from the VPN CIDR","aws ec2 authorize-security-group-ingress \\","    --group-id sg-0xxxx \\","    --protocol tcp \\","    --port 5900 \\","    --cidr 10.0.0.0\/8"],"type":"codeListing"},{"anchor":"Per-VM-Authentication","level":3,"type":"heading","text":"Per-VM Authentication"},{"inlineContent":[{"text":"Each VM has its own macOS user accounts and passwords. You can","type":"text"},{"text":" ","type":"text"},{"text":"create dedicated accounts for different users:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Inside the VM, create a read-only viewer account","sudo dscl . -create \/Users\/viewer","sudo dscl . -create \/Users\/viewer UserShell \/bin\/bash","sudo dscl . -create \/Users\/viewer RealName \"Viewer\"","sudo dscl . -passwd \/Users\/viewer \"viewer-password\"","sudo dscl . -create \/Users\/viewer UniqueID 502","sudo dscl . -create \/Users\/viewer PrimaryGroupID 20","sudo createhomedir -c -u viewer"],"type":"codeListing"},{"anchor":"Isolated-Desktops","level":3,"type":"heading","text":"Isolated Desktops"},{"inlineContent":[{"type":"text","text":"For maximum security, use "},{"type":"codeVoice","code":"NetworkMode\/isolated"},{"type":"text","text":" networking"},{"type":"text","text":" "},{"type":"text","text":"to remove all network interfaces from the VM. Host-guest"},{"type":"text","text":" "},{"type":"text","text":"communication is still possible via the VirtIO socket device,"},{"type":"text","text":" "},{"type":"text","text":"which is always attached regardless of network mode."}],"type":"paragraph"},{"syntax":"bash","code":["spook create secure-desktop \\","    --cpu 4 --memory 8 --disk 64 \\","    --network isolated \\","    --disable-audio"],"type":"codeListing"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Isolated mode removes the network interface entirely."},{"type":"text","text":" "},{"type":"text","text":"VNC requires a network connection, so isolated VMs can only"},{"type":"text","text":" "},{"type":"text","text":"be accessed through the local Spooktacular display window."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"code":"NetworkMode\/nat","type":"codeVoice"},{"type":"text","text":" if you need VNC access with limited"},{"type":"text","text":" "},{"type":"text","text":"exposure."}]}]},{"level":2,"text":"Multiple Users Accessing Different VMs","type":"heading","anchor":"Multiple-Users-Accessing-Different-VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each VM runs independently with its own display, network identity,"},{"type":"text","text":" "},{"type":"text","text":"and user accounts. This enables multi-user scenarios:"}]},{"level":3,"text":"Shared Development Environment","type":"heading","anchor":"Shared-Development-Environment"},{"syntax":"bash","code":["# Create one VM per developer","spook create dev-alice --cpu 4 --memory 8 --disk 64 --network bridged:en0","spook create dev-bob --cpu 4 --memory 8 --disk 64 --network bridged:en0","","# Each developer connects to their own VM via VNC","# Alice: open vnc:\/\/192.168.1.101","# Bob:   open vnc:\/\/192.168.1.102"],"type":"codeListing"},{"level":3,"text":"QA Test Lab","type":"heading","anchor":"QA-Test-Lab"},{"syntax":"bash","code":["# Create VMs for testing (clone from pre-configured bases)","spook clone base-sonoma qa-sonoma","spook set qa-sonoma --network bridged:en0","","spook clone base-sequoia qa-sequoia","spook set qa-sequoia --network bridged:en0","","# QA team members connect to whichever version they need"],"type":"codeListing"},{"level":3,"text":"Kubernetes-Managed Desktops","type":"heading","anchor":"Kubernetes-Managed-Desktops"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-alice","  namespace: desktops","  labels:","    user: alice","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist","---","apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: desktop-bob","  namespace: desktops","  labels:","    user: bob","spec:","  image: ghcr.io\/spooktacular\/macos:15.4","  resources:","    cpu: 4","    memory: 8Gi","    disk: 64Gi","  displays: 1","  network:","    mode: bridged","    interface: en0","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      sudo launchctl load -w \/System\/Library\/LaunchDaemons\/com.apple.screensharing.plist"],"type":"codeListing"},{"syntax":"bash","code":["# Find each user's VM IP","kubectl get macosvm -n desktops -o wide","","# NAMESPACE  NAME           IP              NODE         STATUS","# desktops   desktop-alice  192.168.1.101   mac-host-01  Running","# desktops   desktop-bob    192.168.1.102   mac-host-01  Running"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/remotedesktop"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Remote Desktop Access","role":"collectionGroup"},"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"role":"collectionGroup","title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"url":"\/documentation\/spooktacularkit\/jenkinsguide","abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"role":"collectionGroup","title":"Configuring Jenkins Nodes","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","type":"topic","title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"kind":"article","url":"\/documentation\/spooktacularkit\/versioning","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","role":"collectionGroup","title":"Versioning & Release Schedule","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"title":"Running BlueBubbles iMessage Server","kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"role":"collectionGroup","title":"Machine Learning Workloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","title":"Running OpenClaw in Virtual Machines","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","type":"topic","title":"Getting Started with Spooktacular"}}}