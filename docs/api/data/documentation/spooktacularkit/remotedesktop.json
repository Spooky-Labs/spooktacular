","code":["spook ip desktop-vm","# 192.168.64.3"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open Screen Sharing (Cmd+K in Finder, or open the Screen Sharing"},{"type":"text","text":" "},{"type":"text","text":"app directly):"}]}]}],"type":"orderedList","start":2},{"type":"codeListing","syntax":"bash","code":["open vnc:\/\/192.168.64.3"]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Authenticate with the guest macOS user credentials.","type":"text"}],"type":"paragraph"}]}],"start":3},{"level":3,"type":"heading","text":"From Any VNC Client","anchor":"From-Any-VNC-Client"},{"type":"paragraph","inlineContent":[{"text":"Use any VNC client (RealVNC, TigerVNC, etc.) to connect:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Server:"}],"type":"strong"},{"type":"text","text":" The VM’s IP address (from "},{"type":"codeVoice","code":"spook ip"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Port:","type":"text"}],"type":"strong"},{"type":"text","text":" 5900 (default VNC port)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Authentication:"}],"type":"strong"},{"type":"text","text":" macOS user credentials or VNC password"}]}]}]},{"type":"codeListing","syntax":"bash","code":["# Using a command-line VNC client","vncviewer 192.168.64.3:5900","","# Or with SSH tunnel (see Security section)","ssh -L 5900:192.168.64.3:5900 ec2-user@bastion","vncviewer localhost:5900"]},{"type":"heading","anchor":"Network-Mode-Considerations","text":"Network Mode Considerations","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode"},{"text":" you choose affects how you connect:","type":"text"}]},