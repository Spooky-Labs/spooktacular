 the guest disk image on the host,","type":"text"},{"text":" ","type":"text"},{"text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data","type":"text"},{"text":" ","type":"text"},{"text":"volume, then unmounts. When the VM boots, ","type":"text"},{"type":"codeVoice","code":"launchd"},{"text":" picks up the daemon and","type":"text"},{"text":" ","type":"text"},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This uses Apple’s ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":" (ships with macOS) to attach APFS disk images","type":"text"},{"text":" ","type":"text"},{"text":"and writes only to the data volume (never the Signed System Volume).","type":"text"}]},{"text":"Usage","anchor":"Usage","type":"heading","level":2},{"code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing","syntax":"swift"},{"text":"How It Works","anchor":"How-It-Works","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":" using "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Detaches the disk image so the VM can boot cleanly.","type":"text"}]}]}],"type":"orderedList"},{"text":"Thread Safety","anchor":"Thread-Safety","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"All methods are synchronous and use ","type":"text"},{"type":"codeVoice","code":"Process"},{"text":" to invoke ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Call from a background thread if needed to avoid blocking the main thread.","type":"text"}]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/guestScriptPath":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath","abstract":[{"text":"The path where the user-data script is installed inside the guest.","type":"text"}],"kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"guestScriptPath","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"url":"\/documentation\/spooktacularkit\/diskinjector\/guestscriptpath","type":"topic","title":"guestScriptPath","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector":{"kind":"symbol","url":"\/documentation\/spooktacularkit\/diskinjector","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DiskInjector","kind":"identifier"}],"type":"topic","title":"DiskInjector","navigatorTitle":[{"text":"DiskInjector","kind":"identifier"}],"abstract":[{"text":"Injects a user-data script into a VM’s guest disk a