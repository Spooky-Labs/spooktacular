":"codeVoice"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}]},{"text":"Thread Safety","level":2,"type":"heading","anchor":"Thread-Safety"},{"inlineContent":[{"text":"All methods are synchronous and use ","type":"text"},{"type":"codeVoice","code":"Process"},{"text":" to invoke ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Call from a background thread if needed to avoid blocking the main thread.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/inject(script:into:)":{"kind":"symbol","title":"inject(script:into:)","type":"topic","abstract":[{"text":"Injects a script into the VM’s disk image as a LaunchDaemon.","type":"text"}],"url":"\/documentation\/spooktacularkit\/diskinjector\/inject(script:into:)","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"inject","kind":"identifier"},{"text":"(","kind":"text"},{"text":"script","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"into","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV","text":"VirtualMachineBundle","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector