{"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon."}],"metadata":{"navigatorTitle":[{"text":"DiskInjector","kind":"identifier"}],"symbolKind":"enum","title":"DiskInjector","externalID":"s:15SpooktacularKit12DiskInjectorO","roleHeading":"Enumeration","role":"symbol","modules":[{"name":"SpooktacularKit"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DiskInjector"}]},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateMACAddress()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)"],"anchor":"Type-Methods","generated":true,"title":"Type Methods"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/diskinjector"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, ","type":"text"},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"text":" ","type":"text"},{"text":"volume, then unmounts. When the VM boots, ","type":"text"},{"type":"codeVoice","code":"launchd"},{"text":" picks up the daemon and","type":"text"},{"text":" ","type":"text"},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}],"type":"paragraph"},{"level":2,"text":"Usage","type":"heading","anchor":"Usage"},{"syntax":"swift","type":"codeListing","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"anchor":"How-It-Works","type":"heading","text":"How It Works","level":2},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"type":"codeVoice","code":"disk.img"},{"text":" using ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" without mounting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Finds and mounts the APFS data volume from the attached disk.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/"},{"type":"text","text":" that tells"},{"text":" ","type":"text"},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" to run the script at boot."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}]}]}]},{"level":2,"text":"Thread Safety","type":"heading","anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateLaunchDaemonPlist()":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","title":"generateLaunchDaemonPlist()","type":"topic","url":"\/documentation\/spooktacularkit\/diskinjector\/generatelaunchdaemonplist()","role":"symbol","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"generateLaunchDaemonPlist","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"abstract":[{"text":"Generates the LaunchDaemon plist XML that runs the injected script at boot.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","title":"SpooktacularKit","type":"topic","url":"\/documentation\/spooktacularkit","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}]},"doc://Spooktacu