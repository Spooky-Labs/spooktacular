{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"type":"heading","level":2,"text":"Usage","anchor":"Usage"},{"type":"codeListing","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"syntax":"swift"},{"type":"heading","level":2,"text":"How It Works","anchor":"How-It-Works"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":" using "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" to run the script at boot."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}]}]}],"type":"orderedList"},{"type":"heading","level":2,"text":"Thread Safety","anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/diskinjector"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"role":"symbol","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"externalID":"s:15SpooktacularKit12DiskInjectorO","navigatorTitle":[