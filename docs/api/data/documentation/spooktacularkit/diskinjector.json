{"abstract":[{"text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/diskinjector"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}],"type":"paragraph"},{"anchor":"Usage","level":2,"text":"Usage","type":"heading"},{"syntax":"swift","type":"codeListing","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"anchor":"How-It-Works","level":2,"text":"How It Works","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":" using "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" to run the script at boot."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}]}]}],"type":"orderedList"},{"anchor":"Thread-Safety","level":2,"text":"Thread Safety","type":"heading"},{"inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"generated":true,"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"]},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)"]}],"metadata":{"role":"symbol","externalID":"s:15SpooktacularKit12DiskInjectorO","modules":[{"name":"SpooktacularKit"}],"title":"DiskInjector","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"navigatorTitle":[{"kind":"identifier","text":"DiskInjector"}],"roleHeading":"Enumeration","symbolKind":"enum"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector":{"abstract":[{"text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon.","type":"text"}],"kind":"symbol","title":"DiskInjector","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DiskInjector","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","type":"topic","role":"symbol","navigatorTitle":[{"text":"DiskInjector","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/diskinjector"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","title":"SpooktacularKit","kind":"symbol","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateLaunchDaemonPlist()":{"role":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/diskinjector\/generatelaunchdaemonplist()","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","title":"generateLaunchDaemonPlist()","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"generateLaunchDaemonPlist","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"abstract":[{"type":"text","text":"Generates the LaunchDaemon plist XML that runs the injected script at boot."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/guestScriptPath":{"role":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/diskinjector\/guestscriptpath","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath","title":"guestScriptPath","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"guestScriptPath"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"abstract":[{"type":"text","text":"The path where the user-data script is installed inside the guest."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/daemonLabel":{"role":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/diskinjector\/daemonlabel","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","title":"daemonLabel","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"daemonLabel","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"abstract":[{"text":"The LaunchDaemon label used for injected user-data scripts.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/inject(script:into:)":{"role":"symbol","type":"topic","url":"\/doc