text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"anchor":"Usage","level":2,"type":"heading","text":"Usage"},{"syntax":"swift","type":"codeListing","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"anchor":"How-It-Works","level":2,"type":"heading","text":"How It Works"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"type":"codeVoice","code":"disk.img"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":" without mounting","type":"text"},{"text":" ","type":"text"},{"text":"(to discover the device node).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Finds and mounts the APFS data volume from the attached disk.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"text":" ","type":"text"},{"text":"on the data volume.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/"},{"text":" that tells","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"launchd"},{"text":" to run the script at boot.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Detaches the disk image so the VM can boot cleanly.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Thread-Safety","level":2,"type":"heading","text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/diskinjector"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateMACAddress()":{"url":"\/documentation\/spooktacularkit\/diskinjector\/generatemacaddress()","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateMACAddress()","type":"topic","abstract":[{"text":"Generates a locally administered MAC address from random bytes.","type":"text"}],"kind":"symbol","role":"symbol","title":"generateMACAddress()","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"generateMACAddress","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","type":"topic","title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInject