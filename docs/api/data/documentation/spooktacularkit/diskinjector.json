writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"anchor":"Usage","text":"Usage","type":"heading","level":2},{"code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing","syntax":"swift"},{"anchor":"How-It-Works","text":"How It Works","type":"heading","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":" using "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}]},{"anchor":"Thread-Safety","text":"Thread Safety","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/daemonLabel":{"abstract":[{"type":"text","text":"The LaunchDaemon label used for injected user-data scripts."}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"daemonLabel"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}],"kind":"symbol","title":"daemonLabel","url":"\/documentation\/spooktacularkit\/diskinjector\/daemonlabel","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateLaunchDaemonPlist()":{"title":"generateLaunchDaemonPlist()","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","role":"symbol","kind":"symbol","abstract":[{"text":"Generates the LaunchDaemon plist XML that runs the injected script at boot.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","ki