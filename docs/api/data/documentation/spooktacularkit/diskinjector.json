{"metadata":{"title":"DiskInjector","role":"symbol","externalID":"s:15SpooktacularKit12DiskInjectorO","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"navigatorTitle":[{"kind":"identifier","text":"DiskInjector"}],"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","symbolKind":"enum"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"Before the VM boots, ","type":"text"},{"code":"DiskInjector","type":"codeVoice"},{"text":" mounts the guest disk image on the host,","type":"text"},{"text":" ","type":"text"},{"text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data","type":"text"},{"text":" ","type":"text"},{"text":"volume, then unmounts. When the VM boots, ","type":"text"},{"code":"launchd","type":"codeVoice"},{"text":" picks up the daemon and","type":"text"},{"text":" ","type":"text"},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This uses Apple’s ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" (ships with macOS) to attach APFS disk images","type":"text"},{"text":" ","type":"text"},{"text":"and writes only to the data volume (never the Signed System Volume).","type":"text"}],"type":"paragraph"},{"text":"Usage","anchor":"Usage","type":"heading","level":2},{"syntax":"swift","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing"},{"text":"How It Works","anchor":"How-It-Works","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":" using ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" without mounting","type":"text"},{"text":" ","type":"text"},{"text":"(to discover the device node).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Finds and mounts the APFS data volume from the attached disk.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"text":" ","type":"text"},{"text":"on the data volume.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"text":" that tells","type":"text"},{"text":" ","type":"text"},{"code":"launchd","type":"codeVoice"},{"text":" to run the script at boot.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Detaches the disk image so the VM can boot cleanly.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Thread Safety","anchor":"Thread-Safety","type":"heading","level":2},{"inlineContent":[{"text":"All methods are synchronous and use ","type":"text"},{"code":"Process","type":"codeVoice"},{"text":" to invoke ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Call from a background thread if needed to avoid blocking the main thread.","type":"text"}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc: