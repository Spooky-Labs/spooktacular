{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector"},"sections":[],"abstract":[{"type":"text","text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}],"type":"paragraph"},{"inlineContent":[{"text":"This uses Apple’s ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" (ships with macOS) to attach APFS disk images","type":"text"},{"text":" ","type":"text"},{"text":"and writes only to the data volume (never the Signed System Volume).","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Usage","type":"heading","text":"Usage"},{"type":"codeListing","syntax":"swift","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"text":"How It Works","level":2,"anchor":"How-It-Works","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","tex