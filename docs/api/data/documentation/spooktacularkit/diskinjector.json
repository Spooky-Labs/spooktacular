{"sections":[],"abstract":[{"type":"text","text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/diskinjector"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Before the VM boots, ","type":"text"},{"code":"DiskInjector","type":"codeVoice"},{"text":" mounts the guest disk image on the host,","type":"text"},{"text":" ","type":"text"},{"text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data","type":"text"},{"text":" ","type":"text"},{"text":"volume, then unmounts. When the VM boots, ","type":"text"},{"code":"launchd","type":"codeVoice"},{"text":" picks up the daemon and","type":"text"},{"text":" ","type":"text"},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This uses Apple’s ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" (ships with macOS) to attach APFS disk images","type":"text"},{"text":" ","type":"text"},{"text":"and writes only to the data volume (never the Signed System Volume).","type":"text"}]},{"level":2,"type":"heading","text":"Usage","anchor":"Usage"},{"syntax":"swift","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing"},{"level":2,"type":"heading","text":"How It Works","anchor":"How-It-Works"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":" using ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" without mounting","type":"text"},{"text":" ","type":"text"},{"text":"(to discover the device node).","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Finds and mounts the APFS data volume from the attached disk.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"type":"text","text":" "},{"text":"on the data volume.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"text":" that tells","type":"text"},{"text":" ","type":"text"},{"code":"launchd","type":"codeVoice"},{"text":" to run the script at boot.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Detaches the disk image so the VM can boot cleanly.","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Thread-Safety","text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"code":"Process","type":"codeVoice"},{"type":"text","text":" to invoke "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}],"kind":"content"}],"topicSections":[{"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"],"generated":true,"title":"Type Properties"},{"identifiers":["doc:\/