{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DiskInjector","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"type":"heading","text":"Usage","level":2,"anchor":"Usage"},{"type":"codeListing","syntax":"swift","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"type":"heading","text":"How It Works","level":2,"anchor":"How-It-Works"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"type":"codeVoice","code":"disk.img"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":" without mounting","type":"text"},{"text":" ","type":"text"},{"text":"(to discover the device node).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Finds and mounts the APFS data volume from the attached disk.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"text":" ","type":"text"},{"text":"on the data volume.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/"},{"text":" that tells","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"launchd"},{"text":" to run the script at boot.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Detaches the disk image so the VM can boot cleanly.","type":"text"}]}]}]},{"type":"heading","text":"Thread Safety","level":2,"anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}]}],"abstract":[{"type":"text","text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"symbolKind":"enum","role":"symbol","title":"DiskInjector","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit12DiskInjectorO","navigatorTitle":[{"text":"DiskInjector","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"