"},{"type":"text","text":" "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" to run the script at boot."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}]}]}]},{"level":2,"type":"heading","anchor":"Thread-Safety","text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"code":"Process","type":"codeVoice"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector"},"sections":[],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/inject(script:into:)":{"url":"\/documentation\/spooktacularkit\/diskinjector\/inject(script:into:)","abstract":[{"type":"text","text":"Injects a script into the VM’s disk image as a LaunchDaemon."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"inject"},{"kind":"text","text":"("},{"kind":"externalParam","text":"script"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier","text":"URL"},{"kind":"text","text":", "},{"kind":"externalParam","text":"into"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV","kind":"typeIdentifier","text":"VirtualMachineBundle"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"title":"inject(script:into:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector