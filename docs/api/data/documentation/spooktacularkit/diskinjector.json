{"variants":[{"paths":["\/documentation\/spooktacularkit\/diskinjector"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"]},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)"]}],"metadata":{"role":"symbol","externalID":"s:15SpooktacularKit12DiskInjectorO","roleHeading":"Enumeration","navigatorTitle":[{"kind":"identifier","text":"DiskInjector"}],"title":"DiskInjector","symbolKind":"enum","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}]},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"text":"Usage","type":"heading","level":2,"anchor":"Usage"},{"syntax":"swift","type":"codeListing","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"]},{"text":"How It Works","type":"heading","level":2,"anchor":"How-It-Works"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":" using "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"type":"codeVoice","code":"\/Library\/LaunchDaemons\/"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}]},{"text":"Thread Safety","type":"heading","level":2,"anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"type":"codeVoice","code":"Process"},{"type":"text","text":" to invoke "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/guestScriptPath":{"role":"symbol","kind":"symbol","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath","url":"\/documentation\/spooktacularkit\/diskinjector\/guestscriptpath","abstract":[{"text":"The path where the user-data script is installed inside the guest.","type":"text"}],"title":"guestScriptPath","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"guestScriptPath"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateLaunchDaemonPlist()":{"role":"symbol","kind":"symbol","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","url":"\/documentation\/spooktacularkit\/diskinjector\/generatelaunchdaemonplist()","abstract":[{"text":"Generates the LaunchDaemon plist XML that runs the injected script at boot.","type":"text"}],"title":"generateLaunchDaemonPlist()","fragments":[{"kind":"keyword",