{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"],"generated":true,"anchor":"Type-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateLaunchDaemonPlist()","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)"],"generated":true,"anchor":"Type-Methods"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Before the VM boots, "},{"code":"DiskInjector","type":"codeVoice"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"type":"text","text":"executes the script automatically — no SSH, no agent, no network required."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This uses Apple’s "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}],"type":"paragraph"},{"level":2,"text":"Usage","anchor":"Usage","type":"heading"},{"syntax":"swift","code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing"},{"level":2,"text":"How It Works","anchor":"How-It-Works","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"code":"disk.img","type":"codeVoice"},{"type":"text","text":" using "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes the user’s script to "},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"on the data volume."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"text":"Thread Safety","anchor":"Thread-Safety","type":"heading"},{"inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"code":"Process","type":"codeVoice"},{"type":"text","text":" to invoke "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","symbolKind":"enum","externalID":"s:15SpooktacularKit12DiskInjectorO","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"navigatorTitle":[{"kind":"identifier","text":"DiskInjector"}],"roleHeading":"Enumeration","title":"DiskInjector"},"variants":[{"paths":["\/documentation\/spooktacularkit\/diskinjector"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Injects a user-data script into a VM’s guest disk as a macOS LaunchDaemon.","type":"text"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/inject(script:into:)":{"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/inject(script:into:)","url":"\/documentation\/spooktacularkit\/diskinjector\/inject(script:into:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"inject"},{"text":"(","kind":"text"},{"text":"script","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"into","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VirtualMachineBundle","preciseIdentifier":"s:15SpooktacularKit20VirtualMachineBundleV","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"kind":"symbol","title":"inject(script:into:)","abstract":[{"text":"Injects a script into the VM’s disk image as a LaunchDaemon.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateLaunchDaemonPlist()":{"kind":"symbol","fragments":[{"kind":"keyword","text":"static"}