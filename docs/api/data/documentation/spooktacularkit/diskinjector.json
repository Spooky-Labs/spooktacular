{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiskInjector"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"Before the VM boots, "},{"type":"codeVoice","code":"DiskInjector"},{"type":"text","text":" mounts the guest disk image on the host,"},{"type":"text","text":" "},{"type":"text","text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data"},{"type":"text","text":" "},{"type":"text","text":"volume, then unmounts. When the VM boots, "},{"type":"codeVoice","code":"launchd"},{"type":"text","text":" picks up the daemon and"},{"type":"text","text":" "},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses Apple’s "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" (ships with macOS) to attach APFS disk images"},{"type":"text","text":" "},{"type":"text","text":"and writes only to the data volume (never the Signed System Volume)."}]},{"type":"heading","level":2,"anchor":"Usage","text":"Usage"},{"code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"How-It-Works","text":"How It Works"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attaches the guest’s "},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":" using "},{"type":"codeVoice","code":"hdiutil"},{"type":"text","text":" without mounting"},{"type":"text","text":" "},{"type":"text","text":"(to discover the device node)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"code":"\/usr\/local\/bin\/spooktacular-user-data.sh","type":"codeVoice"},{"text":" ","type":"text"},{"text":"on the data volume.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes a LaunchDaemon plist to ","type":"text"},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"text":" that tells","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"launchd"},{"text":" to run the script at boot.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}]},{"type":"heading","text":"Thread Safety","level":2,"anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are synchronous and use ","type":"text"},{"type":"codeVoice","code":"Process"},{"text":" to invoke ","type":"text"},{"type":"codeVoice","code":"hdiutil"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Call from a background thread if needed to avoid blocking the main thread.","type":"text"}]}]}],"sections":[],"metadata":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DiskInjector","kind":"identifier"}],"navigatorTitle":[{"text":"DiskInjector","kind":"identifier"}],"title":"DiskInjector","symbolKind":"enum","roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit12DiskInjectorO","role":"symbol"},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/daemonLabel","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/guestScriptPath"],"anchor":"Type-Properties","generated":true},{"title":"Typ