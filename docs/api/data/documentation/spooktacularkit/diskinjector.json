"type":"text"},{"text":" ","type":"text"},{"text":"writes a standard macOS LaunchDaemon plist and the user’s script to the data","type":"text"},{"text":" ","type":"text"},{"text":"volume, then unmounts. When the VM boots, ","type":"text"},{"code":"launchd","type":"codeVoice"},{"text":" picks up the daemon and","type":"text"},{"text":" ","type":"text"},{"text":"executes the script automatically — no SSH, no agent, no network required.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This uses Apple’s ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" (ships with macOS) to attach APFS disk images","type":"text"},{"text":" ","type":"text"},{"text":"and writes only to the data volume (never the Signed System Volume).","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Usage","type":"heading","text":"Usage"},{"code":["let scriptURL = URL(fileURLWithPath: \"\/path\/to\/setup.sh\")","let bundle = try VirtualMachineBundle.load(from: bundleURL)","try DiskInjector.inject(script: scriptURL, into: bundle)"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"How-It-Works","type":"heading","text":"How It Works"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Attaches the guest’s ","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":" using ","type":"text"},{"code":"hdiutil","type":"codeVoice"},{"text":" without mounting","type":"text"},{"text":" ","type":"text"},{"text":"(to discover the device node).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Finds and mounts the APFS data volume from the attached disk."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Writes the user’s script to ","type":"text"},{"type":"codeVoice","code":"\/usr\/local\/bin\/spooktacular-user-data.sh"},{"text":" ","type":"text"},{"text":"on the data volume.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Writes a LaunchDaemon plist to "},{"code":"\/Library\/LaunchDaemons\/","type":"codeVoice"},{"type":"text","text":" that tells"},{"type":"text","text":" "},{"code":"launchd","type":"codeVoice"},{"type":"text","text":" to run the script at boot."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Detaches the disk image so the VM can boot cleanly."}],"type":"paragraph"}]}]},{"level":2,"anchor":"Thread-Safety","type":"heading","text":"Thread Safety"},{"inlineContent":[{"type":"text","text":"All methods are synchronous and use "},{"code":"Process","type":"codeVoice"},{"type":"text","text":" to invoke "},{"code":"hdiutil","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Call from a background thread if needed to avoid blocking the main thread."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInjector/generateMACAddress()":{"title":"generateMACAddress()","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"generateMACAddress"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"abstract":[{"type":"text","text":"Generates a locally administered MAC address from random bytes."}],"type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit\/diskinjector\/generatemacaddress()","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/DiskInjector\/generateMACAddress()","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","role":"collection","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/DiskInject