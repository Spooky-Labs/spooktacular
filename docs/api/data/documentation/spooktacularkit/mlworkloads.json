d":"identifier","text":"VirtualMachineConfiguration"}],"role":"symbol","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"type":"topic","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","role":"collectionGroup","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","url":"\/documentation\/spooktacularkit\/clonemanager","type":"topic","title":"CloneManager","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"role":"symbol","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"role":"collectionGroup","kind":"article"}}}