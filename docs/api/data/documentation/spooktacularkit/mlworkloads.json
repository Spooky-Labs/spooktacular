"text":"VirtualMachineConfiguration"}],"navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"title":"Versioning & Release Schedule","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"title":"NetworkMode.bridged(interface:)","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)","abstract":[{"type":"text","text":"Bridged directly to a physical network interface."}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"bridged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"interface","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"title":"minimumCPUCount","abstract":[{"type":"text","text":"The minimum number of CPU cores required for a macOS VM"},{"type":"text","text":" "},{"type":"text","text":"to boot without freezing."}],"type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","kind":"sym