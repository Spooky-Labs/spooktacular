{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","anchor":"Guides","generated":true}],"kind":"article","sections":[],"abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"],"title":"Related Guides","anchor":"Related-Guides"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"],"title":"Key Types","anchor":"Key-Types"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"Apple Silicon’s unified memory architecture gives every Mac direct","type":"text"},{"text":" ","type":"text"},{"text":"access to a powerful GPU and Neural Engine without a discrete graphics","type":"text"},{"text":" ","type":"text"},{"text":"card. Spooktacular VMs expose these capabilities to guest macOS,","type":"text"},{"text":" ","type":"text"},{"text":"making it possible to run GPU-accelerated machine learning workloads","type":"text"},{"text":" ","type":"text"},{"text":"inside isolated virtual machines.","type":"text"}],"type":"paragraph"},{"anchor":"Why-macOS-VMs-for-ML","level":3,"type":"heading","text":"Why macOS VMs for ML?"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Apple Silicon GPU"}],"type":"strong"},{"type":"text","text":" — Metal-accelerated training via MLX, PyTorch"},{"type":"text","text":" "},{"type":"text","text":"MPS, and Create ML"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Neural Engine","type":"text"}]},{"type":"text","text":" — 16-core (or more) Neural Engine for Core ML"},{"type":"text","text":" "},{"type":"text","text":"inference"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Unified memory"}]},{"type":"text","text":" — GPU and CPU share the same memory pool, so"},{"type":"text","text":" "},{"type":"text","text":"there is no PCIe bottleneck for large models"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Reproducible environments"}]},{"type":"text","text":" — Clone a configured ML VM instantly"},{"type":"text","text":" "},{"type":"text","text":"with "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","type":"reference","isActive":true},{"type":"text","text":" for reproducible experiments"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"type":"text","text":" — Run multiple experiments concurrently without"},{"type":"text","text":" "},{"type":"text","text":"dependency conflicts between VMs"}]}]}],"type":"unorderedList"},{"text":"Hardware Configuration for ML","level":2,"anchor":"Hardware-Configuration-for-ML","type":"heading"},{"inlineContent":[{"text":"ML workloads benefit from maximum CPU, memory, and disk allocation.","type":"text"},{"text":" ","type":"text"},{"text":"Allocate resources according to your workload:","type":"text"}],"type":"paragraph"},{"text":"Single-VM Configuration (Dedicated Host)","level":3,"anchor":"Single-VM-Configuration-Dedicated-Host","type":"heading"},{"inlineContent":[{"text":"When the entire host is dedicated to one ML workload:","type":"text"}],"type":"paragraph"},{"code":["spook create ml-trainer \\","    --cpu 8 --memory 24 --disk 200 \\","    --network host-only \\","    --disable-audio"],"type":"codeListing","syntax":"bash"},{"text":"Dual-VM Configuration (Shared Host)","level":3,"anchor":"Dual-VM-Configuration-Shared-Host","type":"heading"},{"inlineContent":[{"text":"When running two ML VMs on one host (e.g., training + inference):","type":"text"}],"type":"paragraph"},{"code":["# Training VM — more CPU and memory","spook create ml-train \\","    --cpu 6 --memory 16 --disk 200 \\","    --network host-only \\","    --disable-audio","","# Inference VM — lighter resources","spook create ml-serve \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --disable-audio"],"type":"codeListing","syntax":"bash"},{"text":"Recommended Specs by Chip","level":3,"anchor":"Recommended-Specs-by-Chip","type":"heading"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Chip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cores"}]}],[{"type":"paragraph","inlineContent":[{"text":"RAM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Single ML VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dual ML VMs"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"M1"}]}],[{"type":"paragraph","inlineContent":[{"text":"8","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6 CPU \/ 12 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4+4 CPU \/ 6+6 GB"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"M2 Pro"}]}],[{"type":"paragraph","inlineContent":[{"text":"12","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"10 CPU \/ 24 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"6+6 CPU \/ 14+14 GB"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M2 Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"12","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"64 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"10 CPU \/ 48 GB","type":"text"}]}],[{"inlineContent":[{"text":"6+6 CPU \/ 28+28 GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"M2 Ultra","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"24","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"192 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"20 CPU \/ 160 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"12+12 CPU \/ 80+80 GB"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"M4","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"10"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"8 CPU \/ 24 GB","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"4+4 CPU \/ 12+12 GB"}],"type":"paragraph"}]]]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Always leave at least 2 CPU cores and 4 GB RAM for the host","type":"text"},{"text":" ","type":"text"},{"text":"macOS. The minimum VM CPU count is 4 (see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","isActive":true},{"text":").","type":"text"}]}],"name":"Note"},{"anchor":"Metal-GPU-Access-in-VMs","type":"heading","level":2,"text":"Metal GPU Access in VMs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Virtualization framework provides GPU access to macOS guests via"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacGraphicsDeviceConfiguration"},{"text":". This is configured automatically","type":"text"},{"text":" ","type":"text"},{"text":"when you create a VM with Spooktacular — every VM gets a virtual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GPU device backed by the host’s Metal-capable hardware."}]},{"level":3,"anchor":"How-It-Works","type":"heading","text":"How It Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)","type":"reference"},{"type":"text","text":" configures a VM, it"},{"text":" ","type":"text"},{"text":"creates a ","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":" with one or two virtual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"displays. The guest macOS sees this as a standard Metal GPU and can"},{"text":" ","type":"text"},{"text":"run any Metal workload: shaders, compute kernels, ML frameworks.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ This happens automatically inside VMConfiguration.applySpec","let graphics = VZMacGraphicsDeviceConfiguration()","graphics.displays = [","    VZMacGraphicsDisplayConfiguration(","        widthInPixels: 1920,","        heightInPixels: 1200,","        pixelsPerInch: 80","    )","]","configuration.graphicsDevices = [graphics]"]},{"level":3,"type":"heading","text":"Verifying GPU Access Inside the VM","anchor":"Verifying-GPU-Access-Inside-the-VM"},{"type":"codeListing","syntax":"bash","code":["# Check Metal device availability","spook exec ml-trainer -- system_profiler SPDisplaysDataType","","# Run a quick Metal compute test","spook exec ml-trainer -- python3 -c \"","import mlx.core as mx","a = mx.ones((1000, 1000))","b = mx.ones((1000, 1000))","c = a @ b","print(f'Matrix multiply result shape: {c.shape}')","print(f'GPU computation successful')","\""]},{"level":3,"anchor":"Headless-GPU-Mode","text":"Headless GPU Mode","type":"heading"},{"inlineContent":[{"type":"text","text":"For ML workloads you typically do not need a visible display"},{"type":"text","text":" "},{"type":"text","text":"window. Run headless to avoid unnecessary display overhead:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start ml-trainer --headless"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The virtual GPU is still fully functional for compute workloads"},{"text":" ","type":"text"},{"type":"text","text":"even in headless mode. Display rendering simply has no visible"},{"text":" ","type":"text"},{"text":"output target.","type":"text"}],"type":"paragraph"},{"text":"Shared Folders for Datasets","anchor":"Shared-Folders-for-Datasets","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Large datasets (often many gigabytes or terabytes) should not be"},{"type":"text","text":" "},{"type":"text","text":"copied into each VM’s disk image. Instead, use VirtIO shared"},{"type":"text","text":" "},{"text":"folders to mount host directories directly inside the guest.","type":"text"}]},{"text":"Mounting Datasets","level":3,"anchor":"Mounting-Datasets","type":"heading"},{"type":"codeListing","syntax":"bash","code":["# Share a dataset directory (read-only) and an output directory (read-write)","spook share ml-trainer add \/data\/imagenet --tag imagenet --read-only","spook share ml-trainer add \/data\/checkpoints --tag checkpoints"]},{"type":"paragraph","inlineContent":[{"text":"Inside the guest, the first shared folder appears automatically in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Finder (macOS automount). Additional folders can be mounted manually:"}]},{"syntax":"bash","type":"codeListing","code":["# Inside the guest VM","sudo mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","sudo mount_virtiofs imagenet \/Volumes\/imagenet","sudo mount_virtiofs checkpoints \/Volumes\/checkpoints"]},{"type":"heading","anchor":"Kubernetes-Configuration","level":3,"text":"Kubernetes Configuration"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: ml-trainer","spec:","  image: ghcr.io\/spooktacular\/macos-ml:15.4","  resources:","    cpu: 8","    memory: 24Gi","    disk: 100Gi","  sharedFolders:","    - hostPath: \/data\/imagenet","      guestTag: imagenet","      readOnly: true","    - hostPath: \/data\/checkpoints","      guestTag: checkpoints","      readOnly: false","  provisioning:","    mode: agent","    userData: |","      #!\/bin\/bash","      mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","      mount_virtiofs imagenet \/Volumes\/imagenet","      mount_virtiofs checkpoints \/Volumes\/checkpoints","      cd \/Volumes\/imagenet && python3 \/opt\/train.py"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder"},{"type":"text","text":" for the API details and "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","type":"reference"},{"text":" ","type":"text"},{"text":"for how shared folders are configured in the VM specification.","type":"text"}]},{"type":"heading","anchor":"MLX-Framework","level":2,"text":"MLX Framework"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/ml-explore\/mlx","isActive":true,"type":"reference"},{"text":" is Apple’s array framework","type":"text"},{"type":"text","text":" "},{"text":"for machine learning on Apple Silicon. It runs natively on the Metal","type":"text"},{"type":"text","text":" "},{"text":"GPU and is designed for the unified memory architecture.","type":"text"}]},{"level":3,"text":"Installing MLX in a VM","type":"heading","anchor":"Installing-MLX-in-a-VM"},{"code":["# Via the provisioning user-data script","spook create ml-trainer --from-ipsw latest \\","    --cpu 8 --memory 24 --disk 100 \\","    --user-data ~\/setup-mlx.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Where "},{"type":"codeVoice","code":"setup-mlx.sh"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["#!\/bin\/bash","set -euo pipefail","","# Install Python and MLX","\/opt\/homebrew\/bin\/brew install python@3.12","pip3 install mlx mlx-lm numpy","","# Verify installation","python3 -c \"import mlx.core as mx; print(f'MLX default device: {mx.default_device()}')\""],"syntax":"bash","type":"codeListing"},{"text":"MLX Training Example","level":3,"anchor":"MLX-Training-Example","type":"heading"},{"code":["# train_mlx.py — runs inside the VM","import mlx.core as mx","import mlx.nn as nn","import mlx.optimizers as optim","","class SimpleModel(nn.Module):","    def __init__(self):","        super().__init__()","        self.layers = [","            nn.Linear(784, 256),","            nn.Linear(256, 128),","            nn.Linear(128, 10),","        ]","","    def __call__(self, x):","        for l in self.layers[:-1]:","            x = nn.relu(l(x))","        return self.layers[-1](x)","","model = SimpleModel()","optimizer = optim.Adam(learning_rate=1e-3)","","# Training loop","for epoch in range(10):","    # ... load data from \/Volumes\/training-data","    loss = train_step(model, optimizer, batch)","    mx.eval(loss)","    print(f\"Epoch {epoch}: loss = {loss.item():.4f}\")","","# Save checkpoint to shared folder","mx.savez(\"\/Volumes\/checkpoints\/model.npz\", **dict(model.parameters()))"],"syntax":"python","type":"codeListing"},{"text":"MLX-LM for Language Models","level":3,"anchor":"MLX-LM-for-Language-Models","type":"heading"},{"inlineContent":[{"text":"Fine-tune or run inference on language models:","type":"text"}],"type":"paragraph"},{"code":["# Inside the VM","pip3 install mlx-lm","","# Download and convert a model","python3 -m mlx_lm.convert --hf-path mistralai\/Mistral-7B-v0.1","","# Run inference","python3 -m mlx_lm.generate --model mlx_model --prompt \"Hello, world\"","","# Fine-tune with LoRA","python3 -m mlx_lm.lora --model mlx_model \\","    --data \/Volumes\/training-data\/finetune.jsonl \\","    --output \/Volumes\/checkpoints\/lora-adapters"],"syntax":"bash","type":"codeListing"},{"text":"PyTorch with MPS Backend","level":2,"anchor":"PyTorch-with-MPS-Backend","type":"heading"},{"inlineContent":[{"type":"text","text":"PyTorch supports Apple Silicon GPU acceleration via the MPS"},{"type":"text","text":" "},{"type":"text","text":"(Metal Performance Shaders) backend."}],"type":"paragraph"},{"text":"Installation","level":3,"anchor":"Installation","type":"heading"},{"code":["#!\/bin\/bash","# setup-pytorch.sh","pip3 install torch torchvision torchaudio"],"syntax":"bash","type":"codeListing"},{"text":"Verifying MPS Availability","level":3,"anchor":"Verifying-MPS-Availability","type":"heading"},{"code":["import torch","","print(f\"MPS available: {torch.backends.mps.is_available()}\")","print(f\"MPS built: {torch.backends.mps.is_built()}\")","","device = torch.device(\"mps\" if torch.backends.mps.is_available() else \"cpu\")","print(f\"Using device: {device}\")","","# Quick benchmark","x = torch.randn(1000, 1000, device=device)","y = torch.randn(1000, 1000, device=device)","z = x @ y","print(f\"Matrix multiply on {device}: {z.shape}\")"],"syntax":"python","type":"codeListing"},{"type":"heading","level":3,"anchor":"PyTorch-Training-Example","text":"PyTorch Training Example"},{"syntax":"python","type":"codeListing","code":["# train_pytorch.py","import torch","import torch.nn as nn","import torchvision","import torchvision.transforms as transforms","","device = torch.device(\"mps\")","","# Load data from shared folder","transform = transforms.Compose([","    transforms.ToTensor(),","    transforms.Normalize((0.5,), (0.5,))","])","","trainset = torchvision.datasets.CIFAR10(","    root=\"\/Volumes\/training-data\", train=True,","    download=False, transform=transform",")","trainloader = torch.utils.data.DataLoader(","    trainset, batch_size=64, shuffle=True",")","","# Simple CNN","model = torchvision.models.resnet18(num_classes=10).to(device)","optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)","criterion = nn.CrossEntropyLoss()","","for epoch in range(10):","    running_loss = 0.0","    for images, labels in trainloader:","        images, labels = images.to(device), labels.to(device)","        optimizer.zero_grad()","        outputs = model(images)","        loss = criterion(outputs, labels)","        loss.backward()","        optimizer.step()","        running_loss += loss.item()","","    avg_loss = running_loss \/ len(trainloader)","    print(f\"Epoch {epoch}: loss = {avg_loss:.4f}\")","","    # Save checkpoint to shared folder","    torch.save(model.state_dict(), f\"\/Volumes\/checkpoints\/epoch_{epoch}.pt\")"]},{"type":"heading","level":2,"anchor":"Core-ML-and-Create-ML","text":"Core ML and Create ML"},{"anchor":"Create-ML-Training-in-a-VM","text":"Create ML Training in a VM","type":"heading","level":3},{"type":"codeListing","code":["# Inside the VM — train an image classifier","swift -e '","import CreateML","import Foundation","","let data = try MLImageClassifier.DataSource.labeledDirectories(","    at: URL(fileURLWithPath: \"\/Volumes\/training-data\/images\")",")","let classifier = try MLImageClassifier(trainingData: data)","try classifier.write(to: URL(fileURLWithPath: \"\/Volumes\/checkpoints\/Classifier.mlmodel\"))","print(\"Model saved successfully\")","'"],"syntax":"bash"},{"anchor":"Core-ML-Inference","text":"Core ML Inference","type":"heading","level":3},{"type":"codeListing","code":["# inference.py — run a Core ML model inside the VM","import coremltools as ct","import numpy as np","","model = ct.models.MLModel(\"\/Volumes\/checkpoints\/Classifier.mlmodel\")","prediction = model.predict({\"image\": input_image})","print(f\"Prediction: {prediction}\")"],"syntax":"python"},{"anchor":"Federated-Learning-Setup","text":"Federated Learning Setup","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Run multiple isolated VMs that each train on a subset of data,"},{"type":"text","text":" "},{"type":"text","text":"then aggregate the results. Host-only networking allows the VMs"},{"type":"text","text":" "},{"type":"text","text":"to communicate with each other without external network access."}]},{"anchor":"Architecture","type":"heading","text":"Architecture","level":3},{"type":"codeListing","code":["+-----------------------------------------+","|  Mac Host                               |","|  +----------+  +----------+            |","|  |  VM-1    |  |  VM-2    |            |","|  |  Worker  |<>|  Worker  |            |","|  |  Shard 1 |  |  Shard 2 |            |","|  +----------+  +----------+            |","|       ^              ^                  |","|       +------+-------+                  |","|         Host-only network               |","|              |                          |","|      +-------v--------+                |","|      |  Aggregator    |                |","|      |  (host script) |                |","|      +----------------+                |","+-----------------------------------------+"],"syntax":null},{"anchor":"Setup","type":"heading","text":"Setup","level":3},{"type":"codeListing","code":["# Create two worker VMs with host-only networking","spook create worker-01 --cpu 4 --memory 8 --disk 64 \\","    --network host-only --disable-audio","","spook create worker-02 --cpu 4 --memory 8 --disk 64 \\","    --network host-only --disable-audio","","# Share different data shards with each","spook share worker-01 add \/data\/shard-01 --tag data --read-only","spook share worker-02 add \/data\/shard-02 --tag data --read-only","","# Share a common output directory","spook share worker-01 add \/data\/federated-output --tag output","spook share worker-02 add \/data\/federated-output --tag output","","# Start both","spook start worker-01 --headless","spook start worker-02 --headless"],"syntax":"bash"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","type":"reference","isActive":true},{"text":" mode is intended to let VMs communicate","type":"text"},{"text":" ","type":"text"},{"text":"with each other and the host over a private network without external","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"internet access – ideal for secure ML training environments."}],"type":"paragraph"},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Host-only networking currently falls back to NAT mode.","type":"text"},{"text":" ","type":"text"},{"text":"VMs will have internet access until a future release adds true","type":"text"},{"text":" ","type":"text"},{"text":"host-only isolation. Plan your network security accordingly.","type":"text"}]}]},{"type":"heading","text":"Training Checkpoints via VM Snapshots","level":2,"anchor":"Training-Checkpoints-via-VM-Snapshots"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a disk-level snapshot before long-running training operations."},{"type":"text","text":" "},{"type":"text","text":"If something goes wrong, restore the disk to the pre-training state:"}]},{"type":"codeListing","syntax":"bash","code":["# Stop the VM and snapshot before a long training run","spook stop ml-trainer","spook snapshot ml-trainer pre-training","spook start ml-trainer --headless","","# Start training","spook exec ml-trainer -- python3 \/opt\/train.py --epochs 100","","# If something goes wrong, stop and restore","spook stop ml-trainer","spook restore ml-trainer pre-training","spook start ml-trainer --headless","","# After successful training, stop and snapshot the trained state","spook stop ml-trainer","spook snapshot ml-trainer trained-v1"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk-level snapshots copy "},{"type":"codeVoice","code":"disk.img"},{"type":"text","text":" and "},{"type":"codeVoice","code":"auxiliary.bin"},{"type":"text","text":". The VM"},{"type":"text","text":" "},{"type":"text","text":"must be stopped before saving or restoring. Combine with"},{"type":"text","text":" "},{"type":"text","text":"application-level checkpointing (saving model weights to shared"},{"type":"text","text":" "},{"type":"text","text":"folders) for the best recovery story."}]},{"type":"heading","text":"Inference Server Deployment","level":2,"anchor":"Inference-Server-Deployment"},{"type":"paragraph","inlineContent":[{"text":"Deploy a trained model as an inference server accessible on the","type":"text"},{"text":" ","type":"text"},{"text":"network:","type":"text"}]},{"type":"heading","text":"NAT Mode (Port Forwarding)","level":3,"anchor":"NAT-Mode-Port-Forwarding"},{"type":"codeListing","syntax":"bash","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"]},{"type":"heading","text":"Bridged Mode (Own LAN IP)","level":3,"anchor":"Bridged-Mode-Own-LAN-IP"},{"type":"paragraph","inlineContent":[{"text":"For production inference servers that need their own IP address","type":"text"},{"text":" ","type":"text"},{"text":"on the local network:","type":"text"}]},{"type":"codeListing","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network bridged:en0 \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"type":"text","text":" mode gives the VM its own"},{"type":"text","text":" "},{"type":"text","text":"DHCP-assigned IP on the host’s LAN, making it directly addressable"},{"type":"text","text":" "},{"type":"text","text":"by other machines."}]},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"Bridged networking requires the ","type":"text"},{"code":"com.apple.vm.networking","type":"codeVoice"},{"text":" ","type":"text"},{"text":"entitlement. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"reference"},{"text":" for details.","type":"text"}],"type":"paragraph"}],"style":"note"},{"text":"Inference Server Script","type":"heading","level":3,"anchor":"Inference-Server-Script"},{"type":"codeListing","code":["#!\/bin\/bash","# setup-inference.sh","set -euo pipefail","","# Mount the model from a shared folder","mkdir -p \/Volumes\/models","mount_virtiofs models \/Volumes\/models","","# Install dependencies","pip3 install flask mlx mlx-lm","","# Start the inference server","cat > \/opt\/serve.py << 'PYEOF'","from flask import Flask, request, jsonify","from mlx_lm import load, generate","","app = Flask(__name__)","model, tokenizer = load(\"\/Volumes\/models\/my-model\")","","@app.route(\"\/predict\", methods=[\"POST\"])","def predict():","    prompt = request.json[\"prompt\"]","    response = generate(model, tokenizer, prompt=prompt, max_tokens=256)","    return jsonify({\"response\": response})","","app.run(host=\"0.0.0.0\", port=8080)","PYEOF","","python3 \/opt\/serve.py"],"syntax":"bash"},{"text":"Performance Tuning Tips","type":"heading","level":2,"anchor":"Performance-Tuning-Tips"},{"text":"Memory Management","type":"heading","level":3,"anchor":"Memory-Management"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Allocate maximum memory","type":"text"}],"type":"strong"},{"text":" — Unified memory is shared between","type":"text"},{"text":" ","type":"text"},{"text":"CPU and GPU. More VM memory means more GPU memory for large","type":"text"},{"text":" ","type":"text"},{"text":"models.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Avoid swap"}],"type":"strong"},{"text":" — If the VM runs out of memory, macOS will swap","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the virtual disk, which drastically reduces performance."},{"type":"text","text":" "},{"type":"text","text":"Size your VMs with enough RAM for your workload."}]}]}],"type":"unorderedList"},{"type":"heading","level":3,"text":"Disk I\/O","anchor":"Disk-IO"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Use shared folders for datasets"}]},{"type":"text","text":" — VirtIO shared folders"},{"type":"text","text":" "},{"type":"text","text":"bypass the virtual disk layer, providing direct host filesystem"},{"type":"text","text":" "},{"type":"text","text":"access."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"SSD-backed hosts"}]},{"type":"text","text":" — Apple Silicon Macs have fast NVMe storage."},{"type":"text","text":" "},{"type":"text","text":"APFS sparse disk images benefit from the underlying SSD speed."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Pre-stage data","type":"text"}]},{"type":"text","text":" — Copy frequently accessed data to the VM’s"},{"type":"text","text":" "},{"type":"text","text":"local disk for maximum I\/O performance during training."}],"type":"paragraph"}]}]},{"type":"heading","level":3,"text":"GPU Utilization","anchor":"GPU-Utilization"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Profile with Metal System Trace"}],"type":"strong"},{"text":" — Use Instruments in Xcode","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to profile GPU utilization inside the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Batch sizes","type":"text"}],"type":"strong"},{"text":" — Larger batch sizes improve GPU utilization but","type":"text"},{"text":" ","type":"text"},{"text":"require more memory. Find the largest batch size that fits.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Avoid CPU-GPU transfers"}]},{"text":" — With unified memory, data stays","type":"text"},{"text":" ","type":"text"},{"text":"in place. But framework-level copies can still occur. Use","type":"text"},{"text":" ","type":"text"},{"text":"in-place operations when possible.","type":"text"}],"type":"paragraph"}]}]},{"level":3,"text":"Network","type":"heading","anchor":"Network"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Host-only for isolation"}]},{"type":"text","text":" — "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","type":"reference","isActive":true},{"type":"text","text":" eliminates"},{"type":"text","text":" "},{"type":"text","text":"network overhead from external traffic."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Shared folders over network mounts"}],"type":"strong"},{"type":"text","text":" — VirtIO shared folders"},{"text":" ","type":"text"},{"text":"are faster than NFS or SMB mounts for data access.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Example: Training a Model with Shared Data","type":"heading","anchor":"Example-Training-a-Model-with-Shared-Data"},{"inlineContent":[{"type":"text","text":"A complete end-to-end example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# 1. Prepare the host","mkdir -p \/data\/cifar10 \/data\/models","","# Download CIFAR-10 to the host","python3 -c \"","import torchvision","torchvision.datasets.CIFAR10('\/data\/cifar10', download=True)","\"","","# 2. Create the ML VM","spook create ml-cifar \\","    --from-ipsw latest \\","    --cpu 6 --memory 16 --disk 64 \\","    --network host-only \\","    --disable-audio \\","    --user-data \/opt\/spooktacular\/train-cifar.sh \\","    --provision disk-inject","","# 3. Add shared folders","spook share ml-cifar add \/data\/cifar10 --tag data --read-only","spook share ml-cifar add \/data\/models --tag models","","# 4. Start training","spook start ml-cifar --headless","","# 5. Monitor progress","spook exec ml-cifar -- tail -f \/tmp\/training.log","","# 6. Results appear in \/data\/models\/ on the host","ls \/data\/models\/","# epoch_0.pt  epoch_1.pt  ...  final_model.pt"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/mlworkloads"]}],"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Machine Learning Workloads","roleHeading":"API Collection","role":"collectionGroup"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/Spo