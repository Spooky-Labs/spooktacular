acularKit/RemoteDesktop":{"url":"\/documentation\/spooktacularkit\/remotedesktop","title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","kind":"article","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI.","type":"text"}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}],"title":"VirtualMachineSpecification","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","title":"Getting Started with Spooktacular","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","type":"topic","kind":"article","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"type":"topic","title":"CloneManager","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","url":"\/documentation\/spooktacularkit\/clonemanager","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}],"kind":"symbol","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","abstract":[{"text":"Bridged directly to a physical network interface.","type":"text"}],"type":"topic","title":"NetworkMode.bridged(interface:)","url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"bridged","kind":"identifier"},{"kind":"text","text":"("},{"text":"interface","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"title":"SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"url":"\/documentation\/spooktacularkit\/sharedfolder","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"url":"\/documentation\/spooktacularkit\/networkmode","type":"topic","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"kind":"symbol","title":"NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"title":"Running BlueBubbles iMessage Server","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","url":"\/documentation\/spooktacularkit\/bluebubblesguide","kind":"article","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"navigatorTitle":[{"text":"VirtualMachineConfiguration","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","title":"VirtualMachineConfiguration","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","abstract":[{"text":"Builds ","type":"text"},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":" objects from a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification"},{"text":".","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier"