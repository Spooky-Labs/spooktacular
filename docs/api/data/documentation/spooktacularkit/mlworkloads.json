t"},{"text":"NetworkMode","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","kind":"symbol","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"title":"NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/clireference","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"title":"Using the spook Command-Line Interface"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineConfiguration","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}],"abstract":[{"type":"text","text":"Builds "},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":" objects from a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference"},{"text":".","type":"text"}],"title":"VirtualMachineConfiguration"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/ec2macdeployment","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","abstract":[{"type":"text","text":"Run Spoo