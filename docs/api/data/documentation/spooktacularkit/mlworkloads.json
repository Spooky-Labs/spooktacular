ed hosts to double your macOS CI capacity.","type":"text"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","kind":"article","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"abstract":[{"text":"A directory shared between the host and the virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","url":"\/documentation\/spooktacularkit\/sharedfolder","kind":"symbol","title":"SharedFolder","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineConfiguration"}],"type":"topic","abstract":[{"type":"text","text":"Builds "},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"type":"text","text":" objects from a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification"},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}],"title":"VirtualMachineConfiguration","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"abstract":[{"text":"The minimum number of CPU cores required for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount","kind":"symbol","title":"minimumCPUCount","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/hostOnly":{"abstract":[{"type":"text","text":"Host-only networking."}],"role":"symbol","url":"\/documentation\/spooktacularkit\/networkmode\/hostonly","title":"NetworkMode.hostOnly","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","kind":"symbol","type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"hostOnly","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"type":"topic","kind":"article","title":"Running BlueBubbles iMessage Server","url":"\/documentation\/spooktacularkit\/bluebubblesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration/applySpec(_:to:)":{"abstract":[{"text":"Applies a ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true,"type":"reference"},{"text":" to a ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"text":".","type":"text"}],"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration\/apply