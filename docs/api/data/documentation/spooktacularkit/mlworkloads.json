/SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount","abstract":[{"text":"The minimum number of CPU cores required for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","title":"minimumCPUCount"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"url":"\/documentation\/spooktacularkit\/sharedfolder","role":"symbol","title":"SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"type":"topic","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)","abstract":[{"text":"Bridged directly to a physical network interface.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"bridged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"interface"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":")"}],"identifier":"d