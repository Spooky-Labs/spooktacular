{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"topicSections":[{"anchor":"Related-Guides","title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop"]},{"anchor":"Key-Types","title":"Key Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"]}],"seeAlsoSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true}],"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"Apple Silicon’s unified memory architecture gives every Mac direct","type":"text"},{"text":" ","type":"text"},{"text":"access to a powerful GPU and Neural Engine without a discrete graphics","type":"text"},{"text":" ","type":"text"},{"text":"card. Spooktacular VMs expose these capabilities to guest macOS,","type":"text"},{"text":" ","type":"text"},{"text":"making it possible to run GPU-accelerated machine learning workloads","type":"text"},{"text":" ","type":"text"},{"text":"inside isolated virtual machines.","type":"text"}],"type":"paragraph"},{"text":"Why macOS VMs for ML?","level":3,"anchor":"Why-macOS-VMs-for-ML","type":"heading"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Apple Silicon GPU"}],"type":"strong"},{"text":" — Metal-accelerated training via MLX, PyTorch","type":"text"},{"text":" ","type":"text"},{"text":"MPS, and Create ML","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Neural Engine"}],"type":"strong"},{"type":"text","text":" — 16-core (or more) Neural Engine for Core ML"},{"type":"text","text":" "},{"type":"text","text":"inference"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Unified memory","type":"text"}]},{"type":"text","text":" — GPU and CPU share the same memory pool, so"},{"type":"text","text":" "},{"type":"text","text":"there is no PCIe bottleneck for large models"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Reproducible environments","type":"text"}]},{"type":"text","text":" — Clone a configured ML VM instantly"},{"type":"text","text":" "},{"type":"text","text":"with "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","isActive":true,"type":"reference"},{"type":"text","text":" for reproducible experiments"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Isolation"}],"type":"strong"},{"text":" — Run multiple experiments concurrently without","type":"text"},{"text":" ","type":"text"},{"text":"dependency conflicts between VMs","type":"text"}]}]}],"type":"unorderedList"},{"text":"Hardware Configuration for ML","type":"heading","level":2,"anchor":"Hardware-Configuration-for-ML"},{"inlineContent":[{"text":"ML workloads benefit from maximum CPU, memory, and disk allocation.","type":"text"},{"text":" ","type":"text"},{"text":"Allocate resources according to your workload:","type":"text"}],"type":"paragraph"},{"text":"Single-VM Configuration (Dedicated Host)","type":"heading","level":3,"anchor":"Single-VM-Configuration-Dedicated-Host"},{"inlineContent":[{"type":"text","text":"When the entire host is dedicated to one ML workload:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create ml-trainer \\","    --cpu 8 --memory 24 --disk 200 \\","    --network host-only \\","    --disable-audio"]},{"text":"Dual-VM Configuration (Shared Host)","type":"heading","level":3,"anchor":"Dual-VM-Configuration-Shared-Host"},{"inlineContent":[{"text":"When running two ML VMs on one host (e.g., training + inference):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# Training VM — more CPU and memory","spook create ml-train \\","    --cpu 6 --memory 16 --disk 200 \\","    --network host-only \\","    --disable-audio","","# Inference VM — lighter resources","spook create ml-serve \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --disable-audio"]},{"type":"heading","text":"Recommended Specs by Chip","anchor":"Recommended-Specs-by-Chip","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Chip","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"RAM"}]}],[{"type":"paragraph","inlineContent":[{"text":"Single ML VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dual ML VMs"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"8"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"6 CPU \/ 12 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4+4 CPU \/ 6+6 GB"}]}]],[[{"inlineContent":[{"type":"text","text":"M2 Pro"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"12"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10 CPU \/ 24 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6+6 CPU \/ 14+14 GB"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"M2 Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"12","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"64 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"10 CPU \/ 48 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6+6 CPU \/ 28+28 GB"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"M2 Ultra"}],"type":"paragraph"}],[{"inlineContent":[{"text":"24","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"192 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"20 CPU \/ 160 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"12+12 CPU \/ 80+80 GB","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"M4"}],"type":"paragraph"}],[{"inlineContent":[{"text":"10","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"32 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8 CPU \/ 24 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4+4 CPU \/ 12+12 GB","type":"text"}],"type":"paragraph"}]]]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Always leave at least 2 CPU cores and 4 GB RAM for the host"},{"type":"text","text":" "},{"type":"text","text":"macOS. The minimum VM CPU count is 4 (see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount"},{"type":"text","text":")."}],"type":"paragraph"}]},{"level":2,"type":"heading","text":"Metal GPU Access in VMs","anchor":"Metal-GPU-Access-in-VMs"},{"type":"paragraph","inlineContent":[{"text":"The Virtualization framework provides GPU access to macOS guests via","type":"text"},{"text":" ","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":". This is configured automatically","type":"text"},{"text":" ","type":"text"},{"text":"when you create a VM with Spooktacular — every VM gets a virtual","type":"text"},{"text":" ","type":"text"},{"text":"GPU device backed by the host’s Metal-capable hardware.","type":"text"}]},{"level":3,"type":"heading","text":"How It Works","anchor":"How-It-Works"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)","isActive":true,"type":"reference"},{"text":" configures a VM, it","type":"text"},{"text":" ","type":"text"},{"text":"creates a ","type":"text"},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"text":" with one or two virtual","type":"text"},{"text":" ","type":"text"},{"text":"displays. The guest macOS sees this as a standard Metal GPU and can","type":"text"},{"text":" ","type":"text"},{"text":"run any Metal workload: shaders, compute kernels, ML frameworks.","type":"text"}]},{"type":"codeListing","code":["\/\/ This happens automatically inside VMConfiguration.applySpec","let graphics = VZMacGraphicsDeviceConfiguration()","graphics.displays = [","    VZMacGraphicsDisplayConfiguration(","        widthInPixels: 1920,","        heightInPixels: 1200,","        pixelsPerInch: 80","    )","]","configuration.graphicsDevices = [graphics]"],"syntax":"swift"},{"level":3,"type":"heading","text":"Verifying GPU Access Inside the VM","anchor":"Verifying-GPU-Access-Inside-the-VM"},{"type":"codeListing","code":["# Check Metal device availability","spook exec ml-trainer -- system_profiler SPDisplaysDataType","","# Run a quick Metal compute test","spook exec ml-trainer -- python3 -c \"","import mlx.core as mx","a = mx.ones((1000, 1000))","b = mx.ones((1000, 1000))","c = a @ b","print(f'Matrix multiply result shape: {c.shape}')","print(f'GPU computation successful')","\""],"syntax":"bash"},{"type":"heading","level":3,"text":"Headless GPU Mode","anchor":"Headless-GPU-Mode"},{"type":"paragraph","inlineContent":[{"text":"For ML workloads you typically do not need a visible display","type":"text"},{"text":" ","type":"text"},{"text":"window. Run headless to avoid unnecessary display overhead:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook start ml-trainer --headless"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The virtual GPU is still fully functional for compute workloads"},{"type":"text","text":" "},{"type":"text","text":"even in headless mode. Display rendering simply has no visible"},{"type":"text","text":" "},{"type":"text","text":"output target."}]},{"type":"heading","level":2,"text":"Shared Folders for Datasets","anchor":"Shared-Folders-for-Datasets"},{"type":"paragraph","inlineContent":[{"text":"Large datasets (often many gigabytes or terabytes) should not be","type":"text"},{"text":" ","type":"text"},{"text":"copied into each VM’s disk image. Instead, use VirtIO shared","type":"text"},{"text":" ","type":"text"},{"text":"folders to mount host directories directly inside the guest.","type":"text"}]},{"type":"heading","level":3,"text":"Mounting Datasets","anchor":"Mounting-Datasets"},{"type":"codeListing","syntax":"bash","code":["# Share a dataset directory (read-only) and an output directory (read-write)","spook share ml-trainer add \/data\/imagenet --tag imagenet --read-only","spook share ml-trainer add \/data\/checkpoints --tag checkpoints"]},{"type":"paragraph","inlineContent":[{"text":"Inside the guest, the first shared folder appears automatically in","type":"text"},{"text":" ","type":"text"},{"text":"Finder (macOS automount). Additional folders can be mounted manually:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Inside the guest VM","sudo mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","sudo mount_virtiofs imagenet \/Volumes\/imagenet","sudo mount_virtiofs checkpoints \/Volumes\/checkpoints"]},{"type":"heading","level":3,"text":"Kubernetes Configuration","anchor":"Kubernetes-Configuration"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: ml-trainer","spec:","  image: ghcr.io\/spooktacular\/macos-ml:15.4","  resources:","    cpu: 8","    memory: 24Gi","    disk: 100Gi","  sharedFolders:","    - hostPath: \/data\/imagenet","      guestTag: imagenet","      readOnly: true","    - hostPath: \/data\/checkpoints","      guestTag: checkpoints","      readOnly: false","  provisioning:","    mode: agent","    userData: |","      #!\/bin\/bash","      mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","      mount_virtiofs imagenet \/Volumes\/imagenet","      mount_virtiofs checkpoints \/Volumes\/checkpoints","      cd \/Volumes\/imagenet && python3 \/opt\/train.py"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","isActive":true,"type":"reference"},{"type":"text","text":" for the API details and "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for how shared folders are configured in the VM specification."}]},{"level":2,"text":"MLX Framework","type":"heading","anchor":"MLX-Framework"},{"inlineContent":[{"identifier":"https:\/\/github.com\/ml-explore\/mlx","isActive":true,"type":"reference"},{"text":" is Apple’s array framework","type":"text"},{"text":" ","type":"text"},{"text":"for machine learning on Apple Silicon. It runs natively on the Metal","type":"text"},{"text":" ","type":"text"},{"text":"GPU and is designed for the unified memory architecture.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Installing MLX in a VM","type":"heading","anchor":"Installing-MLX-in-a-VM"},{"syntax":"bash","code":["# Via the provisioning user-data script","spook create ml-trainer --from-ipsw latest \\","    --cpu 8 --memory 24 --disk 100 \\","    --user-data ~\/setup-mlx.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Where "},{"code":"setup-mlx.sh","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Install Python and MLX","\/opt\/homebrew\/bin\/brew install python@3.12","pip3 install mlx mlx-lm numpy","","# Verify installation","python3 -c \"import mlx.core as mx; print(f'MLX default device: {mx.default_device()}')\""],"type":"codeListing"},{"type":"heading","text":"MLX Training Example","level":3,"anchor":"MLX-Training-Example"},{"type":"codeListing","code":["# train_mlx.py — runs inside the VM","import mlx.core as mx","import mlx.nn as nn","import mlx.optimizers as optim","","class SimpleModel(nn.Module):","    def __init__(self):","        super().__init__()","        self.layers = [","            nn.Linear(784, 256),","            nn.Linear(256, 128),","            nn.Linear(128, 10),","        ]","","    def __call__(self, x):","        for l in self.layers[:-1]:","            x = nn.relu(l(x))","        return self.layers[-1](x)","","model = SimpleModel()","optimizer = optim.Adam(learning_rate=1e-3)","","# Training loop","for epoch in range(10):","    # ... load data from \/Volumes\/training-data","    loss = train_step(model, optimizer, batch)","    mx.eval(loss)","    print(f\"Epoch {epoch}: loss = {loss.item():.4f}\")","","# Save checkpoint to shared folder","mx.savez(\"\/Volumes\/checkpoints\/model.npz\", **dict(model.parameters()))"],"syntax":"python"},{"anchor":"MLX-LM-for-Language-Models","type":"heading","text":"MLX-LM for Language Models","level":3},{"inlineContent":[{"type":"text","text":"Fine-tune or run inference on language models:"}],"type":"paragraph"},{"syntax":"bash","code":["# Inside the VM","pip3 install mlx-lm","","# Download and convert a model","python3 -m mlx_lm.convert --hf-path mistralai\/Mistral-7B-v0.1","","# Run inference","python3 -m mlx_lm.generate --model mlx_model --prompt \"Hello, world\"","","# Fine-tune with LoRA","python3 -m mlx_lm.lora --model mlx_model \\","    --data \/Volumes\/training-data\/finetune.jsonl \\","    --output \/Volumes\/checkpoints\/lora-adapters"],"type":"codeListing"},{"text":"PyTorch with MPS Backend","level":2,"anchor":"PyTorch-with-MPS-Backend","type":"heading"},{"inlineContent":[{"type":"text","text":"PyTorch supports Apple Silicon GPU acceleration via the MPS"},{"type":"text","text":" "},{"type":"text","text":"(Metal Performance Shaders) backend."}],"type":"paragraph"},{"anchor":"Installation","text":"Installation","type":"heading","level":3},{"code":["#!\/bin\/bash","# setup-pytorch.sh","pip3 install torch torchvision torchaudio"],"syntax":"bash","type":"codeListing"},{"anchor":"Verifying-MPS-Availability","text":"Verifying MPS Availability","type":"heading","level":3},{"code":["import torch","","print(f\"MPS available: {torch.backends.mps.is_available()}\")","print(f\"MPS built: {torch.backends.mps.is_built()}\")","","device = torch.device(\"mps\" if torch.backends.mps.is_available() else \"cpu\")","print(f\"Using device: {device}\")","","# Quick benchmark","x = torch.randn(1000, 1000, device=device)","y = torch.randn(1000, 1000, device=device)","z = x @ y","print(f\"Matrix multiply on {device}: {z.shape}\")"],"syntax":"python","type":"codeListing"},{"anchor":"PyTorch-Training-Example","text":"PyTorch Training Example","type":"heading","level":3},{"code":["# train_pytorch.py","import torch","import torch.nn as nn","import torchvision","import torchvision.transforms as transforms","","device = torch.device(\"mps\")","","# Load data from shared folder","transform = transforms.Compose([","    transforms.ToTensor(),","    transforms.Normalize((0.5,), (0.5,))","])","","trainset = torchvision.datasets.CIFAR10(","    root=\"\/Volumes\/training-data\", train=True,","    download=False, transform=transform",")","trainloader = torch.utils.data.DataLoader(","    trainset, batch_size=64, shuffle=True",")","","# Simple CNN","model = torchvision.models.resnet18(num_classes=10).to(device)","optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)","criterion = nn.CrossEntropyLoss()","","for epoch in range(10):","    running_loss = 0.0","    for images, labels in trainloader:","        images, labels = images.to(device), labels.to(device)","        optimizer.zero_grad()","        outputs = model(images)","        loss = criterion(outputs, labels)","        loss.backward()","        optimizer.step()","        running_loss += loss.item()","","    avg_loss = running_loss \/ len(trainloader)","    print(f\"Epoch {epoch}: loss = {avg_loss:.4f}\")","","    # Save checkpoint to shared folder","    torch.save(model.state_dict(), f\"\/Volumes\/checkpoints\/epoch_{epoch}.pt\")"],"syntax":"python","type":"codeListing"},{"anchor":"Core-ML-and-Create-ML","text":"Core ML and Create ML","type":"heading","level":2},{"anchor":"Create-ML-Training-in-a-VM","text":"Create ML Training in a VM","type":"heading","level":3},{"code":["# Inside the VM — train an image classifier","swift -e '","import CreateML","import Foundation","","let data = try MLImageClassifier.DataSource.labeledDirectories(","    at: URL(fileURLWithPath: \"\/Volumes\/training-data\/images\")",")","let classifier = try MLImageClassifier(trainingData: data)","try classifier.write(to: URL(fileURLWithPath: \"\/Volumes\/checkpoints\/Classifier.mlmodel\"))","print(\"Model saved successfully\")","'"],"syntax":"bash","type":"codeListing"},{"anchor":"Core-ML-Inference","text":"Core ML Inference","type":"heading","level":3},{"code":["# inference.py — run a Core ML model inside the VM","import coremltools as ct","import numpy as np","","model = ct.models.MLModel(\"\/Volumes\/checkpoints\/Classifier.mlmodel\")","prediction = model.predict({\"image\": input_image})","print(f\"Prediction: {prediction}\")"],"syntax":"python","type":"codeListing"},{"anchor":"Federated-Learning-Setup","text":"Federated Learning Setup","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Run multiple isolated VMs that each train on a subset of data,"},{"type":"text","text":" "},{"type":"text","text":"then aggregate the results. Host-only networking allows the VMs"},{"type":"text","text":" "},{"type":"text","text":"to communicate with each other without external network access."}],"type":"paragraph"},{"anchor":"Architecture","text":"Architecture","type":"heading","level":3},{"code":["+-----------------------------------------+","|  Mac Host                               |","|  +----------+  +----------+            |","|  |  VM-1    |  |  VM-2    |            |","|  |  Worker  |<>|  Worker  |            |","|  |  Shard 1 |  |  Shard 2 |            |","|  +----------+  +----------+            |","|       ^              ^                  |","|       +------+-------+                  |","|         Host-only network               |","|              |                          |","|      +-------v--------+                |","|      |  Aggregator    |                |","|      |  (host script) |                |","|      +----------------+                |","+-----------------------------------------+"],"syntax":null,"type":"codeListing"},{"anchor":"Setup","text":"Setup","type":"heading","level":3},{"code":["# Create two worker VMs with host-only networking","spook create worker-01 --cpu 4 --memory 8 --disk 64 \\","    --network host-only --disable-audio","","spook create worker-02 --cpu 4 --memory 8 --disk 64 \\","    --network host-only --disable-audio","","# Share different data shards with each","spook share worker-01 add \/data\/shard-01 --tag data --read-only","spook share worker-02 add \/data\/shard-02 --tag data --read-only","","# Share a common output directory","spook share worker-01 add \/data\/federated-output --tag output","spook share worker-02 add \/data\/federated-output --tag output","","# Start both","spook start worker-01 --headless","spook start worker-02 --headless"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","isActive":true,"type":"reference"},{"text":" mode is intended to let VMs communicate","type":"text"},{"text":" ","type":"text"},{"text":"with each other and the host over a private network without external","type":"text"},{"text":" ","type":"text"},{"text":"internet access – ideal for secure ML training environments.","type":"text"}],"type":"paragraph"},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Host-only networking currently falls back to NAT mode."},{"type":"text","text":" "},{"type":"text","text":"VMs will have internet access until a future release adds true"},{"type":"text","text":" "},{"type":"text","text":"host-only isolation. Plan your network security accordingly."}],"type":"paragraph"}],"name":"Important","style":"important"},{"type":"heading","text":"Training Checkpoints via VM Snapshots","level":2,"anchor":"Training-Checkpoints-via-VM-Snapshots"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a disk-level snapshot before long-running training operations."},{"type":"text","text":" "},{"type":"text","text":"If something goes wrong, restore the disk to the pre-training state:"}]},{"type":"codeListing","syntax":"bash","code":["# Stop the VM and snapshot before a long training run","spook stop ml-trainer","spook snapshot ml-trainer pre-training","spook start ml-trainer --headless","","# Start training","spook exec ml-trainer -- python3 \/opt\/train.py --epochs 100","","# If something goes wrong, stop and restore","spook stop ml-trainer","spook restore ml-trainer pre-training","spook start ml-trainer --headless","","# After successful training, stop and snapshot the trained state","spook stop ml-trainer","spook snapshot ml-trainer trained-v1"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk-level snapshots copy "},{"type":"codeVoice","code":"disk.img"},{"text":" and ","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":". The VM","type":"text"},{"text":" ","type":"text"},{"text":"must be stopped before saving or restoring. Combine with","type":"text"},{"text":" ","type":"text"},{"text":"application-level checkpointing (saving model weights to shared","type":"text"},{"text":" ","type":"text"},{"text":"folders) for the best recovery story.","type":"text"}]},{"anchor":"Inference-Server-Deployment","type":"heading","text":"Inference Server Deployment","level":2},{"inlineContent":[{"type":"text","text":"Deploy a trained model as an inference server accessible on the"},{"type":"text","text":" "},{"type":"text","text":"network:"}],"type":"paragraph"},{"anchor":"NAT-Mode-Port-Forwarding","type":"heading","text":"NAT Mode (Port Forwarding)","level":3},{"type":"codeListing","syntax":"bash","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"]},{"anchor":"Bridged-Mode-Own-LAN-IP","type":"heading","text":"Bridged Mode (Own LAN IP)","level":3},{"inlineContent":[{"text":"For production inference servers that need their own IP address","type":"text"},{"text":" ","type":"text"},{"text":"on the local network:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network bridged:en0 \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)"},{"type":"text","text":" mode gives the VM its own"},{"type":"text","text":" "},{"type":"text","text":"DHCP-assigned IP on the host’s LAN, making it directly addressable"},{"type":"text","text":" "},{"type":"text","text":"by other machines."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"type":"codeVoice","code":"com.apple.vm.networking"},{"type":"text","text":" "},{"text":"entitlement. See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","isActive":true,"type":"reference"},{"text":" for details.","type":"text"}]}],"style":"note","name":"Note"},{"type":"heading","anchor":"Inference-Server-Script","level":3,"text":"Inference Server Script"},{"type":"codeListing","code":["#!\/bin\/bash","# setup-inference.sh","set -euo pipefail","","# Mount the model from a shared folder","mkdir -p \/Volumes\/models","mount_virtiofs models \/Volumes\/models","","# Install dependencies","pip3 install flask mlx mlx-lm","","# Start the inference server","cat > \/opt\/serve.py << 'PYEOF'","from flask import Flask, request, jsonify","from mlx_lm import load, generate","","app = Flask(__name__)","model, tokenizer = load(\"\/Volumes\/models\/my-model\")","","@app.route(\"\/predict\", methods=[\"POST\"])","def predict():","    prompt = request.json[\"prompt\"]","    response = generate(model, tokenizer, prompt=prompt, max_tokens=256)","    return jsonify({\"response\": response})","","app.run(host=\"0.0.0.0\", port=8080)","PYEOF","","python3 \/opt\/serve.py"],"syntax":"bash"},{"type":"heading","anchor":"Performance-Tuning-Tips","level":2,"text":"Performance Tuning Tips"},{"type":"heading","anchor":"Memory-Management","level":3,"text":"Memory Management"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Allocate maximum memory"}]},{"type":"text","text":" — Unified memory is shared between"},{"type":"text","text":" "},{"type":"text","text":"CPU and GPU. More VM memory means more GPU memory for large"},{"type":"text","text":" "},{"type":"text","text":"models."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Avoid swap"}]},{"type":"text","text":" — If the VM runs out of memory, macOS will swap"},{"type":"text","text":" "},{"type":"text","text":"to the virtual disk, which drastically reduces performance."},{"type":"text","text":" "},{"type":"text","text":"Size your VMs with enough RAM for your workload."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Disk-IO","level":3,"text":"Disk I\/O"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use shared folders for datasets","type":"text"}],"type":"strong"},{"text":" — VirtIO shared folders","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bypass the virtual disk layer, providing direct host filesystem"},{"type":"text","text":" "},{"type":"text","text":"access."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"SSD-backed hosts"}]},{"type":"text","text":" — Apple Silicon Macs have fast NVMe storage."},{"type":"text","text":" "},{"type":"text","text":"APFS sparse disk images benefit from the underlying SSD speed."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Pre-stage data","type":"text"}]},{"type":"text","text":" — Copy frequently accessed data to the VM’s"},{"type":"text","text":" "},{"type":"text","text":"local disk for maximum I\/O performance during training."}]}]}]},{"type":"heading","level":3,"anchor":"GPU-Utilization","text":"GPU Utilization"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Profile with Metal System Trace"}],"type":"strong"},{"type":"text","text":" — Use Instruments in Xcode"},{"type":"text","text":" "},{"type":"text","text":"to profile GPU utilization inside the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Batch sizes"}],"type":"strong"},{"type":"text","text":" — Larger batch sizes improve GPU utilization but"},{"text":" ","type":"text"},{"type":"text","text":"require more memory. Find the largest batch size that fits."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Avoid CPU-GPU transfers","type":"text"}],"type":"strong"},{"text":" — With unified memory, data stays","type":"text"},{"text":" ","type":"text"},{"text":"in place. But framework-level copies can still occur. Use","type":"text"},{"type":"text","text":" "},{"text":"in-place operations when possible.","type":"text"}]}]}]},{"anchor":"Network","type":"heading","text":"Network","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Host-only for isolation","type":"text"}]},{"text":" — ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","isActive":true},{"text":" eliminates","type":"text"},{"text":" ","type":"text"},{"text":"network overhead from external traffic.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Shared folders over network mounts"}],"type":"strong"},{"type":"text","text":" — VirtIO shared folders"},{"type":"text","text":" "},{"text":"are faster than NFS or SMB mounts for data access.","type":"text"}],"type":"paragraph"}]}]},{"text":"Example: Training a Model with Shared Data","anchor":"Example-Training-a-Model-with-Shared-Data","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A complete end-to-end example:"}]},{"type":"codeListing","code":["# 1. Prepare the host","mkdir -p \/data\/cifar10 \/data\/models","","# Download CIFAR-10 to the host","python3 -c \"","import torchvision","torchvision.datasets.CIFAR10('\/data\/cifar10', download=True)","\"","","# 2. Create the ML VM","spook create ml-cifar \\","    --from-ipsw latest \\","    --cpu 6 --memory 16 --disk 64 \\","    --network host-only \\","    --disable-audio \\","    --user-data \/opt\/spooktacular\/train-cifar.sh \\","    --provision disk-inject","","# 3. Add shared folders","spook share ml-cifar add \/data\/cifar10 --tag data --read-only","spook share ml-cifar add \/data\/models --tag models","","# 4. Start training","spook start ml-cifar --headless","","# 5. Monitor progress","spook exec ml-cifar -- tail -f \/tmp\/training.log","","# 6. Results appear in \/data\/models\/ on the host","ls \/data\/models\/","# epoch_0.pt  epoch_1.pt  ...  final_model.pt"],"syntax":"bash"}],"kind":"content"}],"metadata":{"roleHeading":"API Collection","role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Machine Learning Workloads"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/spooktacularkit\/mlworkloads"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"url":"\/documentation\/spooktacularkit\/bluebubblesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","title":"Running BlueBubbles iMessage Server","role":"collectionGroup","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration/applySpec(_:to:)":{"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration\/applyspec(_:to:)","title":"applySpec(_:to:)","abstract":[{"text":"Applies a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification"},{"text":" to a ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applySpec"},{"text":"(","kind":"text"},{"text":"VirtualMachineSpecification","kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit27VirtualMachineSpecificationV"},{"text":", ","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VZVirtualMachineConfiguration","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)VZVirtualMachineConfiguration"},{"text":")","kind":"text"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount","title":"minimumCPUCount","type":"topic","abstract":[{"text":"The minimum number of CPU cores required for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","role":"symbol","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/sharedFolders":{"title":"sharedFolders","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sharedFolders","kind":"identifier"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit12SharedFolderV","text":"SharedFolder"},{"kind":"text","text":"]"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","kind":"symbol","abstract":[{"type":"text","text":"The directories shared between host and guest."}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/sharedfolders","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","url":"\/documentation\/spooktacularkit\/versioning","type":"topic","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"url":"\/documentation\/spooktacularkit\/networkmode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","title":"NetworkMode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"url":"\/documentation\/spooktacularkit\/sharedfolder","title":"SharedFolder","type":"topic","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"abstract":[{"text":"A directory shared between the host and the virtual machine.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","role":"symbol","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/hostOnly":{"title":"NetworkMode.hostOnly","abstract":[{"type":"text","text":"Host-only networking."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","url":"\/documentation\/spooktacularkit\/networkmode\/hostonly","type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"hostOnly"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"abstract":[{"text":"Bridged directly to a physical network interface.","type":"text"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"bridged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"interface"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":")"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)","title":"NetworkMode.bridged(interface:)","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"url":"\/documentation\/spooktacularkit\/clonemanager","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","title":"CloneManager","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"url":"\/documentation\/spooktacularkit\/remotedesktop","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"url":"\/documentation\/spooktacularkit\/kubernetesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration","role":"collectionGroup","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"type":"topic","title":"VirtualMachineSpecification","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"url":"\/documentation\/spooktacularkit\/ec2macdeployment","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"abstract":[{"type":"text","text":"Builds "},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"type":"text","text":" objects from a "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","title":"VirtualMachineConfiguration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineConfiguration"}],"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}]},"https://github.com/ml-explore/mlx":{"url":"https:\/\/github.com\/ml-explore\/mlx","type":"link","identifier":"https:\/\/github.com\/ml-explore\/mlx","title":"MLX","titleInlineContent":[{"text":"MLX","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"url":"\/documentation\/spooktacularkit\/gettingstarted","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","title":"Getting Started with Spooktacular","role":"collectionGroup","type":"topic","kind":"article"}}}