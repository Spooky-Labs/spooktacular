n\/spooktacularkit\/networkmode","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"title":"Remote Desktop Access","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"type":"topic","kind":"article","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VirtualMachineSpecification"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","type":"topic","abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"role":"symbol","title":"VirtualMachineSpecification"},"https://github.com/ml-explore/mlx":{"title":"MLX","type":"link","url":"https:\/\/github.com\/ml-explore\/mlx","titleInlineContent":[{"type":"text","text":"MLX"}],"identifier":"https:\/\/github.com\/ml-explore\/mlx"}}}