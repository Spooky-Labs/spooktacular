to double your macOS CI capacity.","type":"text"}],"type":"topic","title":"Deploying on EC2 Mac","kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/VMSpec":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VMSpec"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec","abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"type":"topic","url":"\/documentation\/spooktacularkit\/vmspec","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VMSpec"}],"title":"VMSpec","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VMSpec/minimumCPUCount":{"url":"\/documentation\/spooktacularkit\/vmspec\/minimumcpucount","title":"minimumCPUCount","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VMSpec\/minimumCPUCount","type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"abstract":[{"text":"The minimum number of CPU cores required for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","type":"topic","title":"SpooktacularKit","kind":"symbol","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/hostOnly":{"abstract":[{"text":"Host-only networking.","type":"text"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"hostOnly"}],"kind":"symbol","role":"symbol","title":"NetworkMode.hostOnly","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","url":"\/documentation\/spooktacularkit\/networkmode\/hostonly"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"kind":"article","role":"collectionGroup","title":"Getting Started with Spooktacular","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"kind":"article","title":"GitHub Actions Runners","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","type":"topic","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"kind":"article","title":"Running OpenClaw in Virtual Machines","url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","kind":"article","role":"collectionGroup","abstract":[{"text":"Complete reference for the ","type":"text"},{"code":"spook","type":"codeVoice"},{"type":"text","text":" command-line interface."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"CLI Reference"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"kind":"symbol","role":"symbol","title":"NetworkMode","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode"}}}