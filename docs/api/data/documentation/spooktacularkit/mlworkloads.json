workMode"}],"kind":"symbol","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","title":"NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","role":"collectionGroup","title":"Remote Desktop Access","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","url":"\/documentation\/spooktacularkit"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners"}}}