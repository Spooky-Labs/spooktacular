ication\/minimumCPUCount","kind":"symbol","type":"topic","role":"symbol","title":"minimumCPUCount","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"minimumCPUCount","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"role":"collectionGroup","type":"topic","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","title":"Running OpenClaw in Virtual Machines"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/sharedFolders":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sharedFolders"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:15SpooktacularKit12SharedFolderV","kind":"typeIdentifier","text":"SharedFolder"},{"kind":"text","text":"]"}],"abstract":[{"type":"text","text":"The directories shared between host and guest."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","title":"sharedFolders","url":"\/documentation\/spooktacularki