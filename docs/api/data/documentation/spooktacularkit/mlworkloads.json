arKit/CLIReference":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","kind":"article","title":"Using the spook Command-Line Interface","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/sharedFolders":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sharedFolders","kind":"identifier"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:15SpooktacularKit12SharedFolderV","text":"SharedFolder","kind":"typeIdentifier"},{"text":"]","kind":"text"}],"kind":"symbol","title":"sharedFolders","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/sharedfolders","abstract":[{"type":"text","text":"The directories shared between host and guest."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"url":"\/documentation\/spooktacularkit\/clonemanager","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/S