ed for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount","title":"minimumCPUCount","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"minimumCPUCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration/applySpec(_:to:)":{"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration\/applyspec(_:to:)","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applySpec"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit27VirtualMachineSpecificationV","text":"VirtualMachineSpecification"},{"kind":"text","text":", "},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)VZVirtualMachineConfiguration","text":"VZVirtualMachineConfiguration"},{"kind":"text","text":")"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)","title":"applySpec(_:to:)","abstract":[{"type":"text","text":"Applies a "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"type":"text","text":" to a "},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"type":"text","text":"."}],"role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"url":"\/documentation\/spooktacularkit\/bluebubblesguide","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"title":"Running BlueBubbles iMessage Server","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","type":"topic","kind":"article","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"title":"SharedFolder","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"url":"\/documentation\/spooktacularkit\/sharedfolder","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","role":"collectionGroup","title":"Kubernetes Integration","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"role":"collectionGroup","kind":"article","title":"Configuring GitHub Actions Runners","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"kind":"article","role":"collectionGroup","abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"url":"\/documentation\/spooktacularkit\/openclawguide","title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"title":"VirtualMachineSpecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineSpecification"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"navigatorTitle":[{"text":"VirtualMachineConfiguration","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineConfiguration","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","role":"symbol","title":"VirtualMachineConfiguration","abstract":[{"type":"text","text":"Builds "},{"type":"codeVoice","code":"VZVirtualMachineConfiguration"},{"type":"text","text":" objects from a "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true},{"type":"text","text":"."}],"kind":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","title":"Getting Started with Spooktacular","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","role":"collection","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/hostOnly":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/hostOnly","title":"NetworkMode.hostOnly","type":"topic","url":"\/documentation\/spooktacularkit\/networkmode\/hostonly","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"hostOnly"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Host-only networking."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"topic","title":"NetworkMode","role":"symbol","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"url":"\/documentation\/spooktacularkit\/networkmode"}}}