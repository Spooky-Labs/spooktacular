e":"text","text":"The directories shared between host and guest."}],"role":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/sharedfolders","title":"sharedFolders","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","kind":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sharedFolders","kind":"identifier"},{"text":": [","kind":"text"},{"text":"SharedFolder","preciseIdentifier":"s:15SpooktacularKit12SharedFolderV","kind":"typeIdentifier"},{"text":"]","kind":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"type":"topic","kind":"article","title":"Kubernetes Integration","url":"\/documentation\/spooktacularkit\/kubernetesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"type":"topic","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"title":"CloneManager","url":"\/documentation\/spooktacularkit\/clonemanager","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"}}}