SpooktacularKit\/NetworkMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineConfiguration"}],"kind":"symbol","abstract":[{"text":"Builds ","type":"text"},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":" objects from a ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","isActive":true,"type":"reference"},{"text":".","type":"text"}],"title":"VirtualMachineConfiguration","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration/applySpec(_:to:)":{"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applySpec"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit27VirtualMachineSpecificationV","text":"VirtualMachineSpecification"},{"kind":"text","text":", "},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)VZVirtualMachineConfiguration","text":"VZVirtualMachineConfiguration"},{"kind":"text","text":")"}],"abstract":[{"text":"Applies a ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference","isActive":true},{"text":" to a ","type":"text"},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":".","type":"text"}],"title":"applySpec(_:to:)","kind":"symbol","url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration\/applyspec(_:to:)"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/openclawguide","title":"Running OpenClaw in Virtual Machines","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/isolated":{"type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","abstract":[{"text":"No network connectivity.","type":"text"}],"role":"symbol","title":"NetworkMode.isolated","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isolated","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/networkmode\/isolated"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit","type":"topic","url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/sharedFolders":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","kind":"symbol","abstract":[{"text":"The directories shared between host and guest.","type":"text"}],"role":"symbol","title":"sharedFolders","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sharedFolders","kind":"identifier"},{"text":": [","kind":"text"},{"text":"SharedFolder","kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit12SharedFolderV"},{"text":"]","kind":"text"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/sharedfolders"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/minimumCPUCount":{"type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount","abstract":[{"text":"The minimum number of CPU cores required for a macOS VM","type":"text"},{"text":" ","type":"text"},{"text":"to boot without freezing.","type":"text"}],"role":"symbol","title":"minimumCPUCount","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"minimumCPUCount","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/minimumcpucount"},"https://github.com/ml-explore/mlx":{"titleInlineContent":[{"text":"MLX","type":"text"}],"type":"link","title":"MLX","identifier":"https:\/\/github.com\/ml-explore\/mlx","url":"https:\/\/github.com\/ml-explore\/mlx"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"type":"topic","kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide","title":"Running BlueBubbles iMessage Server","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}],"abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"title":"VirtualMachineSpecification","kind":"symbol","navigatorTitle":[{"text":"VirtualMachineSpecification","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"role":"collectionGroup","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/bridged(interface:)":{"type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","abstract":[{"text":"Bridged directly to a physical network interface.","type":"text"}],"role":"symbol","title":"NetworkMode.bridged(interface:)","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"bridged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"interface"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":")"}],"url":"\/documentation\/spooktacularkit\/networkmode\/bridged(interface:)"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article","title":"Deploying on EC2 Mac","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","kind":"symbol","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}],"title":"CloneManager","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"CloneManager","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/clonemanager"}}}