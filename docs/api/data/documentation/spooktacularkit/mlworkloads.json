:"collectionGroup","title":"Running OpenClaw in Virtual Machines","url":"\/documentation\/spooktacularkit\/openclawguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","type":"topic","role":"collectionGroup","title":"Versioning & Release Schedule","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","type":"topic","role":"collectionGroup","title":"Running BlueBubbles iMessage Server","url":"\/documentation\/spooktacularkit\/bluebubblesguide"},"https://github.com/ml-explore/mlx":{"identifier":"https:\/\/github.com\/ml-explore\/mlx","title":"MLX","titleInlineContent":[{"text":"MLX","type":"text"}],"type":"link","url":"https:\/\/github.com\/ml-explore\/mlx"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","kind":"symbol","role":"collection","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit"}}}