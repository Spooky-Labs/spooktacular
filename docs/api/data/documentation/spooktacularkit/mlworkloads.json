{"variants":[{"paths":["\/documentation\/spooktacularkit\/mlworkloads"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"Apple Silicon’s unified memory architecture gives every Mac direct","type":"text"},{"text":" ","type":"text"},{"text":"access to a powerful GPU and Neural Engine without a discrete graphics","type":"text"},{"text":" ","type":"text"},{"text":"card. Spooktacular VMs expose these capabilities to guest macOS,","type":"text"},{"text":" ","type":"text"},{"text":"making it possible to run GPU-accelerated machine learning workloads","type":"text"},{"text":" ","type":"text"},{"text":"inside isolated virtual machines.","type":"text"}],"type":"paragraph"},{"anchor":"Why-macOS-VMs-for-ML","text":"Why macOS VMs for ML?","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Apple Silicon GPU","type":"text"}],"type":"strong"},{"type":"text","text":" — Metal-accelerated training via MLX, PyTorch"},{"type":"text","text":" "},{"type":"text","text":"MPS, and Create ML"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Neural Engine","type":"text"}],"type":"strong"},{"type":"text","text":" — 16-core (or more) Neural Engine for Core ML"},{"type":"text","text":" "},{"type":"text","text":"inference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Unified memory","type":"text"}],"type":"strong"},{"type":"text","text":" — GPU and CPU share the same memory pool, so"},{"type":"text","text":" "},{"type":"text","text":"there is no PCIe bottleneck for large models"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Reproducible environments","type":"text"}],"type":"strong"},{"type":"text","text":" — Clone a configured ML VM instantly"},{"type":"text","text":" "},{"type":"text","text":"with "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","type":"reference","isActive":true},{"type":"text","text":" for reproducible experiments"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"type":"text","text":" — Run multiple experiments concurrently without"},{"type":"text","text":" "},{"type":"text","text":"dependency conflicts between VMs"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Hardware-Configuration-for-ML","text":"Hardware Configuration for ML","type":"heading","level":2},{"inlineContent":[{"text":"ML workloads benefit from maximum CPU, memory, and disk allocation.","type":"text"},{"text":" ","type":"text"},{"text":"Allocate resources according to your workload:","type":"text"}],"type":"paragraph"},{"anchor":"Single-VM-Configuration-Dedicated-Host","text":"Single-VM Configuration (Dedicated Host)","type":"heading","level":3},{"inlineContent":[{"text":"When the entire host is dedicated to one ML workload:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create ml-trainer \\","    --cpu 8 --memory 24 --disk 200 \\","    --network isolated \\","    --disable-audio"],"type":"codeListing"},{"anchor":"Dual-VM-Configuration-Shared-Host","text":"Dual-VM Configuration (Shared Host)","type":"heading","level":3},{"inlineContent":[{"text":"When running two ML VMs on one host (e.g., training + inference):","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Training VM — more CPU and memory","spook create ml-train \\","    --cpu 6 --memory 16 --disk 200 \\","    --network isolated \\","    --disable-audio","","# Inference VM — lighter resources","spook create ml-serve \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --disable-audio"],"type":"codeListing"},{"anchor":"Recommended-Specs-by-Chip","text":"Recommended Specs by Chip","type":"heading","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Chip","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"RAM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Single ML VM","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Dual ML VMs","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6 CPU \/ 12 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4+4 CPU \/ 6+6 GB","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M2 Pro","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"12","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10 CPU \/ 24 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6+6 CPU \/ 14+14 GB","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M2 Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"12","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10 CPU \/ 48 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6+6 CPU \/ 28+28 GB","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M2 Ultra","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"24","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"192 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"20 CPU \/ 160 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"12+12 CPU \/ 80+80 GB","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"M4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"10","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8 CPU \/ 24 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4+4 CPU \/ 12+12 GB","type":"text"}]}]]],"type":"table","header":"row"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Always leave at least 2 CPU cores and 4 GB RAM for the host","type":"text"},{"text":" ","type":"text"},{"text":"macOS. The minimum VM CPU count is 4 (see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/minimumCPUCount"},{"text":").","type":"text"}]}],"type":"aside","name":"Note"},{"anchor":"Metal-GPU-Access-in-VMs","text":"Metal GPU Access in VMs","type":"heading","level":2},{"inlineContent":[{"text":"The Virtualization framework provides GPU access to macOS guests via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VZMacGraphicsDeviceConfiguration"},{"text":". This is configured automatically","type":"text"},{"text":" ","type":"text"},{"text":"when you create a VM with Spooktacular — every VM gets a virtual","type":"text"},{"text":" ","type":"text"},{"text":"GPU device backed by the host’s Metal-capable hardware.","type":"text"}],"type":"paragraph"},{"anchor":"How-It-Works","text":"How It Works","type":"heading","level":3},{"inlineContent":[{"text":"When ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration\/applySpec(_:to:)","type":"reference","isActive":true},{"type":"text","text":" configures a VM, it"},{"type":"text","text":" "},{"type":"text","text":"creates a "},{"code":"VZMacGraphicsDeviceConfiguration","type":"codeVoice"},{"type":"text","text":" with one or two virtual"},{"text":" ","type":"text"},{"text":"displays. The guest macOS sees this as a standard Metal GPU and can","type":"text"},{"text":" ","type":"text"},{"text":"run any Metal workload: shaders, compute kernels, ML frameworks.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ This happens automatically inside VMConfiguration.applySpec","let graphics = VZMacGraphicsDeviceConfiguration()","graphics.displays = [","    VZMacGraphicsDisplayConfiguration(","        widthInPixels: 1920,","        heightInPixels: 1200,","        pixelsPerInch: 80","    )","]","configuration.graphicsDevices = [graphics]"],"type":"codeListing"},{"level":3,"anchor":"Verifying-GPU-Access-Inside-the-VM","text":"Verifying GPU Access Inside the VM","type":"heading"},{"syntax":"bash","code":["# Check Metal device availability","spook exec ml-trainer -- system_profiler SPDisplaysDataType","","# Run a quick Metal compute test","spook exec ml-trainer -- python3 -c \"","import mlx.core as mx","a = mx.ones((1000, 1000))","b = mx.ones((1000, 1000))","c = a @ b","print(f'Matrix multiply result shape: {c.shape}')","print(f'GPU computation successful')","\""],"type":"codeListing"},{"anchor":"Headless-GPU-Mode","type":"heading","level":3,"text":"Headless GPU Mode"},{"inlineContent":[{"text":"For ML workloads you typically do not need a visible display","type":"text"},{"text":" ","type":"text"},{"text":"window. Run headless to avoid unnecessary display overhead:","type":"text"}],"type":"paragraph"},{"code":["spook start ml-trainer --headless"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"type":"text","text":"The virtual GPU is still fully functional for compute workloads"},{"type":"text","text":" "},{"type":"text","text":"even in headless mode. Display rendering simply has no visible"},{"type":"text","text":" "},{"type":"text","text":"output target."}],"type":"paragraph"},{"level":2,"anchor":"Shared-Folders-for-Datasets","text":"Shared Folders for Datasets","type":"heading"},{"inlineContent":[{"text":"Large datasets (often many gigabytes or terabytes) should not be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"copied into each VM’s disk image. Instead, use VirtIO shared"},{"type":"text","text":" "},{"type":"text","text":"folders to mount host directories directly inside the guest."}],"type":"paragraph"},{"level":3,"anchor":"Mounting-Datasets","text":"Mounting Datasets","type":"heading"},{"code":["# Share a dataset directory (read-only) and an output directory (read-write)","spook share ml-trainer add \/data\/imagenet --tag imagenet --read-only","spook share ml-trainer add \/data\/checkpoints --tag checkpoints"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"Inside the guest, the first shared folder appears automatically in","type":"text"},{"text":" ","type":"text"},{"text":"Finder (macOS automount). Additional folders can be mounted manually:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Inside the guest VM","sudo mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","sudo mount_virtiofs imagenet \/Volumes\/imagenet","sudo mount_virtiofs checkpoints \/Volumes\/checkpoints"],"type":"codeListing"},{"anchor":"Kubernetes-Configuration","text":"Kubernetes Configuration","type":"heading","level":3},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVM","metadata:","  name: ml-trainer","spec:","  image: ghcr.io\/spooktacular\/macos-ml:15.4","  resources:","    cpu: 8","    memory: 24Gi","    disk: 100Gi","  sharedFolders:","    - hostPath: \/data\/imagenet","      guestTag: imagenet","      readOnly: true","    - hostPath: \/data\/checkpoints","      guestTag: checkpoints","      readOnly: false","  provisioning:","    mode: agent","    userData: |","      #!\/bin\/bash","      mkdir -p \/Volumes\/imagenet \/Volumes\/checkpoints","      mount_virtiofs imagenet \/Volumes\/imagenet","      mount_virtiofs checkpoints \/Volumes\/checkpoints","      cd \/Volumes\/imagenet && python3 \/opt\/train.py"]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","isActive":true,"type":"reference"},{"text":" for the API details and ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"for how shared folders are configured in the VM specification.","type":"text"}]},{"anchor":"MLX-Framework","text":"MLX Framework","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/ml-explore\/mlx","isActive":true,"type":"reference"},{"text":" is Apple’s array framework","type":"text"},{"text":" ","type":"text"},{"text":"for machine learning on Apple Silicon. It runs natively on the Metal","type":"text"},{"text":" ","type":"text"},{"text":"GPU and is designed for the unified memory architecture.","type":"text"}]},{"text":"Installing MLX in a VM","type":"heading","level":3,"anchor":"Installing-MLX-in-a-VM"},{"type":"codeListing","syntax":"bash","code":["# Via the provisioning user-data script","spook create ml-trainer --from-ipsw latest \\","    --cpu 8 --memory 24 --disk 100 \\","    --user-data ~\/setup-mlx.sh \\","    --provision disk-inject"]},{"type":"paragraph","inlineContent":[{"text":"Where ","type":"text"},{"code":"setup-mlx.sh","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","set -euo pipefail","","# Install Python and MLX","\/opt\/homebrew\/bin\/brew install python@3.12","pip3 install mlx mlx-lm numpy","","# Verify installation","python3 -c \"import mlx.core as mx; print(f'MLX default device: {mx.default_device()}')\""]},{"anchor":"MLX-Training-Example","type":"heading","level":3,"text":"MLX Training Example"},{"type":"codeListing","syntax":"python","code":["# train_mlx.py — runs inside the VM","import mlx.core as mx","import mlx.nn as nn","import mlx.optimizers as optim","","class SimpleModel(nn.Module):","    def __init__(self):","        super().__init__()","        self.layers = [","            nn.Linear(784, 256),","            nn.Linear(256, 128),","            nn.Linear(128, 10),","        ]","","    def __call__(self, x):","        for l in self.layers[:-1]:","            x = nn.relu(l(x))","        return self.layers[-1](x)","","model = SimpleModel()","optimizer = optim.Adam(learning_rate=1e-3)","","# Training loop","for epoch in range(10):","    # ... load data from \/Volumes\/training-data","    loss = train_step(model, optimizer, batch)","    mx.eval(loss)","    print(f\"Epoch {epoch}: loss = {loss.item():.4f}\")","","# Save checkpoint to shared folder","mx.savez(\"\/Volumes\/checkpoints\/model.npz\", **dict(model.parameters()))"]},{"anchor":"MLX-LM-for-Language-Models","type":"heading","level":3,"text":"MLX-LM for Language Models"},{"inlineContent":[{"text":"Fine-tune or run inference on language models:","type":"text"}],"type":"paragraph"},{"code":["# Inside the VM","pip3 install mlx-lm","","# Download and convert a model","python3 -m mlx_lm.convert --hf-path mistralai\/Mistral-7B-v0.1","","# Run inference","python3 -m mlx_lm.generate --model mlx_model --prompt \"Hello, world\"","","# Fine-tune with LoRA","python3 -m mlx_lm.lora --model mlx_model \\","    --data \/Volumes\/training-data\/finetune.jsonl \\","    --output \/Volumes\/checkpoints\/lora-adapters"],"type":"codeListing","syntax":"bash"},{"anchor":"PyTorch-with-MPS-Backend","type":"heading","level":2,"text":"PyTorch with MPS Backend"},{"inlineContent":[{"text":"PyTorch supports Apple Silicon GPU acceleration via the MPS","type":"text"},{"text":" ","type":"text"},{"text":"(Metal Performance Shaders) backend.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Installation","type":"heading","anchor":"Installation"},{"syntax":"bash","code":["#!\/bin\/bash","# setup-pytorch.sh","pip3 install torch torchvision torchaudio"],"type":"codeListing"},{"anchor":"Verifying-MPS-Availability","text":"Verifying MPS Availability","type":"heading","level":3},{"syntax":"python","code":["import torch","","print(f\"MPS available: {torch.backends.mps.is_available()}\")","print(f\"MPS built: {torch.backends.mps.is_built()}\")","","device = torch.device(\"mps\" if torch.backends.mps.is_available() else \"cpu\")","print(f\"Using device: {device}\")","","# Quick benchmark","x = torch.randn(1000, 1000, device=device)","y = torch.randn(1000, 1000, device=device)","z = x @ y","print(f\"Matrix multiply on {device}: {z.shape}\")"],"type":"codeListing"},{"anchor":"PyTorch-Training-Example","text":"PyTorch Training Example","type":"heading","level":3},{"syntax":"python","code":["# train_pytorch.py","import torch","import torch.nn as nn","import torchvision","import torchvision.transforms as transforms","","device = torch.device(\"mps\")","","# Load data from shared folder","transform = transforms.Compose([","    transforms.ToTensor(),","    transforms.Normalize((0.5,), (0.5,))","])","","trainset = torchvision.datasets.CIFAR10(","    root=\"\/Volumes\/training-data\", train=True,","    download=False, transform=transform",")","trainloader = torch.utils.data.DataLoader(","    trainset, batch_size=64, shuffle=True",")","","# Simple CNN","model = torchvision.models.resnet18(num_classes=10).to(device)","optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)","criterion = nn.CrossEntropyLoss()","","for epoch in range(10):","    running_loss = 0.0","    for images, labels in trainloader:","        images, labels = images.to(device), labels.to(device)","        optimizer.zero_grad()","        outputs = model(images)","        loss = criterion(outputs, labels)","        loss.backward()","        optimizer.step()","        running_loss += loss.item()","","    avg_loss = running_loss \/ len(trainloader)","    print(f\"Epoch {epoch}: loss = {avg_loss:.4f}\")","","    # Save checkpoint to shared folder","    torch.save(model.state_dict(), f\"\/Volumes\/checkpoints\/epoch_{epoch}.pt\")"],"type":"codeListing"},{"anchor":"Core-ML-and-Create-ML","text":"Core ML and Create ML","type":"heading","level":2},{"anchor":"Create-ML-Training-in-a-VM","text":"Create ML Training in a VM","type":"heading","level":3},{"syntax":"bash","code":["# Inside the VM — train an image classifier","swift -e '","import CreateML","import Foundation","","let data = try MLImageClassifier.DataSource.labeledDirectories(","    at: URL(fileURLWithPath: \"\/Volumes\/training-data\/images\")",")","let classifier = try MLImageClassifier(trainingData: data)","try classifier.write(to: URL(fileURLWithPath: \"\/Volumes\/checkpoints\/Classifier.mlmodel\"))","print(\"Model saved successfully\")","'"],"type":"codeListing"},{"anchor":"Core-ML-Inference","text":"Core ML Inference","type":"heading","level":3},{"syntax":"python","code":["# inference.py — run a Core ML model inside the VM","import coremltools as ct","import numpy as np","","model = ct.models.MLModel(\"\/Volumes\/checkpoints\/Classifier.mlmodel\")","prediction = model.predict({\"image\": input_image})","print(f\"Prediction: {prediction}\")"],"type":"codeListing"},{"anchor":"Federated-Learning-Setup","text":"Federated Learning Setup","type":"heading","level":2},{"inlineContent":[{"text":"Run multiple isolated VMs that each train on a subset of data,","type":"text"},{"text":" ","type":"text"},{"text":"then aggregate the results. Use ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"text":" mode with","type":"text"},{"text":" ","type":"text"},{"text":"shared folders so VMs exchange data through the host filesystem","type":"text"},{"text":" ","type":"text"},{"text":"without any network access.","type":"text"}],"type":"paragraph"},{"anchor":"Architecture","text":"Architecture","type":"heading","level":3},{"syntax":null,"code":["+-----------------------------------------+","|  Mac Host                               |","|  +----------+  +----------+            |","|  |  VM-1    |  |  VM-2    |            |","|  |  Worker  |  |  Worker  |            |","|  |  Shard 1 |  |  Shard 2 |            |","|  +----------+  +----------+            |","|       \\              \/                  |","|        Shared folders                   |","|              |                          |","|      +-------v--------+                |","|      |  Aggregator    |                |","|      |  (host script) |                |","|      +----------------+                |","+-----------------------------------------+"],"type":"codeListing"},{"anchor":"Setup","text":"Setup","type":"heading","level":3},{"syntax":"bash","code":["# Create two worker VMs with isolated networking","spook create worker-01 --cpu 4 --memory 8 --disk 64 \\","    --network isolated --disable-audio","","spook create worker-02 --cpu 4 --memory 8 --disk 64 \\","    --network isolated --disable-audio","","# Share different data shards with each","spook share worker-01 add \/data\/shard-01 --tag data --read-only","spook share worker-02 add \/data\/shard-02 --tag data --read-only","","# Share a common output directory for aggregation","spook share worker-01 add \/data\/federated-output --tag output","spook share worker-02 add \/data\/federated-output --tag output","","# Start both","spook start worker-01 --headless","spook start worker-02 --headless"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference","isActive":true},{"text":" mode removes all network interfaces","type":"text"},{"text":" ","type":"text"},{"text":"from the VM, ensuring no external internet access. VMs communicate","type":"text"},{"text":" ","type":"text"},{"text":"with the host and each other exclusively through shared folders","type":"text"},{"text":" ","type":"text"},{"text":"and the VirtIO socket device.","type":"text"}],"type":"paragraph"},{"anchor":"Training-Checkpoints-via-VM-Snapshots","text":"Training Checkpoints via VM Snapshots","type":"heading","level":2},{"inlineContent":[{"text":"Save a disk-level snapshot before long-running training operations.","type":"text"},{"text":" ","type":"text"},{"text":"If something goes wrong, restore the disk to the pre-training state:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Stop the VM and snapshot before a long training run","spook stop ml-trainer","spook snapshot ml-trainer pre-training","spook start ml-trainer --headless","","# Start training","spook exec ml-trainer -- python3 \/opt\/train.py --epochs 100","","# If something goes wrong, stop and restore","spook stop ml-trainer","spook restore ml-trainer pre-training","spook start ml-trainer --headless","","# After successful training, stop and snapshot the trained state","spook stop ml-trainer","spook snapshot ml-trainer trained-v1"],"type":"codeListing"},{"inlineContent":[{"text":"Disk-level snapshots copy ","type":"text"},{"code":"disk.img","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"auxiliary.bin","type":"codeVoice"},{"text":". The VM","type":"text"},{"text":" ","type":"text"},{"text":"must be stopped before saving or restoring. Combine with","type":"text"},{"text":" ","type":"text"},{"text":"application-level checkpointing (saving model weights to shared","type":"text"},{"text":" ","type":"text"},{"text":"folders) for the best recovery story.","type":"text"}],"type":"paragraph"},{"anchor":"Inference-Server-Deployment","text":"Inference Server Deployment","type":"heading","level":2},{"inlineContent":[{"text":"Deploy a trained model as an inference server accessible on the","type":"text"},{"text":" ","type":"text"},{"text":"network:","type":"text"}],"type":"paragraph"},{"anchor":"NAT-Mode-Port-Forwarding","text":"NAT Mode (Port Forwarding)","type":"heading","level":3},{"syntax":"bash","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network nat \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"],"type":"codeListing"},{"anchor":"Bridged-Mode-Own-LAN-IP","text":"Bridged Mode (Own LAN IP)","type":"heading","level":3},{"inlineContent":[{"text":"For production inference servers that need their own IP address","type":"text"},{"text":" ","type":"text"},{"text":"on the local network:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create inference-server --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 64 \\","    --network bridged:en0 \\","    --user-data ~\/setup-inference.sh \\","    --provision disk-inject"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/bridged(interface:)","type":"reference","isActive":true},{"text":" mode gives the VM its own","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IP on the host’s LAN, making it directly addressable","type":"text"},{"text":" ","type":"text"},{"text":"by other machines.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Bridged networking requires the "},{"code":"com.apple.vm.networking","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"entitlement. See "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"reference","isActive":true},{"type":"text","text":" for details."}],"type":"paragraph"}],"type":"aside","name":"Note"},{"anchor":"Inference-Server-Script","text":"Inference Server Script","type":"heading","level":3},{"syntax":"bash","code":["#!\/bin\/bash","# setup-inference.sh","set -euo pipefail","","# Mount the model from a shared folder","mkdir -p \/Volumes\/models","mount_virtiofs models \/Volumes\/models","","# Install dependencies","pip3 install flask mlx mlx-lm","","# Start the inference server","cat > \/opt\/serve.py << 'PYEOF'","from flask import Flask, request, jsonify","from mlx_lm import load, generate","","app = Flask(__name__)","model, tokenizer = load(\"\/Volumes\/models\/my-model\")","","@app.route(\"\/predict\", methods=[\"POST\"])","def predict():","    prompt = request.json[\"prompt\"]","    response = generate(model, tokenizer, prompt=prompt, max_tokens=256)","    return jsonify({\"response\": response})","","app.run(host=\"0.0.0.0\", port=8080)","PYEOF","","python3 \/opt\/serve.py"],"type":"codeListing"},{"anchor":"Performance-Tuning-Tips","text":"Performance Tuning Tips","type":"heading","level":2},{"anchor":"Memory-Management","text":"Memory Management","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Allocate maximum memory","type":"text"}],"type":"strong"},{"text":" — Unified memory is shared between","type":"text"},{"text":" ","type":"text"},{"text":"CPU and GPU. More VM memory means more GPU memory for large","type":"text"},{"text":" ","type":"text"},{"text":"models.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Avoid swap","type":"text"}],"type":"strong"},{"text":" — If the VM runs out of memory, macOS will swap","type":"text"},{"text":" ","type":"text"},{"text":"to the virtual disk, which drastically reduces performance.","type":"text"},{"text":" ","type":"text"},{"text":"Size your VMs with enough RAM for your workload.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Disk-IO","text":"Disk I\/O","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Use shared folders for datasets","type":"text"}],"type":"strong"},{"text":" — VirtIO shared folders","type":"text"},{"text":" ","type":"text"},{"text":"bypass the virtual disk layer, providing direct host filesystem","type":"text"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"SSD-backed hosts","type":"text"}],"type":"strong"},{"text":" — Apple Silicon Macs have fast NVMe storage.","type":"text"},{"text":" ","type":"text"},{"text":"APFS sparse disk images benefit from the underlying SSD speed.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Pre-stage data","type":"text"}],"type":"strong"},{"text":" — Copy frequently accessed data to the VM’s","type":"text"},{"text":" ","type":"text"},{"text":"local disk for maximum I\/O performance during training.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"GPU-Utilization","text":"GPU Utilization","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Profile with Metal System Trace","type":"text"}],"type":"strong"},{"text":" — Use Instruments in Xcode","type":"text"},{"text":" ","type":"text"},{"text":"to profile GPU utilization inside the VM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Batch sizes","type":"text"}],"type":"strong"},{"text":" — Larger batch sizes improve GPU utilization but","type":"text"},{"text":" ","type":"text"},{"text":"require more memory. Find the largest batch size that fits.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Avoid CPU-GPU transfers","type":"text"}],"type":"strong"},{"text":" — With unified memory, data stays","type":"text"},{"text":" ","type":"text"},{"text":"in place. But framework-level copies can still occur. Use","type":"text"},{"text":" ","type":"text"},{"text":"in-place operations when possible.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Network","text":"Network","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Isolated mode for security","type":"text"}],"type":"strong"},{"text":" — ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"text":" removes","type":"text"},{"text":" ","type":"text"},{"text":"the network interface entirely, eliminating external traffic.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Shared folders over network mounts","type":"text"}],"type":"strong"},{"text":" — VirtIO shared folders","type":"text"},{"text":" ","type":"text"},{"text":"are faster than NFS or SMB mounts for data access.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example-Training-a-Model-with-Shared-Data","text":"Example: Training a Model with Shared Data","type":"heading","level":2},{"inlineContent":[{"text":"A complete end-to-end example:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# 1. Prepare the host","mkdir -p \/data\/cifar10 \/data\/models","","# Download CIFAR-10 to the host","python3 -c \"","import torchvision","torchvision.datasets.CIFAR10('\/data\/cifar10', download=True)","\"","","# 2. Create the ML VM","spook create ml-cifar \\","    --from-ipsw latest \\","    --cpu 6 --memory 16 --disk 64 \\","    --network isolated \\","    --disable-audio \\","    --user-data \/opt\/spooktacular\/train-cifar.sh \\","    --provision disk-inject","","# 3. Add shared folders","spook share ml-cifar add \/data\/cifar10 --tag data --read-only","spook share ml-cifar add \/data\/models --tag models","","# 4. Start training","spook start ml-cifar --headless","","# 5. Monitor progress","spook exec ml-cifar -- tail -f \/tmp\/training.log","","# 6. Results appear in \/data\/models\/ on the host","ls \/data\/models\/","# epoch_0.pt  epoch_1.pt  ...  final_model.pt"],"type":"codeListing"}]}],"sections":[],"abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","title":"Machine Learning Workloads","role":"collectionGroup"},"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Gett