ifier","text":"CloneManager"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","title":"CloneManager"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI.","type":"text"}],"kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","type":"topic","title":"Using the spook Command-Line Interface","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineConfiguration":{"url":"\/documentation\/spooktacularkit\/virtualmachineconfiguration","abstract":[{"text":"Builds ","type":"text"},{"code":"VZVirtualMachineConfiguration","type":"codeVoice"},{"text":" objects from a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"reference"},{"text":".","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"VirtualMachineConfiguration"}],"navigatorTitle":[{"kind":"identifier","text":"VirtualMachineConfiguration"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineConfiguration","title":"VirtualMachineConfiguration"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","title":"Versioning & Release Schedule","abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic","kind":"article"},"https://github.com/ml-explore/mlx":{"identifier":"https:\/\/github.com\/ml-explore\/mlx","titleInlineConte