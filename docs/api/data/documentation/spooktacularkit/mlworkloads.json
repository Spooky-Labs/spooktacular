aredFolders"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"title":"VirtualMachineSpecification","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","kind":"symbol","navigatorTitle":[{"text":"VirtualMachineSpecification","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","role":"symbol","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"url":"\/documentation\/spooktacularkit\/sharedfolder","title":"SharedFolder","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"type":"topic","title":"Kubernetes Integration","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"title":"CloneManager","abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"identifier":"doc:\/