arKit\/GitHubActionsGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"title":"Using the spook Command-Line Interface","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification/sharedFolders":{"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sharedFolders"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:15SpooktacularKit12SharedFolderV","text":"SharedFolder"},{"text":"]","kind":"text"}],"abstract":[{"text":"The directories shared between host and guest.","type":"text"}],"title":"sharedFolders","role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/virtualmachinespecification\/sharedfolders","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification\/sharedFolders"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"url":"\/documentation\/spooktacularkit\/clonemanager","type":"topic","kind":"symbol","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"title":"CloneManager","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}],"kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/sha