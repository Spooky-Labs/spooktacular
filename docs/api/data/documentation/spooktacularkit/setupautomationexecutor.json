":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SetupAutomationExecutor"},{"type":"text","text":" creates an offscreen "},{"type":"codeVoice","code":"NSWindow"},{"type":"text","text":" containing"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":", then sends synthesized "},{"type":"codeVoice","code":"NSEvent"},{"type":"text","text":" keyboard"},{"type":"text","text":" "},{"type":"text","text":"events to the view for each "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","type":"reference","isActive":true},{"type":"text","text":" in the sequence. The"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework routes these events to the guest OS through"},{"type":"text","text":" "},{"type":"text","text":"the VM’s "},{"type":"codeVoice","code":"VZMacKeyboardConfiguration"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"How It Works","anchor":"How-It-Works"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An offscreen ","type":"text"},{"code":"NSWindow","type":"codeVoice"},{"text":" is created with a ","type":"text"},{"code":"VZVirtualMachineView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"as its content view. The view is connected to the VM’s","type":"text"},{"text":" ","type":"text"},{"code":"VZVirtualMachine","type":"codeVoice"},{"text":" instance.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The window is made the key window (required for keyboard event"},{"type":"text","text":" "},{"type":"text","text":"delivery) but positioned offscreen so it is not visible."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For each "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","isActive":true},{"type":"text","text":", the executor waits for the step’s delay,"},{"type":"text","text":" "},{"type":"text","text":"then synthesizes and delivers "},{"type":"codeVoice","code":"NSEvent"},{"type":"text","text":" key-down\/key-up pairs"},{"type":"text","text":" "},{"type":"text","text":"to the view."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"After all steps complete, the offscreen window is closed.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This approach matches the technique used by"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","isActive":true},{"type":"text","text":" for Packer "},{"code":"boot_command","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"sequences, which has been proven reliable across macOS 13 through 26."}]},{"level":2,"type":"heading","text":"Requirements","anchor":"Requirements"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM must be in the "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState\/running","isActive":true},{"type":"text","text":" state."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NSApplication.shared"},{"type":"text","text":" must exist (the process needs an AppKit"},{"type":"text","text":" "},{"type":"text","text":"event loop). CLI tools should call"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSApplication.shared.setActivationPolicy(.accessory)"},{"text":" before","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"invoking this executor."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Accessibility permissions are "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" required because events are"},{"type":"text","text":" "},{"type":"text","text":"sent directly to the view, not through the system event tap."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["let steps = SetupAutomation.sequence(for: 15)","try await SetupAutomationExecutor.run(steps: steps, on: vm.vzVM!)"]},{"text":"Thread Safety","type":"heading","level":2,"anchor":"Thread-Safety"},{"inlineContent":[{"text":"All methods are ","type":"text"},{"code":"@MainActor","type":"codeVoice"},{"text":" because ","type":"text"},{"code":"NSWindow","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":", and "},{"type":"codeVoice","code":"VZVirtualMachine"},{"type":"text","text":" are main-thread-only."}],"type":"paragraph"}],"kind":"content"}],"references":{"https://github.com/cirruslabs/tart":{"title":"Tart","titleInlineContent":[{"type":"text","text":"Tart"}],"type":"link","identifier":"https:\/\/github.com\/cirruslabs\/tart","url":"https:\/\/github.com\/cirruslabs\/tart"},"doc://SpooktacularKit/documentation/SpooktacularKit/BootStep":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","title":"BootStep","url":"\/documentation\/spooktacularkit\/bootstep","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A single step in a Setup Assistant automation sequence."}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BootStep"}],"navigatorTitle":[{"kind":"identifier","text":"BootStep"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineState/running":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineState\/running","url":"\/documentation\/spooktacularkit\/virtualmachinestate\/running","title":"VirtualMachineState.running","kind"