ootStep","type":"reference"},{"text":" in the sequence. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework routes these events to the guest OS through"},{"type":"text","text":" "},{"type":"text","text":"the VM’s "},{"type":"codeVoice","code":"VZMacKeyboardConfiguration"},{"type":"text","text":"."}]},{"level":2,"anchor":"How-It-Works","type":"heading","text":"How It Works"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"An offscreen "},{"code":"NSWindow","type":"codeVoice"},{"type":"text","text":" is created with a "},{"code":"VZVirtualMachineView","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"as its content view. The view is connected to the VM’s"},{"type":"text","text":" "},{"code":"VZVirtualMachine","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The window is made the key window (required for keyboard event"},{"type":"text","text":" "},{"type":"text","text":"delivery) but positioned offscreen so it is not visible."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"For each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep"},{"type":"text","text":", the executor waits for the step’s delay,"},{"type":"text","text":" "},{"type":"text","text":"then synthesizes and delivers "},{"code":"NSEvent","type":"codeVoice"},{"type":"text","text":" key-down\/key-up pairs"},{"type":"text","text":" "},{"type":"text","text":"to the view."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"After all steps complete, the offscreen window is closed."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This approach matches the technique used by"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","