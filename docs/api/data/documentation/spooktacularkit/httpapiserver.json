{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"actor"},{"kind":"text","text":" "},{"kind":"identifier","text":"HTTPAPIServer"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"HTTPAPIServer"},{"type":"text","text":" provides a RESTful JSON API over plain HTTP, built on"},{"type":"text","text":" "},{"type":"text","text":"Apple’s "},{"type":"codeVoice","code":"Network.framework"},{"type":"text","text":" ("},{"type":"codeVoice","code":"NWListener"},{"type":"text","text":"). It exposes endpoints for"},{"type":"text","text":" "},{"type":"text","text":"listing, creating, starting, stopping, and deleting VMs, as well as"},{"type":"text","text":" "},{"type":"text","text":"resolving VM IP addresses and performing health checks."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The server binds to localhost by default and does "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" provide TLS."},{"type":"text","text":" "},{"type":"text","text":"Set the "},{"type":"codeVoice","code":"SPOOK_API_TOKEN"},{"type":"text","text":" environment variable to require Bearer-token"},{"type":"text","text":" "},{"type":"text","text":"authentication on all endpoints except "},{"type":"codeVoice","code":"\/health"},{"type":"text","text":". Use a reverse proxy"},{"type":"text","text":" "},{"type":"text","text":"(e.g., Caddy, nginx) for production deployments that require encryption."}],"type":"paragraph"},{"type":"heading","anchor":"Endpoints","level":2,"text":"Endpoints"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Method","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Path","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent