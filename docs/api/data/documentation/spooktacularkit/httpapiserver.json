esponse-Format","text":"Response Format","type":"heading"},{"inlineContent":[{"type":"text","text":"All responses use a consistent JSON envelope:"}],"type":"paragraph"},{"syntax":"json","code":["{\"status\": \"ok\", \"data\": { ... }}","{\"status\": \"error\", \"message\": \"VM 'foo' not found.\"}"],"type":"codeListing"},{"level":2,"anchor":"Usage","text":"Usage","type":"heading"},{"syntax":"swift","code":["let server = try HTTPAPIServer(","    host: \"127.0.0.1\",","    port: 8484,","    vmDirectory: Paths.vms,","    spookPath: \"\/usr\/local\/bin\/spook\"",")","try await server.start()"],"type":"codeListing"},{"level":2,"anchor":"Thread-Safety","text":"Thread Safety","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"HTTPAPIServer"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"actor"},{"type":"text","text":", ensuring all mutable state is accessed"},{"type":"text","text":" "},{"type":"text","text":"serially. Connection handling and request routing run on the Network"},{"type":"text","text":" "},{"type":"text","text":"framework’s internal dispatch queues, with results forwarded back to"},{"type":"text","text":" "},{"type":"text","text":"the actor for safe mutation."}],"type":"paragraph"}],"kind":"content"}],"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP","doc:\/\/SpooktacularKit\/ScA"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/HTTPAPIServer/Actor-Implementations":{"title":"Actor Implementations","abstract":[],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/HTTPAPIServer\/Actor-Implementations","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/httpapiserver\/actor-implementations","kind":"article"},"doc://SpooktacularKit/s16SendableMetatypeP":{"identifi