{"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs","type":"text"},{"text":" ","type":"text"},{"text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity.","type":"text"}]},{"level":2,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac with Spooktacular installed"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Jenkins controller (runs on any OS)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"SSH connectivity between Jenkins controller and Mac host"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM with Xcode and the Jenkins agent installed"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Creating a Base Image","anchor":"Creating-a-Base-Image"},{"code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"],"type":"codeListing","syntax":"bash"},{"level":2,"type":"heading","text":"Provisioning Script","anchor":"Provisioning-Script"},{"type":"paragraph","inlineContent":[{"text":"Create a provisioning script that registers the VM as a Jenkins agent:","type":"text"}]},{"code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""],"type":"codeListing","syntax":"bash"},{"level":2,"type":"heading","text":"Clone and Start Agents","anchor":"Clone-and-Start-Agents"},{"code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing","syntax":"bash"},{"level":2,"type":"heading","text":"Ephemeral Agents","anchor":"Ephemeral-Agents"},{"type":"paragraph","inlineContent":[{"text":"For clean builds every time, use ephemeral mode. The VM is","type":"text"},{"text":" ","type":"text"},{"text":"destroyed after the agent disconnects:","type":"text"}]},{"code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Combine with a cron job or Jenkins pipeline that re-clones","type":"text"},{"text":" ","type":"text"},{"text":"and re-starts agents between builds.","type":"text"}]},{"level":2,"type":"heading","text":"Running as a Service","anchor":"Running-as-a-Service"},{"type":"paragraph","inlineContent":[{"text":"For persistent agents that survive Mac reboots:","type":"text"}]},{"code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"type":"codeListing","syntax":"bash"},{"level":2,"type":"heading","text":"Kubernetes Integration","anchor":"Kubernetes-Integration"},{"type":"paragraph","inlineContent":[{"text":"If your Jenkins runs on Kubernetes, use the Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"Kubernetes operator to manage agents declaratively:","type":"text"}]},{"code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"type":"codeListing","syntax":"yaml"}],"kind":"content"}],"metadata":{"role":"collectionGroup","modules":[{"name":"SpooktacularKit"}],"title":"Configuring Jenkins Nodes"},"schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/Spo