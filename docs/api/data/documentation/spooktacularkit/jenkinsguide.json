tation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}],"type":"paragraph"},{"anchor":"Prerequisites","text":"Prerequisites","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Creating-a-Base-Image","text":"Creating a Base Image","level":2,"type":"heading"},{"syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"],"type":"codeListing"},{"anchor":"Provisioning-Script","text":"Provisioning Script","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""],"type":"codeListing"},{"anchor":"Clone-and-Start-Agents","text":"Clone and Start Agents","level":2,"type":"heading"},{"syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"anchor":"Ephemeral-Agents","text":"Ephemeral Agents","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}],"type":"paragraph"},{"anchor":"Running-as-a-Service","text":"Running as a Service","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}],"type":"paragraph"},{"syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"type":"codeListing"},{"anchor":"Kubernetes-Integration","text":"Kubernetes Integration","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}],"type":"paragraph"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"sections":[],"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","title":"Configuring GitHub Actions Runners","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","title":"Using the spook Command-Line Interface","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","title":"Versioning & Release Schedule","role":"collectionGroup","type":"topic","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/d