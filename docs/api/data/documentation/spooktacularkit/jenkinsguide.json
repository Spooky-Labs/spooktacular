ted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}]},{"type":"heading","level":2,"anchor":"Prerequisites","text":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Creating-a-Base-Image","text":"Creating a Base Image"},{"type":"codeListing","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"],"syntax":"bash"},{"type":"heading","level":2,"anchor":"Provisioning-Script","text":"Provisioning Script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}]},{"type":"codeListing","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""],"syntax":"bash"},{"type":"heading","level":2,"anchor":"Clone-and-Start-Agents","text":"Clone and Start Agents"},{"type":"codeListing","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"syntax":"bash"},{"type":"heading","level":2,"anchor":"Ephemeral-Agents","text":"Ephemeral Agents"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}]},{"type":"codeListing","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}]},{"type":"heading","level":2,"anchor":"Running-as-a-Service","text":"Running as a Service"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}]},{"type":"codeListing","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"syntax":"bash"},{"type":"heading","level":2,"anchor":"Kubernetes-Integration","text":"Kubernetes Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}]},{"type":"codeListing","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"syntax":"yaml"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/jenkinsguide"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"type":"topic","url":"\/documentation\/spooktacularkit\/openclawguide","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"title":"Running OpenClaw in Virtual Machines","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"role":"collectionGroup","type":"topic","title":"Using the spook Command-Line Interface","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"role":"collectionGroup","url":"\/documentation\/spooktaculark