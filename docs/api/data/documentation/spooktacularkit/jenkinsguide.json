{"topicSections":[{"anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"title":"Related Guides"}],"sections":[],"kind":"article","metadata":{"title":"Configuring Jenkins Nodes","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs","type":"text"},{"text":" ","type":"text"},{"text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity.","type":"text"}],"type":"paragraph"},{"text":"Prerequisites","anchor":"Prerequisites","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Jenkins controller (runs on any OS)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"SSH connectivity between Jenkins controller and Mac host"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A base VM with Xcode and the Jenkins agent installed"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Creating a Base Image","anchor":"Creating-a-Base-Image","level":2,"type":"heading"},{"syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"],"type":"codeListing"},{"text":"Provisioning Script","anchor":"Provisioning-Script","level":2,"type":"heading"},{"inlineContent":[{"text":"Create a provisioning script that registers the VM as a Jenkins agent:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""],"type":"codeListing"},{"text":"Clone and Start Agents","anchor":"Clone-and-Start-Agents","level":2,"type":"heading"},{"syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"text":"Ephemeral Agents","anchor":"Ephemeral-Agents","level":2,"type":"heading"},{"inlineContent":[{"text":"For clean builds every time, use ephemeral mode. The VM is","type":"text"},{"text":" ","type":"text"},{"text":"destroyed after the agent disconnects:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"inlineContent":[{"text":"Combine with a cron job or Jenkins pipeline that re-clones","type":"text"},{"text":" ","type":"text"},{"text":"and re-starts agents between builds.","type":"text"}],"type":"paragraph"},{"text":"Running as a Service","anchor":"Running-as-a-Service","level":2,"type":"heading"},{"inlineContent":[{"text":"For persistent agents that survive Mac reboots:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"type":"codeListing"},{"text":"Kubernetes Integration","anchor":"Kubernetes-Integration","level":2,"type":"heading"},{"inlineContent":[{"text":"If your Jenkins runs on Kubernetes, use the Spooktacular","type":"text"},{"text":" ","type":"text"},{"text":"Kubernetes operator to manage agents declaratively:","type":"text"}],"type":"paragraph"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/jenkinsguide"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"},"seeAlsoSections":[{"anchor":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit