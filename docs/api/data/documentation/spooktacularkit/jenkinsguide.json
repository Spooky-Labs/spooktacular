{"kind":"article","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"title":"Related Guides","anchor":"Related-Guides"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SSHExecutor"],"title":"Key Types","anchor":"Key-Types"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"variants":[{"paths":["\/documentation\/spooktacularkit\/jenkinsguide"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"API Collection","title":"Configuring Jenkins Nodes","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}],"type":"paragraph"},{"text":"Prerequisites","anchor":"Prerequisites","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac with Spooktacular installed"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}]}]}]},{"text":"Creating a Base Image","anchor":"Creating-a-Base-Image","type":"heading","level":2},{"syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"],"type":"codeListing"},{"text":"Provisioning Script","anchor":"Provisioning-Script","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}],"type":"paragraph"},{"syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""],"type":"codeListing"},{"text":"Clone and Start Agents","anchor":"Clone-and-Start-Agents","type":"heading","level":2},{"syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"text":"Ephemeral Agents","anchor":"Ephemeral-Agents","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}],"type":"paragraph"},{"syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}],"type":"paragraph"},{"text":"Running as a Service","anchor":"Running-as-a-Service","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}],"type":"paragraph"},{"syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"type":"codeListing"},{"text":"Kubernetes Integration","anchor":"Kubernetes-Integration","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}],"type":"paragraph"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"type":"codeListing"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","kind":"article","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"title":"VirtualMachineSpecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VirtualMachineSpecification","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/docu