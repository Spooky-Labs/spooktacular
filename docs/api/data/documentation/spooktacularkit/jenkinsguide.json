ge":"swift"},"abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"topicSections":[{"title":"Related Guides","anchor":"Related-Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]},{"title":"Key Types","anchor":"Key-Types","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SSHExecutor"]}],"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/jenkinsguide"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Guides","anchor":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"metadata":{"roleHeading":"API Collection","title":"Configuring Jenkins Nodes","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}]},{"level":2,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Creating a Base Image","anchor":"Creating-a-Base-Image"},{"type":"codeListing","syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"]},{"level":2,"type":"heading","text":"Provisioning Script","anchor":"Provisioning-Script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""]},{"level":2,"type":"heading","text":"Clone and Start Agents","anchor":"Clone-and-Start-Agents"},{"type":"codeListing","syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"level":2,"type":"heading","text":"Ephemeral Agents","anchor":"Ephemeral-Agents"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}]},{"type":"codeListing","syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}]},{"level":2,"type":"heading","text":"Running as a Service","anchor":"Running-as-a-Service"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}]},{"type":"codeListing","syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"]},{"level":2,"type":"heading","text":"Kubernetes Integration","anchor":"Kubernetes-Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}]},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"role":"symbol","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"title":"ProvisioningMode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/provisioningmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/ec2macdeployment","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"tit