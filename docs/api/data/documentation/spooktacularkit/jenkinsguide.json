{"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}],"type":"paragraph"},{"text":"Prerequisites","anchor":"Prerequisites","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}]}]}],"type":"unorderedList"},{"text":"Creating a Base Image","anchor":"Creating-a-Base-Image","level":2,"type":"heading"},{"type":"codeListing","syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"]},{"text":"Provisioning Script","anchor":"Provisioning-Script","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""]},{"text":"Clone and Start Agents","anchor":"Clone-and-Start-Agents","level":2,"type":"heading"},{"type":"codeListing","syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"text":"Ephemeral Agents","anchor":"Ephemeral-Agents","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}],"type":"paragraph"},{"text":"Running as a Service","anchor":"Running-as-a-Service","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"]},{"text":"Kubernetes Integration","anchor":"Kubernetes-Integration","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}],"type":"paragraph"},{"type":"codeListing","syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"]}]}],"topicSections":[{"title":"Related Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],"anchor":"Related-Guides"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"],["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKi