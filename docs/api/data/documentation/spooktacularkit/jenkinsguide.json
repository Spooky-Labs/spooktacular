rKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide"},"kind":"article","sections":[],"abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/jenkinsguide"]}],"metadata":{"role":"collectionGroup","title":"Configuring Jenkins Nodes","modules":[{"name":"SpooktacularKit"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","generated":true,"anchor":"Guides"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Jenkins can use Spooktacular VMs as build agents. Each Mac runs"},{"type":"text","text":" "},{"type":"text","text":"2 VMs, each VM runs a Jenkins agent — doubling your Mac CI capacity."}]},{"type":"heading","text":"Prerequisites","level":2,"anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Apple Silicon Mac with Spooktacular installed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Jenkins controller (runs on any OS)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"SSH connectivity between Jenkins controller and Mac host","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A base VM with Xcode and the Jenkins agent installed","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Creating a Base Image","level":2,"anchor":"Creating-a-Base-Image"},{"type":"codeListing","syntax":"bash","code":["# Create the base VM","spook create jenkins-base --from-ipsw latest","","# Install Xcode and Jenkins agent in the base VM","# (Use SSH after the VM boots, or disk-inject provisioning)","spook start jenkins-base","spook ssh jenkins-base","","# Inside the VM:","# 1. Install Xcode from the App Store or xcode-select","# 2. Download the Jenkins agent .jar from your Jenkins controller","# 3. Create a LaunchAgent to start the agent on boot"]},{"type":"heading","text":"Provisioning Script","level":2,"anchor":"Provisioning-Script"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a provisioning script that registers the VM as a Jenkins agent:"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# jenkins-agent-setup.sh","","JENKINS_URL=\"https:\/\/jenkins.example.com\"","AGENT_NAME=\"$(hostname)\"","AGENT_SECRET=\"YOUR_AGENT_SECRET\"","","# Download the agent .jar","curl -sO \"$JENKINS_URL\/jnlpJars\/agent.jar\"","","# Start the agent","java -jar agent.jar \\","  -url \"$JENKINS_URL\" \\","  -secret \"$AGENT_SECRET\" \\","  -name \"$AGENT_NAME\" \\","  -workDir \"\/Users\/admin\/jenkins\""]},{"type":"heading","text":"Clone and Start Agents","level":2,"anchor":"Clone-and-Start-Agents"},{"type":"codeListing","syntax":"bash","code":["# Clone the base image for each agent","spook clone jenkins-base jenkins-agent-01","spook clone jenkins-base jenkins-agent-02","","# Start with the provisioning script","spook start jenkins-agent-01 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh","","spook start jenkins-agent-02 --headless \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"type":"heading","text":"Ephemeral Agents","level":2,"anchor":"Ephemeral-Agents"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For clean builds every time, use ephemeral mode. The VM is"},{"type":"text","text":" "},{"type":"text","text":"destroyed after the agent disconnects:"}]},{"type":"codeListing","syntax":"bash","code":["spook start jenkins-agent-01 --headless --ephemeral \\","  --user-data .\/jenkins-agent-setup.sh --provision ssh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine with a cron job or Jenkins pipeline that re-clones"},{"type":"text","text":" "},{"type":"text","text":"and re-starts agents between builds."}]},{"type":"heading","text":"Running as a Service","level":2,"anchor":"Running-as-a-Service"},{"inlineContent":[{"type":"text","text":"For persistent agents that survive Mac reboots:"}],"type":"paragraph"},{"syntax":"bash","code":["sudo spook service install jenkins-agent-01","sudo spook service install jenkins-agent-02"],"type":"codeListing"},{"level":2,"anchor":"Kubernetes-Integration","text":"Kubernetes Integration","type":"heading"},{"inlineContent":[{"type":"text","text":"If your Jenkins runs on Kubernetes, use the Spooktacular"},{"type":"text","text":" "},{"type":"text","text":"Kubernetes operator to manage agents declaratively:"}],"type":"paragraph"},{"syntax":"yaml","code":["apiVersion: spooktacular.app\/v1alpha1","kind: MacOSVM","metadata:","  name: jenkins-agent-01","spec:","  sourceVM: jenkins-base","  cpu: 4","  memoryInGigabytes: 8","  provisioning:","    mode: ssh","    script: |","      #!\/bin\/bash","      curl -sO https:\/\/jenkins.example.com\/jnlpJars\/agent.jar","      java -jar agent.jar -url https:\/\/jenkins.example.com \\","        -secret $AGENT_SECRET -name $(hostname) -workDir \/tmp\/jenkins"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","title":"Getting Started with Spooktacular","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"role":"collectionGroup","title":"Configuring GitHub Actions Runners","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawGuide":{"role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","url":"\/documentation\/spooktacularkit\/openclawguide","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","kind":"article","title":"Using the spook Command-Line Interface","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}]