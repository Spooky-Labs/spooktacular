t","text":"screen transitions, which vary depending on the macOS version"},{"type":"text","text":" "},{"type":"text","text":"and VM performance."}],"type":"paragraph"},{"anchor":"How-It-Works","level":2,"type":"heading","text":"How It Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setup Assistant automation sends keyboard input to the VM’s"},{"type":"text","text":" "},{"type":"text","text":"virtual display using "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":". This follows the"},{"type":"text","text":" "},{"type":"text","text":"same approach used by "},{"isActive":true,"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"for Packer "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" sequences, which has been proven"},{"type":"text","text":" "},{"type":"text","text":"reliable across macOS 13 through 26."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":" must be attached to the"},{"type":"text","text":" "},{"type":"text","text":"VM (even offscreen) for keyboard events to be delivered."},{"type":"text","text":" "},{"type":"text","text":"Without a view, the Virtualization framework discards"},{"type":"text","text":" "},{"type":"text","text":"keyboard input."}]}],"type":"aside","style":"important","name":"Important"},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"codeListing","syntax":"swift","code":["let step = BootStep(delay: 10, action: .text(\"admin\"))"]}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/bootstep"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"A single step in a Setup Assistant automation sequence."}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSe