{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BootStep"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"BootStep"},{"type":"text","text":" pairs a delay (time to wait before acting) with"},{"type":"text","text":" "},{"type":"text","text":"an action to perform. The delay accounts for Setup Assistant"},{"type":"text","text":" "},{"type":"text","text":"screen transitions, which vary depending on the macOS version"},{"type":"text","text":" "},{"type":"text","text":"and VM performance."}]},{"type":"heading","level":2,"text":"How It Works","anchor":"How-It-Works"},{"type":"paragraph","inlineContent":[{"text":"Setup Assistant automation sends keyboard input to the VM’s","type":"text"},{"text":" ","type":"text"},{"text":"virtual display using ","type":"text"},{"code":"VZVirtualMachineView","type":"codeVoice"},{"type":"text","text":". This follows the"},{"type":"text","text":" "},{"type":"text","text":"same approach used by "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for Packer "},{"code":"boot_command","type":"codeVoice"},{"type":"text","text":" sequences, which has been proven"},{"type":"text","text":" "},{"type":"text","text":"reliable across macOS 13 through 26."}]},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"VZVirtualMachineView","type":"codeVoice"},{"type":"text","text":" must be attached to the"},{"type":"text","text":" "},{"type":"text","text":"VM (even offscreen) for keyboard events to be delivered."},{"type":"text","text":" "},{"type":"text","text":"Without a view, the Virtualization framework discards"},{"type":"text","text":" "},{"type":"text","text":"keyboard input."}]}],"style":"important"},{"type":"heading","anchor":"Example","text":"Example","level":2},{"type":"codeListing","code":["let step = BootStep(delay: 10, action: .text(\"admin\"))"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"type":"text","text":"A single step in a Setup Assistant automation sequence."}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","interfaceLanguage":"swift"},"sections":[],"metadata":{"title":"BootStep","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"BootStep"}],"navigatorTitle":[{"kind":"identifier","text":"BootStep"}],"symbolKind":"struct","roleHeading":"Structure","role":"symbol","externalID":"s:15SpooktacularKit8BootStepV","modules":[{"name":"SpooktacularKit"}]},"relationshipsSections":[{"identifiers":["doc:\/\/SpooktacularKit\/SQ","doc:\/\/SpooktacularKit\/s8SendableP","doc:\/\/SpooktacularKit\/s16SendableMetatypeP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/bootstep"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/init(delay:action:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/action","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/delay"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/Equatable-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"kind":"symbol","seeAlsoSe