{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"A single step in a Setup Assistant automation sequence.","type":"text"}],"metadata":{"role":"symbol","externalID":"s:15SpooktacularKit8BootStepV","title":"BootStep","symbolKind":"struct","modules":[{"name":"SpooktacularKit"}],"roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"BootStep"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BootStep","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/init(delay:action:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/action","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/delay"],"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep\/Equatable-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BootStep","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"BootStep"},{"type":"text","text":" pairs a delay (time to wait before acting) with"},{"type":"text","text":" "},{"type":"text","text":"an action to perform. The delay accounts for Setup Assistant"},{"type":"text","text":" "},{"type":"text","text":"screen transitions, which vary depending on the macOS version"},{"type":"text","text":" "},{"type":"text","text":"and VM performance."