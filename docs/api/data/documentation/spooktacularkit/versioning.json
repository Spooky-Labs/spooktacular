{"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"Spooktacular follows ","type":"text"},{"identifier":"https:\/\/semver.org","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Every part of the version number communicates specific guarantees","type":"text"},{"text":" ","type":"text"},{"text":"to enterprise teams integrating Spooktacular into their infrastructure.","type":"text"}],"type":"paragraph"},{"anchor":"Version-Format","level":3,"text":"Version Format","type":"heading"},{"code":["MAJOR.MINOR.PATCH[-PRERELEASE]","","1.0.0-rc1    Release candidate (test in staging)","1.0.0        Stable release (safe for production)","1.1.0        Feature release (backward-compatible)","1.1.1        Bug fix (upgrade immediately)","2.0.0        Breaking change (migration guide provided)"],"syntax":null,"type":"codeListing"},{"anchor":"What-Each-Part-Means","level":3,"text":"What Each Part Means","type":"heading"},{"inlineContent":[{"inlineContent":[{"text":"MAJOR","type":"text"}],"type":"strong"},{"text":" — Breaking changes to the CLI, ","type":"text"},{"code":"config.json","type":"codeVoice"},{"text":" schema, or","type":"text"},{"text":" ","type":"text"},{"text":"VM bundle format. We provide migration guides and at least one","type":"text"},{"text":" ","type":"text"},{"text":"release candidate before shipping.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"MINOR","type":"text"}],"type":"strong"},{"text":" — New features that are backward-compatible. Your existing","type":"text"},{"text":" ","type":"text"},{"text":"VMs, scripts, and CI configurations continue working.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"PATCH","type":"text"}],"type":"strong"},{"text":" — Bug fixes and security patches. No behavior changes.","type":"text"},{"text":" ","type":"text"},{"text":"Ships within 48 hours of confirmed fix.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Pre-release tags:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"-alpha.N","type":"codeVoice"},{"text":" — Early development. APIs may change.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-beta.N","type":"codeVoice"},{"text":" — Feature-complete. APIs stable, may have bugs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-rc.N","type":"codeVoice"},{"text":" — Production-ready candidate. If clean for 1 week,","type":"text"},{"text":" ","type":"text"},{"text":"ships as stable.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Compatibility-Guarantees","level":3,"text":"Compatibility Guarantees","type":"heading"},{"inlineContent":[{"text":"These are part of the public API and follow semver:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"CLI command names and flags","type":"text"}]},{"text":" — renaming is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"--json","type":"codeVoice"},{"text":" output schemas","type":"text"}]},{"text":" — removing fields is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"config.json","type":"codeVoice"},{"text":" format","type":"text"}]},{"text":" — removing fields is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VM bundle structure"}]},{"text":" — old bundles readable indefinitely","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Adding new flags, JSON fields, or config keys is a minor bump.","type":"text"}],"type":"paragraph"},{"anch