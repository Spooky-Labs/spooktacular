{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"Spooktacular follows "},{"type":"reference","isActive":true,"identifier":"https:\/\/semver.org"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Every part of the version number communicates specific guarantees"},{"type":"text","text":" "},{"type":"text","text":"to enterprise teams integrating Spooktacular into their infrastructure."}],"type":"paragraph"},{"anchor":"Version-Format","type":"heading","text":"Version Format","level":3},{"type":"codeListing","syntax":null,"code":["MAJOR.MINOR.PATCH[-PRERELEASE]","","1.0.0-rc1    Release candidate (test in staging)","1.0.0        Stable release (safe for production)","1.1.0        Feature release (backward-compatible)","1.1.1        Bug fix (upgrade immediately)","2.0.0        Breaking change (migration guide provided)"]},{"anchor":"What-Each-Part-Means","level":3,"text":"What Each Part Means","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"MAJOR","type":"text"}]},{"type":"text","text":" — Breaking changes to the CLI, "},{"type":"codeVoice","code":"config.json"},{"type":"text","text":" schema, or"},{"text":" ","type":"text"},{"text":"VM bundle format. We provide migration guides and at least one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"release candidate before shipping."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"MINOR"}],"type":"strong"},{"text":" — New features that are backward-compatible. Your existing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"VMs, scripts, and CI configurations continue working."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"PATCH"}]},{"type":"text","text":" — Bug fixes and security patches. No behavior changes."},{"type":"text","text":" "},{"t