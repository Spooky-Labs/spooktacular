ype":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"PATCH"}],"type":"strong"},{"text":" — Bug fixes and security patches. No behavior changes.","type":"text"},{"text":" ","type":"text"},{"text":"Ships within 48 hours of confirmed fix.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Pre-release tags:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"-alpha.N","type":"codeVoice"},{"text":" — Early development. APIs may change.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-beta.N","type":"codeVoice"},{"text":" — Feature-complete. APIs stable, may have bugs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-rc.N","type":"codeVoice"},{"text":" — Production-ready candidate. If clean for 1 week,","type":"text"},{"text":" ","type":"text"},{"text":"ships as stable.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Compatibility-Guarantees","text":"Compatibility Guarantees","level":3,"type":"heading"},{"inlineContent":[{"text":"These are part of the public API and follow semver:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CLI command names and flags","type":"text"}],"type":"strong"},{"text":" — renaming is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"--json","type":"codeVoice"},{"text":" output schemas","type":"text"}],"type":"strong"},{"text":" — removing fields is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"config.json","type":"codeVoice"},{"text":" format","type":"text"}],"type":"strong"},{"text":" — removing fields is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"VM bundle structure","type":"te