ible. Your existing"},{"type":"text","text":" "},{"type":"text","text":"VMs, scripts, and CI configurations continue working."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"PATCH"}]},{"text":" — Bug fixes and security patches. No behavior changes.","type":"text"},{"text":" ","type":"text"},{"text":"Ships within 48 hours of confirmed fix.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Pre-release tags:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"-alpha.N","type":"codeVoice"},{"text":" — Early development. APIs may change.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"-beta.N"},{"text":" — Feature-complete. APIs stable, may have bugs.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"-rc.N","type":"codeVoice"},{"text":" — Production-ready candidate. If clean for 1 week,","type":"text"},{"text":" ","type":"text"},{"text":"ships as stable.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Compatibility-Guarantees","type":"heading","text":"Compatibility Guarantees"},{"type":"paragraph","inlineContent":[{"text":"These are part of the public API and follow semver:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"CLI command names and flags"}]},{"text":" — renaming is a major bump","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"--json"},{"type":"text","text":" output schemas"}],"type":"strong"},{"text":" — removing fields is a major bump","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"config.json","type":"codeVoice"},{"text":" format","type":"text"}]},{"type":"text","text":" — removing fields is a major bump"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"VM bundle structure"}]},{"type":"text","text":" — old bundles readable indefinitely"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding new flags, JSON fields, or config keys is a minor bump."}]},{"type":"heading","level":3,"text":"Release Process","anchor":"Release-Process"},{"type":"codeListing","syntax":null,"code":["Feature branch → PR → CI (235+ tests) → Review → Merge","    → TestFlight (automatic on main)","    → GitHub Release + App Store (automatic on tag)","    → Notarized Homebrew zip (automatic on tag)","    → DocC docs update (automatic on main)"]},{"type":"heading","level":3,"text":"Pinning Versions","anchor":"Pinning-Versions"},{"type":"paragraph","inlineContent":[{"text":"For CI pipelines and infrastructure-as-code:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# Homebrew","brew install --cask spooktacular@1.0","","# Direct download (specific version)","curl -L https:\/\/github.com\/Spooky-Labs\/spooktacular\/releases\/download\/v1.0.0\/Spooktacular.app.zip"]}]}],"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"],"title":"Related"}],"seeAlsoSections":[{"generated":true,"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/Spookta