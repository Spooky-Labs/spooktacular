{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular follows "},{"type":"reference","isActive":true,"identifier":"https:\/\/semver.org"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Every part of the version number communicates specific guarantees"},{"type":"text","text":" "},{"type":"text","text":"to enterprise teams integrating Spooktacular into their infrastructure."}]},{"type":"heading","text":"Version Format","level":3,"anchor":"Version-Format"},{"syntax":null,"type":"codeListing","code":["MAJOR.MINOR.PATCH[-PRERELEASE]","","1.0.0-rc1    Release candidate (test in staging)","1.0.0        Stable release (safe for production)","1.1.0        Feature release (backward-compatible)","1.1.1        Bug fix (upgrade immediately)","2.0.0        Breaking change (migration guide provided)"]},{"type":"heading","text":"What Each Part Means","level":3,"anchor":"What-Each-Part-Means"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MAJOR"}]},{"type":"text","text":" — Breaking changes to the CLI, "},{"type":"codeVoice","code":"config.json"},{"type":"text","text":" schema, or"},{"type":"text","text":" "},{"type":"text","text":"VM bundle format. We provide migration guides and at least one"},{"type":"text","text":" "},{"type":"text","text":"release candidate before shipping."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MINOR"}]},{"type":"text","text":" — New features that are backward-compatible. Your existing"},{"type":"text","text":" "},{"type":"text","text":"VMs, scripts, and CI configurations continue working."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"PATCH"}]},{"type":"text","text":" — Bug fixes and security patches. No behavior changes."},{"type":"text","text":" "},{"type":"text","text":"Ships within 48 hours of confirmed fix."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Pre-release tags:"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"-alpha.N","type":"codeVoice"},{"type":"text","text":" — Early development. APIs may change."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-beta.N","type":"codeVoice"},{"type":"text","text":" — Feature-complete. APIs stable, may have bugs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"-rc.N","type":"codeVoice"},{"type":"text","text":" — Production-ready candidate. If clean for 1 week,"},{"type":"text","text":" "},{"type":"text","text":"ships as stable."}]}]}]},{"type":"heading","text":"Compatibility Guarantees","level":3,"anchor":"Compatibility-Guarantees"},{"type":"paragraph","inlineContent":[{"type":"text","text":"These are part of the public API and follow semver:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CLI command names and flags"}],"type":"strong"},{"type":"text","text":" — renaming is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"--json"},{"type":"text","text":" output schemas"}],"type":"strong"},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"config.json"},{"type":"text","text":" format"}],"type":"strong"},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"VM bundle structure"}],"type":"strong"},{"type":"text","text":" — old bundles readable indefinitely"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding new flags, JSON fields, or config keys is a minor bump."}]},{"type":"heading","text":"Release Process","level":3,"anchor":"Release-Process"},{"syntax":null,"type":"codeListing","code":["Feature branch → PR → CI (360+ tests) → Review → Merge","    → TestFlight (automatic on main)","    → GitHub Release + App Store (automatic on tag)","    → Notarized Homebrew zip (automatic on tag)","    → DocC docs update (automatic on main)"]},{"type":"heading","text":"Pinning Versions","level":3,"anchor":"Pinning-Versions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For CI pipelines and infrastructure-as-code:"}]},{"syntax":"bash","type":"codeListing","code":["# Homebrew","brew install --cask spooktacular@1.0","","# Direct download (specific version)","curl -L https:\/\/github.com\/Spooky-Labs\/spooktacular\/releases\/download\/v1.0.0\/Spooktacular.app.zip"]}]}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/spooktacularkit\/versioning"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"seeAlsoSections":[{"generated":true,"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"]}],"metadata":{"role":"collectionG