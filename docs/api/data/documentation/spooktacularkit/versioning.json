{"abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Spooktacular follows "},{"type":"reference","isActive":true,"identifier":"https:\/\/semver.org"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Every part of the version number communicates specific guarantees"},{"type":"text","text":" "},{"type":"text","text":"to enterprise teams integrating Spooktacular into their infrastructure."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Version Format","anchor":"Version-Format"},{"type":"codeListing","syntax":null,"code":["MAJOR.MINOR.PATCH[-PRERELEASE]","","1.0.0-rc1    Release candidate (test in staging)","1.0.0        Stable release (safe for production)","1.1.0        Feature release (backward-compatible)","1.1.1        Bug fix (upgrade immediately)","2.0.0        Breaking change (migration guide provided)"]},{"type":"heading","level":3,"text":"What Each Part Means","anchor":"What-Each-Part-Means"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MAJOR"}]},{"type":"text","text":" — Breaking changes to the CLI, "},{"type":"codeVoice","code":"config.json"},{"type":"text","text":" schema, or"},{"type":"text","text":" "},{"type":"text","text":"VM bundle format. We provide migration guides and at least one"},{"type":"text","text":" "},{"type":"text","text":"release candidate before shipping."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MINOR"}]},{"type":"text","text":" — New features that are backward-compatible. Your existing"},{"type":"text","text":" "},{"type":"text","text":"VMs, scripts, and CI configurations continue working."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"PATCH"}]},{"type":"text","text":" — Bug fixes and security patches. No behavior changes."},{"type":"text","text":" "},{"type":"text","text":"Ships within 48 hours of confirmed fix."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Pre-release tags:"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-alpha.N"},{"type":"text","text":" — Early development. APIs may change."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-beta.N"},{"type":"text","text":" — Feature-complete. APIs stable, may have bugs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-rc.N"},{"type":"text","text":" — Production-ready candidate. If clean for 1 week,"},{"type":"text","text":" "},{"type":"text","text":"ships as stable."}]}]}]},{"type":"heading","level":3,"text":"Compatibility Guarantees","anchor":"Compatibility-Guarantees"},{"inlineContent":[{"type":"text","text":"These are part of the public API and follow semver:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CLI command names and flags"}],"type":"strong"},{"type":"text","text":" — renaming is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"--json","type":"codeVoice"},{"type":"text","text":" output schemas"}],"type":"strong"},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"config.json","type":"codeVoice"},{"type":"text","text":" format"}],"type":"strong"},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"VM bundle structure"}],"type":"strong"},{"type":"text","text":" — old bundles readable indefinitely"}]}]}]},{"i