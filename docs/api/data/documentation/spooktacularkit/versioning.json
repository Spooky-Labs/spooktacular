{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular follows "},{"identifier":"https:\/\/semver.org","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Every part of the version number communicates specific guarantees"},{"type":"text","text":" "},{"type":"text","text":"to enterprise teams integrating Spooktacular into their infrastructure."}]},{"level":3,"type":"heading","anchor":"Version-Format","text":"Version Format"},{"syntax":null,"code":["MAJOR.MINOR.PATCH[-PRERELEASE]","","1.0.0-rc1    Release candidate (test in staging)","1.0.0        Stable release (safe for production)","1.1.0        Feature release (backward-compatible)","1.1.1        Bug fix (upgrade immediately)","2.0.0        Breaking change (migration guide provided)"],"type":"codeListing"},{"level":3,"type":"heading","anchor":"What-Each-Part-Means","text":"What Each Part Means"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"MAJOR","type":"text"}]},{"type":"text","text":" — Breaking changes to the CLI, "},{"type":"codeVoice","code":"config.json"},{"type":"text","text":" schema, or"},{"type":"text","text":" "},{"type":"text","text":"VM bundle format. We provide migration guides and at least one"},{"type":"text","text":" "},{"type":"text","text":"release candidate before shipping."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"MINOR","type":"text"}]},{"type":"text","text":" — New features that are backward-compatible. Your existing"},{"type":"text","text":" "},{"type":"text","text":"VMs, scripts, and CI configurations continue working."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"PATCH","type":"text"}]},{"type":"text","text":" — Bug fixes and security patches. No behavior changes."},{"type":"text","text":" "},{"type":"text","text":"Ships within 48 hours of confirmed fix."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Pre-release tags:","type":"text"}]}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-alpha.N"},{"type":"text","text":" — Early development. APIs may change."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-beta.N"},{"type":"text","text":" — Feature-complete. APIs stable, may have bugs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-rc.N"},{"type":"text","text":" — Production-ready candidate. If clean for 1 week,"},{"type":"text","text":" "},{"type":"text","text":"ships as stable."}]}]}],"type":"unorderedList"},{"level":3,"type":"heading","anchor":"Compatibility-Guarantees","text":"Compatibility Guarantees"},{"type":"paragraph","inlineContent":[{"type":"text","text":"These are part of the public API and follow semver:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"CLI command names and flags","type":"text"}]},{"type":"text","text":" — renaming is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"--json","type":"codeVoice"},{"text":" output schemas","type":"text"}]},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"config.json","type":"codeVoice"},{"text":" format","type":"text"}]},{"type":"text","text":" — removing fields is a major bump"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"VM bundle structure","type":"text"}]},{"type":"text","text":" — old bundles readable indefinitely"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding new flags, JSON fields, or config keys is a minor bump."}]},{"level":3,"type":"heading","anchor":"Release-Process","text":"Release Process"},{"syntax":null,"code":["Feature branch → PR → CI (235+ tests) → Review → Merge","    → TestFlight (automatic on main)","    → GitHub Release + App Store (automatic on tag)","    → Notarized Homebrew zip (automatic on tag)","    → DocC docs update (automatic on main)"],"type":"codeListing"},{"level":3,"type":"heading","anchor":"Pinning-Versions","text":"Pinning Versions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For CI pipelines and infrastructure-as-code:"}]},{"syntax":"bash","code":["# Homebrew","brew install --cask spooktacular@1.0","","# Direct download (specific version)","curl -L https:\/\/github.com\/Spooky-Labs\/spooktacular\/releases\/download\/v1.0.0\/Spooktacular.app.zip"],"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/versioning"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide"],"