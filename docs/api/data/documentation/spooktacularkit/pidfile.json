{"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"text":"Other commands (","type":"text"},{"type":"codeVoice","code":"stop"},{"text":", ","type":"text"},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"code":"ip","type":"codeVoice"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"text":"determine whether a VM is running and to signal the process.","type":"text"}]},{"type":"heading","text":"PID File Lifecycle","level":2,"anchor":"PID-File-Lifecycle"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" writes the PID file before booting the VM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph",