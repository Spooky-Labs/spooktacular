{"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","generated":true},{"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/writeAndEnsureCapacity(bundleURL:vmDirectory:)"],"title":"Type Methods","generated":true}],"metadata":{"externalID":"s:15SpooktacularKit7PIDFileO","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PIDFile"}],"symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"modules":[{"name":"SpooktacularKit"}],"role":"symbol","title":"PIDFile","roleHeading":"Enumeration"},"abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}]},{"text":"PID File Lifecycle","type":"heading","anchor":"PID-File-Lifecycle","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" writes the PID file before booting the VM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"spook stop","type":"codeVoice"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","type":"reference"},{"text":" detects stale PID files by checking","type":"text"},{"text":" ","type":"text"},{"text":"whether the recorded process is still running.","type":"text"}],"type":"paragraph"}]}]},{"text":"Thread Safety","type":"heading","anchor":"Thread-Safety","level":2},{"type":"paragraph","i