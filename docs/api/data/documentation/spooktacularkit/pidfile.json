{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}],"type":"paragraph"},{"anchor":"PID-File-Lifecycle","text":"PID File Lifecycle","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" writes the PID file before booting the VM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"text":" detects stale PID files by checking","type":"text"},{"text":" ","type":"text"},{"text":"whether the recorded process is still running.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Thread-Safety","text":"Thread Safety","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pidfile"]}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","anchor":"Type-Properties"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/writeAndEnsureCapacity(bundleURL:vmDirectory:)"],"title":"Type Methods","anchor":"Type-Methods"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"identifier":{"interfaceLa