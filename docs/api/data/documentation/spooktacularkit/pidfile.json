{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}]},{"level":2,"text":"PID File Lifecycle","type":"heading","anchor":"PID-File-Lifecycle"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}]}]}]},{"type":"heading","anchor":"Thread-Safety","text":"Thread Safety","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"metadata":{"roleHeading":"Enumeration","role":"symbol","symbolKind":"enum","externalID":"s:15SpooktacularKit7PIDFileO","navigatorTitle":[{"text":"PIDFile","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PIDFile"}],"modules":[{"name":"SpooktacularKit"}],"title":"PIDFile"},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pidfile"]}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"title":"Type Methods","generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\