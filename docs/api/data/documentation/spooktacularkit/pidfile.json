ffectively atomic at the file-system level."}]}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pidfile"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile":{"navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"title":"PIDFile","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"url":"\/documentation\/spooktacularkit\/pidfile","abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"type":"topic","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"url":"\/documentation\/spooktacularkit","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/remove(from:)":{"type":"topic","role":"symbol","url":"\/documentation\/spooktacularkit\/pidfile\/remove(from:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"kind":"externalParam","text":"from"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier","text":"URL"},{"kind":"text","text":")"}],"title":"remove(from:)","kind":"symbol","abstract":[{"type":"text","text":"Removes the PID file from the VM bundle directory."}]},"doc://SpooktacularKit/do