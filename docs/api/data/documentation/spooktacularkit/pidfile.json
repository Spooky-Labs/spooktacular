{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"type":"codeVoice","code":"spook start"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"type":"codeVoice","code":"stop"},{"text":", ","type":"text"},{"type":"codeVoice","code":"list"},{"text":", ","type":"text"},{"type":"codeVoice","code":"ip"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}]},{"level":2,"type":"heading","anchor":"PID-File-Lifecycle","text":"PID File Lifecycle"},{"items":[{"content":[{"inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}]}]},{"content":[{"inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","type":"reference","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Thread Safety","anchor":"Thread-Safety","type":"heading","level":2},{"inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}]}],"metadata":{"roleHeading":"Enumeration","symbolKind":"enum","role":"symbol","externalID":"s:15SpooktacularKit7PIDFileO","navigatorTitle":[{"text":"PIDFile","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"title":"PIDFile"},"topicSections":[{"generated":true,"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"]},{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Spoo