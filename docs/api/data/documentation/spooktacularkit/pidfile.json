{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"code":"spook start","type":"codeVoice"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"code":"stop","type":"codeVoice"},{"text":", ","type":"text"},{"code":"list","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}]},{"type":"heading","level":2,"anchor":"PID-File-Lifecycle","text":"PID File Lifecycle"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Thread-Safety","text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"text":"are effectively atomic at the file-system level.","type":"text"}]}]}],"metadata":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"title":"PIDFile","externalID":"s:15SpooktacularKit7PIDFileO","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"roleHeading":"Enumeration","symbolKind":"enum"},"kind":"symbol","topicSections":[{"generated":true,"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"]},{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/document