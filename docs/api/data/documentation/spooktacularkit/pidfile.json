{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit7PIDFileO","roleHeading":"Enumeration","title":"PIDFile","symbolKind":"enum","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PIDFile"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"code":"spook start","type":"codeVoice"},{"type":"text","text":" process that owns the VM."},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"code":"stop","type":"codeVoice"},{"text":", ","type":"text"},{"code":"list","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"determine whether a VM is running and to signal the process."}]},{"anchor":"PID-File-Lifecycle","level":2,"type":"heading","text":"PID File Lifecycle"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" writes the PID file before booting the VM.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"anchor":"Thread-Safety","type":"heading","text":"Thread Safety"},{"inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","anchor":"Type-Properties"},{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/do