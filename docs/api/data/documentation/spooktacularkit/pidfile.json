{"kind":"symbol","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"code":"spook start","type":"codeVoice"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"code":"stop","type":"codeVoice"},{"text":", ","type":"text"},{"code":"list","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}]},{"type":"heading","anchor":"PID-File-Lifecycle","level":2,"text":"PID File Lifecycle"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" writes the PID file before booting the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"type":"text","text":" reads the PID file and sends SIGTERM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}]}]}]},{"type":"heading","anchor":"Thread-Safety","level":2,"text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"text":"are effectively atomic at the file-system level.","type":"text"}]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"metadata":{"symbolKind":"enum","roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"externalID":"s:15SpooktacularKit7PIDFileO","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"modules":[{"name":"SpooktacularKit"}],"title":"PIDFile"},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"topicSections":[{"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"generated":true},{"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/docum