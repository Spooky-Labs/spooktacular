{"metadata":{"role":"symbol","title":"PIDFile","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"symbolKind":"enum","externalID":"s:15SpooktacularKit7PIDFileO"},"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"code":"spook start","type":"codeVoice"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"code":"stop","type":"codeVoice"},{"type":"text","text":", "},{"code":"list","type":"codeVoice"},{"type":"text","text":", "},{"code":"ip","type":"codeVoice"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}],"type":"paragraph"},{"anchor":"PID-File-Lifecycle","type":"heading","level":2,"text":"PID File Lifecycle"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Thread-Safety","type":"heading","level":2,"text":"Thread Safety"},{"inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}]}],"sections":[],"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","generated":true},{"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFil