{"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile"},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"PIDFile","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"text":") read the PID file to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}]},{"type":"heading","level":2,"text":"PID File Lifecycle","anchor":"PID-File-Lifecycle"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"text":" detects stale PID files by checking","type":"text"},{"text":" ","type":"text"},{"text":"whether the recorded process is still running.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Thread Safety","level":2,"anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"type":"text","text":" "},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"text":"are effectively atomic at the file-system level.","type":"text"}]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","generated":true},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/writeAndEns