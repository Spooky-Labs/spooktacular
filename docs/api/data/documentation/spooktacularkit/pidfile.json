{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","title":"PIDFile","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"externalID":"s:15SpooktacularKit7PIDFileO","roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"type":"text","text":" "},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"type":"text","text":". The file contains the"},{"text":" ","type":"text"},{"type":"text","text":"process ID of the "},{"code":"spook start","type":"codeVoice"},{"type":"text","text":" process that owns the VM."},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}],"type":"paragraph"},{"anchor":"PID-File-Lifecycle","level":2,"text":"PID File Lifecycle","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" writes the PID file before booting the VM."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stops the VM, removes the PID file, and exits."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true,"type":"reference"},{"text":" detects stale PID files by checking","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}]}]}],"type":"orderedList"},{"anchor":"Thread-Safety","text":"Thread Safety","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"text":"are effectively atomic at the file-system level.","type":"text"}]}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"anchor":"Type-Properties","title":"Type Properties"},{"anchor":"Type-Methods","generated":true,"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL