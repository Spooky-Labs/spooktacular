{"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","generated":true,"anchor":"Type-Properties"},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)"],"title":"Type Methods","generated":true,"anchor":"Type-Methods"}],"sections":[],"metadata":{"externalID":"s:15SpooktacularKit7PIDFileO","symbolKind":"enum","title":"PIDFile","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}],"type":"paragraph"},{"text":"PID File Lifecycle","level":2,"anchor":"PID-File-Lifecycle","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Thread Safety","level":2,"anchor":"Thread-Safety","type":"heading"},{"inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/terminate(bundleURL:gracePeriod:)":{"url":"\/documentation\/spooktacularkit\/pidfile\/terminate(bundleurl:graceperiod:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","type":"topic","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"terminate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"bundleURL","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"gracePeriod","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"}],"abstract":[{"type":"text","text":"Sends "},{"type":"codeVoice","code":"SIGTERM"},{"type":"text","text":" to the process owning the VM, waits for it to"},{"type":"text","text":" "},{"type":"text","text":"exit, escalates to "},{"type":"codeVoice","code":"SIGKILL"},{"type":"text","text":" if needed, and removes the PID file."}],"title":"terminate(bundleURL:gracePeriod:)","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","role":"collection","abstract":[{"type":"text","text":