{"kind":"symbol","metadata":{"roleHeading":"Enumeration","symbolKind":"enum","title":"PIDFile","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit7PIDFileO","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"navigatorTitle":[{"text":"PIDFile","kind":"identifier"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"anchor":"Type-Properties","title":"Type Properties","generated":true},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/writeAndEnsureCapacity(bundleURL:vmDirectory:)"],"anchor":"Type-Methods","title":"Type Methods","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"type":"codeVoice","code":"spook start"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"type":"codeVoice","code":"stop"},{"text":", ","type":"text"},{"type":"codeVoice","code":"list"},{"text":", ","type":"text"},{"type":"codeVoice","code":"ip"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}]},{"text":"PID File Lifecycle","type":"heading","level":2,"anchor":"PID-File-Lifecycle"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" writes the PID file before booting the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"type":"text","text":" reads the PID file and sends SIGTERM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}]}]}]},{"text":"Thread Safety","type":"heading","level":2,"anchor":"Thread-Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"text":"are effectively atomic at the file-system level.","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile"},"abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pidfile"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/isProcessAlive(_:)":{"url":"\/documentation\/spooktacularkit\/pidfile\/isprocessalive(_:)","role":"symbol","abstract":[{"text":"Checks whether the given process ID refers to a running process.","type":"text"}],"title":"isProcessAlive(_:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isProcessAlive","kind":"identifier"},{"text":"(","kind":"text"},{"text":"pid_t","preciseIdentifier":"c:@T@pid_t","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"kind":"symbol","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","role":"collection","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/isRunning(bundleURL:)":{"kind":"symbol","url":"\/documentation\/spooktacularkit\/pidfile\/isrunning(bundleurl:)","title":"isRunning(bundleURL:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunnin