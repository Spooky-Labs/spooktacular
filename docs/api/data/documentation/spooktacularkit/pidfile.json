{"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"kind":"symbol","metadata":{"modules":[{"name":"SpooktacularKit"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"navigatorTitle":[{"text":"PIDFile","kind":"identifier"}],"symbolKind":"enum","roleHeading":"Enumeration","title":"PIDFile","externalID":"s:15SpooktacularKit7PIDFileO"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/pidfile"]}],"topicSections":[{"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"generated":true},{"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)"],"generated":true}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}]}]},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"type":"text","text":" "},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"type":"text","text":". The file contains the"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"code":"spook start","type":"codeVoice"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Other commands ("},{"code":"stop","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"text":", ","type":"text"},{"type":"codeVoice","code":"ip"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"PID-File-Lifecycle","text":"PID File Lifecycle","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"type":"text","text":" reads the PID file and sends SIGTERM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stops the VM, removes the PID file, and exits."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Thread Safety","anchor":"Thread-Safety","type":"heading","level":2},{"inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"text":"are effectively atomic at the file-system level.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"title":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit","role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/terminate(bundleURL:gracePeriod:)":{"abstract":[{"text":"Sends ","type":"text"},{"code":"SIGTERM","type":"codeVoice"},{"text":" to the process owning the VM, waits for it to","type":"text"},{"text":" ","type":"text"},{"text":"exit, escalates to ","type":"text"},{"code":"SIGKILL","type":"codeVoice"},{"text":" if needed, and removes the PID file.","type":"text"}],"title":"terminate(bundleURL:gracePeriod:)","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"terminate"},{"kind":"text","text":"("},{"kind":"externalParam","text":"bundleURL"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"URL","preciseIdentifier":"s:10Foundation3URLV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"gracePeriod"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TimeInterval","preciseIdentifier":"c:@T@NSTimeInterval"},{"kind":"text","text":") "},{"text":"async","kind":"keyword