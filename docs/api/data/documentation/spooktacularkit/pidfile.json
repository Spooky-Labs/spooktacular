{"kind":"symbol","abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"type":"text","text":", "},{"type":"codeVoice","code":"ip"},{"type":"text","text":") read the PID file to"},{"type":"text","text":" "},{"type":"text","text":"determine whether a VM is running and to signal the process."}]},{"type":"heading","level":2,"text":"PID File Lifecycle","anchor":"PID-File-Lifecycle"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" writes the PID file before booting the VM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook stop"},{"type":"text","text":" reads the PID file and sends SIGTERM."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"type":"text","text":" installs a SIGTERM handler that gracefully"},{"type":"text","text":" "},{"type":"text","text":"stops the VM, removes the PID file, and exits."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the process crashes, the PID file becomes stale."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)"},{"type":"text","text":" detects stale PID files by checking"},{"type":"text","text":" "},{"type":"text","text":"whether the recorded process is still running."}]}]}]},{"type":"heading","level":2,"anchor":"Thread-Safety","text":"Thread Safety"},{"type":"paragraph","inlineContent":[{"text":"All methods are static and operate on the file system. They","type":"text"},{"text":" ","type":"text"},{"text":"are safe to call from any thread. The PID file is a plain","type":"text"},{"text":" ","type":"text"},{"text":"text file containing a single integer, so reads and writes","type":"text"},{"text":" ","type":"text"},{"text":"are effectively atomic at the file-system level.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"PIDFile","symbolKind":"enum","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit7PIDFileO","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PIDFile"}],"navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"role":"symbol","roleHeading":"Enumeration"},"sections":[],"topicSections":[{"generated":true,"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"]},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\