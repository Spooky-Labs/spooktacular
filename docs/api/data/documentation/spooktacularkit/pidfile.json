{"abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"sections":[],"metadata":{"symbolKind":"enum","modules":[{"name":"SpooktacularKit"}],"externalID":"s:15SpooktacularKit7PIDFileO","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"PIDFile","kind":"identifier"}],"roleHeading":"Enumeration","title":"PIDFile"},"topicSections":[{"generated":true,"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"anchor":"Type-Properties"},{"generated":true,"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)"],"anchor":"Type-Methods"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Each running VM writes a PID file at","type":"text"},{"text":" ","type":"text"},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"text":". The file contains the","type":"text"},{"text":" ","type":"text"},{"text":"process ID of the ","type":"text"},{"code":"spook start","type":"codeVoice"},{"text":" process that owns the VM.","type":"text"},{"text":" ","type":"text"},{"text":"Other commands (","type":"text"},{"code":"stop","type":"codeVoice"},{"text":", ","type":"text"},{"code":"list","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"text":") read the PID file to","type":"text"},{"text":" ","type":"text"},{"text":"determine whether a VM is running and to signal the process.","type":"text"}],"type":"paragraph"},{"level":2,"text":"PID File Lifecycle","anchor":"PID-File-Lifecycle","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" writes the PID file before booting the VM.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook stop","type":"codeVoice"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"spook start","type":"codeVoice"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true},{"text":" detects stale PID files by checking","type":"text"},{"text":" ","type":"text"},{"text":"whether the recorded process is still running.","type":"text"}]}]}],"type":"orderedList"},{"level":2,"text":"Thread Safety","anchor":"Thread-Safety","type":"heading"},{"inlineContent":[{"text":"