{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Manages PID files for tracking running virtual machines."}],"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"title":"Type Properties","anchor":"Type-Properties","generated":true},{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/writeAndEnsureCapacity(bundleURL:vmDirectory:)"],"title":"Type Methods","anchor":"Type-Methods","generated":true}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"metadata":{"title":"PIDFile","symbolKind":"enum","roleHeading":"Enumeration","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"externalID":"s:15SpooktacularKit7PIDFileO","modules":[{"name":"SpooktacularKit"}]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"code":"~\/.spooktacular\/vms\/<name>.vm\/pid","type":"codeVoice"},{"text":". The