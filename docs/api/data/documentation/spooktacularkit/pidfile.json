{"abstract":[{"text":"Manages PID files for tracking running virtual machines.","type":"text"}],"metadata":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PIDFile"}],"roleHeading":"Enumeration","title":"PIDFile","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PIDFile"}],"externalID":"s:15SpooktacularKit7PIDFileO","modules":[{"name":"SpooktacularKit"}],"symbolKind":"enum"},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/fileName"],"anchor":"Type-Properties","title":"Type Properties"},{"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isRunning(bundleURL:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/read(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/remove(from:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/write(to:)"],"generated":true,"title":"Type Methods"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PIDFile","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"Each running VM writes a PID file at"},{"type":"text","text":" "},{"type":"codeVoice","code":"~\/.spooktacular\/vms\/<name>.vm\/pid"},{"type":"text","text":". The file contains the"},{"type":"text","text":" "},{"type":"text","text":"process ID of the "},{"type":"codeVoice","code":"spook start"},{"type":"text","text":" process that owns the VM."},{"type":"text","text":" "},{"type":"text","text":"Other commands ("},{"type":"codeVoice","code":"stop"},{"type":"text","text":", "},{"type":"codeVoice","code":"list"},{"text":", ","type":"text"},{"code":"ip","type":"codeVoice"},{"type":"text","text":") read the PID file to"},{"text":" ","type":"text"},{"type":"text","text":"determine whether a VM is running and to signal the process."}],"type":"paragraph"},{"text":"PID File Lifecycle","anchor":"PID-File-Lifecycle","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" writes the PID file before booting the VM.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"spook stop"},{"text":" reads the PID file and sends SIGTERM.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"spook start"},{"text":" installs a SIGTERM handler that gracefully","type":"text"},{"text":" ","type":"text"},{"text":"stops the VM, removes the PID file, and exits.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"If the process crashes, the PID file becomes stale.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/isProcessAlive(_:)","isActive":true,"type":"reference"},{"type":"text","text":" detects stale PID files by checking"},{"text":" ","type":"text"},{"text":"whether the recorded process is still running.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","level":2,"anchor":"Thread-Safety","text":"Thread Safety"},{"inlineContent":[{"type":"text","text":"All methods are static and operate on the file system. They"},{"type":"text","text":" "},{"type":"text","text":"are safe to call from any thread. The PID file is a plain"},{"type":"text","text":" "},{"type":"text","text":"text file containing a single integer, so reads and writes"},{"type":"text","text":" "},{"type":"text","text":"are effectively atomic at the file-system level."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/pidfile"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","references":{"doc://SpooktacularKit/documentation/SpooktacularKit/PIDFile/terminate(bundleURL:gracePeriod:)":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/PIDFile\/terminate(bundleURL:gracePeriod:)","kind":"symbol","title":"terminate(bundleURL:gracePeriod:)","abstract":[{"text":"Sends ","type":"text"},{"code":"SIGTERM","type":"codeVoice"},{"text":" to the process owning the VM, waits for it to","type":"text"},{"text":" ","type":"text"},{"text":"exit, escalates to ","type":"text"},{"code":"SIGKILL","type":"codeVoice"},{"text":" if needed, and removes the PID file.","type":"text"}],"role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"terminate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"bundleURL","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"URL","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV"},{"text":", ","kind":"text"},{"text":"gracePeriod","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TimeInterval","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"}],"type":"topic","url":"\/documentation\/spooktacularkit\/pidfile\/terminate(bundleurl:graceperiod:)"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","type":"topic","title":"SpooktacularKit","abstrac