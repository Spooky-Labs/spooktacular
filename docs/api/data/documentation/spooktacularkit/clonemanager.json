{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}],"title":"CloneManager","symbolKind":"enum","externalID":"s:15SpooktacularKit12CloneManagerO","role":"symbol","roleHeading":"Enumeration","navigatorTitle":[{"kind":"identifier","text":"CloneManager"}]},"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"topicSections":[{"title":"Type Methods","generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" uses APFS "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"text":"new","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}],"type":"paragraph"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"syntax":"swift","type":"codeListing"},{"anchor":"Important","level":2,"text":"Important","type":"heading"},{"inlineContent":[{"type":"text","text":"The hardware model ("},{"type":"codeVoice","code":"hardware-model.bin"},{"type":"text","text":") is copied as-is"},{"type":"text","text":" "},{"type":"text","text":"because it must match the macOS version installed on the"},{"type":"text","text":" "},{"type":"text","text":"disk. The machine identifier ("},{"type":"codeVoice","code":"machine-identifier.bin"},{"type":"text","text":") is"},{"type":"text","text":" "},{"type":"text","text":"always regenerated — never copied."}],"type":"paragraph"}]}],"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/clonemanager"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","url":"\/documentation\/spooktacularkit\/clonemanager","type":"topic","title":"CloneManager","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"role":"symbol","kind":"symbol