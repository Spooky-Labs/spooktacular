ion"},{"type":"text","text":" "},{"type":"text","text":"framework."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"codeListing","code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"syntax":"swift"},{"text":"Important","type":"heading","level":2,"anchor":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The hardware model ("},{"type":"codeVoice","code":"hardware-model.bin"},{"type":"text","text":") is copied as-is"},{"type":"text","text":" "},{"type":"text","text":"because it must match the macOS version installed on the"},{"type":"text","text":" "},{"type":"text","text":"disk. The machine identifier ("},{"type":"codeVoice","code":"machine-identifier.bin"},{"type":"text","text":") is"},{"type":"text","text":" "},{"type":"text","text":"always regenerated — never copied."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/clonemanager"]}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CloneManager"}],"abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"url":"\/documentation\/spooktacularkit\/clonemanager","kind":"symbol","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}],"title":"CloneManager","type":"topic","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager