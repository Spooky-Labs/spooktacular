{"kind":"symbol","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" uses APFS "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"type":"text","text":"new"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Important","anchor":"Important","type":"heading"},{"inlineContent":[{"type":"text","text":"The hardware model ("},{"ty