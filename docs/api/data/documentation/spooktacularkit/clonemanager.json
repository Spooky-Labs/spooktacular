{"metadata":{"roleHeading":"Enumeration","title":"CloneManager","symbolKind":"enum","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"externalID":"s:15SpooktacularKit12CloneManagerO","modules":[{"name":"SpooktacularKit"}],"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"CloneManager","kind":"identifier"}]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"code":"CloneManager","type":"codeVoice"},{"type":"text","text":" uses APFS "},{"code":"clonefile(2)","type":"codeVoice"},{"text":" for the disk image,","type":"text"},{"type":"text","text":" "},{"text":"which creates an instant copy that shares physical blocks","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"type":"text","text":"new"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"text":" to","type":"text"},{"type":"text","text":" "},{"text":"ensure each VM has a unique identity. Reusing identifiers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"syntax":"swift","code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"type":"codeListing"},{"text":"Important","anchor":"Important","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The hardware model (","type":"text"},{"code":"hardware-model.bin","type":"codeVoice"},{"text":") is copied as-is","type":"text"},{"text":" ","type":"text"},{"text":"because it must match the macOS version installed on the","type":"text"},{"text":" ","type":"text"},{"text":"disk. The machine identifier (","type":"text"},{"type":"codeVoice","code":"machine-identifier.bin"},{"text":") is","type":"text"},{"text":" ","type":"text"},{"text":"always regenerated — never copied.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","interfaceLanguage":"swift"},"topicSections":[{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"],"generated":true,"anchor":"Type-Methods"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/clonemanager"]}],"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"url":"\/documentation\/spooktacularkit\/clonemanager","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","title":"CloneManager","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}