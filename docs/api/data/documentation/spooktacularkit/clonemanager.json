{"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"code":"CloneManager","type":"codeVoice"},{"type":"text","text":" uses APFS "},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"text":"new","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Important","anchor":"Important","type":"heading"},{"inlineContent":[{"type":"text","text":"The hardware model ("},{"code":"hardware-model.bin","type":"codeVoice"},{"type":"text","text":") is copied as-is"},{"type":"text","text":" "},{"type":"text","text":"because it must match the macOS version installed on the"},{"type":"text","text":" "},{"type":"text","text":"disk. The machine identifier ("},{"code":"machine-identifier.bin","type":"codeVoice"},{"type":"text","text":") is"},{"type":"text","text":" "},{"type":"text","text":"always regenerated — never copied."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}],"role":"symbol","externalID":"s:15SpooktacularKit12CloneManagerO","navigatorTitle":[{"text":"CloneManager","kind":"identifier"}],"symbolKind":"enum","title":"CloneManager"},"topicSections":[{"generated":true,"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"]}],"variants":[{"paths":["\/documentation\/spooktacularkit\/clonemanager"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","interfaceLanguage":"swift"},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"title":"SpooktacularKit","url":"\/documentation\/spooktacularkit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager/clone(source:to:)":{"title":"clone(source:to:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind"