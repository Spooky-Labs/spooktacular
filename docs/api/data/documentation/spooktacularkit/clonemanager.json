{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"},"variants":[{"paths":["\/documentation\/spooktacularkit\/clonemanager"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"code":"CloneManager","type":"codeVoice"},{"type":"text","text":" uses APFS "},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every clone receives a "},{"type":"strong","inlineContent":[{"text":"new","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"syntax":"swift","code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"type":"codeListing"},{"text":"Important","anchor":"Important","level":2,"type":"heading"},{"inlineContent":[{"text":"The hardware model (","type":"text"},{"code":"hardware-model.bin","type":"codeVoice"},{"text":") is copied as-is","type":"text"},{"text":" ","type":"text"},{"text":"because it must match the macOS version installed on the","type":"text"},{"text":" ","type":"text"},{"text":"disk. The machine identifier (","type":"text"},{"code":"machine-identifier.bin","type":"codeVoice"},{"text":") is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always regenerated — never copied."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"],"anchor":"Type-Methods","title":"Type Methods"}],"kind":"symbol","metadata":{"externalID":"s:15SpooktacularKit12CloneManagerO","navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"role":"symbol","symbolKind":"enum","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"title":"CloneManager","roleHeading":"Enumeration","modules":[{"name":"SpooktacularKit"}]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager/clone(source:to:)":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)","url":"\/documentation\/spooktacularkit\/clonemanager\/clone(source:to:)","role":"symbol","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"clone","kind":"identifier"},{"text":"(","kind":"text"},{"text":"source","kind":"externalParam"},{"text":": ","kin