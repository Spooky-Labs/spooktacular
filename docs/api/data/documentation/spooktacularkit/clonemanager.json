{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"text":"Creates copy-on-write clones of virtual machine bundles.","type":"text"}],"kind":"symbol","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"code":"CloneManager","type":"codeVoice"},{"type":"text","text":" uses APFS "},{"code":"clonefile(2)","type":"codeVoice"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"text":"new","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"VZMacMachineIdentifier","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"syntax":"swift","code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"type":"codeListing"},{"level":2,"text":"Important","anchor":"Important","type":"heading"},{"inlineContent":[{"type":"text","text":"The hardware model ("},{"code":"hardware-model.bin","type":"codeVoice"},{"type":"text","text":") is copied as-is"},{"text":" ","type":"text"},{"text":"because it must match the macOS version installed on the","type":"text"},{"text":" ","type":"text"},{"text":"disk. The machine identifier (","type":"text"},{"type":"codeVoice","code":"machine-identifier.bin"},{"text":") is","type":"text"},{"text":" ","type":"text"},{"text":"always regenerated — never copied.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/clonemanager"]}],"metadata":{"externalID":"s:15SpooktacularKit12CloneManagerO","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"symbolKind":"enum","navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"modules":[{"name":"SpooktacularKit"}],"role":"symbol","title":"CloneManager","roleHeading":"Enumeration"},"topicSections":[{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"],"anchor":"Type-Methods","generated":true}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","type":"topic","role":"collection","title":"SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager/clone(source:to:)":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","