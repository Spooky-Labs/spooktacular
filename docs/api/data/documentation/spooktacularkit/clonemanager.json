{"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager"},"abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"kind":"symbol","metadata":{"roleHeading":"Enumeration","title":"CloneManager","navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"symbolKind":"enum","externalID":"s:15SpooktacularKit12CloneManagerO","role":"symbol","modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloneManager","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" uses APFS "},{"code":"clonefile(2)","type":"codeVoice"},{"text":" for the disk image,","type":"text"},{"text":" ","type":"text"},{"text":"which creates an instant copy that shares physical blocks","type":"text"},{"text":" ","type":"text"},{"text":"with the source. A 30 GB disk image clones in milliseconds.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every clone receives a "},{"type":"strong","inlineContent":[{"text":"new","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (preserved)","\/\/ clone.metadata.id != source.metadata.id (new identity)","\/\/ disk.img is a COW clone (instant, space-efficient)","\/\/ machine-identifier.bin is freshly generated"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Important","type":"heading","anchor":"Important"},{"inlineContent":[{"text":"The hardware model (","type":"text"},{"code":"hardware-model.bin","type":"codeVoice"},{"text":") is copied as-is","type":"text"},{"text":" ","type":"text"},{"text":"because it must match the macOS version installed on the","type":"text"},{"text":" ","type":"text"},{"text":"disk. The machine identifier (","type":"text"},{"type":"codeVoice","code":"machine-identifier.bin"},{"type":"text","text":") is"},{"type":"text","text":" "},{"text":"always regenerated — never copied.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/clonemanager"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"title":"Type Methods","anchor":"Type-Methods","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager\/clone(source:to:)"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CloneManager":{"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"title":"CloneManager","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CloneManager","kind":"symbol","url":"\/documentation\/spooktacularkit\/clonemanager","abstract":[{"type":"text","text":"Creates copy-on-write clones of virtual machine bundles."}],"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"type":"topic