{"sections":[],"metadata":{"modules":[{"name":"SpooktacularKit"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"CloneManager"}],"navigatorTitle":[{"kind":"identifier","text":"CloneManager"}],"title":"CloneManager","role":"symbol","symbolKind":"enum","roleHeading":"Enumeration","externalID":"s:15SpooktacularKit12CloneManagerO"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CloneManager"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CloneManager"},{"type":"text","text":" uses APFS "},{"type":"codeVoice","code":"clonefile(2)"},{"type":"text","text":" for the disk image,"},{"type":"text","text":" "},{"type":"text","text":"which creates an instant copy that shares physical blocks"},{"type":"text","text":" "},{"type":"text","text":"with the source. A 30 GB disk image clones in milliseconds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every clone receives a "},{"inlineContent":[{"type":"text","text":"new"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"VZMacMachineIdentifier"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"ensure each VM has a unique identity. Reusing identifiers"},{"type":"text","text":" "},{"type":"text","text":"across VMs causes undefined behavior in the Virtualization"},{"type":"text","text":" "},{"type":"text","text":"framework."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["let source = try VirtualMachineBundle.load(from: sourceURL)","let clone = try CloneManager.clone(source: source, to: destinationURL)","","\/\/ clone.spec == source.spec (p