{"seeAlsoSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/openclaw.ai"},{"type":"text","text":" is an open-source self-hosted AI assistant"},{"type":"text","text":" "},{"type":"text","text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw"},{"type":"text","text":" "},{"type":"text","text":"in macOS VMs with Spooktacular gives you:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Isolation"}],"type":"strong"},{"text":" — each instance has its own macOS environment, API keys,","type":"text"},{"text":" ","type":"text"},{"text":"and workspace. A misconfigured agent can’t affect the other.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"2 instances per Mac","type":"text"}]},{"type":"text","text":" — Apple Silicon’s 2-VM kernel limit maps"},{"type":"text","text":" "},{"type":"text","text":"perfectly to running a pair of agents (e.g., work + personal,"},{"type":"text","text":" "},{"type":"text","text":"or production + staging)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Kubernetes-managed","type":"text"}]},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"code":"MacOSVMPool","type":"codeVoice"},{"type":"text","text":"."}]}]}]},{"anchor":"Prerequisites","type":"heading","level":3,"text":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"macOS 14+ on the host"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular installed ("},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"API key from Anthropic, OpenAI, or Google"}]}]}]},{"anchor":"Quick-Start-Two-OpenClaw-Instances","type":"heading","level":2,"text":"Quick Start: Two OpenClaw Instances"},{"anchor":"1-Create-the-first-VM","type":"heading","text":"1. Create the first VM","level":3},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"anchor":"2-Clone-for-the-second-instance","type":"heading","text":"2. Clone for the second instance","level":3},{"syntax":"bash","type":"codeListing","code":["spook clone openclaw-work openclaw-personal"]},{"inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}],"type":"paragraph"},{"anchor":"3-Start-both","type":"heading","text":"3. Start both","level":3},{"syntax":"bash","type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"inlineContent":[{"type":"text","text":"Both VMs boot and run OpenClaw independently. Each listens"},{"type":"text","text":" "},{"type":"text","text":"on its own IP address, port 18789."}],"type":"paragraph"},{"anchor":"4-Check-status","type":"heading","text":"4. Check status","level":3},{"syntax":"bash","type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"anchor":"User-Data-Script-for-OpenClaw","type":"heading","text":"User-Data Script for OpenClaw","level":2},{"inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}],"type":"aside","name":"Note"},{"anchor":"Passing-API-Keys-Securely","type":"heading","text":"Passing API Keys Securely","level":3},{"inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"inlineContent":[{"type":"text","text":"In the setup script, copy the config from the shared folder:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"text":"Kubernetes: OpenClaw Fleet","level":2,"type":"heading","anchor":"Kubernetes-OpenClaw-Fleet"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy OpenClaw instances across multiple Macs using"},{"type":"text","text":" "},{"type":"text","text":"the Kubernetes operator:"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}]},{"text":"Networking Between Instances","level":2,"type":"heading","anchor":"Networking-Between-Instances"},{"type":"paragraph","inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-coordinator --from-ipsw latest --network host-only","spook create openclaw-worker --from-ipsw latest --network host-only"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Host-only networking lets the VMs talk to each other"},{"type":"text","text":" "},{"type":"text","text":"and to the host Mac, but not to the internet. The"},{"type":"text","text":" "},{"type":"text","text":"coordinator can reach the worker’s gateway at its"},{"type":"text","text":" "},{"type":"text","text":"host-only IP on port 18789."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For internet access + inter-VM communication, use"},{"type":"text","text":" "},{"type":"text","text":"NAT networking — both VMs can reach each other via"},{"type":"text","text":" "},{"type":"text","text":"their NAT-assigned IPs."}]},{"text":"Resource Planning","level":2,"type":"heading","anchor":"Resource-Planning"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"CPU"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Memory"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk"}]}],[{"type":"paragraph","inlineContent":[{"text":"Notes","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud models only","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Minimal — OpenClaw is lightweight","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Cloud + light local models"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Ollama with small models","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Heavy local models (Llama 3)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6 cores"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Needs unified memory","type":"text"}]}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}]},{"level":2,"anchor":"Monitoring","text":"Monitoring","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check OpenClaw health in each VM:"}]},{"code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"],"type":"codeListing","syntax":"bash"},{"level":2,"anchor":"Snapshots","text":"Snapshots","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a working OpenClaw configuration before making changes."},{"type":"text","text":" "},{"type":"text","text":"The VM must be stopped to take or restore a disk-level snapshot:"}]},{"code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"],"type":"codeListing","syntax":"bash"}]}],"metadata":{"title":"Running OpenClaw in Virtual Machines","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","interfaceLanguage":"swift"},"abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/openclawguide"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/