 user-data scripts for OpenClaw AI agent VMs."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OpenClawTemplate"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenClawTemplate"}],"title":"OpenClawTemplate","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"}}}