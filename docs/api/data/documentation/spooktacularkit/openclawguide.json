tifier"}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","url":"\/documentation\/spooktacularkit\/virtualmachinespecification","role":"symbol","navigatorTitle":[{"text":"VirtualMachineSpecification","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"title":"NetworkMode","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode","role":"symbol","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}]}}}