{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","generated":true}],"sections":[],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","interfaceLanguage":"swift"},"metadata":{"title":"Running OpenClaw in Virtual Machines","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"],"anchor":"Related"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/openclaw.ai"},{"type":"text","text":" is an open-source self-hosted AI assistant"},{"type":"text","text":" "},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"type":"text","text":" — each instance has its own macOS environment, API keys,"},{"type":"text","text":" "},{"type":"text","text":"and workspace. A misconfigured agent can’t affect the other."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"2 instances per Mac"}],"type":"strong"},{"text":" — Apple Silicon’s 2-VM kernel limit maps","type":"text"},{"text":" ","type":"text"},{"text":"perfectly to running a pair of agents (e.g., work + personal,","type":"text"},{"text":" ","type":"text"},{"text":"or production + staging).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Kubernetes-managed"}],"type":"strong"},{"text":" — scale OpenClaw instances across a fleet","type":"text"},{"text":" ","type":"text"},{"text":"of Macs using ","type":"text"},{"type":"codeVoice","code":"MacOSVMPool"},{"text":".","type":"text"}]}]}]},{"level":3,"text":"Prerequisites","type":"heading","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"macOS 14+ on the host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular installed ("},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}]}]}]},{"level":2,"text":"Quick Start: Two OpenClaw Instances","type":"heading","anchor":"Quick-Start-Two-OpenClaw-Instances"},{"level":3,"text":"1. Create the first VM","type":"heading","anchor":"1-Create-the-first-VM"},{"type":"codeListing","syntax":"bash","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"level":3,"text":"2. Clone for the second instance","type":"heading","anchor":"2-Clone-for-the-second-instance"},{"type":"codeListing","syntax":"bash","code":["spook clone openclaw-work openclaw-personal"]},{"inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}],"type":"paragraph"},{"level":3,"text":"3. Start both","type":"heading","anchor":"3-Start-both"},{"type":"codeListing","syntax":"bash","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"text":"on its own IP address, port 18789.","type":"text"}],"type":"paragraph"},{"level":3,"text":"4. Check status","type":"heading","anchor":"4-Check-status"},{"type":"codeListing","syntax":"bash","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"level":2,"text":"User-Data Script for OpenClaw","type":"heading","anchor":"User-Data-Script-for-OpenClaw"},{"inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}]},{"level":3,"text":"Passing API Keys Securely","type":"heading","anchor":"Passing-API-Keys-Securely"},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"embedding secrets in the script:"}]},{"type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"],"syntax":"bash"},{"inlineContent":[{"type":"text","text":"In the setup script, copy the config from the shared folder:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Deploy OpenClaw instances across multiple Macs using"},{"type":"text","text":" "},{"type":"text","text":"the Kubernetes operator:"}],"type":"paragraph"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}],"type":"paragraph"},{"text":"Networking Between Instances","anchor":"Networking-Between-Instances","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your OpenClaw instances need to communicate (e.g.,"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"]},{"type":"paragraph","inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"text":" ","type":"text"},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true,"type":"reference"},{"text":" if you need to prevent internet","type":"text"},{"type":"text","text":" "},{"type":"text","text":"access entirely, communicating through shared folders"},{"text":" ","type":"text"},{"type":"text","text":"and the VirtIO socket instead."}]},{"inlineContent":[{"type":"text","text":"For internet access + inter-VM communication, use"},{"type":"text","text":" "},{"type":"text","text":"NAT networking — both VMs can reach each other via"},{"type":"text","text":" "},{"type":"text","text":"their NAT-assigned IPs."}],"type":"paragraph"},{"text":"Resource Planning","anchor":"Resource-Planning","type":"heading","level":2},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"CPU"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Memory"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Disk"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notes"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Cloud models only"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}]}]],[[{"inlineContent":[{"text":"Cloud + light local models","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"8 GB"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"Ollama with small models","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"6 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"64 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Needs unified memory"}]}]]]},{"type":"paragraph","inlineContent":[{"text":"Since macOS VMs share the host’s unified memory via","type":"text"},{"type":"text","text":" "},{"text":"the Virtualization framework, the GPU (Metal) is","type":"text"},{"text":" ","type":"text"},{"text":"available inside the VM for local model inference.","type":"text"}]},{"level":2,"type":"heading","text":"Monitoring","anchor":"Monitoring"},{"type":"paragraph","inlineContent":[{"text":"Check OpenClaw health in each VM:","type":"text"}]},{"type":"codeListing","syntax":"bash","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"level":2,"anchor":"Snapshots","text":"Snapshots","type":"heading"},{"inlineContent":[{"type":"text","text":"Save a working OpenClaw configuration before making changes."},{"type":"text","text":" "},{"type":"text","text":"The VM must be stopped to take or restore a disk-level snapshot:"}],"type":"paragraph"},{"code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"],"syntax":"bash","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/openclawguide"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"https://openclaw.ai":{"titleInlineContent":[{"type":"text","text":"OpenClaw"}],"title":"OpenClaw","type":"link","url":"https:\/\/openclaw.ai","identifier":"https:\/\/openclaw.ai"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"role":"collectionGroup","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"title":"Kubernetes Integration","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"url":"\/documentation\/spooktacularkit\/openclawtemplate","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","type":"topic","abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"title":"OpenClawTemplate","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","kind":"article","abstract":[{"type":"text","text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows."}],"url":"\/documentation\/spooktacularkit\/bluebubblesguide","title":"Running BlueBubbles iMessage Server","type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"role":"collectionGroup","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"title":"Machine Learning Workloads","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","url":"\/documentation\/spooktacularkit\/mlworkloads","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"kind":"article","title":"Deploying on EC2 Mac","type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"role":"collectionGroup","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"title":"Configuring GitHub Actions Runners","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","url":"\/documentation\/spooktacularkit\/githubactionsguide","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"role":"collectionGroup","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"title":"Remote Desktop Access","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"role":"symbol","abstract":[{"type":"text",