ployment","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","title":"Deploying on EC2 Mac","role":"collectionGroup","type":"topic","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"role":"symbol","url":"\/documentation\/spooktacularkit\/openclawtemplate","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"title":"OpenClawTemplate","abstract":[{"type":"text","text":"Generates user-data scripts for OpenClaw AI agent VMs."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"url":"\/documentation\/spooktacularkit\/mlworkloads","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","role":"collectionGroup","type":"topic","kind":"article"}}}