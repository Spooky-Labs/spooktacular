":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","title":"Kubernetes Integration","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator.","type":"text"}],"role":"collectionGroup"}}}