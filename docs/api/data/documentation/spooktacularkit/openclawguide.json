 Spooktacular virtual machines.","type":"text"}],"kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"role":"symbol","type":"topic","title":"NetworkMode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","kind":"symbol","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"url":"\/documentation\/spooktacularkit\/networkmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"role":"collectionGroup","type":"topic","title":"Configuring GitHub Actions Runners","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","kind":"article","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"url":"\/documentation\/spooktacularkit\/githubactionsguide"},"https://openclaw.ai":{"type":"link","title":"OpenClaw","identifier":"https:\/\/openclaw.ai","titleInlineContent":[{"type":"text","text":"OpenClaw"}],"url":"https:\/\/openclaw.ai"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"role":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"title":"ProvisioningMode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"role":"collectionGroup","type":"topic","title":"Using the spook Command-Line Int