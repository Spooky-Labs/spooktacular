{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/openclaw.ai","type":"reference"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"text":" — each instance has its own macOS environment, API keys,","type":"text"},{"text":" ","type":"text"},{"text":"and workspace. A misconfigured agent can’t affect the other.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"2 instances per Mac","type":"text"}],"type":"strong"},{"text":" — Apple Silicon’s 2-VM kernel limit maps","type":"text"},{"text":" ","type":"text"},{"text":"perfectly to running a pair of agents (e.g., work + personal,","type":"text"},{"text":" ","type":"text"},{"text":"or production + staging).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working OpenClaw configuration, experiment,","type":"text"},{"text":" ","type":"text"},{"text":"and roll back if something breaks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Kubernetes-managed","type":"text"}],"type":"strong"},{"text":" — scale OpenClaw instances across a fleet","type":"text"},{"text":" ","type":"text"},{"text":"of Macs using ","type":"text"},{"type":"codeVoice","code":"MacOSVMPool"},{"text":".","type":"text"}]}]}]},{"text":"Prerequisites","type":"heading","level":3,"anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac (M1 or later)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"macOS 14+ on the host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Spooktacular installed (","type":"text"},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}]}]}]},{"text":"Quick Start: Two OpenClaw Instances","type":"heading","level":2,"anchor":"Quick-Start-Two-OpenClaw-Instances"},{"text":"1. Create the first VM","type":"heading","level":3,"anchor":"1-Create-the-first-VM"},{"type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"],"syntax":"bash"},{"text":"2. Clone for the second instance","type":"heading","level":3,"anchor":"2-Clone-for-the-second-instance"},{"type":"codeListing","code":["spook clone openclaw-work openclaw-personal"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}]},{"text":"3. Start both","type":"heading","level":3,"anchor":"3-Start-both"},{"type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"text":"on its own IP address, port 18789.","type":"text"}]},{"text":"4. Check status","type":"heading","level":3,"anchor":"4-Check-status"},{"type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"],"syntax":"bash"},{"text":"User-Data Script for OpenClaw","type":"heading","level":2,"anchor":"User-Data-Script-for-OpenClaw"},{"type":"paragraph","inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}]},{"type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""],"syntax":"bash"},{"content":[{"inlineContent":[{"text":"For production deployments, pass the API key via","type":"text"},{"text":" ","type":"text"},{"text":"a shared folder or environment variable rather than","type":"text"},{"text":" ","type":"text"},{"text":"hardcoding it in the script.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"text":"Passing API Keys Securely","type":"heading","level":3,"anchor":"Passing-API-Keys-Securely"},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}]},{"syntax":"bash","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"],"type":"codeListing"},{"inlineContent":[{"text":"In the setup script, copy the config from the shared folder:","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"],"type":"codeListing"},{"level":2,"anchor":"Kubernetes-OpenClaw-Fleet","text":"Kubernetes: OpenClaw Fleet","type":"heading"},{"inlineContent":[{"text":"Deploy OpenClaw instances across multiple Macs using","type":"text"},{"text":" ","type":"text"},{"text":"the Kubernetes operator:","type":"text"}],"type":"paragraph"},{"syntax":"yaml","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"],"type":"codeListing"},{"inlineContent":[{"text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs =","type":"text"},{"text":" ","type":"text"},{"text":"20 OpenClaw instances.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Networking-Between-Instances","text":"Networking Between Instances","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}]},{"code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"text":" ","type":"text"},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","type":"reference"},{"text":" if you need to prevent internet","type":"text"},{"text":" ","type":"text"},{"text":"access entirely, communicating through shared folders","type":"text"},{"text":" ","type":"text"},{"text":"and the VirtIO socket instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For internet access + inter-VM communication, use","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking — both VMs can reach each other via","type":"text"},{"text":" ","type":"text"},{"text":"their NAT-assigned IPs.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Resource Planning","type":"heading","anchor":"Resource-Planning"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Setup","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"CPU","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Memory","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Disk","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Notes","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud models only","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Minimal — OpenClaw is lightweight","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud + light local models","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Ollama with small models","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Heavy local models (Llama 3)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Needs unified memory","type":"text"}]}]]],"type":"table"},{"inlineContent":[{"text":"Since macOS VMs share the host’s unified memory via","type":"text"},{"text":" ","type":"text"},{"text":"the Virtualization framework, the GPU (Metal) is","type":"text"},{"text":" ","type":"text"},{"text":"available inside the VM for local model inference.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Monitoring","type":"heading","anchor":"Monitoring"},{"inlineContent":[{"text":"Check OpenClaw health in each VM:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"level":2,"text":"Snapshots","type":"heading","anchor":"Snapshots"},{"inlineContent":[{"text":"Save a working OpenClaw configuration before making changes.","type":"text"},{"text":" ","type":"text"},{"text":"The VM must be stopped to take or restore a disk-level snapshot:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}]}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"anchor":"Guides","generated":true}],"metadata":{"title":"Running OpenClaw in Virtual Machines","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection","role":"collectionGroup"},"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentatio