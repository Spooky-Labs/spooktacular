"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","role":"collectionGroup","title":"Getting Started with Spooktacular","abstract":[{"type":"text","text":"Create your first macOS virtual machine in minutes."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"url":"\/documentation\/spooktacularkit\/sharedfolder","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"title":"SharedFolder","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","role":"collectionGroup","title":"Kubernetes Integration","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article"},"https://openclaw.ai":{"url":"https:\/\/openclaw.ai","identifier":"https:\/\/openclaw.ai","title":"OpenClaw","titleInlineContent":[{"text":"OpenClaw","type":"text"}],"type":"link"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","kind":"symbol","type":"topic","role":"collection","title":"SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/G