e":"SpooktacularKit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","kind":"symbol","url":"\/documentation\/spooktacularkit","role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"title":"VirtualMachineSpecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VirtualMachineSpecification","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VirtualMachineSpecification"}]}}}