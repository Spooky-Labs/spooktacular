{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/openclawguide"]}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"title":"Running OpenClaw in Virtual Machines"},"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/openclaw.ai","isActive":true,"type":"reference"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"text":" — each instance has its own macOS environment, API keys,","type":"text"},{"text":" ","type":"text"},{"text":"and workspace. A misconfigured agent can’t affect the other.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"2 instances per Mac","type":"text"}],"type":"strong"},{"text":" — Apple Silicon’s 2-VM kernel limit maps","type":"text"},{"text":" ","type":"text"},{"text":"perfectly to running a pair of agents (e.g., work + personal,","type":"text"},{"text":" ","type":"text"},{"text":"or production + staging).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working OpenClaw configuration, experiment,","type":"text"},{"text":" ","type":"text"},{"text":"and roll back if something breaks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Kubernetes-managed","type":"text"}],"type":"strong"},{"text":" — scale OpenClaw instances across a fleet","type":"text"},{"text":" ","type":"text"},{"text":"of Macs using ","type":"text"},{"type":"codeVoice","code":"MacOSVMPool"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Prerequisites","level":3,"type":"heading","text":"Prerequisites"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac (M1 or later)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"macOS 14+ on the host","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Spooktacular installed (","type":"text"},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Quick-Start-Two-OpenClaw-Instances","level":2,"type":"heading","text":"Quick Start: Two OpenClaw Instances"},{"anchor":"1-Create-the-first-VM","level":3,"type":"heading","text":"1. Create the first VM"},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"anchor":"2-Clone-for-the-second-instance","level":3,"type":"heading","text":"2. Clone for the second instance"},{"syntax":"bash","type":"codeListing","code":["spook clone openclaw-work openclaw-personal"]},{"type":"paragraph","inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}]},{"anchor":"3-Start-both","level":3,"type":"heading","text":"3. Start both"},{"syntax":"bash","type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"type":"paragraph","inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"text":"on its own IP address, port 18789.","type":"text"}]},{"anchor":"4-Check-status","level":3,"type":"heading","text":"4. Check status"},{"syntax":"bash","type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"anchor":"User-Data-Script-for-OpenClaw","level":2,"type":"heading","text":"User-Data Script for OpenClaw"},{"type":"paragraph","inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}],"style":"note","name":"Note"},{"anchor":"Passing-API-Keys-Securely","level":3,"type":"heading","text":"Passing API Keys Securely"},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"type":"paragraph","inlineContent":[{"text":"In the setup script, copy the config from the shared folder:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"anchor":"Kubernetes-OpenClaw-Fleet","level":2,"type":"heading","text":"Kubernetes: OpenClaw Fleet"},{"type":"paragraph","inlineContent":[{"text":"Deploy OpenClaw instances across multiple Macs using","type":"text"},{"text":" ","type":"text"},{"text":"the Kubernetes operator:","type":"text"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"type":"paragraph","inlineContent":[{"text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs =","type":"text"},{"text":" ","type":"text"},{"text":"20 OpenClaw instances.","type":"text"}]},{"type":"heading","text":"Networking Between Instances","level":2,"anchor":"Networking-Between-Instances"},{"inlineContent":[{"type":"text","text":"If your OpenClaw instances need to communicate (e.g.,"},{"type":"text","text":" "},{"type":"text","text":"a coordinator agent delegating to worker agents):"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"]},{"inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"type":"text","text":" "},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"type":"text","text":" "},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" if you need to prevent internet"},{"text":" ","type":"text"},{"type":"text","text":"access entirely, communicating through shared folders"},{"text":" ","type":"text"},{"text":"and the VirtIO socket instead.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For internet access + inter-VM communication, use","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking — both VMs can reach each other via","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"their NAT-assigned IPs."}]},{"anchor":"Resource-Planning","level":2,"type":"heading","text":"Resource Planning"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"CPU"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Memory"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Notes"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloud models only"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"inlineContent":[{"text":"4 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloud + light local models"}]}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"8 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Ollama with small models"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6 cores"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"64 GB"}]}],[{"inlineContent":[{"type":"text","text":"Needs unified memory"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"text":" ","type":"text"},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}]},{"type":"heading","text":"Monitoring","level":2,"anchor":"Monitoring"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check OpenClaw health in each VM:"}]},{"type":"codeListing","syntax":"bash","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"type":"heading","text":"Snapshots","level":2,"anchor":"Snapshots"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a working OpenClaw configuration before making changes."},{"type":"text","text":" "},{"type":"text","text":"The VM must be stopped to take or restore a disk-level snapshot:"}]},{"type":"codeListing","syntax":"bash","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}],"kind":"content"}],"seeAlsoSections":[{"anchor":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides"}],"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc: