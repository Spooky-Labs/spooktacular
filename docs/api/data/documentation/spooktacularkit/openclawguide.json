 terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"type":"topic"},"https://openclaw.ai":{"url":"https:\/\/openclaw.ai","type":"link","identifier":"https:\/\/openclaw.ai","titleInlineContent":[{"type":"text","text":"OpenClaw"}],"title":"OpenClaw"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","kind":"symbol","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"role":"collectionGroup","title":"Kubernetes Integration","url":"\/documentation\/spooktacularkit\/kubernetesguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","kind":"article","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"role":"collectionGroup","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"title":"ProvisioningMode","url":"\/documentation\/spooktacularkit\/provisioningmode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","kind":"symbol","abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ProvisioningMode"}],"type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SharedFolder"}],"role":"symbol","navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/sharedfolder","title":"SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}]}}}