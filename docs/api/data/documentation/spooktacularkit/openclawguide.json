/documentation/SpooktacularKit/GettingStarted":{"title":"Getting Started with Spooktacular","kind":"article","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator."}],"url":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","kind":"article","title":"Kubernetes Integration","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenClawTemplate"}],"kind":"symbol","abstract":[{"type":"text","text":"Generates user-data scripts for OpenClaw AI agent VMs."}],"title":"OpenClawTemplate","url":"\/documentation\/spooktacularkit\/openclawtemplate","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","navigatorTitle":[{"kind":"identifier","text":"OpenClawTemplate"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/isolated":{"type":"topic","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","abstract":[{"text":"No network connectivity.","type":"text"}],"role":"symbol","title":"NetworkMode.isolated","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isolated","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/networkmode\/isolated"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"role":"collection","kind":"symbol","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit","type":"topic","url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"title":"ProvisioningMode","kind":"symbol","type":"topic","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"url":"\/documentation\/spooktacularkit\/provisioningmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"title":"Configuring GitHub Actions Runners","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","role":"collectionGroup","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}],"url":"\/documentation\/spooktacularkit\/githubactionsguide"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","type":"topic","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","role":"collectionGroup","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"url":"\/documentation\/spooktacularkit\/clireference"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"type":"topic","ki