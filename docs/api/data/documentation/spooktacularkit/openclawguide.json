{"kind":"article","hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"topicSections":[{"title":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"],"anchor":"Related"}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"role":"collectionGroup","title":"Running OpenClaw in Virtual Machines","modules":[{"name":"SpooktacularKit"}],"roleHeading":"API Collection"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"identifier":"https:\/\/openclaw.ai","isActive":true,"type":"reference"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in macOS VMs with Spooktacular gives you:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"text":" — each instance has its own macOS environment, API keys,","type":"text"},{"text":" ","type":"text"},{"text":"and workspace. A misconfigured agent can’t affect the other.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"2 instances per Mac","type":"text"}]},{"text":" — Apple Silicon’s 2-VM kernel limit maps","type":"text"},{"text":" ","type":"text"},{"text":"perfectly to running a pair of agents (e.g., work + personal,","type":"text"},{"type":"text","text":" "},{"text":"or production + staging).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"text":" — save a working OpenClaw configuration, experiment,","type":"text"},{"text":" ","type":"text"},{"text":"and roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Kubernetes-managed","type":"text"}],"type":"strong"},{"text":" — scale OpenClaw instances across a fleet","type":"text"},{"text":" ","type":"text"},{"text":"of Macs using ","type":"text"},{"code":"MacOSVMPool","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Prerequisites","type":"heading","level":3,"text":"Prerequisites"},{"items":[{"content":[{"inlineContent":[{"text":"Apple Silicon Mac (M1 or later)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"macOS 14+ on the host","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Spooktacular installed (","type":"text"},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Quick-Start-Two-OpenClaw-Instances","type":"heading","level":2,"text":"Quick Start: Two OpenClaw Instances"},{"type":"heading","anchor":"1-Create-the-first-VM","level":3,"text":"1. Create the first VM"},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"type":"heading","anchor":"2-Clone-for-the-second-instance","level":3,"text":"2. Clone for the second instance"},{"syntax":"bash","type":"codeListing","code":["spook clone openclaw-work openclaw-personal"]},{"inlineContent":[{"type":"text","text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a"},{"type":"text","text":" "},{"type":"text","text":"unique machine identifier automatically."}],"type":"paragraph"},{"text":"3. Start both","type":"heading","anchor":"3-Start-both","level":3},{"syntax":"bash","type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on its own IP address, port 18789."}],"type":"paragraph"},{"type":"heading","anchor":"4-Check-status","level":3,"text":"4. Check status"},{"code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"],"type":"codeListing","syntax":"bash"},{"type":"heading","anchor":"User-Data-Script-for-OpenClaw","level":2,"text":"User-Data Script for OpenClaw"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a script that installs and configures OpenClaw automatically:"}]},{"type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""],"syntax":"bash"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}]}]},{"anchor":"Passing-API-Keys-Securely","type":"heading","level":3,"text":"Passing API Keys Securely"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a shared folder to deliver configuration without"},{"type":"text","text":" "},{"type":"text","text":"embedding secrets in the script:"}]},{"type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the setup script, copy the config from the shared folder:"}]},{"type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"],"syntax":"bash"},{"anchor":"Kubernetes-OpenClaw-Fleet","type":"heading","level":2,"text":"Kubernetes: OpenClaw Fleet"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy OpenClaw instances across multiple Macs using"},{"type":"text","text":" "},{"type":"text","text":"the Kubernetes operator:"}]},{"type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}]},{"anchor":"Networking-Between-Instances","type":"heading","level":2,"text":"Networking Between Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your OpenClaw instances need to communicate (e.g.,"},{"type":"text","text":" "},{"type":"text","text":"a coordinator agent delegating to worker agents):"}]},{"type":"codeListing","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"],"syntax":"bash"},{"type":"paragraph","inlineContent":[{"type":"text","text":"NAT networking lets the VMs reach each other via their"},{"type":"text","text":" "},{"type":"text","text":"DHCP-assigned IPs and the host Mac. The coordinator can"},{"type":"text","text":" "},{"type":"text","text":"reach the worker’s gateway on port 18789. Use"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" if you need to prevent internet"},{"type":"text","text":" "},{"type":"text","text":"access entirely, communicating through shared folders"},{"type":"text","text":" "},{"type":"text","text":"and the VirtIO socket instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For internet access + inter-VM communication, use"},{"type":"text","text":" "},{"type":"text","text":"NAT networking — both VMs can reach each other via"},{"type":"text","text":" "},{"type":"text","text":"their NAT-assigned IPs."}]},{"anchor":"Resource-Planning","type":"heading","level":2,"text":"Resource Planning"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Setup"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"CPU"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Memory"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Notes"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloud models only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloud + light local models"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"8 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ollama with small models"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"6 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"16 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"64 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Needs unified memory"}]}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}]},{"anchor":"Monitoring","type":"heading","level":2,"text":"Monitoring"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check OpenClaw health in each VM:"}]},{"type":"codeListing","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"],"syntax":"bash"},{"anchor":"Snapshots","type":"heading","level":2,"text":"Snapshots"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a working OpenClaw configuration before making changes."},{"type":"text","text":" "},{"type":"text","text":"The VM must be stopped to take or restore a disk-level snapshot:"}]},{"type":"codeListing","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"],"syntax":"bash"}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic","title":"Kubernetes Integration","kind":"article","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","type":"topic","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic","title":"Using the spook Command-Line Interface","kind":"article","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"title":"NetworkMode","kind":"symbol","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"url":"\/documentation\/spooktacularkit\/networkmode"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"url":"\/documentation\/spooktacularkit\/githubactionsguide","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","type":"topic","title":"Configuring GitHub Actions Runners","kind":"article","abstract":[{"type":"text","text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"topic","title":"Deploying on EC2 Mac","kind":"article","abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"kind":"symbol","title":"SharedFolder","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"url":"\/documentation\/spooktacularkit\/sharedfolder"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"text":"Create and manage macOS virtual machines 