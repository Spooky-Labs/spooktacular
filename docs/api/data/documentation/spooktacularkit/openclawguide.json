"\/documentation\/spooktacularkit\/sharedfolder","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"title":"SharedFolder","role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"kind":"symbol","url":"\/documentation\/spooktacularkit\/networkmode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NetworkMode","kind":"identifier"}],"type":"topic","role":"symbol","title":"NetworkMode","navigatorTitle":[{"text":"NetworkMode","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide","type":"topic","role":"collectionGroup","title":"Running BlueBubbles iMessage Server"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}],"kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads","type":"topic","role":"collectionGroup","title":"Machine Learning Workloads"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"kind":"article","url":"\/doc