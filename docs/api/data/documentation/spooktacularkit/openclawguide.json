e":[{"text":"NetworkMode","kind":"identifier"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"title":"SharedFolder","abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"role":"symbol","url":"\/documentation\/spooktacularkit\/sharedfolder","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"type":"text","text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity."}],"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/ec2macdeployment","title":"Deploying on EC2 Mac","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","title":"SpooktacularKit","type":"topic","role":"collection","url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]}}}