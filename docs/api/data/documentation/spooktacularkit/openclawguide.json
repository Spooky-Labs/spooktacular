{"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"]}],"kind":"article","variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/openclaw.ai"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"type":"text","text":" — each instance has its own macOS environment, API keys,"},{"type":"text","text":" "},{"type":"text","text":"and workspace. A misconfigured agent can’t affect the other."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"2 instances per Mac"}]},{"type":"text","text":" — Apple Silicon’s 2-VM kernel limit maps"},{"type":"text","text":" "},{"type":"text","text":"perfectly to running a pair of agents (e.g., work + personal,"},{"type":"text","text":" "},{"type":"text","text":"or production + staging)."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Kubernetes-managed"}],"type":"strong"},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"type":"codeVoice","code":"MacOSVMPool"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple Silicon Mac (M1 or later)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"macOS 14+ on the host"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Spooktacular installed ("},{"code":"brew install --cask spooktacular","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"API key from Anthropic, OpenAI, or Google"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Quick Start: Two OpenClaw Instances","anchor":"Quick-Start-Two-OpenClaw-Instances"},{"level":3,"type":"heading","text":"1. Create the first VM","anchor":"1-Create-the-first-VM"},{"code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"],"type":"codeListing","syntax":"bash"},{"level":3,"type":"heading","text":"2. Clone for the second instance","anchor":"2-Clone-for-the-second-instance"},{"code":["spook clone openclaw-work openclaw-personal"],"type":"codeListing","syntax":"bash"},{"type":"paragraph","inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}]},{"level":3,"type":"heading","text":"3. Start both","anchor":"3-Start-both"},{"code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"],"type":"codeListing","syntax":"bash"},{"inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"text":"on its own IP address, port 18789.","type":"text"}],"type":"paragraph"},{"text":"4. Check status","anchor":"4-Check-status","type":"heading","level":3},{"syntax":"bash","type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"text":"User-Data Script for OpenClaw","anchor":"User-Data-Script-for-OpenClaw","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}]},{"text":"Passing API Keys Securely","anchor":"Passing-API-Keys-Securely","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"type":"paragraph","inlineContent":[{"text":"In the setup script, copy the config from the shared folder:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy OpenClaw instances across multiple Macs using"},{"type":"text","text":" "},{"type":"text","text":"the Kubernetes operator:"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}]},{"text":"Networking Between Instances","anchor":"Networking-Between-Instances","type":"heading","level":2},{"inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}],"type":"paragraph"},{"syntax":"bash","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"text":" ","type":"text"},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","isActive":true},{"text":" if you need to prevent internet","type":"text"},{"text":" ","type":"text"},{"text":"access entirely, communicating through shared folders","type":"text"},{"text":" ","type":"text"},{"text":"and the VirtIO socket instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For internet access + inter-VM communication, use","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking — both VMs can reach each other via","type":"text"},{"text":" ","type":"text"},{"text":"their NAT-assigned IPs.","type":"text"}]},{"type":"heading","level":2,"text":"Resource Planning","anchor":"Resource-Planning"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"text":"CPU","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Memory","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Disk","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Notes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Cloud models only","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Minimal — OpenClaw is lightweight","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud + light local models","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"8 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"32 GB"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ollama with small models"}]}]],[[{"inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"6 cores","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16 GB","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Needs unified memory"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"text":"the Virtualization framework, the GPU (Metal) is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"available inside the VM for local model inference."}],"type":"paragraph"},{"text":"Monitoring","anchor":"Monitoring","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check OpenClaw health in each VM:"}]},{"type":"codeListing","syntax":"bash","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"type":"heading","text":"Snapshots","anchor":"Snapshots","level":2},{"inlineContent":[{"text":"Save a working OpenClaw configuration before making changes.","type":"text"},{"text":" ","type":"text"},{"text":"The VM must be stopped to take or restore a disk-level snapshot:","type":"text"}],"type":"paragraph"},{"code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"],"syntax":"bash","type":"codeListing"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"metadata":{"roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup","title":"Running OpenClaw in Virtual Machines"},"seeAlsoSections":[{"anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true,"title":"Guides"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"type":"text","text":"The strategy for executing a user-data script on a VM."}],"title":"ProvisioningMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"role":"symbol","kind":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"title":"Kubernetes Integration","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/kubernetesguide","kind":"article","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"title":"Deploying on EC2 Mac","role":"collectionGroup","kind":"article","url":"\/documentation\/spooktacularkit\/ec2macdeployment","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment"},"doc://Spooktacula