ed","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"title":"Getting Started with Spooktacular"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","type":"topic","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"title":"Deploying on EC2 Mac"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"title":"VirtualMachineSpecification","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","role":"symbol","navigatorTitle":[{"text":"VirtualMachineSpecification","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"url":"\/documentation\/spooktacularkit\/virtualmachinespecification","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"title":"OpenClawTemplate","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OpenClawTemplate"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenClawTemplate"}],"url":"\/documentation\/spooktacularkit\/openclawtemplate","abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}],"kind":"symbol","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","type":"topic","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"title":"Versioning & Release Schedule"}}}