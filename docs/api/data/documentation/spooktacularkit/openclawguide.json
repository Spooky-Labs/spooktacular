","kind":"identifier"}],"abstract":[{"text":"The hardware specification for a virtual machine.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VirtualMachineSpecification","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"title":"OpenClawTemplate","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/openclawtemplate","abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"}}}