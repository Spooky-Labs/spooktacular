acularKit\/GettingStarted","title":"Getting Started with Spooktacular","kind":"article","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"role":"collectionGroup","url":"\/documentation\/spooktacularkit\/gettingstarted"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","kind":"symbol","title":"SharedFolder","type":"topic","navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}],"abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"role":"symbol","url":"\/documentation\/spooktacularkit\/sharedfolder"}}}