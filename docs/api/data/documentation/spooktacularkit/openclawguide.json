ategy for executing a user-data script on a VM.","type":"text"}],"url":"\/documentation\/spooktacularkit\/provisioningmode","title":"ProvisioningMode","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"abstract":[{"type":"text","text":"Understand what version numbers mean and what to expect from each release."}],"type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/spooktacularkit\/versioning","title":"Versioning & Release Schedule","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}],"url":"\/documentation\/spooktacularkit\/sharedfolder","title":"SharedFolder","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"url":"\/documentation\/spooktacularkit\/networkmode","title":"NetworkMode","kind":"symbol"},"do