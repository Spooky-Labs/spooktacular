 Mac","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"kind":"article","url":"\/documentation\/spooktacularkit\/bluebubblesguide","type":"topic","title":"Running BlueBubbles iMessage Server","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"kind":"symbol","url":"\/documentation\/spooktacularkit\/provisioningmode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"type":"topic","title":"ProvisioningMode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","role":"symbol"},"https://openclaw.ai":{"titleInlineContent":[{"text":"OpenClaw","type":"text"}],"identifier":"https:\/\/openclaw.ai","title":"OpenClaw","url":"https:\/\/openclaw.ai","type":"link"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"kind":"symbol","url":"\/documentation\/spooktacularkit\/sharedfolder","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"type":"topic","title":"SharedFolder","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}],"abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\