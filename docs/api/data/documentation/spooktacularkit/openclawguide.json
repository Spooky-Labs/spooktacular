{"kind":"article","identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"seeAlsoSections":[{"anchor":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides"}],"topicSections":[{"anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"],"title":"Related"}],"variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"title":"Running OpenClaw in Virtual Machines"},"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/openclaw.ai"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"type":"text","text":" — each instance has its own macOS environment, API keys,"},{"type":"text","text":" "},{"type":"text","text":"and workspace. A misconfigured agent can’t affect the other."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"2 instances per Mac","type":"text"}],"type":"strong"},{"type":"text","text":" — Apple Silicon’s 2-VM kernel limit maps"},{"type":"text","text":" "},{"type":"text","text":"perfectly to running a pair of agents (e.g., work + personal,"},{"type":"text","text":" "},{"type":"text","text":"or production + staging)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Snapshots","type":"text"}],"type":"strong"},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Kubernetes-managed","type":"text"}],"type":"strong"},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"type":"codeVoice","code":"MacOSVMPool"},{"type":"text","text":"."}]}]}]},{"level":3,"type":"heading","text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS 14+ on the host"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Spooktacular installed ("},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"API key from Anthropic, OpenAI, or Google"}]}]}]},{"level":2,"type":"heading","text":"Quick Start: Two OpenClaw Instances","anchor":"Quick-Start-Two-OpenClaw-Instances"},{"level":3,"type":"heading","text":"1. Create the first VM","anchor":"1-Create-the-first-VM"},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"level":3,"type":"heading","text":"2. Clone for the second instance","anchor":"2-Clone-for-the-second-instance"},{"syntax":"bash","type":"codeListing","code":["spook clone openclaw-work openclaw-personal"]},{"type":"paragraph","inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}]},{"level":3,"type":"heading","text":"3. Start both","anchor":"3-Start-both"},{"syntax":"bash","type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"type":"paragraph","inlineContent":[{"text":"Both VMs boot and run OpenClaw independently. Each listens","type":"text"},{"text":" ","type":"text"},{"text":"on its own IP address, port 18789.","type":"text"}]},{"level":3,"type":"heading","text":"4. Check status","anchor":"4-Check-status"},{"syntax":"bash","type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"level":2,"type":"heading","text":"User-Data Script for OpenClaw","anchor":"User-Data-Script-for-OpenClaw"},{"type":"paragraph","inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"level":3,"type":"heading","text":"Passing API Keys Securely","anchor":"Passing-API-Keys-Securely"},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"type":"paragraph","inlineContent":[{"text":"In the setup script, copy the config from the shared folder:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"level":2,"type":"heading","text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet"},{"type":"paragraph","inlineContent":[{"text":"Deploy OpenClaw instances across multiple Macs using","type":"text"},{"text":" ","type":"text"},{"text":"the Kubernetes operator:","type":"text"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"type":"paragraph","inlineContent":[{"text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs =","type":"text"},{"text":" ","type":"text"},{"text":"20 OpenClaw instances.","type":"text"}]},{"level":2,"type":"heading","text":"Networking Between Instances","anchor":"Networking-Between-Instances"},{"type":"paragraph","inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"]},{"type":"paragraph","inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"text":" ","type":"text"},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"text":" if you need to prevent internet","type":"text"},{"text":" ","type":"text"},{"text":"access entirely, communicating through shared folders","type":"text"},{"text":" ","type":"text"},{"text":"and the VirtIO socket instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For internet access + inter-VM communication, use","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking — both VMs can reach each other via","type":"text"},{"text":" ","type":"text"},{"text":"their NAT-assigned IPs.","type":"text"}]},{"level":2,"type":"heading","text":"Resource Planning","anchor":"Resource-Planning"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"CPU"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Memory"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Disk"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notes"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Cloud models only"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Cloud + light local models"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"8 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Ollama with small models"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"6 cores"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"64 GB"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Needs unified memory"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"Since macOS VMs share the host’s unified memory via","type":"text"},{"text":" ","type":"text"},{"text":"the Virtualization framework, the GPU (Metal) is","type":"text"},{"text":" ","type":"text"},{"text":"available inside the VM for local model inference.","type":"text"}]},{"level":2,"type":"heading","text":"Monitoring","anchor":"Monitoring"},{"type":"paragraph","inlineContent":[{"text":"Check OpenClaw health in each VM:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"level":2,"type":"heading","text":"Snapshots","anchor":"Snapshots"},{"type":"paragraph","inlineContent":[{"text":"Save a working OpenClaw configuration before making changes.","type":"text"},{"text":" ","type":"text"},{"text":"The VM must be stopped to take or restore a disk-level snapshot:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"url":"\/documentation\/spooktacularkit\/clireference","title":"Using the spook Command-Line Interface","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","type":"topic","kind":"article","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"type":"codeVoice","code":"spook"},{"text":" CLI.","type":"text"}],"role":"collectionGroup"},"https://openclaw.ai":{"identifier":"https:\/\/openclaw.ai","type":"link","titleInlineContent":[{"type":"text","text":"OpenClaw"}],"url":"https:\/\/openclaw.ai","title":"OpenClaw"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"url":"\/documentation\/spooktacularkit\/versioning","type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","title":"Versioning & Release Schedule"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"url":"\/documentation\/spooktacularkit\/kubernetesguide","type":"topic","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","abstract":[{"type":"text","text":"Manage macOS virtual machines as Kubernetes resources using the MacOSVM custom resource definition."}],"ki