it\/openclawtemplate","kind":"symbol","abstract":[{"type":"text","text":"Generates user-data scripts for OpenClaw AI agent VMs."}],"role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"url":"\/documentation\/spooktacularkit","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}],"title":"SpooktacularKit","kind":"symbol","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/JenkinsGuide":{"url":"\/documentation\/spooktacularkit\/jenkinsguide","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/JenkinsGuide","role":"collectionGroup","abstract":[{"type":"text","text":"Run Jenkins build agents in Spooktacular VMs for iOS and macOS CI\/CD."}],"title":"Configuring Jenkins Nodes","kind":"article","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"abstract":[{"type":"text","text":"A directory shared between the host and the virtual machine."}],"url":"\/documentation\/spooktacularkit\/sharedfolder","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SharedFolder"}],"title":"SharedFolder","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","type":"topic","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}]},"https://openclaw.ai":{"titleInlineContent":[{"text":"OpenClaw","type":"text"}],"url":"https:\/\/openclaw.ai","identifier":"https:\/\/openclaw.ai","type":"link","title":"OpenClaw"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"url":"