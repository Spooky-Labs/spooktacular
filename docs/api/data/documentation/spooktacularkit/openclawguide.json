ktacularKit/documentation/SpooktacularKit/SharedFolder":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}],"abstract":[{"text":"A directory shared between the host and the virtual machine.","type":"text"}],"title":"SharedFolder","url":"\/documentation\/spooktacularkit\/sharedfolder","type":"topic","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","type":"topic","title":"Deploying on EC2 Mac","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","type":"topic","title":"Running BlueBubbles iMessage Server","url":"\/documentation\/spooktacularkit\/bluebubblesguide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","type":"topic","title":"Kubernetes Integration","url":"\/documentation\/spooktacularkit\/kubernetesguide","abstract":[{"text":"Manage macOS virtual machines as Kubernetes resources with custom CRDs and an operator.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"url":"\/documentation\/spooktacularkit\/networkmode","type":"topic","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","type":"topic","url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}]},"https://openclaw.ai":{"title":"OpenClaw","type":"link","url":"https:\/\/openclaw.ai","identifier":"https:\/\/openclaw.ai","titleInlineContent":[{"text":"OpenClaw","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit":{"kind":"symbol","role":"collection","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","type":"topic","url":"\/documentation\/spooktacularkit","title":"SpooktacularKit","abstract":[{"text":"Create and manage macOS virtual machines on Apple Silicon.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","type":"topic","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"type":"topic","url":"\/documentation\/spooktacularkit\/provisioningmode","title":"ProvisioningMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/isolated":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"isolated"}],"title":"NetworkMode.isolated","abstract":[{"text":"No network connectivity.","type":"text"}],"url":"\/documentation\/spooktacularkit\/networkmode\/isolated","type":"topic","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"type":"topic","title":"OpenClawTemplate","url":"\/documentation\/spooktacularkit\/openclawtemplate","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","type":"topic","title":"Machine Learning Workloads","url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines.","type":"text"}]}}}