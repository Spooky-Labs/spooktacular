t\/sharedfolder","title":"SharedFolder","kind":"symbol","type":"topic","abstract":[{"text":"A directory shared between the host and the virtual machine.","type":"text"}]},"https://openclaw.ai":{"title":"OpenClaw","type":"link","titleInlineContent":[{"text":"OpenClaw","type":"text"}],"url":"https:\/\/openclaw.ai","identifier":"https:\/\/openclaw.ai"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"url":"\/documentation\/spooktacularkit\/provisioningmode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"title":"ProvisioningMode","type":"topic","navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"role":"symbol","kind":"symbol","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","role":"collectionGroup","title":"Getting Started with Spooktacular","url":"\/documentation\/spooktacularkit\/gettingstarted","kind":"article","type":"topic","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","role":"collectionGroup","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article","type":"topic","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"title":"OpenClawTemplate","url":"\/documentation\/spooktacularkit\/openclawtemplate","kind":"symbol","type":"topic","abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}]}}}