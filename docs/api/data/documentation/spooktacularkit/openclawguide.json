{"seeAlsoSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"generated":true}],"identifier":{"url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"],"anchor":"Related","title":"Related"}],"abstract":[{"text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/openclaw.ai"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Isolation","type":"text"}],"type":"strong"},{"text":" — each instance has its own macOS environment, API keys,","type":"text"},{"text":" ","type":"text"},{"text":"and workspace. A misconfigured agent can’t affect the other.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"2 instances per Mac"}],"type":"strong"},{"text":" — Apple Silicon’s 2-VM kernel limit maps","type":"text"},{"text":" ","type":"text"},{"text":"perfectly to running a pair of agents (e.g., work + personal,","type":"text"},{"text":" ","type":"text"},{"text":"or production + staging).","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Snapshots"}],"type":"strong"},{"text":" — save a working OpenClaw configuration, experiment,","type":"text"},{"text":" ","type":"text"},{"text":"and roll back if something breaks.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Kubernetes-managed","type":"text"}]},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"type":"codeVoice","code":"MacOSVMPool"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"text":"Prerequisites","anchor":"Prerequisites","level":3,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"macOS 14+ on the host"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Spooktacular installed (","type":"text"},{"code":"brew install --cask spooktacular","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Quick-Start-Two-OpenClaw-Instances","level":2,"text":"Quick Start: Two OpenClaw Instances","type":"heading"},{"anchor":"1-Create-the-first-VM","level":3,"text":"1. Create the first VM","type":"heading"},{"code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"],"syntax":"bash","type":"codeListing"},{"anchor":"2-Clone-for-the-second-instance","level":3,"text":"2. Clone for the second instance","type":"heading"},{"code":["spook clone openclaw-work openclaw-personal"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a"},{"type":"text","text":" "},{"type":"text","text":"unique machine identifier automatically."}],"type":"paragraph"},{"anchor":"3-Start-both","level":3,"text":"3. Start both","type":"heading"},{"code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Both VMs boot and run OpenClaw independently. Each listens"},{"type":"text","text":" "},{"type":"text","text":"on its own IP address, port 18789."}],"type":"paragraph"},{"anchor":"4-Check-status","level":3,"text":"4. Check status","type":"heading"},{"code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"],"syntax":"bash","type":"codeListing"},{"anchor":"User-Data-Script-for-OpenClaw","level":2,"text":"User-Data Script for OpenClaw","type":"heading"},{"inlineContent":[{"text":"Create a script that installs and configures OpenClaw automatically:","type":"text"}],"type":"paragraph"},{"code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""],"syntax":"bash","type":"codeListing"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"For production deployments, pass the API key via","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}],"type":"paragraph"}],"type":"aside"},{"level":3,"text":"Passing API Keys Securely","anchor":"Passing-API-Keys-Securely","type":"heading"},{"inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"text":"embedding secrets in the script:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"inlineContent":[{"type":"text","text":"In the setup script, copy the config from the shared folder:"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"level":2,"text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet","type":"heading"},{"inlineContent":[{"text":"Deploy OpenClaw instances across multiple Macs using","type":"text"},{"text":" ","type":"text"},{"text":"the Kubernetes operator:","type":"text"}],"type":"paragraph"},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}],"type":"paragraph"},{"level":2,"text":"Networking Between Instances","anchor":"Networking-Between-Instances","type":"heading"},{"inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-coordinator --from-ipsw latest --network nat","spook create openclaw-worker --from-ipsw latest --network nat"]},{"inlineContent":[{"text":"NAT networking lets the VMs reach each other via their","type":"text"},{"text":" ","type":"text"},{"text":"DHCP-assigned IPs and the host Mac. The coordinator can","type":"text"},{"text":" ","type":"text"},{"text":"reach the worker’s gateway on port 18789. Use","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated"},{"type":"text","text":" if you need to prevent internet"},{"type":"text","text":" "},{"type":"text","text":"access entirely, communicating through shared folders"},{"type":"text","text":" "},{"type":"text","text":"and the VirtIO socket instead."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For internet access + inter-VM communication, use"},{"type":"text","text":" "},{"type":"text","text":"NAT networking — both VMs can reach each other via"},{"type":"text","text":" "},{"type":"text","text":"their NAT-assigned IPs."}],"type":"paragraph"},{"text":"Resource Planning","anchor":"Resource-Planning","type":"heading","level":2},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Setup","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"CPU","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Memory"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Disk","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notes"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Cloud models only","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4 cores"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Cloud + light local models"}],"type":"paragraph"}],[{"inlineContent":[{"text":"4 cores","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"8 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"32 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Ollama with small models","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Heavy local models (Llama 3)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"6 cores","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"16 GB"}],"type":"paragraph"}],[{"inlineContent":[{"text":"64 GB","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Needs unified memory","type":"text"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}]},{"anchor":"Monitoring","level":2,"type":"heading","text":"Monitoring"},{"type":"paragraph","inlineContent":[{"text":"Check OpenClaw health in each VM:","type":"text"}]},{"type":"codeListing","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"],"syntax":"bash"},{"anchor":"Snapshots","level":2,"type":"heading","text":"Snapshots"},{"type":"paragraph","inlineContent":[{"text":"Save a working OpenClaw configuration before making changes.","type":"text"},{"text":" ","type":"text"},{"text":"The VM must be stopped to take or restore a disk-level snapshot:","type":"text"}]},{"syntax":"bash","type":"codeListing","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}],"kind":"content"}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"Running OpenClaw in Virtual Machines","roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"role":"collectionGroup"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/spooktacularkit\/openclawguide"]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"type":"topic","abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","url":"\/documentation\/spooktacularkit","role":"collection","title":"SpooktacularKit"},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"url":"\/documentation\/spooktacularkit\/mlworkloads","abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"title":"Machine Learning Workloads","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","role":"collectionGroup","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"url":"\/documentation\/spooktacularkit\/provisioningmode","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"title":"ProvisioningMode","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProvisioningMode"}],"navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"type":"topic","abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}],"navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","url":"\/documentation\/spooktacularkit\/openclawtemplate","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenClawTemplate"}],"title":"OpenClawTemplate"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode/isolated":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode\/isolated","url":"\/documentation\/spooktacularkit\/networkmode\/isolated","role":"symbol","title":"NetworkMode.isolated","abstract":[{"type":"text","text":"No network connectivity."}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isolated"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"title":"Using the spook Command-Line Interface","kind":"article","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"type":"text","text":"Manage macOS virtual machines from the terminal with the "},{"type":"codeVoice","code":"spook"},{"type":"text","text":" CLI."}],"type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","url":"\/documentation\/spooktacularkit\/versioning","role":"collectionGroup","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"title":"Versioning & Release Schedule","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"title":"NetworkMode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The network configuration mode for a virtual machine."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/SharedFolder":{"kind":"symbol","type":"topic","url":"\/documentation\/spooktacularkit\/sharedfolder","title":"SharedFolder","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","abstract":[{"text":"A directory shared between the host and the virtual machine.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SharedFolder"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"title":"Deploying on EC2 Mac","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","role":"collectionGroup","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"url":"\/documentation\/spooktacularkit\/bluebubblesguide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"title":"Running BlueBubbles iMessage Server","type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","role":"collectionGroup","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/VirtualMachineSpecification":{"type":"topic","abstract":[{"type":"text","text":"The hardware specification for a virtual machine."}],"navigatorTitle":[{"kind":"identifier","tex