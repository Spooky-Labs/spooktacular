{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"],"title":"Guides","anchor":"Guides","generated":true}],"metadata":{"roleHeading":"API Collection","modules":[{"name":"SpooktacularKit"}],"title":"Running OpenClaw in Virtual Machines","role":"collectionGroup"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/openclaw.ai","type":"reference","isActive":true},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Isolation"}]},{"type":"text","text":" — each instance has its own macOS environment, API keys,"},{"type":"text","text":" "},{"type":"text","text":"and workspace. A misconfigured agent can’t affect the other."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"2 instances per Mac"}]},{"type":"text","text":" — Apple Silicon’s 2-VM kernel limit maps"},{"type":"text","text":" "},{"type":"text","text":"perfectly to running a pair of agents (e.g., work + personal,"},{"type":"text","text":" "},{"type":"text","text":"or production + staging)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Snapshots"}]},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Kubernetes-managed"}]},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"type":"codeVoice","code":"MacOSVMPool"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"level":3,"type":"heading","anchor":"Prerequisites","text":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"macOS 14+ on the host"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Spooktacular installed ("},{"type":"codeVoice","code":"brew install --cask spooktacular"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"API key from Anthropic, OpenAI, or Google"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Quick-Start-Two-OpenClaw-Instances","text":"Quick Start: Two OpenClaw Instances"},{"level":3,"type":"heading","anchor":"1-Create-the-first-VM","text":"1. Create the first VM"},{"type":"codeListing","syntax":"bash","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"text":"2. Clone for the second instance","anchor":"2-Clone-for-the-second-instance","type":"heading","level":3},{"code":["spook clone openclaw-work openclaw-personal"],"syntax":"bash","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a","type":"text"},{"text":" ","type":"text"},{"text":"unique machine identifier automatically.","type":"text"}]},{"text":"3. Start both","anchor":"3-Start-both","type":"heading","level":3},{"code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Both VMs boot and run OpenClaw independently. Each listens"},{"type":"text","text":" "},{"type":"text","text":"on its own IP address, port 18789."}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"4-Check-status","text":"4. Check status"},{"code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"],"syntax":"bash","type":"codeListing"},{"level":2,"type":"heading","anchor":"User-Data-Script-for-OpenClaw","text":"User-Data Script for OpenClaw"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a script that installs and configures OpenClaw automatically:"}]},{"type":"codeListing","syntax":"bash","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"For production deployments, pass the API key via","type":"text"},{"text":" ","type":"text"},{"text":"a shared folder or environment variable rather than","type":"text"},{"text":" ","type":"text"},{"text":"hardcoding it in the script.","type":"text"}]}],"name":"Note"},{"type":"heading","level":3,"text":"Passing API Keys Securely","anchor":"Passing-API-Keys-Securely"},{"type":"paragraph","inlineContent":[{"text":"Use a shared folder to deliver configuration without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"embedding secrets in the script:"}]},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"inlineContent":[{"text":"In the setup script, copy the config from the shared folder:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet","type":"heading","level":2},{"inlineContent":[{"text":"Deploy OpenClaw instances across multiple Macs using","type":"text"},{"text":" ","type":"text"},{"text":"the Kubernetes operator:","type":"text"}],"type":"paragraph"},{"code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"],"syntax":"yaml","type":"codeListing"},{"inlineContent":[{"text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs =","type":"text"},{"type":"text","text":" "},{"type":"text","text":"20 OpenClaw instances."}],"type":"paragraph"},{"text":"Networking Between Instances","anchor":"Networking-Between-Instances","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"If your OpenClaw instances need to communicate (e.g.,","type":"text"},{"text":" ","type":"text"},{"text":"a coordinator agent delegating to worker agents):","type":"text"}]},{"code":["spook create openclaw-coordinator --from-ipsw latest --network host-only","spook create openclaw-worker --from-ipsw latest --network host-only"],"syntax":"bash","type":"codeListing"},{"inlineContent":[{"text":"Host-only networking lets the VMs talk to each other","type":"text"},{"text":" ","type":"text"},{"text":"and to the host Mac, but not to the internet. The","type":"text"},{"text":" ","type":"text"},{"text":"coordinator can reach the worker’s gateway at its","type":"text"},{"text":" ","type":"text"},{"text":"host-only IP on port 18789.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For internet access + inter-VM communication, use","type":"text"},{"text":" ","type":"text"},{"text":"NAT networking — both VMs can reach each other via","type":"text"},{"text":" ","type":"text"},{"text":"their NAT-assigned IPs.","type":"text"}],"type":"paragraph"},{"text":"Resource Planning","anchor":"Resource-Planning","type":"heading","level":2},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Setup"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"CPU"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Memory"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disk"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Notes"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cloud models only"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimal — OpenClaw is lightweight"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud + light local models","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 cores"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"8 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"32 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Ollama with small models","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Heavy local models (Llama 3)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"6 cores"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Needs unified memory","type":"text"}]}]]]},{"inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}],"type":"paragraph"},{"text":"Monitoring","anchor":"Monitoring","type":"heading","level":2},{"inlineContent":[{"text":"Check OpenClaw health in each VM:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"text":"Snapshots","level":2,"type":"heading","anchor":"Snapshots"},{"inlineContent":[{"text":"Save a working OpenClaw configuration before making changes.","type":"text"},{"text":" ","type":"text"},{"text":"The VM must be stopped to take or restore a disk-level snapshot:","type":"text"}],"type":"paragraph"},{"syntax":"bash","type":"codeListing","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}],"kind":"content"}],"kind":"article","topicSections":[{"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"],"title":"Related","anchor":"Related"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/NetworkMode":{"title":"NetworkMode","role":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","url":"\/documentation\/spooktacularkit\/networkmode","type":"topic","abstract":[{"text":"The network configuration mode for a virtual machine.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMode"}],"navigatorTitle":[{"kind":"identifier","text":"NetworkMode"}],"kind":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"url":"\/documentation\/spooktacularkit\/openclawtemplate","type":"topic","kind":"symbol","title":"OpenClawTemplate","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenClawTemplate","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"OpenClawTemplate","kind":"identifier"}],"abstract":[{"type":"text","text":"Generates user-data scripts for OpenClaw AI agent VMs."}]},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"type":"topic","url":"\/documentation\/spooktacularkit\/remotedesktop","abstract":[{"text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","kind":"article","title":"Remote Desktop Access","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"navigatorTitle":[{"text":"ProvisioningMode","kind":"identifier"}],"type":"topic","url":"\/documentation\/spooktacularkit\/provisioningmode","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","kind":"symbol","title":"ProvisioningMode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProvisioningMode","kind":"identifier"}],"role":"symbol"},"doc://SpooktacularKit/documentation/SpooktacularKit/CLIReference":{"type":"topic","url":"\/documentation\/spooktacularkit\/clireference","abstract":[{"text":"Manage macOS virtual machines from the terminal with the ","type":"text"},{"code":"spook","type":"codeVoice"},{"text":" CLI.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","kind":"article","title":"Using the spook Command-Line Interface","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/EC2MacDeployment":{"type":"topic","url":"\/documentation\/spooktacularkit\/ec2macdeployment","abstract":[{"text":"Run Spooktacular on AWS EC2 Mac dedicated hosts to double your macOS CI capacity.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","kind":"article","title":"Deploying on EC2 Mac","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"type":"topic","url":"\/documentation\/spooktacularkit\/versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","kind":"article","title":"Versioning & Release Schedule","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/GettingStarted":{"type":"topic","url":"\/documentation\/spooktacularkit\/gettingstarted","abstract":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","kind":"article","title":"Getting Started with Spooktacular","role":"collectionGroup"},"do