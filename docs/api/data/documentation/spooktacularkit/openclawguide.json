":"keyword"},{"text":" ","kind":"text"},{"text":"SharedFolder","kind":"identifier"}],"title":"SharedFolder","kind":"symbol","type":"topic","role":"symbol","navigatorTitle":[{"text":"SharedFolder","kind":"identifier"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/ProvisioningMode":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","abstract":[{"text":"The strategy for executing a user-data script on a VM.","type":"text"}],"url":"\/documentation\/spooktacularkit\/provisioningmode","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ProvisioningMode"}],"title":"ProvisioningMode","kind":"symbol","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ProvisioningMode"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/GitHubActionsGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","abstract":[{"text":"Run self-hosted macOS GitHub Actions runners in Spooktacular VMs with ephemeral isolation and automatic scaling.","type":"text"}],"url":"\/documentation\/spooktacularkit\/githubactionsguide","title":"Configuring GitHub Actions Runners","kind":"article","type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"url":"\/documentation\/spooktacularkit\/versioning","title":"Versioning & Release Schedule","kind":"article","type":"topic","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/BlueBubblesGuide":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","abstract":[{"text":"Set up a BlueBubbles iMessage server in a macOS VM — a dramatically simpler alternative to VMware on Windows.","type":"text"}],"u