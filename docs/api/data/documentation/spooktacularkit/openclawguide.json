act":[{"text":"Create your first macOS virtual machine in minutes.","type":"text"}],"kind":"article","url":"\/documentation\/spooktacularkit\/gettingstarted","type":"topic","role":"collectionGroup","title":"Getting Started with Spooktacular"},"https://openclaw.ai":{"title":"OpenClaw","type":"link","identifier":"https:\/\/openclaw.ai","url":"https:\/\/openclaw.ai","titleInlineContent":[{"type":"text","text":"OpenClaw"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/Versioning":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning","abstract":[{"text":"Understand what version numbers mean and what to expect from each release.","type":"text"}],"kind":"article","url":"\/documentation\/spooktacularkit\/versioning","type":"topic","role":"collectionGroup","title":"Versioning & Release Schedule"}}}