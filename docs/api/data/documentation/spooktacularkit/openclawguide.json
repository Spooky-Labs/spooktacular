{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Run two isolated OpenClaw AI agent instances on a single Mac — each with its own workspace, channels, and API keys."}],"seeAlsoSections":[{"title":"Guides","anchor":"Guides","generated":true,"identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GettingStarted","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/CLIReference","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/GitHubActionsGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/EC2MacDeployment","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KubernetesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BlueBubblesGuide","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Versioning"]}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"topicSections":[{"title":"Related","anchor":"Related","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/ProvisioningMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/VirtualMachineSpecification","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/NetworkMode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SharedFolder","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawGuide"},"metadata":{"modules":[{"name":"SpooktacularKit"}],"title":"Running OpenClaw in Virtual Machines","roleHeading":"API Collection","role":"collectionGroup"},"kind":"article","variants":[{"paths":["\/documentation\/spooktacularkit\/openclawguide"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/openclaw.ai","isActive":true,"type":"reference"},{"text":" is an open-source self-hosted AI assistant","type":"text"},{"text":" ","type":"text"},{"text":"that connects to Claude, GPT-4, Gemini, and other models. Running OpenClaw","type":"text"},{"text":" ","type":"text"},{"text":"in macOS VMs with Spooktacular gives you:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Isolation","type":"text"}]},{"type":"text","text":" — each instance has its own macOS environment, API keys,"},{"type":"text","text":" "},{"type":"text","text":"and workspace. A misconfigured agent can’t affect the other."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"2 instances per Mac","type":"text"}]},{"type":"text","text":" — Apple Silicon’s 2-VM kernel limit maps"},{"type":"text","text":" "},{"type":"text","text":"perfectly to running a pair of agents (e.g., work + personal,"},{"type":"text","text":" "},{"type":"text","text":"or production + staging)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Snapshots","type":"text"}]},{"type":"text","text":" — save a working OpenClaw configuration, experiment,"},{"type":"text","text":" "},{"type":"text","text":"and roll back if something breaks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Kubernetes-managed"}]},{"type":"text","text":" — scale OpenClaw instances across a fleet"},{"type":"text","text":" "},{"type":"text","text":"of Macs using "},{"code":"MacOSVMPool","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"type":"heading","level":3,"text":"Prerequisites","anchor":"Prerequisites"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Silicon Mac (M1 or later)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS 14+ on the host"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Spooktacular installed (","type":"text"},{"code":"brew install --cask spooktacular","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"API key from Anthropic, OpenAI, or Google","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Quick Start: Two OpenClaw Instances","anchor":"Quick-Start-Two-OpenClaw-Instances"},{"type":"heading","level":3,"text":"1. Create the first VM","anchor":"1-Create-the-first-VM"},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-work --from-ipsw latest \\","    --cpu 4 --memory 8 --disk 32 \\","    --network nat \\","    --user-data .\/setup-openclaw.sh \\","    --provision disk-inject"]},{"type":"heading","level":3,"text":"2. Clone for the second instance","anchor":"2-Clone-for-the-second-instance"},{"syntax":"bash","type":"codeListing","code":["spook clone openclaw-work openclaw-personal"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The clone takes ~50ms (APFS copy-on-write). Each VM gets a"},{"type":"text","text":" "},{"type":"text","text":"unique machine identifier automatically."}]},{"type":"heading","level":3,"text":"3. Start both","anchor":"3-Start-both"},{"syntax":"bash","type":"codeListing","code":["spook start openclaw-work --headless","spook start openclaw-personal --headless"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both VMs boot and run OpenClaw independently. Each listens"},{"type":"text","text":" "},{"type":"text","text":"on its own IP address, port 18789."}]},{"type":"heading","level":3,"text":"4. Check status","anchor":"4-Check-status"},{"syntax":"bash","type":"codeListing","code":["spook list","spook ip openclaw-work","spook ip openclaw-personal"]},{"type":"heading","level":2,"text":"User-Data Script for OpenClaw","anchor":"User-Data-Script-for-OpenClaw"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a script that installs and configures OpenClaw automatically:"}]},{"syntax":"bash","type":"codeListing","code":["#!\/bin\/bash","# setup-openclaw.sh — installs OpenClaw in a macOS VM","","set -euo pipefail","","# Install Homebrew (if not present)","if ! command -v brew &>\/dev\/null; then","    \/bin\/bash -c \"$(curl -fsSL https:\/\/raw.githubusercontent.com\/Homebrew\/install\/HEAD\/install.sh)\"","    eval \"$(\/opt\/homebrew\/bin\/brew shellenv)\"","fi","","# Install Node.js 24","brew install node@24","echo 'export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"' >> ~\/.zshrc","export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","","# Install OpenClaw","npm install -g openclaw@latest","","# Run onboard with daemon installation","# (The API key should be set via environment variable or","#  injected via the shared folder)","openclaw onboard --install-daemon","","echo \"OpenClaw installed and running on port 18789\""]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production deployments, pass the API key via"},{"type":"text","text":" "},{"type":"text","text":"a shared folder or environment variable rather than"},{"type":"text","text":" "},{"type":"text","text":"hardcoding it in the script."}]}]},{"type":"heading","level":3,"text":"Passing API Keys Securely","anchor":"Passing-API-Keys-Securely"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a shared folder to deliver configuration without"},{"type":"text","text":" "},{"type":"text","text":"embedding secrets in the script:"}]},{"syntax":"bash","type":"codeListing","code":["# On the host: create a config directory","mkdir -p ~\/openclaw-configs\/work","cat > ~\/openclaw-configs\/work\/openclaw.json << 'EOF'","{","    \"model\": \"claude-sonnet-4-5-20250514\",","    \"anthropicApiKey\": \"sk-ant-your-key-here\"","}","EOF","","# Create VM with shared folder","spook create openclaw-work --from-ipsw latest \\","    --share ~\/openclaw-configs\/work:config:ro \\","    --user-data .\/setup-openclaw.sh"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the setup script, copy the config from the shared folder:"}]},{"syntax":"bash","type":"codeListing","code":["# Inside setup-openclaw.sh","mkdir -p ~\/.openclaw","cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/openclaw.json","openclaw config validate"]},{"type":"heading","level":2,"text":"Kubernetes: OpenClaw Fleet","anchor":"Kubernetes-OpenClaw-Fleet"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deploy OpenClaw instances across multiple Macs using"},{"type":"text","text":" "},{"type":"text","text":"the Kubernetes operator:"}]},{"syntax":"yaml","type":"codeListing","code":["apiVersion: spooktacular.io\/v1alpha1","kind: MacOSVMPool","metadata:","  name: openclaw-agents","  namespace: ai","spec:","  replicas: 2","  image: ghcr.io\/spooktacular\/macos:15.4","","  provisioning:","    mode: disk-inject","    userData: |","      #!\/bin\/bash","      brew install node@24","      export PATH=\"\/opt\/homebrew\/opt\/node@24\/bin:$PATH\"","      npm install -g openclaw@latest","      mkdir -p ~\/.openclaw","      # Config injected via K8s secret → shared folder","      cp \"\/Volumes\/My Shared Files\/openclaw.json\" ~\/.openclaw\/","      openclaw onboard --install-daemon","","  resources:","    cpu: 4","    memory: 8Gi","    disk: 32Gi","","  network:","    mode: nat"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each Mac in the fleet runs 2 OpenClaw VMs. Ten Macs ="},{"text":" ","type":"text"},{"text":"20 OpenClaw instances.","type":"text"}]},{"type":"heading","level":2,"text":"Networking Between Instances","anchor":"Networking-Between-Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your OpenClaw instances need to communicate (e.g.,"},{"type":"text","text":" "},{"type":"text","text":"a coordinator agent delegating to worker agents):"}]},{"syntax":"bash","type":"codeListing","code":["spook create openclaw-coordinator --from-ipsw latest --network host-only","spook create openclaw-worker --from-ipsw latest --network host-only"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Host-only networking lets the VMs talk to each other"},{"type":"text","text":" "},{"type":"text","text":"and to the host Mac, but not to the internet. The"},{"type":"text","text":" "},{"text":"coordinator can reach the worker’s gateway at its","type":"text"},{"type":"text","text":" "},{"text":"host-only IP on port 18789.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For internet access + inter-VM communication, use"},{"type":"text","text":" "},{"type":"text","text":"NAT networking — both VMs can reach each other via"},{"type":"text","text":" "},{"type":"text","text":"their NAT-assigned IPs."}]},{"type":"heading","text":"Resource Planning","anchor":"Resource-Planning","level":2},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Setup"}]}],[{"type":"paragraph","inlineContent":[{"text":"CPU","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Memory","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Disk","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Notes","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud models only","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4 GB"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Minimal — OpenClaw is lightweight","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Cloud + light local models","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"8 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"32 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Ollama with small models","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Heavy local models (Llama 3)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6 cores","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"16 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"64 GB","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Needs unified memory","type":"text"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since macOS VMs share the host’s unified memory via"},{"type":"text","text":" "},{"type":"text","text":"the Virtualization framework, the GPU (Metal) is"},{"type":"text","text":" "},{"type":"text","text":"available inside the VM for local model inference."}]},{"type":"heading","text":"Monitoring","anchor":"Monitoring","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check OpenClaw health in each VM:"}]},{"type":"codeListing","syntax":"bash","code":["# From the host","spook ssh openclaw-work -- \"openclaw status\"","spook ssh openclaw-personal -- \"openclaw status\"","","# Or via the gateway API","curl http:\/\/$(spook ip openclaw-work):18789\/health","curl http:\/\/$(spook ip openclaw-personal):18789\/health"]},{"type":"heading","text":"Snapshots","anchor":"Snapshots","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Save a working OpenClaw configuration before making changes."},{"type":"text","text":" "},{"type":"text","text":"The VM must be stopped to take or restore a disk-level snapshot:"}]},{"type":"codeListing","syntax":"bash","code":["spook stop openclaw-work","spook snapshot openclaw-work pre-upgrade","spook start openclaw-work --headless","# ... make changes, install new version ...","# If something breaks:","spook stop openclaw-work","spook restore openclaw-work pre-upgrade","spook start openclaw-work --headless"]}]}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit":{"abstract":[{"type":"text","text":"Create and manage macOS virtual machines on Apple Silicon."}],"type":"topic","title":"SpooktacularKit","url":"\/documentation\/spooktacularkit","kind":"symbol","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit","role":"collection"},"doc://SpooktacularKit/documentation/SpooktacularKit/OpenClawTemplate":{"abstract":[{"text":"Generates user-data scripts for OpenClaw AI agent VMs.","type":"text"}],"role":"symbol","url":"\/documentation\/spooktacularkit\/openclawtemplate","title":"OpenClawTemplate","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/OpenClawTemplate","navigatorTitle":[{"kind":"identifier","text":"OpenClawTemplate"}],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenClawTemplate"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/MLWorkloads":{"abstract":[{"type":"text","text":"Run ML training and inference on Apple Silicon GPUs inside Spooktacular virtual machines."}],"type":"topic","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/MLWorkloads","title":"Machine Learning Workloads","kind":"article","url":"\/documentation\/spooktacularkit\/mlworkloads","role":"collectionGroup"},"doc://SpooktacularKit/documentation/SpooktacularKit/RemoteDesktop":{"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/RemoteDesktop","type":"topic","abstract":[{"type":"text","text":"Connect to Spooktacular VMs via VNC for remote development, QA testing, and design review."}],"role":"collectionGroup","title":"Remote Desktop Access","url":"\/documentation\/spooktacularkit\/remotedesktop","kind":"article"},"doc://SpooktacularKit/documentation/SpooktacularKit/KubernetesGuide":{"abstract":