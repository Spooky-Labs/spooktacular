{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"text":" provides version-specific keyboard input sequences","type":"text"},{"text":" ","type":"text"},{"text":"that walk through the macOS Setup Assistant without any human","type":"text"},{"text":" ","type":"text"},{"text":"interaction. After the sequence completes, the VM has:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A user account (configurable, defaults to ","type":"text"},{"type":"codeVoice","code":"admin"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"admin"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH (Remote Login) enabled","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A UTC timezone configured","type":"text"}]}]}]},{"anchor":"Design","type":"heading","text":"Design","level":2},{"type":"paragraph","inlineContent":[{"text":"This follows the approach pioneered by","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/cirruslabs\/tart"},{"text":" for Packer","type":"text"},{"text":" ","type":"text"},{"code":"boot_command","type":"codeVoice"},{"text":" automation. The sequences have been verified against","type":"text"},{"text":" ","type":"text"},{"text":"Tart’s working Packer plugin and adapted for direct use via the","type":"text"},{"text":" ","type":"text"},{"text":"Virtualization framework’s keyboard API.","type":"text"}]},{"anchor":"Requirements","type":"heading","text":"Requirements","level":2},{"type":"unorderedList","items":[{"content"