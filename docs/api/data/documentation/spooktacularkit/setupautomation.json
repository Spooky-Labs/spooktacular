{"sections":[],"abstract":[{"text":"Automated macOS Setup Assistant sequences for headless VM provisioning.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"navigatorTitle":[{"text":"SetupAutomation","kind":"identifier"}],"modules":[{"name":"SpooktacularKit"}],"title":"SetupAutomation","role":"symbol","symbolKind":"enum","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SetupAutomation","kind":"identifier"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SetupAutomationO"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SetupAutomation","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"type":"text","text":" provides version-specific keyboard input sequences"},{"type":"text","text":" "},{"type":"text","text":"that walk through the macOS Setup Assistant without any human"},{"type":"text","text":" "},{"type":"text","text":"interaction. After the sequence completes, the VM has:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A user account (configurable, defaults to ","type":"text"},{"code":"admin","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"admin","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH (Remote Login) enabled","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A UTC timezone configured","type":"text"}]}]}]},{"level":2,"text":"Design","type":"heading","anchor":"Design"},{"inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","isActive":true},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework’s keyboard API."}],"type":"paragraph"},{"level":2,"text":"Requirements","type":"heading","anchor":"Requirements"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"VZVirtualMachineView","type":"codeVoice"},{"text":" must be attached to the VM (even","type":"text"},{"text":" ","type":"text"},{"text":"offscreen) for keyboard events to reach the guest.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The VM must be freshly installed from an IPSW — previously","type":"text"},{"text":" ","type":"text"},{"text":"configured VMs will not show the Setup Assistant.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sequences are version-specific because Apple changes the Setup","type":"text"},{"text":" ","type":"text"},{"text":"Assistant layout between major macOS releases.","type":"text"}]}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Adding Support for New macOS Versions","type":"heading","anchor":"Adding-Support-for-New-macOS-Versions"},{"inlineContent":[{"type":"text","te