oard API.","type":"text"}]},{"anchor":"Requirements","type":"heading","level":2,"text":"Requirements"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":" must be attached to the VM (even"},{"type":"text","text":" "},{"type":"text","text":"offscreen) for keyboard events to reach the guest."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The VM must be freshly installed from an IPSW — previously"},{"type":"text","text":" "},{"type":"text","text":"configured VMs will not show the Setup Assistant."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Sequences are version-specific because Apple changes the Setup"},{"type":"text","text":" "},{"type":"text","text":"Assistant layout between major macOS releases."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"]},{"type":"heading","level":2,"text":"Adding Support for New macOS Versions","anchor":"Adding-Support-for-New-macOS-Versions"},{"type":"paragraph","inlineContent":[{"text":"When a new macOS version ships, its Setup Assistant layout must","type":"text"},{"text":" ","type":"text"},{"text":"be mapped by hand:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Install the new macOS in a VM with a display attached."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Walk through Setup Assistant, recording each screen’s"},{"type":"text","text":" "},{"type":"text","text":"navigation keys."}],"t