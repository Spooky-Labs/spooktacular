{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"type":"text","text":" provides version-specific keyboard input sequences"},{"text":" ","type":"text"},{"text":"that walk through the macOS Setup Assistant without any human","type":"text"},{"text":" ","type":"text"},{"text":"interaction. After the sequence completes, the VM has:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A user account (configurable, defaults to "},{"type":"codeVoice","code":"admin"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"admin"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH (Remote Login) enabled"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A UTC timezone configured"}]}]}]},{"text":"Design","level":2,"type":"heading","anchor":"Design"},{"inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cirruslabs\/tart"},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework’s keyboard API."}],"type":"paragraph"},{"text":"Requirements","level":2,"type":"heading","anchor":"Requirements"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":" must be attached to the VM (even"},{"type":"text","text":" "},{"type":"text","text":"offscreen) for keyboard events to reach the guest."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM must be freshly installed from an IPSW — previously"},{"type":"text","text":" "},{"text":"configured VMs will not show the Setup Assistant.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Sequences are version-specific because Apple changes the Setup","type":"text"},{"text":" ","type":"text"},{"text":"Assistant layout between major macOS releases.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Adding Support for New macOS Versions","type":"heading","anchor":"Adding-Support-for-New-macOS-Versions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a new macOS version ships, its Setup Assistant layout must"},{"type":"text","text":" "},{"type":"text","text":"be mapped by hand:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Install the new macOS in a VM with a display attached."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Walk through Setup Assistant, recording each screen’s","type":"text"},{"text":" ","type":"text"},{"text":"navigation keys.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add a new ","type":"