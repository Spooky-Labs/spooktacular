:"The VM must be freshly installed from an IPSW — previously","type":"text"},{"text":" ","type":"text"},{"text":"configured VMs will not show the Setup Assistant.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Sequences are version-specific because Apple changes the Setup","type":"text"},{"text":" ","type":"text"},{"text":"Assistant layout between major macOS releases.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"syntax":"swift","code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing"},{"level":2,"text":"Adding Support for New macOS Versions","anchor":"Adding-Support-for-New-macOS-Versions","type":"heading"},{"inlineContent":[{"type":"text","text":"When a new macOS version ships, its Setup Assistant layout must"},{"type":"text","text":" "},{"type":"text","text":"be mapped by hand:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Install the new macOS in a VM with a display attached.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Walk through Setup Assistant, recording each screen’s","type":"text"},{"text":" ","type":"text"},{"text":"navigation keys.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Add a new ","type":"text"},{"code":"case","type":"codeVoice"},{"text":" in ","type":"text"},{"type":"reference","identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/sequence(for:username:password:)","isActive":true},{"text":" ","type":"text"},{"text":"with the recorded steps.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Test against a f