{"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"sections":[],"variants":[{"paths":["\/documentation\/spooktacularkit\/setupautomation"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"enum","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"modules":[{"name":"SpooktacularKit"}],"role":"symbol","title":"SetupAutomation","navigatorTitle":[{"kind":"identifier","text":"SetupAutomation"}],"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SetupAutomationO"},"abstract":[{"text":"Automated macOS Setup Assistant sequences for headless VM provisioning.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SetupAutomation"}]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"text":" provides version-specific keyboard input sequences","type":"text"},{"text":" ","type":"text"},{"text":"that walk through the macOS Setup Assistant without any human","type":"text"},{"text":" ","type":"text"},{"text":"interaction. After the sequence completes, the VM has:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A user account (configurable, defaults to "},{"code":"admin","type":"codeVoice"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"admin"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SSH (Remote Login) enabled"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A UTC timezone configured"}]}]}]},{"anchor":"Design","text":"Design","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cirruslabs\/tart"},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework’s keyboard API."}],"type":"paragraph"},{"anchor":"Requirements","text":"Requirements","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":" must be attached to the VM (even"},{"type":"text","text":" "},{"type":"text","text":"offscreen) for keyboard events to reach the guest."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VM must be freshly installed from an IPSW — previously"},{"type":"text","text":" "},{"type":"text","text":"configured VMs will not show the Setup Assistant."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sequences are version-specific because Apple changes the Setup"},{"type":"text","text":" "},{"text":"Assistant layout between major macOS releases.","type":"text"}]}]}]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Adding-Support-for-New-macOS-Ver