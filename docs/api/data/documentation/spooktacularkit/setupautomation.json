"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SetupAutomation","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"type":"text","text":" provides version-specific keyboard input sequences"},{"type":"text","text":" "},{"type":"text","text":"that walk through the macOS Setup Assistant without any human"},{"type":"text","text":" "},{"type":"text","text":"interaction. After the sequence completes, the VM has:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A user account (configurable, defaults to "},{"type":"codeVoice","code":"admin"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"admin"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"SSH (Remote Login) enabled"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A UTC timezone configured"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Design","anchor":"Design"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"identifier":"https:\/\/github.com\/cirruslabs\/tart","type":"reference","isActive":true},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework’s keyboard API."}]},{"level":2,"type":"heading","text":"Requirements","anchor":"Requirements"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"VZVirtualMachineView"},{"type":"text","text":" must be attached to the VM (even"},{"type":"text","text":" "},{"type":"text","text":"offscreen) for keyboard events to reach the guest."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The VM must be freshly installed from an IPSW — previously"},{"type":"text","text":" "},{"type":"text","text":"configured VMs will not show the Setup Assistant."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Sequences are version-specific because Apple changes the Setup"},{"type":"text","text":" "},{"type":"text","text":"Assistant layout between major macOS releases."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"codeListing","code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"syntax":"swift"},{"level":2,"type":"heading","text":"Adding Support for New macOS Versions","anchor":"Adding-Support-for-New-macOS-Versions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a new macOS version ships, its Setup Assistant layout must"},{"type":"text","text":" "},{"type":"text","text":"be mapped by hand:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Install the new macOS in a VM with a display attached."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Walk through Setup Assistant, recording each screen’s"},{"type":"text","text":" "},{"type":"text","text":"navigation keys."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add a new "},{"type":"codeVoice","code":"case"},{"type":"text","text":" in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/sequence(for:username:password:)"},{"type":"text","text":" "},{"type":"text","text":"with the recorded steps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Test against a fresh IPSW install."}],"type":"paragraph"}]}]}],"kind":"content"}],"references":{"doc://SpooktacularKit/documentation/SpooktacularKit/BootStep":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BootStep"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","url":"\/documentation\/spooktacularkit\/bootstep","role":"symbol","abstract":[{"type":"text","text":"A single step in a Setup Assistant automation sequence."}],"navigatorTitle":[{"kind":"identifier","text":"BootStep"}],"title":"BootStep","kind":"symbol","type":"topic"},"doc://SpooktacularKit/documentation/SpooktacularKit/SetupAutomation":{"title":"SetupAutomation","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"abstract":[{"text":"Automated macOS Setup Assistant sequences for headless VM provisioning.","type":"text"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation","url":"\/documentation\/spooktacularkit\/setupautomation","role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SetupAutomation"}]},"doc://SpooktacularKit/documentation/SpooktacularKit/BootAction":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"BootAction"}],"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootAction","url":"\/documentation\/spooktacularkit\/bootaction","role":"symbol","abstract":[{"type":"text","text":"A keyboard action to send to the VM during Setup Assistant automation."}],"navigatorTitle":[{"kind":"identifier","text":"BootAction"}],"title":"BootAction","kind":"symbol"