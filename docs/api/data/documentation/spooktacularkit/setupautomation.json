{"metadata":{"externalID":"s:15SpooktacularKit15SetupAutomationO","navigatorTitle":[{"text":"SetupAutomation","kind":"identifier"}],"symbolKind":"enum","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"modules":[{"name":"SpooktacularKit"}],"roleHeading":"Enumeration","title":"SetupAutomation"},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/supportedVersions"],"generated":true,"anchor":"Type-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/isSupported(macOSVersion:)","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/sequence(for:username:password:)"],"generated":true,"anchor":"Type-Methods"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"title":"Setup Automation","identifiers":["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomationExecutor","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomationExecutorError","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootStep","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/BootAction","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/KeyCode","doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/Modifier"],"generated":true,"anchor":"Setup-Automation"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation"},"hierarchy":{"paths":[["doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit"]]},"abstract":[{"text":"Automated macOS Setup Assistant sequences for headless VM provisioning.","type":"text"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SetupAutomation"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"type":"text","text":" provides version-specific keyboard input sequences"},{"type":"text","text":" "},{"type":"text","text":"that walk through the macOS Setup Assistant without any human"},{"type":"text","text":" "},{"type":"text","text":"interaction. After the sequence completes, the VM has:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A user account (configurable, defaults to "},{"type":"codeVoice","code":"admin"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"admin"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SSH (Remote Login) enabled","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A UTC timezone configured"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Design","text":"Design","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cirruslabs\/tart"},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"type":"text","text":" "},{"type":"text","text":"Virtualization framework’s keyboard API."}],"type":"paragraph"},{"anchor":"Requirements","text":"Requirements","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A "},{"code":"VZVirtualMachineView","type":"codeVoice"},{"type":"text","text":" must be attached to the VM (even"},{"type":"text","text":" "},{"type":"text","text":"offscreen) for keyboard events to reach the guest."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The VM must be freshly installed from an IPSW — previously"},{"type":"text","text":" "},{"type":"text","text":"configured VMs will not show the Setup Assistant."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Sequences are version-specific because Apple changes the Setup"},{"type":"text","text":" "},{"type":"text","text":"Assistant layout between major macOS releases."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"syntax":"swift","code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing"},{"anchor":"Adding-Support-for-New-macOS-Versions","text":"Adding Support for New macOS Versions","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"When a new macOS version ships, its Setup Assistant layout must"},{"type":"text","text":" "},{"type":"text","text":"be mapped by hand:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Install the new macOS in a VM with a display attached."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Walk through Setup Assistant, recording each screen’s"},{"type":"text","text":" "},{"type":"text","text":"navigation keys."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add a new "},{"code":"case","type":"codeVoice"},{"type":"text","text":" in "},{"isActive":true,"identifier":"doc:\/\/SpooktacularKit\/documentation\/SpooktacularKit\/SetupAutomation\/sequence(for:username:password:)","type":"reference"},{"type":"text","text":" "},{"type":"text","te