{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Enumeration","externalID":"s:15SpooktacularKit15SetupAutomationO","symbolKind":"enum","modules":[{"name":"SpooktacularKit"}],"navigatorTitle":[{"text":"SetupAutomation","kind":"identifier"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SetupAutomation","kind":"identifier"}],"title":"SetupAutomation"},"abstract":[{"text":"Automated macOS Setup Assistant sequences for headless VM provisioning.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SetupAutomation","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"SetupAutomation"},{"text":" provides version-specific keyboard input sequences","type":"text"},{"text":" ","type":"text"},{"text":"that walk through the macOS Setup Assistant without any human","type":"text"},{"text":" ","type":"text"},{"text":"interaction. After the sequence completes, the VM has:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A user account (configurable, defaults to ","type":"text"},{"type":"codeVoice","code":"admin"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"admin"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"SSH (Remote Login) enabled"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A UTC timezone configured","type":"text"}]}]}],"type":"unorderedList"},{"text":"Design","level":2,"type":"heading","anchor":"Design"},{"inlineContent":[{"type":"text","text":"This follows the approach pioneered by"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/cirruslabs\/tart"},{"type":"text","text":" for Packer"},{"type":"text","text":" "},{"type":"codeVoice","code":"boot_command"},{"type":"text","text":" automation. The sequences have been verified against"},{"type":"text","text":" "},{"type":"text","text":"Tart’s working Packer plugin and adapted for direct use via the"},{"text":" ","type":"text"},{"text":"Virtualization framework’s keyboard API.","type":"text"}],"type":"paragraph"},{"text":"Requirements","level":2,"type":"heading","anchor":"Requirements"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"VZVirtualMachineView"},{"text":" must be attached to the VM (even","type":"text"},{"text":" ","type":"text"},{"text":"offscreen) for keyboard events to reach the guest.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The VM must be freshly installed from an IPSW — previously","type":"text"},{"text":" ","type":"text"},{"text":"configured VMs will not show the Setup Assistant.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sequences are version-specific because Apple changes the Setup","type":"text"},{"text":" ","type":"text"},{"text":"Assistant layout between major macOS releases.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"code":["guard SetupAutomation.isSupported(macOSVersion: 15) else {","    fatalError(\"No automation sequence for this version\")","}","","let steps = SetupAutomation.sequence(for: 15)","for step in steps {","    try await Task.sleep(for: .seconds(step.delay))","    await keyboardDriver.perform(step.action)","}"],"type":"codeListing","syntax":"swift"},{"text":"Adding Support for New macOS Versions","level":2,"type":"heading","anchor":"Adding-Support-for-New-macOS-Versions"},{"inlineContent":[{"text":"When a new macOS version ships, its Setup Assistant layout must","type":"text"},{"text":" ","type":"text"},{"text":"be mapp