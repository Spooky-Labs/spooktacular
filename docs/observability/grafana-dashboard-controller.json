{
  "title": "Spooktacular — Controller",
  "uid": "spooktacular-controller",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["spooktacular", "controller", "kubernetes"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "pod",
        "type": "query",
        "label": "Controller pod",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"spook-controller\"}, pod)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Controller up",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(up{job=\"spook-controller\",pod=~\"$pod\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Watch stream uptime (7d)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "avg(avg_over_time(up{job=\"spook-controller\",pod=~\"$pod\"}[7d]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.99  },
              { "color": "green",  "value": 0.999 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reconcile queue depth (p95)",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pod) (rate(spooktacular_reconcile_queue_depth_bucket{pod=~\"$pod\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          }
        }
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Reconcile latency",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Reconcile latency (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(spooktacular_reconcile_duration_seconds_bucket{pod=~\"$pod\"}[5m])))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(spooktacular_reconcile_duration_seconds_bucket{pod=~\"$pod\"}[5m])))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(spooktacular_reconcile_duration_seconds_bucket{pod=~\"$pod\"}[5m])))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Reconcile error rate (%)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(spooktacular_reconcile_errors_total{pod=~\"$pod\"}[5m])) / clamp_min(sum(rate(spooktacular_reconcile_attempts_total{pod=~\"$pod\"}[5m])), 1)",
          "refId": "A",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "API traffic",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "API request p95 (s)",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(spooktacular_api_request_duration_seconds_bucket{pod=~\"$pod\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "API error rate (%)",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(spooktacular_api_errors_total{pod=~\"$pod\"}[5m])) / clamp_min(sum(rate(spooktacular_api_requests_total{pod=~\"$pod\"}[5m])), 1)",
          "refId": "A",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    }
  ]
}
