default_platform(:mac)

platform :mac do

  # ──────────────────────────────────────────────────
  # Test
  # ──────────────────────────────────────────────────

  desc "Run all unit tests"
  lane :test do
    sh("cd .. && swift test")
  end

  # ──────────────────────────────────────────────────
  # Build
  # ──────────────────────────────────────────────────

  desc "Build the .app bundle (release)"
  lane :build do
    # Pass signing identity and provisioning profile from match.
    identity = ENV["sigh_com.spooktacular.app_appstore_macos_certificate-name"] || ""
    profile = ENV["sigh_com.spooktacular.app_appstore_macos_profile-path"] || ""

    sh(
      "cd .. && chmod +x build-app.sh && " \
      "CODESIGN_IDENTITY='#{identity}' " \
      "PROVISIONING_PROFILE='#{profile}' " \
      "./build-app.sh release"
    )
  end

  # ──────────────────────────────────────────────────
  # Package — Create .pkg from .app
  # ──────────────────────────────────────────────────

  desc "Package the .app into a .pkg for App Store submission"
  lane :package do
    # App Store Connect and TestFlight require .pkg for macOS,
    # not a raw .app bundle. Use productbuild to create an
    # installer package with the app placed in /Applications.
    #
    # The installer cert identity comes from match (via
    # additional_cert_types: mac_installer_distribution) or
    # the INSTALLER_CERT_NAME env var. Falls back to the
    # team-based identity name if neither is set.
    # The installer cert identity installed by match. Use the full
    # name from `security find-identity` or the SHA-1 hash.
    installer_identity = ENV["INSTALLER_CERT_NAME"] ||
      "3rd Party Mac Developer Installer: Perris Davis (4AM5US9G8B)"

    sh("cd .. && productbuild --component Spooktacular.app /Applications --sign '#{installer_identity}' Spooktacular.pkg")
    UI.success("Package created: Spooktacular.pkg")
  end

  # ──────────────────────────────────────────────────
  # Code Signing — match
  # ──────────────────────────────────────────────────

  desc "Sync code-signing certificates and profiles via match"
  lane :signing do
    setup_ci if ENV['CI']

    api_key = get_api_key
    match(
      api_key: api_key,
      type: "appstore",
      additional_cert_types: ["mac_installer_distribution"],
      readonly: is_ci
    )
  end

  # ──────────────────────────────────────────────────
  # Notarize — Direct distribution
  # ──────────────────────────────────────────────────

  desc "Notarize the .app for direct distribution"
  lane :notarize_app do
    notarize(
      package: "Spooktacular.app",
      bundle_id: "com.spooktacular.app",
      verbose: true
    )
  end

  # ──────────────────────────────────────────────────
  # Beta — TestFlight
  # ──────────────────────────────────────────────────

  desc "Build, package, and upload to TestFlight"
  lane :beta do |options|
    test
    signing
    build
    package

    api_key = get_api_key

    pilot(
      api_key: api_key,
      app_identifier: "com.spooktacular.app",
      app_platform: "osx",
      pkg: "Spooktacular.pkg",
      team_id: "4AM5US9G8B",

      # Beta app metadata
      beta_app_description: "Spooktacular is an enterprise macOS virtualization tool for Apple Silicon. " \
        "Run 2 macOS VMs per Mac — the maximum Apple's EULA allows. " \
        "Build iOS apps, sign code, run CI pipelines, host remote desktops, " \
        "and deploy computer-using AI agents. " \
        "Features: APFS copy-on-write cloning (48ms), SSH provisioning, " \
        "disk-inject provisioning, unattended Setup Assistant, ephemeral runners, " \
        "HTTP REST API, Kubernetes operator, 14 CLI commands, SwiftUI GUI with Liquid Glass.",
      beta_app_feedback_email: "davisperris@gmail.com",

      # Beta review info
      beta_app_review_info: {
        contact_email: "davisperris@gmail.com",
        contact_first_name: "Perris",
        contact_last_name: "Davis",
        contact_phone: "+1 (555) 000-0000",
        demo_account_required: false,
        notes: "Spooktacular uses Apple's Virtualization.framework to create and manage " \
          "macOS virtual machines on Apple Silicon Macs. The app requires the " \
          "com.apple.security.virtualization entitlement. No VMs can be created on " \
          "Intel Macs. The app includes a bundled CLI tool (spook) and an HTTP API server. " \
          "No account or network connection is required to use the app — all VMs run locally."
      },

      # Build info
      changelog: options[:changelog] || "v1.0.0 — First release.\n\n" \
        "• Create macOS VMs from IPSW restore images\n" \
        "• APFS copy-on-write cloning in 48ms\n" \
        "• Unattended Setup Assistant automation\n" \
        "• SSH and disk-inject provisioning\n" \
        "• GitHub Actions runner template with ephemeral mode\n" \
        "• Remote desktop and OpenClaw templates\n" \
        "• HTTP REST API (9 endpoints)\n" \
        "• Kubernetes operator (MacOSVM CRD)\n" \
        "• SwiftUI GUI with Liquid Glass (macOS 26+)\n" \
        "• Menu bar extra for quick access\n" \
        "• Full VoiceOver accessibility\n" \
        "• 318 tests across 39 suites",

      # Localized beta app info
      localized_app_info: {
        "en-US" => {
          feedback_email: "davisperris@gmail.com",
          marketing_url: "https://spooktacular.app",
          privacy_policy_url: "https://spooktacular.app/privacy.html",
          description: "Spooktacular is an enterprise macOS virtualization tool for Apple Silicon. " \
            "Run 2 macOS VMs per Mac — the maximum Apple's EULA allows. " \
            "Build iOS apps, sign code, run CI pipelines, host remote desktops, " \
            "and deploy computer-using AI agents. Each VM gets Metal GPU access " \
            "and unified memory."
        }
      },

      # Localized build info (what to test)
      localized_build_info: {
        "en-US" => {
          whats_new: options[:changelog] || "v1.0.0 — First release.\n\n" \
            "• Create macOS VMs from IPSW restore images\n" \
            "• APFS copy-on-write cloning in 48ms\n" \
            "• Unattended Setup Assistant automation\n" \
            "• SSH and disk-inject provisioning\n" \
            "• GitHub Actions runner template with ephemeral mode\n" \
            "• HTTP REST API (9 endpoints)\n" \
            "• Kubernetes operator (MacOSVM CRD)\n" \
            "• SwiftUI GUI with Liquid Glass (macOS 26+)\n" \
            "• 318 tests across 39 suites"
        }
      },

      uses_non_exempt_encryption: false,
      demo_account_required: false,
      skip_submission: false,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false,
      expire_previous_builds: true
    )
  end

  # ──────────────────────────────────────────────────
  # Release — App Store
  # ──────────────────────────────────────────────────

  desc "Build, notarize, and submit to the App Store"
  lane :release do |options|
    test
    signing
    build
    notarize_app
    package

    api_key = get_api_key

    deliver(
      api_key: api_key,
      app_identifier: "com.spooktacular.app",
      app_platform: "osx",
      team_id: "4AM5US9G8B",

      # Metadata & screenshots from directories
      metadata_path: "./metadata",
      screenshots_path: "./screenshots",

      # Binary
      pkg: "Spooktacular.pkg",
      skip_binary_upload: false,

      # Metadata control
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,

      # Age rating from JSON config
      app_rating_config_path: "./metadata/age_rating_config.json",

      # Categories
      primary_category: "DEVELOPER_TOOLS",
      secondary_category: "BUSINESS",

      # Submission
      submit_for_review: options[:submit] || false,
      automatic_release: options[:auto_release] || false,
      phased_release: true,
      force: true,

      # Review information (also reads from metadata/review_information/*.txt)
      app_review_information: {
        first_name: "Perris",
        last_name: "Davis",
        phone_number: "+1 (555) 000-0000",
        email_address: "davisperris@gmail.com",
        demo_user: "",
        demo_password: "",
        notes: "Spooktacular uses Apple's Virtualization.framework (com.apple.security.virtualization " \
          "entitlement) to create and manage macOS VMs on Apple Silicon. Works only on Apple Silicon Macs. " \
          "The app includes a GUI, a bundled CLI (spook), and an HTTP API server. No account or internet " \
          "connection required — all VMs run locally. No demo account needed."
      },

      # Compliance
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      }
    )
  end

  # ──────────────────────────────────────────────────
  # Homebrew — Notarized zip for Homebrew cask
  # ──────────────────────────────────────────────────

  desc "Build, notarize, and package for Homebrew distribution"
  lane :homebrew do
    build
    notarize_app
    sh("cd .. && ditto -c -k --sequesterRsrc --keepParent Spooktacular.app Spooktacular.app.zip")
    UI.success("Homebrew package ready: Spooktacular.app.zip")
  end

  # ──────────────────────────────────────────────────
  # Screenshots — Capture App Store screenshots
  # ──────────────────────────────────────────────────

  desc "Capture and process App Store screenshots"
  lane :screenshots do
    build

    # Shell-based capture (SwiftPM projects don't have an Xcode
    # project for XCUITest / Fastlane snapshot).
    sh("cd .. && chmod +x scripts/capture-screenshots.sh && ./scripts/capture-screenshots.sh")
    sh("cd .. && chmod +x scripts/process-screenshots.sh && ./scripts/process-screenshots.sh")

    # Add device frames and promotional text via frameit.
    # Config: screenshots/Framefile.json + en-US/title.strings
    frameit(
      path: "./screenshots",
      white: false,
      force_orientation_block: proc { |_| :portrait }
    )

    UI.success("Screenshots captured, processed, and framed.")
    UI.message("Output: fastlane/screenshots/en-US/")
  end

  # ──────────────────────────────────────────────────
  # DocC — Generate documentation
  # ──────────────────────────────────────────────────

  desc "Generate DocC documentation"
  lane :generate_docs do
    sh("cd .. && chmod +x scripts/build-docs.sh && ./scripts/build-docs.sh --static")
  end

  # ──────────────────────────────────────────────────
  # Lint — Validate metadata
  # ──────────────────────────────────────────────────

  desc "Validate App Store metadata"
  lane :lint do
    check_app_store_metadata(
      default_rule_level: :error,
      negative_apple_sentiment: true,
      placeholder_text: true
    )
  end

  # ──────────────────────────────────────────────────
  # Setup — Register app ID in Apple Developer Portal
  # ──────────────────────────────────────────────────

  desc "Register app identifier in Apple Developer Portal and App Store Connect"
  lane :register_app do
    api_key = get_api_key

    produce(
      app_identifier: "com.spooktacular.app",
      app_name: "Spooktacular",
      language: "English",
      app_version: "1.0.0",
      platform: "osx",
      sku: "com.spooktacular.app.macos"
    )
  end

  # ──────────────────────────────────────────────────
  # Helpers
  # ──────────────────────────────────────────────────

  private_lane :get_api_key do
    app_store_connect_api_key(
      key_id: ENV["APPLE_API_KEY_ID"],
      issuer_id: ENV["APPLE_API_ISSUER_ID"],
      key_content: ENV["APPLE_API_KEY_P8"],
      is_key_content_base64: true,
      in_house: false
    )
  end

  after_all do |lane|
    UI.success("Lane '#{lane}' completed successfully.")
  end

  error do |lane, exception|
    UI.error("Lane '#{lane}' failed: #{exception.message}")
  end
end
