default_platform(:mac)

# Project root (Fastfile runs from fastlane/, so parent is root)
PROJECT_ROOT = File.expand_path("..", __dir__)
APP_BUNDLE = File.join(PROJECT_ROOT, "Spooktacular.app")
PKG_FILE = File.join(PROJECT_ROOT, "Spooktacular.pkg")
APP_IDENTIFIER = "com.spooktacular.app"

# Developer contact fields — sourced from .env so forks can override
# without editing the Fastfile. Defaults keep Spooktacular's canonical
# submission flow working without configuration.
#
# `env_or` treats both nil and empty string as "not set". Plain
# `ENV["X"] || default` breaks when something exports `X=` (empty),
# because Ruby's `||` treats "" as truthy and returns the empty
# string — which App Store Connect then rejects with
# "You must provide a value for the attribute 'contactEmail'".
def env_or(key, default)
  value = ENV[key]
  (value.nil? || value.empty?) ? default : value
end

TEAM_ID                 = env_or("FASTLANE_TEAM_ID",                 "4AM5US9G8B")
ITC_TEAM_ID             = env_or("FASTLANE_ITC_TEAM_ID",             TEAM_ID)
APPLE_ID                = env_or("FASTLANE_APPLE_ID",                "davisperris@gmail.com")
CONTACT_FIRST_NAME      = env_or("FASTLANE_CONTACT_FIRST_NAME",      "Perris")
CONTACT_LAST_NAME       = env_or("FASTLANE_CONTACT_LAST_NAME",       "Davis")
CONTACT_EMAIL           = env_or("FASTLANE_CONTACT_EMAIL",           APPLE_ID)
APP_REVIEW_EMAIL        = env_or("FASTLANE_APP_REVIEW_EMAIL",        APPLE_ID)
APP_FEEDBACK_EMAIL      = env_or("FASTLANE_APP_FEEDBACK_EMAIL",      APPLE_ID)

# App Store Connect's contactPhone validator wants a digits-only
# string (fastlane's own example:
# https://docs.fastlane.tools/actions/upload_to_testflight/ shows
# `"5558675309"`), not E.164 or formatted. Accept any human-
# convenient input in the env var (`+1 (206) 555-1212`,
# `206.555.1212`, `+12065551212`) and strip everything that isn't
# a digit before handing it to pilot/deliver. The raw default
# `5550000000` falls in NANP's fictional range and will still fail
# Apple's real-carrier lookup — every real submission must set
# `FASTLANE_CONTACT_PHONE` to a reachable number.
CONTACT_PHONE_RAW       = env_or("FASTLANE_CONTACT_PHONE",           "5550000000")
CONTACT_PHONE           = CONTACT_PHONE_RAW.gsub(/\D/, "")

platform :mac do

  # Run fastlane's canonical pre-lane discipline exactly once, in
  # the place the docs tell us to.
  #
  # `ensure_bundle_exec` — per
  # https://docs.fastlane.tools/actions/ensure_bundle_exec — forces
  # every invocation to go through `bundle exec fastlane`, so the
  # pinned Gemfile.lock resolves dependencies identically on CI
  # and on a contributor's laptop. No-op when already under
  # bundler; fails loudly otherwise.
  #
  # `setup_ci` — per
  # https://docs.fastlane.tools/actions/setup_ci — creates a
  # temporary keychain so `match` can import certificates without
  # prompting, switches `match` to read-only, and sets up log
  # paths. Without it, builds can freeze forever on a hidden
  # keychain prompt. Guarded on `CI` so a developer running
  # `bundle exec fastlane beta` locally isn't forced into a
  # throwaway keychain.
  before_all do
    ensure_bundle_exec
    setup_ci if ENV["CI"]
  end

  # ──────────────────────────────────────────────────
  # Test
  # ──────────────────────────────────────────────────

  desc "Run all unit tests (parallel) with a false-green guard"
  lane :test do
    Dir.chdir(PROJECT_ROOT) do
      # `swift test` exits 0 on no-tests-ran (e.g. if a compile
      # crash silently skips the entire suite), which lets false-
      # green slip past CI. We tee the output and then require the
      # summary line — any deviation aborts the lane.
      #
      # `--skip SpooktacularUITests` excludes the XCUITest bundle
      # from the RUN phase (the target is still compiled by the
      # Xcode-build CI job for regression catches). SwiftPM can
      # host an XCUITest target for compile-only use, but
      # `XCUIApplication().launch()` aborts with SIGABRT at
      # runtime because SwiftPM can't wire a test-host application
      # bundle (Apple limit). Proper runtime coverage needs an
      # `.xcodeproj` with a UI Testing Bundle target — tracked as
      # a separate infra task.
      output = sh(
        "swift", "test", "--parallel", "--skip", "SpooktacularUITests",
        log: true
      )
      unless output.include?("Test run with") || output.include?("Executed ")
        UI.user_error!(
          "swift test produced no test-run summary — this is the " \
          "false-green pattern where a compile crash silently yields " \
          "exit 0 and zero tests. Inspect the log above for the real " \
          "failure."
        )
      end
    end
  end

  # ──────────────────────────────────────────────────
  # Build
  # ──────────────────────────────────────────────────

  desc "Build the .app bundle (release)"
  lane :build do
    identity = ENV["sigh_#{APP_IDENTIFIER}_appstore_macos_certificate-name"] || ""
    profile = ENV["sigh_#{APP_IDENTIFIER}_appstore_macos_profile-path"] || ""

    Dir.chdir(PROJECT_ROOT) do
      sh(
        { "CODESIGN_IDENTITY" => identity, "PROVISIONING_PROFILE" => profile },
        "./build-app.sh", "release"
      )
    end
  end

  # ──────────────────────────────────────────────────
  # Package — Create .pkg from .app
  # ──────────────────────────────────────────────────

  desc "Package the .app into a .pkg for App Store submission"
  lane :package do
    # Query the keychain for the installer cert match installed,
    # instead of string-interpolating a name. The previous
    # `"3rd Party Mac Developer Installer: Perris Davis (#{TEAM_ID})"`
    # fallback broke when `TEAM_ID` evaluated to an empty string
    # (Ruby's `||` treats "" as truthy, so `ENV[..] || default`
    # returns "" when FASTLANE_TEAM_ID is exported empty). Keychain
    # lookup returns the authoritative name match actually created —
    # `3rd Party Mac Developer Installer: <Person> (<TEAM_ID>)`
    # including the real team ID — so the identity always matches
    # what productbuild resolves.
    installer_identity = ENV["INSTALLER_CERT_NAME"].to_s.empty? ?
      sh(
        "security find-identity -v | " \
        "awk '/3rd Party Mac Developer Installer/ " \
        "{ sub(/^[^\"]+\"/, \"\"); sub(/\".*$/, \"\"); print; exit }'",
        log: false
      ).strip :
      ENV["INSTALLER_CERT_NAME"]

    UI.user_error!(
      "No '3rd Party Mac Developer Installer' cert in keychain — " \
      "did the `signing` lane run before `package`?"
    ) if installer_identity.empty?

    UI.message("Packaging with installer identity: #{installer_identity}")

    Dir.chdir(PROJECT_ROOT) do
      sh("productbuild",
         "--component", "Spooktacular.app", "/Applications",
         "--sign", installer_identity,
         "Spooktacular.pkg")
    end
    UI.success("Package created: #{PKG_FILE}")
  end

  # ──────────────────────────────────────────────────
  # Code Signing — match
  # ──────────────────────────────────────────────────

  desc "Sync code-signing certificates and profiles via match"
  lane :signing do
    # `setup_ci` already ran via `before_all`; match picks up the
    # temporary keychain automatically.
    api_key = get_api_key
    match(
      api_key: api_key,
      type: "appstore",
      additional_cert_types: ["mac_installer_distribution"],
      readonly: is_ci
    )
  end

  # ──────────────────────────────────────────────────
  # Notarize — Direct distribution
  # ──────────────────────────────────────────────────

  desc "Notarize the .app for direct distribution"
  lane :notarize_app do
    api_key = get_api_key
    notarize(
      package: APP_BUNDLE,
      bundle_id: APP_IDENTIFIER,
      api_key: api_key,
      verbose: true,
      print_log: true
    )
    UI.success("Notarization complete — ticket stapled to #{APP_BUNDLE}")
  end

  # ──────────────────────────────────────────────────
  # Beta — TestFlight
  # ──────────────────────────────────────────────────

  desc "Build, package, and upload to TestFlight"
  lane :beta do |options|
    test
    signing
    build
    package

    api_key = get_api_key
    changelog = options[:changelog] || default_changelog

    pilot(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      app_platform: "osx",
      pkg: PKG_FILE,
      team_id: TEAM_ID,

      beta_app_description: app_description,
      beta_app_feedback_email: APP_FEEDBACK_EMAIL,

      beta_app_review_info: {
        contact_email: CONTACT_EMAIL,
        contact_first_name: CONTACT_FIRST_NAME,
        contact_last_name: CONTACT_LAST_NAME,
        contact_phone: CONTACT_PHONE,
        demo_account_required: false,
        notes: review_notes
      },

      changelog: changelog,

      localized_app_info: {
        "en-US" => {
          feedback_email: APP_FEEDBACK_EMAIL,
          marketing_url: "https://spooktacular.app",
          privacy_policy_url: "https://spooktacular.app/privacy.html",
          description: app_description
        }
      },

      localized_build_info: {
        "en-US" => { whats_new: changelog }
      },

      uses_non_exempt_encryption: false,
      demo_account_required: false,
      skip_submission: false,
      skip_waiting_for_build_processing: true,

      # Internal-only for now. App Store Connect auto-distributes
      # to all internal App Store Connect users who have access to
      # this app record; no `groups:` filter needed at this stage.
      #
      # External distribution will go here when there's a real
      # external beta group (pilot's `groups:` + `distribute_external:
      # true` lookup is against the *external* namespace, not the
      # internal one — internal group names like "Homies" are not
      # valid there). Keep `notify_external_testers: false` so pilot
      # doesn't email anyone until external is wired up.
      # Source: https://docs.fastlane.tools/actions/upload_to_testflight/
      notify_external_testers: false,
      expire_previous_builds: true
    )
  end

  # ──────────────────────────────────────────────────
  # Release — App Store
  # ──────────────────────────────────────────────────

  desc "Build, notarize, and submit to the App Store"
  lane :release do |options|
    test
    signing
    build
    notarize_app
    package

    api_key = get_api_key

    deliver(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      app_platform: "osx",
      team_id: TEAM_ID,

      metadata_path: "./metadata",
      screenshots_path: "./screenshots",

      pkg: PKG_FILE,
      skip_binary_upload: false,

      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,

      app_rating_config_path: "./metadata/age_rating_config.json",

      primary_category: "DEVELOPER_TOOLS",
      secondary_category: "BUSINESS",

      submit_for_review: options[:submit] || false,
      automatic_release: options[:auto_release] || false,
      phased_release: true,
      force: true,

      app_review_information: {
        first_name: CONTACT_FIRST_NAME,
        last_name: CONTACT_LAST_NAME,
        phone_number: CONTACT_PHONE,
        email_address: APP_REVIEW_EMAIL,
        demo_user: "",
        demo_password: "",
        notes: review_notes
      },

      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      }
    )
  end

  # ──────────────────────────────────────────────────
  # Promote — TestFlight → App Store
  # ──────────────────────────────────────────────────

  desc "Promote an existing TestFlight build to App Store review (no rebuild)"
  #
  # Invoked on tag push. The signed + notarized binary already lives
  # in TestFlight — uploaded by the `:beta` lane on merge to main —
  # so we reuse it via `deliver(skip_binary_upload: true)` rather
  # than rebuilding and re-uploading. This keeps the App Store bits
  # byte-identical to what beta testers validated.
  #
  # Usage:
  #   bundle exec fastlane promote version:1.2.3
  #   bundle exec fastlane promote version:1.2.3 build_number:47
  #   bundle exec fastlane promote version:1.2.3 auto_release:true
  #
  # If `build_number` is omitted, the latest TestFlight build for
  # the given version is used.
  lane :promote do |options|
    api_key = get_api_key

    version = options[:version] || ENV["APP_VERSION"]
    UI.user_error!("version: parameter or APP_VERSION env required (e.g., version:1.2.3)") if version.nil? || version.empty?

    build_number = options[:build_number] || latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      version: version,
      platform: "osx"
    )

    UI.message("Promoting TestFlight build #{build_number} (v#{version}) to App Store review")

    deliver(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      app_platform: "osx",
      team_id: TEAM_ID,

      # Point at the existing TestFlight binary — no re-upload.
      app_version: version.to_s,
      build_number: build_number.to_s,
      skip_binary_upload: true,

      # Refresh metadata + screenshots on every promotion so App
      # Store copy stays in sync with the repo. The `promote`
      # workflow runs `bundle exec fastlane ui_tests` immediately
      # before this action, which populates
      # `fastlane/screenshots/en-US/` from the XCUITest run, so
      # `overwrite_screenshots: true` is a full refresh every time
      # — never stale App Store artwork.
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,

      metadata_path: "./metadata",
      screenshots_path: "./screenshots",
      app_rating_config_path: "./metadata/age_rating_config.json",

      primary_category: "DEVELOPER_TOOLS",
      secondary_category: "BUSINESS",

      submit_for_review: true,
      automatic_release: options[:auto_release] || false,
      phased_release: true,
      force: true,

      app_review_information: {
        first_name: CONTACT_FIRST_NAME,
        last_name: CONTACT_LAST_NAME,
        phone_number: CONTACT_PHONE,
        email_address: APP_REVIEW_EMAIL,
        demo_user: "",
        demo_password: "",
        notes: review_notes
      },

      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      }
    )

    UI.success("TestFlight build #{build_number} (v#{version}) submitted for App Store review")
  end

  # ──────────────────────────────────────────────────
  # Homebrew — Notarized zip for Homebrew cask
  # ──────────────────────────────────────────────────

  desc "Build, notarize, and package for Homebrew distribution"
  lane :homebrew do
    build
    notarize_app
    Dir.chdir(PROJECT_ROOT) do
      sh("ditto", "-c", "-k", "--sequesterRsrc", "--keepParent",
         "Spooktacular.app", "Spooktacular.app.zip")
    end
    UI.success("Homebrew package ready: Spooktacular.app.zip")
  end

  # ──────────────────────────────────────────────────
  # UI Tests — XCUITest via `scan`, then extract screenshot
  # attachments from the .xcresult bundle.
  # ──────────────────────────────────────────────────

  desc "Run UI tests and extract XCTAttachment screenshots into fastlane/screenshots/en-US/"
  #
  # This lane works headlessly — no display required — because
  # XCUITest captures each screen via `XCTAttachment` inside the
  # test run (see Tests/SpooktacularUITests/ScreenshotTests.swift).
  # CI (GitHub Actions macos-26) and a developer's laptop follow
  # the same path, so screenshots produced on a PR look the same
  # as the ones a dev would commit locally.
  lane :ui_tests do
    # Install signing on CI before launching the app under test.
    # Rationale: macOS App Sandbox (`com.apple.security.app-sandbox
    # = true` in Spooktacular.entitlements) is enforced by
    # taskgated, which refuses to launch unsigned sandboxed apps.
    # The XCUITest runner then aborts with "Test crashed with
    # signal kill before establishing connection." Using ad-hoc
    # signing (`CODE_SIGN_IDENTITY="-"`) is worse — runner and
    # plugin end up with mismatched hash-based Team IDs and fail
    # with "mapping process and mapped file (non-platform) have
    # different Team IDs."
    #
    # Fix: run `match` twice — once for Distribution (reuses the
    # `:signing` lane the release pipeline already depends on)
    # and once for Development. The UI-test build in Debug config
    # wants a Mac Development cert + profile, which the `appstore`
    # match type does NOT provide. Without the Development cert,
    # Xcode's automatic signing fails with "No 'Mac Development'
    # signing certificate matching team ID '4AM5US9G8B'".
    #
    # Guarded on CI because match requires MATCH_PASSWORD +
    # cert-repo access that a developer laptop often lacks.
    if ENV["CI"]
      signing
      api_key = get_api_key
      # `readonly: false` — bootstraps the Mac Development cert +
      # profile into the `spooktacular-certificates` match repo
      # on the first run. Subsequent CI runs find what's already
      # there and reuse it (match is idempotent; this never
      # double-creates). The Distribution cert used by `:signing`
      # gets `readonly: is_ci` because it was created manually
      # once; the Development cert has never been created, so we
      # let CI handle the bootstrap with the App Store Connect
      # API key.
      #
      # Requires: APPLE_API_KEY_* secrets scoped to an Apple ID
      # with at least "App Manager" role so match can create
      # certs + profiles on App Store Connect. MATCH_PASSWORD +
      # MATCH_GIT_BASIC_AUTHORIZATION must also grant write
      # access to the cert repo.
      match(
        api_key: api_key,
        type: "development",
        platform: "macos",
        readonly: false
      )
    end

    # Regenerate the `.xcodeproj` from `project.yml` so the
    # file can't drift between what xcodegen would produce and
    # what's on disk. xcodegen is idempotent and cheap (sub-second)
    # on a cold run.
    Dir.chdir(PROJECT_ROOT) do
      sh("xcodegen", "generate")
    end

    # `scheme: "SpooktacularApp"` targets the xcodegen-generated
    # scheme. Naming it `SpooktacularApp` (not `Spooktacular`)
    # avoids a collision with SwiftPM's auto-generated scheme for
    # the `Spooktacular` executable target — see `project.yml`
    # header comment for the full story.
    # `-allowProvisioningUpdates` lets xcodebuild use the
    # App Store Connect API key (already in the environment via
    # APPLE_API_KEY_ID / APPLE_API_ISSUER_ID / APPLE_API_KEY_P8)
    # to download or create a Mac Development provisioning
    # profile on the fly, matching the Development cert that
    # `match` just installed into the CI keychain. Without this
    # flag, automatic signing fails with:
    #   "No profiles for 'com.spooktacular.app' were found"
    # because the profile isn't in the cert-match git repo yet.
    # With the flag, xcodebuild registers the profile once,
    # caches it for future runs. Source:
    # https://developer.apple.com/documentation/xcode-release-notes/xcode-13-release-notes#Signing-and-Distribution
    scan(
      project: "Spooktacular.xcodeproj",
      scheme: "SpooktacularApp",
      destination: "platform=macOS",
      only_testing: ["SpooktacularUITests"],
      result_bundle: true,
      output_directory: "./fastlane/test_output",
      output_types: "html,junit",
      xcargs: "-allowProvisioningUpdates",
      fail_build: true
    )

    Dir.chdir(PROJECT_ROOT) do
      xcresult = Dir.glob("fastlane/test_output/*.xcresult").first
      UI.user_error!("no .xcresult bundle produced by scan") if xcresult.nil?
      sh("./scripts/extract-xcresult-screenshots.sh",
         xcresult,
         "./fastlane/screenshots/en-US")
    end
  end

  # ──────────────────────────────────────────────────
  # Screenshots — App Store artwork pipeline (local dev)
  # ──────────────────────────────────────────────────

  desc "Capture, process, and frame App Store screenshots (requires an interactive macOS session)"
  #
  # Local-dev counterpart to `:ui_tests`. Uses
  # `scripts/capture-screenshots.sh` (screencapture + osascript) to
  # produce un-framed App Store-sized PNGs, then runs frameit to
  # wrap them in device chrome for App Store submission.
  #
  # Skipped on CI because screencapture requires a display.
  # Reviewers should use the `ui_tests` lane output, which is
  # uploaded as a PR artifact.
  lane :screenshots do
    build

    Dir.chdir(PROJECT_ROOT) do
      sh("./scripts/capture-screenshots.sh")
      sh("./scripts/process-screenshots.sh")
    end

    frameit(
      path: "./fastlane/screenshots",
      white: false,
      force_orientation_block: proc { |_| :portrait }
    )

    UI.success("Screenshots captured, processed, and framed.")
  end

  # ──────────────────────────────────────────────────
  # DocC — Generate documentation
  # ──────────────────────────────────────────────────

  desc "Generate DocC documentation"
  lane :generate_docs do
    Dir.chdir(PROJECT_ROOT) do
      sh("./scripts/build-docs.sh", "--static")
    end
  end

  # ──────────────────────────────────────────────────
  # Lint — SwiftLint + App Store metadata
  # ──────────────────────────────────────────────────

  desc "Run SwiftLint (strict) against Sources/ and Tests/"
  #
  # Thin wrapper around fastlane's built-in `swiftlint` action
  # (https://docs.fastlane.tools/actions/swiftlint) so CI and a
  # contributor's laptop share one entry point and the SwiftLint
  # version used is the one in Homebrew on the runner.
  #
  # No `config_file:` — SwiftLint auto-discovers
  # `.swiftlint.yml` at the repo root and the nested
  # `Tests/.swiftlint.yml` (which relaxes a handful of rules that
  # don't carry quality signal in test code). Passing
  # `config_file:` would disable that discovery per the SwiftLint
  # README.
  lane :lint do
    swiftlint(
      mode: :lint,
      strict: true,
      raise_if_swiftlint_error: true
    )
  end

  desc "Validate App Store metadata (description, release notes, keywords, …)"
  #
  # Runs before `:promote` so deliver doesn't reject the push on
  # a trailing whitespace or the word \"Android\". The underlying
  # `precheck` / `check_app_store_metadata` action hits App
  # Store Connect to pull current live metadata for the diff, so
  # it needs an authenticated API key — we feed it the same
  # ``get_api_key`` helper every publish lane uses.
  #
  # Gracefully skipped when the ASC API key is missing or
  # malformed (common symptom: "invalid curve name" from OpenSSL
  # when the `APPLE_API_KEY_P8` secret isn't correctly
  # base64-encoded). The release lanes will re-surface the same
  # credential error at publish time, so we don't silently paper
  # over it — just don't block the lint job on upstream
  # credential state.
  lane :lint_metadata do
    unless ENV["APPLE_API_KEY_ID"] && ENV["APPLE_API_ISSUER_ID"] && ENV["APPLE_API_KEY_P8"]
      UI.important("APPLE_API_* env vars unset — skipping App Store metadata precheck.")
      next
    end
    api_key = begin
      get_api_key
    rescue => e
      UI.important("App Store Connect API key is invalid (#{e.message}). " \
                   "Skipping metadata precheck; the release lane will re-raise " \
                   "this at publish time where it belongs.")
      next
    end
    check_app_store_metadata(
      api_key: api_key,
      default_rule_level: :error,
      negative_apple_sentiment: true,
      placeholder_text: true
    )
  end

  desc "Run Danger against the current pull request (PR hygiene + strict SwiftLint on changed files)"
  #
  # Named `pr_review` to avoid shadowing the built-in `danger`
  # action (fastlane refuses a lane whose name matches an
  # action's name). Wraps fastlane's `danger` action — which
  # auto-uses `bundle exec` when a Gemfile is present — with the
  # Dangerfile at the repo root and the danger-swiftlint gem.
  #
  # Invoked from `.github/workflows/ci.yml` only on
  # pull_request events so the strict force-unwrap rule runs on
  # the contributor's diff and never on push-to-main (which has
  # no PR context for Danger to read).
  lane :pr_review do
    danger(
      github_api_token: ENV["GITHUB_TOKEN"] || ENV["DANGER_GITHUB_API_TOKEN"],
      fail_on_errors: true,
      new_comment: false,
      remove_previous_comments: true
    )
  end

  # ──────────────────────────────────────────────────
  # Setup — Register app ID
  # ──────────────────────────────────────────────────

  desc "Register app identifier in Apple Developer Portal"
  lane :register_app do
    get_api_key

    produce(
      app_identifier: APP_IDENTIFIER,
      app_name: "Spooktacular",
      language: "English",
      app_version: "1.0.0",
      platform: "osx",
      sku: "com.spooktacular.app.macos"
    )
  end

  # ──────────────────────────────────────────────────
  # Helpers
  # ──────────────────────────────────────────────────

  # Resolves an App Store Connect API key (.p8) in the form
  # `app_store_connect_api_key` + the underlying `spaceship`
  # token can actually parse.
  #
  # Why this is not a one-line call to `app_store_connect_api_key`:
  #
  # The canonical pattern (key_content: ENV["APPLE_API_KEY_P8"],
  # is_key_content_base64: true) is broken on GitHub Actions —
  # see fastlane/fastlane#29478. The secret's base64 payload
  # survives intact through the `env:` block, but OpenSSL fails
  # to parse it back into a P-256 EC key, producing
  # "OpenSSL::PKey::ECError: invalid curve name" right at the
  # JWT-signing moment. The workaround that the thread
  # consistently lands on (and that we adopt here) is to
  # write the decoded .p8 to disk ourselves and hand fastlane
  # a `key_filepath:` — which goes through a completely
  # different `OpenSSL::PKey.read` path that *does* work.
  #
  # Callers keep their environment variable layout unchanged:
  # APPLE_API_KEY_ID, APPLE_API_ISSUER_ID, and a base64-encoded
  # APPLE_API_KEY_P8 (produced by
  # `cat AuthKey_XXXXXXXXXX.p8 | openssl base64 -A`). The
  # .p8 we write to disk is owner-only (mode 0600), lives under
  # `fastlane/ci/AuthKey.p8` inside the repo's work tree so a
  # single-run CI job's cleanup step can `rm -rf fastlane/ci`
  # without thinking about paths, and is never committed
  # (`.gitignore` excludes the directory).
  private_lane :get_api_key do
    filepath = ensure_api_key_on_disk
    app_store_connect_api_key(
      key_id: ENV["APPLE_API_KEY_ID"],
      issuer_id: ENV["APPLE_API_ISSUER_ID"],
      key_filepath: filepath,
      in_house: false
    )
  end

  # Decodes APPLE_API_KEY_P8 (base64) → `fastlane/ci/AuthKey.p8`
  # exactly once per fastlane run. Returns the absolute path.
  # Idempotent: re-running is a no-op that returns the same
  # path. The caller (``get_api_key``) is responsible for
  # feeding the path to the action; this lane does not call
  # `app_store_connect_api_key` so it's safe to invoke from
  # anywhere without starting a spaceship session.
  private_lane :ensure_api_key_on_disk do
    UI.user_error!("APPLE_API_KEY_ID is unset") if (ENV["APPLE_API_KEY_ID"] || "").empty?
    UI.user_error!("APPLE_API_ISSUER_ID is unset") if (ENV["APPLE_API_ISSUER_ID"] || "").empty?

    if ENV["APPLE_API_KEY_FILEPATH"] && File.exist?(ENV["APPLE_API_KEY_FILEPATH"])
      next ENV["APPLE_API_KEY_FILEPATH"]
    end
    UI.user_error!("APPLE_API_KEY_P8 is unset") if (ENV["APPLE_API_KEY_P8"] || "").empty?

    require 'base64'
    dir = File.expand_path("./fastlane/ci", PROJECT_ROOT)
    path = File.join(dir, "AuthKey.p8")

    FileUtils.mkdir_p(dir)
    raw = ENV["APPLE_API_KEY_P8"]
    # `strict_decode64` would reject base64 that contains
    # newlines — which some CI systems introduce when the
    # secret was encoded without `openssl base64 -A`. Use
    # the lenient `decode64` so both single-line and
    # multi-line base64 inputs produce the same .p8 bytes.
    pem = Base64.decode64(raw)

    unless pem.include?("BEGIN PRIVATE KEY") || pem.include?("BEGIN EC PRIVATE KEY")
      UI.user_error!(
        "APPLE_API_KEY_P8 did not decode to a PEM-formatted .p8 key. " \
        "Re-encode with `cat AuthKey_XXXXXXXXXX.p8 | openssl base64 -A` " \
        "and update the secret."
      )
    end

    File.write(path, pem)
    File.chmod(0o600, path)
    ENV["APPLE_API_KEY_FILEPATH"] = path
    UI.message("Wrote App Store Connect API key → #{path} (mode 0600)")
    path
  end

  # Shared text — defined once, used everywhere.

  def self.app_description
    "macOS Virtualization for Teams on Apple Silicon. " \
    "Run 2 macOS VMs per Mac — the maximum Apple's EULA allows. " \
    "Build iOS apps, sign code, run CI pipelines, host remote desktops, " \
    "and deploy computer-using AI agents."
  end

  def self.review_notes
    "Spooktacular uses Apple's Virtualization.framework " \
    "(com.apple.security.virtualization entitlement) to create and manage " \
    "macOS VMs on Apple Silicon. Works only on Apple Silicon Macs. " \
    "The app includes a GUI, a bundled CLI (spook), and an HTTP API server. " \
    "No account or internet connection required — all VMs run locally."
  end

  def self.default_changelog
    "• Create and clone macOS VMs (APFS copy-on-write, ~48ms)\n" \
    "• GitHub Actions, CircleCI, and Jenkins runner pools\n" \
    "• Ephemeral, warm-pool, and persistent runner modes\n" \
    "• SSH and disk-inject provisioning\n" \
    "• HTTP REST API with TLS and bearer token auth\n" \
    "• Kubernetes operator (MacOSVM + RunnerPool CRDs)\n" \
    "• SwiftUI GUI with Liquid Glass (macOS 26+)\n" \
    "• Full VoiceOver accessibility"
  end

  after_all do |lane|
    UI.success("Lane '#{lane}' completed successfully.")
  end

  error do |lane, exception|
    UI.error("Lane '#{lane}' failed: #{exception.message}")
  end
end
